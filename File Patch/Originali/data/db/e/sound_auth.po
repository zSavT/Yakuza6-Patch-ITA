msgstr ""

msgctxt "60||speech_list_sub_a25||table||123||||4"
msgid "That was fantastic, Kiryu-san!\nBoth your diet and training were flawless!"
msgstr ""

msgctxt "60||speech_list_sub_a25||table||124||||4"
