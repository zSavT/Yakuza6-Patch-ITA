msgstr ""

#. Max bytes: 44
msgctxt "Offset_0x2E7E0_Len_44"
msgid "I'm sure I'll be fine once I start using it."
msgstr ""

#. Max bytes: 44
msgctxt "Offset_0x2EA40_Len_44"
msgid "But I'll give it a try when I'm in the mood."
msgstr ""

#. Max bytes: 9
msgctxt "Offset_0x2EBB0_Len_9"
