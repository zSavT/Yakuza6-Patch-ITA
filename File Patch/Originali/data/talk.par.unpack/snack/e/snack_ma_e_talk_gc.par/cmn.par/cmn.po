#. Max bytes: 20
msgctxt "Offset_0x24230_Len_20"
msgid "If you can't, I can."
msgstr ""

#. Max bytes: 49
msgctxt "Offset_0x24260_Len_49"
msgid "There's jus' no way I can use that fancy machine."
msgstr ""

#. Max bytes: 53
msgctxt "Offset_0x24550_Len_53"
msgid "It's even got a remote control with a screen on it..."
msgstr ""

#. Max bytes: 4
msgctxt "Offset_0x24680_Len_4"
msgid "Mama"
msgstr ""

#. Max bytes: 8
msgctxt "Offset_0x246C0_Len_8"
msgid "I agree."
msgstr ""

#. Max bytes: 11
msgctxt "Offset_0x246E0_Len_11"
msgid "I disagree."
msgstr ""

#. Max bytes: 14
msgctxt "Offset_0x24700_Len_14"
msgid "I need to pee."
