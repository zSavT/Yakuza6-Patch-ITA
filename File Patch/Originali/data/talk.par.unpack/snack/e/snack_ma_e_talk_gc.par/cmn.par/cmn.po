#. Max bytes: 24
msgctxt "Offset_0x2B470_Len_24"
msgid "Why didn't you tell me!?"
msgstr ""

#. Max bytes: 4
msgctxt "Offset_0x2B6E0_Len_4"
msgid "Mama"
msgstr ""

#. Max bytes: 12
msgctxt "Offset_0x2B720_Len_12"
msgid "She's right."
