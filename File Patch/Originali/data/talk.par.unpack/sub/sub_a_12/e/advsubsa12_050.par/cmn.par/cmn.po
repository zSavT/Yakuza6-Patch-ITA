#. Max bytes: 35
msgctxt "Offset_0x25298_Len_35"
msgid "\"What the hell's going on, Kiryu!?\""
msgstr ""

#. Max bytes: 62
msgctxt "Offset_0x25388_Len_62"
msgid "\"Kiryu, you've been had!\nMy account got hacked the other day!\""
msgstr ""

#. Max bytes: 37
msgctxt "Offset_0x254A8_Len_37"
msgid "\"That wasn't me you were talking to!\""
msgstr ""

#. Max bytes: 41
msgctxt "Offset_0x255B8_Len_41"
msgid "\"Your 50 grand could be anywhere by now!\""
msgstr ""

#. Max bytes: 13
msgctxt "Offset_0x25698_Len_13"
msgid "\"No, dammit!\""
msgstr ""

#. Max bytes: 68
msgctxt "Offset_0x25758_Len_68"
msgid "\"I'll see what I can do.\nThat scammer's not getting away with this.\""
msgstr ""

#. Max bytes: 83
msgctxt "Offset_0x25888_Len_83"
msgid "\"Sorry, 50 grand really is a lot.\nI'll buy you a drink sometime to make up for it.\""
msgstr ""

#. Max bytes: 16
msgctxt "Offset_0x259D8_Len_16"
msgid "\"Family issues.\""
msgstr ""

#. Max bytes: 12
msgctxt "Offset_0x25AA8_Len_12"
msgid "\"Kamurocho.\""
msgstr ""

#. Max bytes: 46
msgctxt "Offset_0x25B68_Len_46"
msgid "\"Just send them already.\nI'm in a hurry here.\""
msgstr ""

#. Max bytes: 22
msgctxt "Offset_0x25C48_Len_22"
msgid "\"Fine. Let's meet up.\""
