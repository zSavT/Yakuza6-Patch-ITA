msgctxt "10||kaiten_lariat||explanation"
msgid "Inflict small damage to enemies in range."
msgstr "Infligge danni lievi ai nemici nel raggio d'azione."

msgctxt "11||kaiten_lariat_kiwami||explanation"
msgid "Inflict medium damage to enemies in range."
msgstr "Infligge danni medi ai nemici nel raggio d'azione."

msgctxt "12||bakugeki||explanation"
msgid "Inflict major damage to enemies in range."
msgstr "Infligge danni ingenti ai nemici nel raggio d'azione."

msgctxt "13||Healing||explanation"
msgid "Recover some health for all allies."
msgstr "Ripristina parte della salute di tutti gli alleati."

msgctxt "14||Healing_kiwami||explanation"
msgid "Recover medium health for all allies."
msgstr "Ripristina una discreta quantità di salute di tutti gli alleati."

msgctxt "15||recovery||explanation"
msgid "Fully recover your own health."
msgstr "Ripristina completamente la propria salute."

msgctxt "16||offensive||explanation"
msgid "Increase the deployment gauge by 70."
msgstr "Aumenta la barra di schieramento di 70."

msgctxt "17||tyouhatu_A||explanation"
msgid "Text copied from name. Bug."
msgstr "Testo copiato dal nome. Bug."

msgctxt "18||tyouhatu_B||explanation"
msgid "Text copied from name. Bug."
msgstr "Testo copiato dal nome. Bug."

msgctxt "19||daisyuugou||explanation"
msgid "Gather allies within range to your position."
msgstr "Raduna gli alleati nel raggio d'azione presso la tua posizione."

msgctxt "20||bibirase||explanation"
msgid "Stun all enemies and restrict their movement."
msgstr "Stordisce tutti i nemici e ne limita i movimenti."

msgctxt "21||muscleparty||explanation"
msgid "All allies take no damage for 10 seconds."
msgstr "Tutti gli alleati non subiscono danni per 10 secondi."

msgctxt "22||rain_maker||explanation"
msgid "Inflict tremendous damage and stun enemies in range."
msgstr "Infligge danni enormi e stordisce i nemici nel raggio d'azione."

msgctxt "23||Love_of_the_warrior||explanation"
msgid "Resurrect ally leaders and recover some health for all allies."
msgstr "Rianima i leader alleati e ripristina parte della salute di tutti gli alleati."

msgctxt "24||tranquilo||explanation"
msgid "Inflict tremendous damage and restrict movement of enemies in range."
msgstr "Infligge danni enormi e limita i movimenti dei nemici nel raggio d'azione."

msgctxt "25||ytr||explanation"
msgid "Throw grenades that inflict major damage to enemies in range."
msgstr "Lancia granate che infliggono danni ingenti ai nemici nel raggio d'azione."

msgctxt "26||violent_bull||explanation"
msgid "Inflict major damage to enemies in range."
msgstr "Infligge danni ingenti ai nemici nel raggio d'azione."

msgctxt "27||cozy_crash||explanation"
msgid "Take no damage for 20 seconds."
msgstr "Non subisce danni per 20 secondi."

msgctxt "28||rolling_slash||explanation"
msgid "Inflict major damage and stun enemies in range."
msgstr "Infligge danni ingenti e stordisce i nemici nel raggio d'azione."

msgctxt "29||gokurennki_daifugaku||explanation"
