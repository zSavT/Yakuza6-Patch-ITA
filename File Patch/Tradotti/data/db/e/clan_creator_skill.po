msgctxt "4||drop_kick||explanation"
msgid "Inflict medium damage to enemies in range."
msgstr "Infligge danni medi ai nemici nel raggio d'azione."

msgctxt "5||drop_kick_kiwami||explanation"
msgid "Inflict major damage to enemies in range."
