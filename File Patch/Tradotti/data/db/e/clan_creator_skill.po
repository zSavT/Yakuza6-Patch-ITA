msgstr "Infligge danni ingenti e stordisce i nemici nel raggio d'azione."

msgctxt "30||goutai||explanation"
msgid "All allies enter a state of frenzied attack for 10 seconds."
msgstr "Tutti gli alleati entrano in uno stato di attacco frenetico per 10 secondi."

msgctxt "31||offensive_toujoukai||explanation"
msgid "Increase the deployment gauge by 150."
msgstr "Aumenta la barra di schieramento di 150."

