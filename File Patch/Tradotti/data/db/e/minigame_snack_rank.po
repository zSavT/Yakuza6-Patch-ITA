msgctxt "1||rank_f||rank_title"
msgid "Unknown"
msgstr "Sconosciuto"

msgctxt "2||rank_e||rank_title"
msgid "Occasional Customer"
msgstr "Cliente occasionale"

msgctxt "3||rank_d||rank_title"
msgid "Frequent Customer"
msgstr "Cliente assiduo"

msgctxt "4||rank_c||rank_title"
msgid "Regular Customer"
msgstr "Cliente abituale"

msgctxt "5||rank_b||rank_title"
msgid "Beloved Customer"
msgstr "Cliente adorato"

msgctxt "6||rank_a||rank_title"
msgid "King of New Gaudi"
msgstr "Re del New Gaudi"

msgctxt "1||rank_f||mamas_comment"
msgid "Nobody really knows you right now.\r\nStart off by making a friend or two."
msgstr "Nessuno ti conosce davvero qui, per ora.\r\nInizia col farti un amico o due."

msgctxt "2||rank_e||mamas_comment"
msgid "You're still not too important here.\r\nShow off your darts and karaoke skills!"
msgstr "Non sei ancora molto importante qui.\r\nMetti in mostra le tue abilità a freccette e karaoke!"

msgctxt "3||rank_d||mamas_comment"
msgid "Everyone at least knows who you are now.\r\nTry and get a little closer with our less outgoing patrons!"
msgstr "Ora almeno tutti sanno chi sei.\r\nCerca di legare un po' di più con i clienti meno socievoli!"

msgctxt "4||rank_c||mamas_comment"
msgid "Looks like you made friends with everyone!\r\nKeep up that socializing, Kiryu-san."
msgstr "Sembra che tu abbia fatto amicizia con tutti!\r\nContinua a socializzare così, Kiryu-san."

msgctxt "5||rank_b||mamas_comment"
msgid "You're really popular around here.\r\nEveryone loves when you stop by, Kiryu-san!"
msgstr "Sei davvero popolare da queste parti.\r\nTutti adorano quando passi a trovarci, Kiryu-san!"

msgctxt "6||rank_a||mamas_comment"
msgid "You're like some kind of bargoing legend!\r\nWell, at least in this bar."
msgstr "Sei una specie di leggenda del bar!\r\nBeh, almeno in questo bar."
