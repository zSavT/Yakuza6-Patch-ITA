msgctxt "1||paper_fortune_s||open_msg"
msgid "A supreme blessing!?"
msgstr "Una benedizione suprema!?"

msgctxt "2||paper_fortune_a||open_msg"
msgid "A great blessing!"
msgstr "Una grande benedizione!"

msgctxt "3||paper_fortune_b||open_msg"
msgid "A good blessing!"
msgstr "Una buona benedizione!"

msgctxt "4||paper_fortune_c||open_msg"
msgid "A regular blessing."
msgstr "Una benedizione normale."

msgctxt "5||paper_fortune_d||open_msg"
msgid "A poor blessing..."
msgstr "Una scarsa benedizione..."

msgctxt "6||paper_fortune_e||open_msg"
msgid "A curse..."
msgstr "Una maledizione..."

msgctxt "1||paper_fortune_s||info_exp_msg"
msgid "The Seven Gods of Fortune smile upon you!\r\nYou now earn more EXP than usual.\r\nThis boost will last for your next 9 battles."
msgstr "Le Sette Divinità della Fortuna ti sorridono!\r\nOra ottieni più ESP del solito.\r\nQuesto potenziamento durerà per le tue prossime 9 battaglie."

