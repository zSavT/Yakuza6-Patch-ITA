msgid ""
msgstr ""
"Project-Id-Version: Yakuza 6 Translation\n"
"Last-Translator: SavT\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Language: it\n"

msgctxt "0||||4"
msgid "Hm? What the..."
msgstr "(Uhm? Che diavolo...)"

msgctxt "1||||4"
msgid "Whoa. Those are <font_kind=yakuza_italic>huge</font_kind>!"
msgstr "Uao. Quelli sono <font_kind=yakuza_italic>giganti</font_kind>!"

msgctxt "2||||4"
msgid "Aren't they amazing?\r\nPulled fresh out of the sea today."
msgstr "Non sono fantastici?\r\nTirati fuori freschi dal mare oggi stesso."

msgctxt "3||||4"
msgid "Really?\r\nWait, did you catch these?"
msgstr "Davvero?\r\nAspetta, li hai pescati tu?"

msgctxt "4||||4"
msgid "'Course not!\r\nYou've got him to thank for that."
msgstr "Certo che no!\r\nÈ lui che devi ringraziare per questo."

msgctxt "5||||4"
msgid "Isao-san, this is a great haul!"
msgstr "Isao-san, questo è un pescato fantastico!"

msgctxt "6||||4"
msgid "Darn tootin'."
msgstr "Puoi dirlo forte."

msgctxt "7||||4"
msgid "Been ages since I caught somethin' this nice.\r\nHow 'bout we celebrate with drinks n' sashimi?"
msgstr "Era da un pezzo che non pescavo niente di così bello.\r\nChe ne dite di festeggiare con drink e sashimi?"

msgctxt "8||||4"
msgid "That sounds fantastic!\r\nI can prep it!"
msgstr "Sembra fantastico!\r\nPosso prepararlo io!"

msgctxt "9||||4"
msgid "Huh? Who're you?"
msgstr "Eh? Tu chi sei?"

msgctxt "10||||4"
msgid "Just a passerby.\r\nDon't mind me."
msgstr "Solo un passante.\r\nNon fate caso a me."

msgctxt "11||||4"
msgid "These fish really lured me in, though.\r\nThey're incredible."
msgstr "Questi pesci mi hanno proprio attirato, però.\r\nSono incredibili."

msgctxt "12||||4"
msgid "That's nice of ya t'say."
msgstr "È gentile da parte tua dirlo."

msgctxt "13||||4"
msgid "I know, why don't y'join us?\r\nDrinks n' sashimi on me!"
msgstr "Sai che ti dico? Perché non ti unisci a noi?\r\nDrink e sashimi offro io!"

msgctxt "14||||4"
msgid "I'm invited, too? But..."
msgstr "Sono invitato anch'io? Ma..."

msgctxt "15||||4"
msgid "C'mon, don't go bein' shy on me now.\r\nWe ain't ever gonna eat this all on our own."
msgstr "Andiamo, non fare il timido ora.\r\nNon riusciremmo mai a mangiare tutto questo da soli."

msgctxt "16||||4"
msgid "He's got a point. We have tons of fish\r\nto go around, so you might as well join!"
msgstr "Ha ragione. Abbiamo tonnellate di pesce\r\nda condividere, tanto vale che ti unisci a noi!"

msgctxt "17||||4"
msgid "You sure?\r\nAll right, I'll take you up on that."
msgstr "Siete sicuri?\r\nD'accordo, accetto volentieri."

msgctxt "18||||4"
msgid "Mkay! Let's get ready t'party!"
msgstr "Okay! Prepariamoci a festeggiare!"

msgctxt "19||||4"
msgid "I'm stuffed t'the brim..."
msgstr "(Sono pieno fino all'orlo...)"

msgctxt "20||||4"
msgid "What a meal!"
msgstr "(Che pasto!)"

msgctxt "21||||4"
msgid "Thanks again.\r\nThat was really something special."
msgstr "Grazie ancora.\r\nÈ stato davvero qualcosa di speciale."

msgctxt "22||||4"
msgid "Don't worry 'bout it.\r\nI'm jus' glad t'see a fresh face."
msgstr "Non preoccupartene.\r\nMi fa solo piacere vedere una faccia nuova."

msgctxt "23||||4"
msgid "By the way, the name's Isao.\r\nPleased t'meet ya."
msgstr "A proposito, il mio nome è Isao.\r\nPiacere di conoscerti."

msgctxt "24||||4"
msgid "And I'm Amano, from Amano Fish.\r\nI sell what Isao-san catches."
msgstr "E io sono Amano, di Amano Fish.\r\nVendo ciò che Isao-san pesca."

msgctxt "25||||4"
msgid "I'm Kiryu. Honestly, I'm pretty new to this place,\r\nso it's nice to see some friendly faces."
msgstr "Io sono Kiryu. Ad essere onesto, sono arrivato da poco in questo posto,\r\nquindi è bello vedere delle facce amichevoli."

msgctxt "26||||4"
msgid "Kiryu-san. How 'bout ya come out\r\nfishin' with me next time?"
msgstr "Kiryu-san. Che ne dici di venire a\r\npescare con me la prossima volta?"

msgctxt "27||||4"
msgid "Really?"
msgstr "Davvero?"

msgctxt "28||||4"
msgid "Fer sure. Y'got a strong body, Kiryu-san.\r\nYa'd probly be an expert fisherman."
msgstr "Certo. Hai un fisico forte, Kiryu-san.\r\nSaresti probabilmente un pescatore esperto."

msgctxt "29||||4"
msgid "Sounds like fun."
msgstr "Sembra divertente."

msgctxt "30||||4"
msgid "Great. Well, I'll let ya know if I pull up\r\nanythin' tasty in the future, Kiryu-san."
msgstr "Fantastico. Beh, ti farò sapere se tiro su\r\nqualcosa di gustoso in futuro, Kiryu-san."

msgctxt "31||||4"
msgid "N' we're always 'round these parts,\r\nso be sure t'come back."
msgstr "E noi siamo sempre da queste parti,\r\nquindi assicurati di tornare."

msgctxt "32||||4"
msgid "Of course."
msgstr "Certamente."

msgctxt "33||||4"
msgid "(That fish was the freshest I've ever tasted.\r\nI want to catch some myself sometime...)"
msgstr "(Quel pesce era il più fresco che abbia mai assaggiato.\r\nVoglio pescarne un po' io stesso prima o poi...)"

msgctxt "35||||4"
msgid "(Wait... Isn't that Isao-san?)"
msgstr "(Aspetta... Quello non è Isao-san?)"

msgctxt "36||||4"
msgid "Hey, Isao-san! Are you okay!?"
msgstr "Ehi, Isao-san! Stai bene!?"

msgctxt "37||||4"
msgid "I got real messed up out on the water...\r\nThink y'can call a doctor fer me?"
msgstr "Mi sono ferito di brutto in mare...\r\nPensi di potermi chiamare un medico?"

msgctxt "38||||4"
msgid "I'm on it...!"
msgstr "Ci penso io...!"

msgctxt "39||||4"
msgid "Sorry 'bout that...\r\nGlad y'came fer me, Kiryu-san."
msgstr "Scusa per questo...\r\nSono felice che tu sia venuto ad aiutarmi, Kiryu-san."

msgctxt "40||||4"
msgid "Are you okay now?"
msgstr "Stai bene ora?"

msgctxt "41||||4"
msgid "Thankfully, it wasn't anythin' too major.\r\nReckon I'm gonna be outta action fer a bit, though."
msgstr "Per fortuna non è stato niente di troppo grave.\r\nPenso che sarò fuori gioco per un po', però."

msgctxt "42||||4"
msgid "Sorry to hear that."
msgstr "Mi dispiace sentirlo."

msgctxt "43||||4"
msgid "Isao-san! I heard you got hurt... You okay?\r\nDon't tell me it got you again..."
msgstr "Isao-san! Ho saputo che ti sei fatto male... Stai bene?\r\nNon dirmi che è stato di nuovo lui..."

msgctxt "44||||4"
msgid "It did."
msgstr "Proprio così."

msgctxt "45||||4"
msgid "...<font_kind=yakuza_italic>It</font_kind>?"
msgstr "...<font_kind=yakuza_italic>Lui</font_kind>?"

msgctxt "46||||4"
msgid "Oh, that's our problem.\r\nY'don't gotta worry yerself."
msgstr "Oh, questo è un problema nostro.\r\nNon devi preoccuparti."

msgctxt "47||||4"
msgid "This ain't so good, though.\r\nI'm gonna be outta commission fer a while."
msgstr "Questo non va affatto bene, però.\r\nSarò fuori servizio per un po'."

msgctxt "48||||4"
msgid "I don't really mind... but Amano won't\r\nhave any fish if I ain't out catchin'."
msgstr "A me non dispiace in realtà... ma Amano non\r\navrà nessun pesce se non vado a pescare."

msgctxt "49||||4"
msgid "Not much choice, though. I'll just have\r\nto shutter up while Isao-san's hurt."
msgstr "Non c'è molta scelta, però. Dovrò semplicemente\r\ntirare giù la serranda finché Isao-san è ferito."

msgctxt "50||||4"
msgid "Y'can't do that, kid!\r\nYer mom's still sick, ain't she?"
msgstr "Non puoi farlo, ragazza!\r\nTua mamma è ancora malata, no?"

msgctxt "51||||4"
msgid "How're ya gonna pay fer her bills\r\nif y'can't keep the store open?"
msgstr "Come farai a pagarle le cure\r\nse non puoi tenere aperto il negozio?"

msgctxt "52||||4"
msgid "You have a point, but..."
msgstr "Hai ragione, ma..."

msgctxt "53||||4"
msgid "Can't you just get fish from\r\nthe other fishermen in town?"
msgstr "Non puoi semplicemente prendere il pesce\r\ndagli altri pescatori in città?"

msgctxt "54||||4"
msgid "To be honest, I'm still pretty new at this.\r\nI don't really know anyone else yet."
msgstr "Ad essere onesta, sono ancora abbastanza nuova in questo.\r\nNon conosco ancora nessun altro."

msgctxt "55||||4"
msgid "Nobody trusts me with selling their catch.\r\nNobody but Isao-san, that is."
msgstr "Nessuno si fida di me per vendere il proprio pescato.\r\nNessuno tranne Isao-san, ecco."

msgctxt "56||||4"
msgid "The other fishermen're real hardheaded.\r\nNot an ounce of sympathy fer youth."
msgstr "Gli altri pescatori sono dei veri testardi.\r\nNon hanno un briciolo di comprensione per i giovani."

msgctxt "57||||4"
msgid "So, all the young'uns move to Tokyo instead.\r\nWhich leaves us with a bunch o' old farts."
msgstr "Così, tutti i giovani finiscono per trasferirsi a Tokyo.\r\nE ci lasciano con un branco di vecchi rimbambiti."

msgctxt "58||||4"
msgid "Huh..."
msgstr "Capisco..."

msgctxt "59||||4"
msgid "But Amano here's a real passionate girl.\r\nThat passion's why I trust her t'sell my hauls."
msgstr "Ma Amano qui è una ragazza con una gran passione.\r\nÈ per questa passione che mi fido di lei per vendere il mio pescato."

msgctxt "60||||4"
msgid "But now... we're in a real pinch."
msgstr "Ma ora... siamo in un bel pasticcio."

msgctxt "61||||4"
msgid "Yeah..."
msgstr "Già..."

msgctxt "62||||4"
msgid "Huh? That's it!"
msgstr "Eh? Ma certo!"

msgctxt "63||||4"
msgid "Hm?"
msgstr "Uhm?"

msgctxt "64||||4"
msgid "Kiryu-san. Didn't ya say y'wanted\r\nto try fishin' sometime?"
msgstr "Kiryu-san. Non avevi detto che volevi\r\nprovare a pescare qualche volta?"

msgctxt "65||||4"
msgid "Hm? I-I did..."
msgstr "Uhm? S-sì..."

msgctxt "66||||4"
msgid "Well, how 'bout ya do my fishin' fer me?"
msgstr "Beh, che ne diresti di pescare tu al mio posto?"

msgctxt "67||||4"
msgid "<font_kind=yakuza_italic>Me</font_kind>?"
msgstr "<font_kind=yakuza_italic>Io</font_kind>?"

msgctxt "68||||4"
msgid "Yup. 'Course, I'll explain everythin' first."
msgstr "Sì. Certo, prima ti spiegherò tutto."

msgctxt "69||||4"
msgid "There's no way... I don't have any experience,\r\nlet alone a license."
msgstr "Non se ne parla... Non ho alcuna esperienza,\r\nper non parlare della licenza."

msgctxt "70||||4"
msgid "Well 'round here, y'can fish without\r\na license so long as I'm in the boat."
msgstr "Beh, da queste parti, puoi pescare senza\r\nlicenza a patto che ci sia io sulla barca."

msgctxt "71||||4"
msgid "I can take care o' all the extra prep, too,\r\nso y'don't gotta worry about a thing."
msgstr "Posso occuparmi anche di tutta la preparazione extra,\r\ncosì non dovrai preoccuparti di nulla."

msgctxt "72||||4"
msgid "But..."
msgstr "Ma..."

msgctxt "73||||4"
msgid "No buts, y'hear? The decision's simple!"
msgstr "Niente ma, mi hai sentito? La decisione è semplice!"

msgctxt "74||||4"
msgid "Y'don't gotta do it as good as I do.\r\nJus' take it easy, act natural."
msgstr "Non devi farlo bene quanto me.\r\nPrenditela comoda, comportati in modo naturale."

msgctxt "75||||4"
msgid "'Course, y'can keep whatever cash ya make\r\nfrom selling yer hauls to Amano, too."
msgstr "Certo, potrai anche tenerti i soldi che\r\nguadagnerai vendendo il tuo pescato ad Amano."

msgctxt "76||||4"
msgid "Ya get to fish <font_kind=yakuza_italic>and</font_kind> earn some spendin' money.\r\nTwo birds with one stone, yeah? Don't it sound good?"
msgstr "Potrai pescare <font_kind=yakuza_italic>e</font_kind> guadagnare qualche soldo extra.\r\nDue piccioni con una fava, no? Non ti sembra un'ottima idea?"

msgctxt "77||||4"
msgid "Hmmm..."
msgstr "Uhm..."

msgctxt "78||||4"
msgid "I'm beggin' ya, Kiryu-san. I wanna try\r\nn' help Amano, even jus' a little bit."
msgstr "Ti supplico, Kiryu-san. Voglio cercare di\r\naiutare Amano, anche solo un po'."

msgctxt "79||||4"
msgid "We've gotta do our darnedest t'make sure\r\nshe can pay fer her mom's bills."
msgstr "Dobbiamo fare tutto il possibile per assicurarci\r\nche possa pagare le cure per sua madre."

msgctxt "80||||4"
msgid "Isao-san..."
msgstr "Isao-san..."

msgctxt "82||||4"
msgid "I'll do it."
msgstr "Lo farò."

msgctxt "83||||4"
msgid "Y'mean it?"
msgstr "Dici sul serio?"

msgctxt "84||||4"
msgid "Yeah. I've never done this before, though.\r\nI can't promise I'll be any good."
msgstr "Sì. Ma non l'ho mai fatto prima d'ora.\r\nNon posso promettere che sarò bravo."

msgctxt "85||||4"
msgid "Kiryu-san... Thank ya!"
msgstr "Kiryu-san... Grazie!"

msgctxt "86||||4"
msgid "This'll be such a big help! Are you sure, though?\r\nIt's not gonna be easy..."
msgstr "Sarà un aiuto grandissimo! Ma ne sei sicuro?\r\nNon sarà facile..."

msgctxt "87||||4"
msgid "You treated me to an amazing meal earlier.\r\nI'm just returning the favor."
msgstr "Mi hai offerto un pasto fantastico prima.\r\nTi sto solo restituendo il favore."

msgctxt "88||||4"
msgid "Kiryu-san... Thank you so much!"
msgstr "Kiryu-san... Grazie infinite!"

msgctxt "89||||4"
msgid "Now, let's strike while the fish're bitin'!\r\nJus' talk to me when yer ready to head out."
msgstr "Ora, battiamo il ferro finché è caldo!\r\nParlami non appena sarai pronto a salpare."

msgctxt "90||||4"
msgid "Will do."
msgstr "Lo farò."

msgctxt "91||||4"
msgid "Oh, Kiryu-san.\r\nY'ready to fish?"
msgstr "Oh, Kiryu-san.\r\nPronto a pescare?"

msgctxt "92||||4"
msgid "Talk t'me when ya wanna weigh anchor."
msgstr "Parlami quando vuoi levare l'ancora."

msgctxt "93||||4"
msgid "Mkay! I'll do the steerin'!"
msgstr "Okay! Penserò io a governare la barca!"

msgctxt "94||||4"
msgid "Well? How'd ya like fishin'?"
msgstr "Allora? Ti è piaciuto pescare?"

msgctxt "95||||4"
msgid "It was tough...\r\nBut I can't say I didn't enjoy myself."
msgstr "È stata dura...\r\nMa non posso dire di non essermi divertito."

msgctxt "96||||4"
msgid "This big a haul on yer first go is amazin'.\r\nI knew y'had talent for this, Kiryu-san."
msgstr "Un simile bottino al tuo primo tentativo è incredibile.\r\nSapevo che avevi talento per questo, Kiryu-san."

msgctxt "97||||4"
msgid "Enough of the flattery."
msgstr "Basta con le lusinghe."

msgctxt "98||||4"
msgid "Kiryu-san, here's your payment for today.\r\nI threw in a little extra since it's your first time."
msgstr "Kiryu-san, ecco il tuo compenso per oggi.\r\nHo aggiunto qualcosina visto che è la tua prima volta."

msgctxt "99||||4"
msgid "Yer gonna get paid jus' like this\r\ndependin' on what ya haul up."
msgstr "Verrai pagato sempre così,\r\na seconda di quello che tirerai su."

msgctxt "100||||4"
msgid "The more ya catch, the more money ya get.\r\nKeep that in mind."
msgstr "Più peschi, più soldi guadagni.\r\nTienilo a mente."

msgctxt "101||||4"
msgid "Okay."
msgstr "D'accordo."

msgctxt "102||||4"
msgid "Oh, n' if ya fish real good in that one spot,\r\nI'll even take ya over to new fishin' grounds."
msgstr "Oh, e se peschi davvero bene in quel punto lì,\r\nti porterò anche in nuove zone di pesca."

msgctxt "103||||4"
msgid "These new places're tougher fer sure,\r\nbut they've got pricier fish. Eh, y'can do it."
msgstr "Questi nuovi posti sono sicuramente più tosti,\r\nma ci troverai pesci di maggior valore. Eh, ce la puoi fare."

msgctxt "104||||4"
msgid "Understood."
msgstr "Capito."

msgctxt "105||||4"
msgid "Well then, fer the time bein'...\r\nwe're countin' on ya, Kiryu-san!"
msgstr "Beh allora, per il momento...\r\ncontiamo su di te, Kiryu-san!"

msgctxt "106||||4"
msgid "Right."
msgstr "Certo."

msgctxt "107||||4"
msgid "Well then, how about we have a drink and eat\r\nsome of this fish Kiryu-san caught?"
msgstr "Beh allora, che ne dite di bere qualcosa e mangiare\r\nun po' di questo pesce pescato da Kiryu-san?"

msgctxt "108||||4"
msgid "You sure? Won't you run out of product to sell?"
msgstr "Sei sicura? Non rimarrai senza prodotto da vendere?"

msgctxt "109||||4"
msgid "If it's a small amount, it'll be fine!\r\nRight, Isao-san?"
msgstr "Se è solo un pochino, andrà bene!\r\nVero, Isao-san?"

msgctxt "110||||4"
msgid "Yup! The first fish you catch should be commemorated.\r\nIt'll definitely be delicious, you should eat it."
msgstr "Sì! Il primo pesce che si pesca andrebbe celebrato.\r\nSarà sicuramente delizioso, dovresti mangiarlo."

msgctxt "111||||4"
msgid "Well then... It's time to prepare for a party!\r\nLet's drink, Kiryu-san!"
msgstr "Beh allora... È ora di preparare la festa!\r\nBeviamo, Kiryu-san!"

msgctxt "112||||4"
msgid "Yeah."
msgstr "Sì."

msgctxt "113||||4"
msgid "(I can't believe I'm fishing for these people.\r\nLife takes you to strange places sometimes...)"
msgstr "(Non riesco a credere che stia pescando per questa gente.\r\nLa vita ti porta in posti strani, a volte...)"

msgctxt "114||||4"
msgid "Hey! Kiryu-san, lend us a hand!"
msgstr "Ehi! Kiryu-san, dacci una mano!"

msgctxt "115||||4"
msgid "Oh yeah, sorry, sorry."
msgstr "Oh sì, scusa, scusa."

msgctxt "116||||4"
msgid "Yo, Kiryu-san.\r\nHow 'bout a round of fishin'?"
msgstr "Ehi, Kiryu-san.\r\nChe ne diresti di fare un po' di pesca?"

msgctxt "117||||4"
msgid "Talk t'me when ya wanna weigh anchor."
msgstr "Parlami quando vuoi levare l'ancora."

msgctxt "118||||4"
msgid "Great, I'll prep the boat!"
msgstr "Fantastico, preparo la barca!"

msgctxt "119||||4"
msgid "Good work, Kiryu-san!"
msgstr "Ottimo lavoro, Kiryu-san!"

msgctxt "120||||4"
msgid "This will be today's payment."
msgstr "Questo sarà il compenso di oggi."

msgctxt "121||||4"
msgid "I look forward to next time."
msgstr "Non vedo l'ora che arrivi la prossima volta."

msgctxt "122||||4"
msgid "It was a big haul!\r\nI look forward to next time."
msgstr "È stato un bel bottino!\r\nNon vedo l'ora che arrivi la prossima volta."

msgctxt "123||||4"
msgid "It didn't go too well today.\r\nI hope you can catch more next time."
msgstr "Non è andata troppo bene oggi.\r\nSpero che riuscirai a pescare di più la prossima volta."
