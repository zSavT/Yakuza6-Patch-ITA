msgstr "Una piccola conchiglia."

msgctxt "614||drifters_buoy||explanation"
msgid "A buoy that has drifted from somewhere."
msgstr "Una boa che è andata alla deriva da qualche parte."

msgctxt "615||drifters_dust||explanation"
msgid "Looks like it came from another country."
msgstr "Sembra provenire da un altro paese."

msgctxt "616||drifters_wakame||explanation"
