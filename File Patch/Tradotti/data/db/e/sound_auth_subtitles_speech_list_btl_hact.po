"Language: it\n"

msgctxt "0||||4"
msgid "Kiryu-aniki!"
msgstr "Kiryu-aniki!"

msgctxt "1||||4"
msgid "We'll help you out, Kiryu-aniki!"
msgstr "Ti diamo una mano noi, Kiryu-aniki!"

msgctxt "2||||4"
msgid "Let's head down there!"
msgstr "Andiamo laggiù!"

msgctxt "3||||4"
msgid "Y'better not've forgotten 'bout us!"
msgstr "Vedi di non esserti dimenticato di noi!"

msgctxt "4||||4"
msgid "Get ready for a righteous\r\nwhoopin'!"
msgstr "Preparati a prendere\r\nuna bella batosta!"

msgctxt "6||||4"
msgid "C'mon, let's do this!"
msgstr "Forza, facciamolo!"

msgctxt "8||||4"
msgid "Y'little shit!"
msgstr "Pezzo di merda!"

msgctxt "9||||4"
msgid "I'm gonna kill ya!"
msgstr "Ti ammazzo!"

msgctxt "11||||4"
msgid "Gah, fuck this..."
msgstr "Gah, fanculo..."

msgctxt "12||||4"
msgid "Yo, old man!"
msgstr "Ehi, vecchio!"

msgctxt "13||||4"
msgid "Hurry up and hand over your wallet!"
msgstr "Sbrigati a consegnare il portafogli!"

msgctxt "14||||4"
msgid "I could use a bit of spendin' money!"
msgstr "Mi farebbero comodo un po' di soldi da spendere!"

msgctxt "15||||4"
msgid "All right... Let's do this!"
msgstr "D'accordo... Facciamolo!"

msgctxt "16||||4"
msgid "Right."
msgstr "Bene."

msgctxt "17||||4"
msgid "Sounds like you need to learn some manners."
msgstr "Sembra che tu abbia bisogno di imparare un po' di buone maniere."

msgctxt "18||||4"
msgid "I need to keep moving."
msgstr "Devo continuare a muovermi."

msgctxt "19||||4"
msgid "This isn't the right way..."
msgstr "Non è la strada giusta..."

msgctxt "20||||4"
msgid "Let's do this!"
msgstr "Facciamolo!"

msgctxt "21||||4"
msgid "Don't let your guard down."
msgstr "Non abbassare la guardia."

msgctxt "22||||4"
msgid "Nagumo!?"
msgstr "Nagumo!?"

msgctxt "24||||4"
msgid "Get outta my way!"
msgstr "Togliti di mezzo!"

msgctxt "25||||4"
msgid "Dammit."
msgstr "Maledizione."

msgctxt "27||||4"
msgid "Good luck."
msgstr "Buona fortuna."

msgctxt "28||||4"
msgid "I'll be counting on you."
msgstr "Conto su di te."

msgctxt "29||||4"
msgid "Always with the helicopters...\r\nWhat a pain in the ass."
msgstr "Sempre con questi elicotteri...\r\nChe rottura di coglioni."

msgctxt "30||||4"
msgid "The elevator doesn't go past here..."
msgstr "L'ascensore non va oltre questo piano..."

msgctxt "31||||4"
msgid "Looks like we have to fight..."
msgstr "Sembra che ci tocchi combattere..."

msgctxt "32||||4"
msgid "Sorry..."
msgstr "Scusa..."

msgctxt "33||||4"
msgid "Look what we got here. Let's take 'em down!"
msgstr "Guarda un po' chi c'è. Mettiamoli al tappeto!"

msgctxt "34||||4"
msgid "There they are!"
msgstr "Eccoli lì!"

msgctxt "35||||4"
msgid "[Hey, there they are!]"
msgstr "[Ehi, eccoli lì!]"

msgctxt "36||||4"
msgid "Is that it?"
msgstr "Tutto qui?"

msgctxt "37||||4"
msgid "I'll tear you apart!"
msgstr "Ti faccio a pezzi!"

msgctxt "38||||4"
msgid "You're finished!"
msgstr "Sei finito!"

msgctxt "40||||4"
msgid "Come here!"
msgstr "Vieni qui!"

msgctxt "48||||4"
msgid "Looks like I'll finally get the workout\r\nI've been itching for this whole time."
msgstr "Sembra che finalmente farò l'allenamento\r\nche aspettavo da tutto questo tempo."

msgctxt "49||||4"
msgid "Is something wrong, Kiryu-san?"
msgstr "C'è qualcosa che non va, Kiryu-san?"

msgctxt "50||||4"
msgid "Goddammit!"
msgstr "Porca puttana!"

msgctxt "62||||4"
msgid "Just my luck!"
msgstr "Che sfiga!"

msgctxt "63||||4"
msgid "Kiryu-san."
msgstr "Kiryu-san."

msgctxt "64||||4"
msgid "When I say your name, come over to me."
msgstr "Quando dico il tuo nome, vieni da me."

msgctxt "65||||4"
msgid "Kiryu-san. I'll go on ahead and scout it out."
msgstr "Kiryu-san. Vado avanti io a dare un'occhiata."

msgctxt "66||||4"
msgid "Good luck."
msgstr "Buona fortuna."

msgctxt "67||||4"
msgid "I'll be counting on you."
msgstr "Conto su di te."

msgctxt "68||||4"
msgid "I need to keep moving."
msgstr "Devo continuare a muovermi."

msgctxt "69||||4"
msgid "This isn't the right way..."
msgstr "Non è la strada giusta..."

