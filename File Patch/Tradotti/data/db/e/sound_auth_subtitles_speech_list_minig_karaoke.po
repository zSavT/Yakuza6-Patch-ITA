msgctxt "0||||4"
msgid "Welcome.\r\nFor how many people?"
msgstr ""

msgctxt "1||||4"
msgid "Very well. That will be \\500."
msgstr ""

msgctxt "2||||4"
msgid "I'll show you to your room."
msgstr ""

msgctxt "3||||4"
msgid "Very well.\r\nWe await your return."
msgstr ""

msgctxt "4||||4"
msgid "It will be \\1,000 for two people."
msgstr ""

msgctxt "5||||4"
msgid "Please enjoy your time here."
msgstr ""

msgctxt "6||||4"
msgid "Thank you for your patronage.\r\nWe await your return."
msgstr ""

msgctxt "7||||4"
msgid "Your time is almost up...\r\nWould you like to extend your time?"
msgstr ""

msgctxt "8||||4"
msgid "It will cost \\500 to extend your time."
msgstr ""

msgctxt "9||||4"
msgid "Very well.\r\nPlease continue to enjoy your time here."
msgstr ""

msgctxt "10||||4"
msgid "Your time is almost up.\r\nPlease begin preparing to leave."
msgstr ""

msgctxt "11||||4"
msgid "Very well. Please be sure to take all\r\nof your belongings when you leave."
msgstr ""

msgctxt "12||||4"
msgid "I apologize."
msgstr ""

msgctxt "13||||4"
msgid "For one."
msgstr ""

msgctxt "14||||4"
msgid "For two."
msgstr ""

msgctxt "15||||4"
msgid "I want to call someone over."
msgstr ""

msgctxt "16||||4"
msgid "I'd like more time."
msgstr ""

msgctxt "17||||4"
msgid "No, it's fine."
msgstr ""

msgctxt "18||||4"
msgid "Got it."
msgstr ""

msgctxt "19||||4"
msgid "I'll come back another time."
msgstr ""

msgctxt "20||||4"
msgid "Sorry..."
msgstr ""

