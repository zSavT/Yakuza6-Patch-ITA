msgctxt "1||mission||explanation"
msgid "Select a mission to begin a Clan Battle."
msgstr "Seleziona una missione per iniziare una battaglia tra clan."

msgctxt "2||edit||explanation"
msgid "Customize the organization and select a Strike Team."
msgstr "Personalizza l'organizzazione e seleziona una squadra d'assalto."

msgctxt "3||ability||explanation"
msgid "Strengthen your leaders with Kiryu's experience points."
msgstr "Potenzia i tuoi leader con i punti esperienza di Kiryu."

msgctxt "4||network||explanation"
msgid "Play exclusive online content."
msgstr "Gioca con contenuti online esclusivi."

msgctxt "5||help||explanation"
msgid "Review Clan Creator tutorials."
msgstr "Rivedi i tutorial del Creatore clan."

msgctxt "7||customize_chart||explanation"
msgid "Restructure the Kiryu Clan."
msgstr "Ristruttura il Clan Kiryu."

msgctxt "8||customize_deck||explanation"
msgid "Select leaders to participate in battle."
msgstr "Seleziona i leader che parteciperanno alla battaglia."

msgctxt "9||network_attack||explanation"
msgid "Battle against other clans online."
msgstr "Affronta altri clan online."

msgctxt "10||network_defense||explanation"
msgid "Upload your team to fight in automatic battles online."
msgstr "Carica la tua squadra per partecipare a battaglie online automatiche."

msgctxt "12||network_return||explanation"
msgid "Return to the previous screen."
msgstr "Torna alla schermata precedente."

msgctxt "13||network_limited||explanation"
msgid "Play missions available only for a limited time."
msgstr "Gioca missioni disponibili per un periodo limitato."

msgctxt "14||network_ranker||explanation"
msgid "Take on the Defense Force of the top 10 players."
msgstr "Sfida la forza di difesa dei 10 migliori giocatori."

msgctxt "15||network_friend||explanation"
msgid "Challenge your Friends on PlayStation™Network.\r\n*EXP and rewards are not given in this mode."
msgstr "Sfida i tuoi amici sul PlayStation™Network.\r\n*In questa modalità non si ottengono EXP o ricompense."

msgctxt "16||network_agreement||explanation"
msgid "Review the terms of use."
msgstr "Consulta i Termini d'uso."

