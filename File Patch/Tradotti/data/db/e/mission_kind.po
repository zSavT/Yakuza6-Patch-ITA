msgctxt "542||m_adv03_150||mission_info"
msgid ""
"(Chapter 3)\r\n"
"It seems like I'll be able to get some milk from\r\n"
"the barber shop over in the bar district."
msgstr ""
"(Capitolo 3)\r\n"
"Sembra che riuscirò a prendere del latte dal\r\n"
"barbiere nel quartiere dei bar."

msgctxt "543||i_harutobtl_c03_a||mission_info"
msgid ""
"These guys are a real thorn in my side.\r\n"
"Not much choice but to fight them, though."
msgstr ""
"Questi tizi sono una vera spina nel fianco.\r\n"
"Non ho altra scelta se non combatterli, però."

msgctxt "544||i_42_falling||mission_info"
msgid ""
"Someone's going to fall off the roof\r\n"
"of the arcade. I need to help them!"
msgstr ""
"Qualcuno sta per cadere dal tetto\r\n"
"della sala giochi. Devo aiutarlo!"

