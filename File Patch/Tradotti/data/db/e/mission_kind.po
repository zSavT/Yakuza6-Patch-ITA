msgctxt "298||i_03_event_encount_A01||mission_info"
msgid ""
"I'll crush these bastards for\r\n"
"targeting defenseless women."
msgstr ""
"Distruggerò questi bastardi per\r\n"
"aver preso di mira delle donne indifese."

msgctxt "299||i_03_event_encount_A02||mission_info"
msgid ""
