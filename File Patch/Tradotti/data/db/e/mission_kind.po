msgctxt "292||i_01_event_encount_A01||mission_info"
msgid ""
"These guys are notorious for mugging civilians.\r\n"
"Now it's their turn to pay up."
msgstr ""
"Questi tizi sono famosi per rapinare i civili.\r\n"
"Ora è il loro turno di pagare."

