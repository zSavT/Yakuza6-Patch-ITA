msgctxt "537||m_adv11_040||mission_info"
msgid ""
"(Chapter 11)\r\n"
"I need to tell Nagumo and the others\r\n"
"what's going on before I head up to Kamurocho."
msgstr ""
"(Capitolo 11)\r\n"
"Devo dire a Nagumo e agli altri\r\n"
"cosa sta succedendo prima di andare a Kamurocho."

msgctxt "540||m_adv01_120_before||mission_info"
msgid ""
"(Chapter 1)\r\n"
"Let's see if there's any more info near Sky Finance..."
msgstr ""
"(Capitolo 1)\r\n"
"Vediamo se ci sono altre informazioni vicino alla Sky Finance..."

