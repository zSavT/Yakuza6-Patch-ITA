msgctxt "608||s_SUB_A_06_03_02||mission_info"
msgid ""
"I keep hearing someone calling for help on Tenkaichi\r\n"
"Street. Pretty sure it's coming from higher up..."
msgstr ""
"Continuo a sentire qualcuno chiamare aiuto in Tenkaichi\r\n"
"Street. Sono abbastanza sicuro che provenga dall'alto..."

msgctxt "609||s_SUB_A_14_02||mission_info"
msgid ""
"The legendary Paul Lim...\r\n"
"I should play him again if I have some time."
msgstr ""
"Il leggendario Paul Lim...\r\n"
"Dovrei sfidarlo di nuovo se avrò un po' di tempo."

msgctxt "610||i_tm18_houkama_k01||mission_info"
msgid ""
"If this arsonist likes to set fires so much,\r\n"
"I'll give him the heat he deserves."
msgstr ""
"Se a questo piromane piace così tanto appiccare incendi,\r\n"
"gli darò io il fuoco che si merita."

msgctxt "611||i_tm19_kaji_k02||mission_info"
msgid ""
"Sounds like there's a small fire in Kamurocho.\r\n"
"I should find a fire extinguisher and put it out."
msgstr ""
"Sembra che ci sia un piccolo incendio a Kamurocho.\r\n"
"Dovrei trovare un estintore e spegnerlo."

msgctxt "612||i_tm20_kaji_k03||mission_info"
msgid ""
"Another small fire in Kamurocho.\r\n"
"I should find a fire extinguisher and put it out."
msgstr ""
"Un altro piccolo incendio a Kamurocho.\r\n"
"Dovrei trovare un estintore e spegnerlo."

msgctxt "613||i_tm21_kaji_k04||mission_info"
msgid ""
"Yet another small fire in Kamurocho.\r\n"
"I should find a fire extinguisher and put it out."
msgstr ""
"Eppure un altro piccolo incendio a Kamurocho.\r\n"
"Dovrei trovare un estintore e spegnerlo."

msgctxt "614||i_tm22_kaji_k05||mission_info"
msgid ""
"Sounds like a building in Kamurocho is up in flames.\r\n"
"I should find a fire extinguisher and put it out."
msgstr ""
"Sembra che un edificio a Kamurocho sia in fiamme.\r\n"
"Dovrei trovare un estintore e spegnerlo."

msgctxt "615||i_tm24_kaji_o02||mission_info"
msgid ""
"Sounds like there's a small fire in Onomichi.\r\n"
"I should find a fire extinguisher and put it out."
msgstr ""
"Sembra che ci sia un piccolo incendio a Onomichi.\r\n"
"Dovrei trovare un estintore e spegnerlo."

msgctxt "616||i_tm25_kaji_o03||mission_info"
msgid ""
