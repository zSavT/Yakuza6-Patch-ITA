msgid "Save the civilian"
msgstr "Salva il civile"

msgctxt "122||i_haruto_dandle||mission"
msgid "Get Haruto to stop crying"
msgstr "Fai smettere di piangere Haruto"

msgctxt "123||i_encount_btl||mission"
msgid "Defeat the enemy"
msgstr "Sconfiggi il nemico"

msgctxt "124||i_test_encount_boss||mission"
msgid "Defeat the powerful enemy"
msgstr "Sconfiggi il potente nemico"

msgctxt "128||i_09_ikinari_shikaku||mission"
msgid "Defeat the assassin"
msgstr "Sconfiggi il sicario"

msgctxt "129||i_11_kami_ga_nai||mission"
msgid "Help the man in the bathroom"
msgstr "Aiuta l'uomo in bagno"

msgctxt "130||i_25_kuinige||mission"
msgid "Catch the dine-and-dasher"
msgstr "Cattura lo scroccone"

msgctxt "135||m_adv01_050||mission"
msgid "I need a plan to find Haruka."
msgstr "Mi serve un piano per trovare Haruka."

msgctxt "136||m_adv01_070||mission"
msgid "Why did Akiyama change his number?"
msgstr "Perché Akiyama ha cambiato numero?"

msgctxt "138||m_adv01_086||mission"
msgid "I wanted to avoid this..."
msgstr "Volevo evitarlo..."

msgctxt "141||m_adv01_150||mission"
msgid "Finally, a warm lead on Akiyama."
msgstr "Finalmente una pista su Akiyama."

msgctxt "142||m_adv01_160||mission"
msgid "The homeless guy deserves that much."
msgstr "Il senzatetto si merita almeno questo."

msgctxt "143||m_adv01_170||mission"
msgid "Akiyama's really down there?"
msgstr "Akiyama è davvero laggiù?"

msgctxt "144||m_adv01_210||mission"
msgid "What happened to Haruka!?"
msgstr "Cos'è successo ad Haruka!?"

msgctxt "145||m_adv02_010||mission"
msgid "There's got to be some clues here."
msgstr "Ci deve essere qualche indizio qui."

msgctxt "146||m_adv02_060||mission"
msgid "The last place I want to be..."
msgstr "L'ultimo posto in cui vorrei essere..."

msgctxt "147||m_adv02_070||mission"
msgid "Maybe there's been an update."
msgstr "Forse c'è qualche novità."

msgctxt "148||m_adv02_071||mission"
msgid "This town has to know something."
msgstr "Questa città deve sapere qualcosa."

msgctxt "149||m_adv03_010||mission"
msgid "Someone must know Haruka."
msgstr "Qualcuno deve conoscere Haruka."

msgctxt "150||m_adv03_050||mission"
msgid "Haruto is waiting for me."
msgstr "Haruto mi sta aspettando."

msgctxt "152||m_adv03_110||mission"
msgid "Haruto won't calm down!"
msgstr "Haruto non vuole calmarsi!"

msgctxt "153||m_adv03_120||mission"
msgid "They should have some milk."
msgstr "Dovrebbero avere del latte."

msgctxt "154||m_adv03_130||mission"
msgid "She can reach Ino at this hour."
msgstr "Lei può contattare Ino a quest'ora."

msgctxt "155||m_adv03_140||mission"
msgid "I just need milk..."
msgstr "Mi serve solo del latte..."

msgctxt "156||m_adv03_160||mission"
msgid "We've earned some rest."
msgstr "Ci siamo guadagnati un po' di riposo."

msgctxt "157||m_adv03_180||mission"
msgid "I should hit the town again."
msgstr "Dovrei farmi di nuovo un giro in città."

msgctxt "158||m_adv03_190||mission"
msgid "I owe Kiyomi a lot."
msgstr "Devo molto a Kiyomi."

msgctxt "160||m_adv03_250||mission"
msgid "Kiyomi asked me to stop by."
msgstr "Kiyomi mi ha chiesto di passare."

msgctxt "161||m_adv03_270||mission"
msgid "This fool..."
msgstr "Questo idiota..."

msgctxt "162||m_adv03_271||mission"
msgid "Looks like I need to walk."
msgstr "Sembra che io debba camminare."

msgctxt "163||m_adv04_020||mission"
msgid "Nothing about this sounded right."
msgstr "Non c'era niente di rassicurante in questo."

msgctxt "164||m_adv04_060||mission"
msgid "Haruto's waiting for me."
msgstr "Haruto mi sta aspettando."

msgctxt "165||m_adv04_090||mission"
msgid "Now I can ask them about Haruto."
msgstr "Ora posso chiedere loro di Haruto."

msgctxt "166||m_adv04_140||mission"
msgid "Kiyomi has something to say."
msgstr "Kiyomi ha qualcosa da dirmi."

msgctxt "167||m_adv04_210||mission"
msgid "He can't take the fall for this."
msgstr "Non può prendersi la colpa per questo."

msgctxt "168||m_adv05_010||mission"
msgid "I guess I've got time to explore."
msgstr "Credo di avere tempo per esplorare."

msgctxt "169||m_adv06_040||mission"
msgid "We can discuss the plan there."
msgstr "Possiamo discutere il piano lì."

msgctxt "171||m_adv06_120||mission"
msgid "The Jingweon have Stardust..."
msgstr "I Jingweon hanno lo Stardust..."

msgctxt "172||m_adv06_190||mission"
msgid "Found you, Tatsukawa."
msgstr "Ti ho trovato, Tatsukawa."

msgctxt "173||m_adv07_010||mission"
msgid "Nagumo and Yuta are waiting."
msgstr "Nagumo e Yuta mi stanno aspettando."

msgctxt "174||m_adv07_120||mission"
msgid "We'll meet Akiyama there."
msgstr "Incontreremo Akiyama lì."

msgctxt "175||m_adv08_060||mission"
msgid "This brings back bad memories."
msgstr "Questo riporta alla mente brutti ricordi."

msgctxt "176||m_adv09_010||mission"
msgid "I need to catch up with the others."
msgstr "Devo raggiungere gli altri."

msgctxt "177||m_adv09_030||mission"
msgid "Matsunaga and Tagashira are there."
msgstr "Matsunaga e Tagashira sono lì."

msgctxt "179||m_adv09_150||mission"
msgid "Hirose apparently drinks here."
msgstr "A quanto pare Hirose beve qui."

msgctxt "180||m_adv09_170||mission"
msgid "Let's get some answers."
msgstr "Andiamo a prendere delle risposte."

msgctxt "181||m_adv10_030||mission"
msgid "Is everyone okay?"
msgstr "Stanno tutti bene?"

msgctxt "182||m_adv10_050||mission"
msgid "Ino apparently has a boat for us."
msgstr "A quanto pare Ino ha una barca per noi."

msgctxt "183||m_adv11_020||mission"
msgid "Let's head home."
msgstr "Andiamo a casa."

msgctxt "184||m_adv11_080||mission"
msgid "I can't take Haruto to Little Asia."
msgstr "Non posso portare Haruto a Little Asia."

msgctxt "186||m_btl01_010||mission"
msgid "This guy's getting on my nerves."
msgstr "Questo tizio mi sta dando sui nervi."

msgctxt "187||m_btl01_020||mission"
msgid "I didn't ask for this."
msgstr "Non l'ho chiesto io."

msgctxt "188||m_btl01_030||mission"
msgid "I won't let them murder that guy."
msgstr "Non permetterò che uccidano quel tizio."

msgctxt "189||m_btl01_040||mission"
msgid "This guy's gonna be a problem."
msgstr "Questo tizio sarà un problema."

msgctxt "190||m_btl02_010||mission"
msgid "Why would he take pictures of me?"
msgstr "Perché dovrebbe scattarmi delle foto?"

msgctxt "191||m_btl02_020||mission"
msgid "Not even you can stand in my way."
msgstr "Nemmeno tu puoi metterti sulla mia strada."

msgctxt "192||m_btl03_010||mission"
msgid "This guy's a sorry excuse for a yakuza."
msgstr "Questo tizio è una povera scusa per uno yakuza."

msgctxt "193||m_btl03_020||mission"
msgid "Let's teach some manners."
msgstr "Insegniamo un po' di buone maniere."

msgctxt "194||m_btl03_030||mission"
msgid "Clear the bench..."
msgstr "Rissa in campo..."

msgctxt "195||m_btl03_040||mission"
msgid "Nagumo doesn't deserve to die."
msgstr "Nagumo non merita di morire."

msgctxt "196||m_btl04_010||mission"
msgid "Every town has its assholes."
msgstr "Ogni città ha i suoi stronzi."

msgctxt "197||m_btl04_020||mission"
msgid "Must have wounded Masuzoe's pride."
msgstr "Devo aver ferito l'orgoglio di Masuzoe."

msgctxt "198||m_btl04_030||mission"
msgid "You're just slowing me down, guys."
msgstr "Mi state solo rallentando, ragazzi."

msgctxt "199||m_btl04_040||mission"
msgid "He wants a second beating."
msgstr "Vuole un'altra lezione."

msgctxt "200||m_btl05_010_01||mission"
msgid "We have a welcoming party."
msgstr "Abbiamo un comitato di benvenuto."

msgctxt "201||m_btl05_010_02||mission"
msgid "I need to search the guest rooms."
msgstr "Devo perquisire le stanze degli ospiti."

msgctxt "202||m_btl05_010_03||mission"
msgid "I need to search the guest rooms."
msgstr "Devo perquisire le stanze degli ospiti."

msgctxt "203||m_btl05_020||mission"
msgid "Get back here!"
msgstr "Torna qui!"

msgctxt "204||m_btl05_030||mission"
msgid "Modern yakuza... Right."
msgstr "Yakuza moderna... Certo."

msgctxt "205||m_btl06_010||mission"
msgid "Their grudges never die."
msgstr "I loro rancori non muoiono mai."

msgctxt "206||m_btl06_020||mission"
msgid "I'll finish the fight, Yuta."
msgstr "Finirò io lo scontro, Yuta."

msgctxt "207||m_btl07_010||mission"
msgid "I fell right into their trap..."
msgstr "Sono caduto dritto nella loro trappola..."

msgctxt "208||m_btl07_020||mission"
msgid "Who are these guys?"
msgstr "Chi sono questi tizi?"

msgctxt "209||m_btl07_030||mission"
msgid "He must be somewhere here."
msgstr "Deve essere da qualche parte qui."

msgctxt "210||m_btl07_040||mission"
msgid "I'll make him talk."
msgstr "Lo farò parlare."

msgctxt "211||m_btl08_010||mission"
msgid "This was a lot easier before."
msgstr "Questo era molto più facile prima."

msgctxt "212||m_btl08_020||mission"
msgid "He had it all planned out."
msgstr "Aveva pianificato tutto."

msgctxt "213||m_btl09_010||mission"
msgid "The Yomei Alliance thinks they're strong."
msgstr "L'Alleanza Yomei pensa di essere forte."

msgctxt "214||m_btl09_020||mission"
msgid "(Chapter Nine)"
msgstr "(Capitolo 9)"

msgctxt "215||m_btl09_030||mission"
msgid "These guys are in my way."
msgstr "Questi tizi sono in mezzo ai piedi."

msgctxt "216||m_btl09_040||mission"
msgid "(Chapter Nine)"
msgstr "(Capitolo 9)"

msgctxt "217||m_btl09_050||mission"
msgid "He won't slow me down."
msgstr "Non mi rallenterà."

msgctxt "218||m_btl10_010||mission"
msgid "This is for Haruto!"
msgstr "Questo è per Haruto!"

msgctxt "219||m_btl10_020||mission"
msgid "Why is he here?"
msgstr "Perché è qui?"

msgctxt "220||m_btl10_030||mission"
msgid "Haruto!"
