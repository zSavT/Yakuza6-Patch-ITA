msgctxt "47||rarabai_weak00||ゲーム中の独り言_4"
msgid "I'll fight till the end!"
msgstr "Lotterò fino alla fine!"

msgctxt "48||rarabai_weak01||ゲーム中の独り言_4"
msgid "Ah, nicely played."
msgstr "Ah, ben giocata."

msgctxt "49||rarabai_weak02||ゲーム中の独り言_4"
msgid "I can't lose."
msgstr "Non posso perdere."

msgctxt "50||rarabai_weak03||ゲーム中の独り言_4"
msgid "Gimme some tea!"
msgstr "Datemi del tè!"

msgctxt "51||rarabai_weak04||ゲーム中の独り言_4"
msgid "I could use a vacation."
msgstr "Mi servirebbe una vacanza."

msgctxt "52||rarabai_middle00||ゲーム中の独り言_4"
msgid "Right, let's play."
msgstr "Bene, giochiamo."

msgctxt "53||rarabai_middle01||ゲーム中の独り言_4"
msgid "Man, too far..."
msgstr "Amico, è troppo lontano..."

msgctxt "54||rarabai_middle02||ゲーム中の独り言_4"
msgid "Not too bad."
msgstr "Non c'è male."

msgctxt "55||rarabai_middle03||ゲーム中の独り言_4"
msgid "Can go for tenpai with this."
msgstr "Posso puntare al tenpai con questo."

msgctxt "56||rarabai_middle04||ゲーム中の独り言_4"
msgid "Where'd I put that candy?"
msgstr "Dove ho messo quella caramella?"

msgctxt "57||kindai_middle00||ゲーム中の独り言_4"
msgid "Wow, I'm doing great!"
msgstr "Wow, sto andando alla grande!"

msgctxt "58||kindai_middle01||ゲーム中の独り言_4"
msgid "Got a good feelin'!"
msgstr "Ho un buon presentimento!"

msgctxt "59||kindai_middle02||ゲーム中の独り言_4"
msgid "These draws are garbage."
msgstr "Queste pescate fanno schifo."

msgctxt "60||kindai_middle03||ゲーム中の独り言_4"
msgid "What to have for dinner...?"
msgstr "Cosa mangio per cena...?"

msgctxt "61||kindai_middle04||ゲーム中の独り言_4"
msgid "Is this table rigged?"
msgstr "Questo tavolo è truccato?"

msgctxt "62||kindai_strong00||ゲーム中の独り言_4"
msgid "This is not a game of luck."
msgstr "Questo non è un gioco di fortuna."

msgctxt "63||kindai_strong01||ゲーム中の独り言_4"
msgid "I'm getting in the groove."
msgstr "Sto entrando nel ritmo."

msgctxt "64||kindai_strong02||ゲーム中の独り言_4"
msgid "Mahjong is my life."
msgstr "Il Mahjong è la mia vita."

msgctxt "65||kindai_strong03||ゲーム中の独り言_4"
msgid "Don't ya think mahjong's the best?"
msgstr "Non pensi che il Mahjong sia il massimo?"

msgctxt "66||kindai_strong04||ゲーム中の独り言_4"
msgid "I have a good feeling about this!"
msgstr "Ho un buon presentimento a riguardo!"

msgctxt "67||rarabai_event_00||ゲーム中の独り言_4"
msgid "Don't be so cocksure, kid."
msgstr "Non fare il gradasso, ragazzino."

msgctxt "68||rarabai_event_01||ゲーム中の独り言_4"
msgid "Gotta make a change..."
msgstr "Devo cambiare qualcosa..."

msgctxt "69||rarabai_event_02||ゲーム中の独り言_4"
msgid "I might even win!"
msgstr "Potrei persino vincere!"

msgctxt "70||kindai_event_00||ゲーム中の独り言_4"
msgid "I have only just begun..."
msgstr "Ho appena iniziato..."

msgctxt "71||kindai_event_01||ゲーム中の独り言_4"
msgid "It's time for me to shine."
msgstr "È il mio momento di brillare."

msgctxt "72||kindai_event_02||ゲーム中の独り言_4"
msgid "The air is thick with anticipation."
msgstr "L'aria è carica di aspettative."

msgctxt "47||rarabai_weak00||ゲーム中の独り言_2"
msgid "Can't stop me now!"
msgstr "Nessuno può fermarmi!"

msgctxt "48||rarabai_weak01||ゲーム中の独り言_2"
msgid "Not sure what to do."
msgstr "Non so cosa fare."

msgctxt "49||rarabai_weak02||ゲーム中の独り言_2"
msgid "Easy peasy."
msgstr "Gioco da ragazzi."

msgctxt "50||rarabai_weak03||ゲーム中の独り言_2"
msgid "His wife's useless..."
msgstr "Sua moglie è un'incapace..."

msgctxt "51||rarabai_weak04||ゲーム中の独り言_2"
msgid "Oh, this is good."
msgstr "Oh, questo è buono."

msgctxt "52||rarabai_middle00||ゲーム中の独り言_2"
msgid "Someone tell me a joke."
msgstr "Qualcuno mi racconti una barzelletta."

msgctxt "53||rarabai_middle01||ゲーム中の独り言_2"
msgid "Oh boy..."
msgstr "Oh cavolo..."

msgctxt "54||rarabai_middle02||ゲーム中の独り言_2"
msgid "How's it goin'?"
msgstr "Come va?"

msgctxt "55||rarabai_middle03||ゲーム中の独り言_2"
msgid "Not a bad draw."
msgstr "Non è una cattiva pescata."

msgctxt "56||rarabai_middle04||ゲーム中の独り言_2"
msgid "My salary's peanuts..."
msgstr "Mi pagano due spiccioli..."

msgctxt "57||kindai_middle00||ゲーム中の独り言_2"
msgid "Crap, luck's not on my side..."
msgstr "Cavolo, la fortuna non è dalla mia..."

msgctxt "58||kindai_middle01||ゲーム中の独り言_2"
msgid "Gettin' bored here."
msgstr "Mi sto annoiando."

msgctxt "59||kindai_middle02||ゲーム中の独り言_2"
msgid "Going well..."
msgstr "Sta andando bene..."

msgctxt "60||kindai_middle03||ゲーム中の独り言_2"
msgid "Now that's a good draw."
msgstr "Questa sì che è una bella pescata."

msgctxt "61||kindai_middle04||ゲーム中の独り言_2"
msgid "This game's all mine."
msgstr "Questa partita è mia."

msgctxt "62||kindai_strong00||ゲーム中の独り言_2"
msgid "I'll eat you alive."
msgstr "Vi mangerò vivi."

msgctxt "63||kindai_strong01||ゲーム中の独り言_2"
msgid "I can't give up just yet."
msgstr "Non posso arrendermi proprio ora."

msgctxt "64||kindai_strong02||ゲーム中の独り言_2"
msgid "I will stay in this until the end."
msgstr "Resterò in gioco fino alla fine."

msgctxt "65||kindai_strong03||ゲーム中の独り言_2"
msgid "Which am I gonna get rid of...?"
msgstr "Di quale mi sbarazzo...?"

msgctxt "66||kindai_strong04||ゲーム中の独り言_2"
msgid "I hope I can win this one..."
msgstr "Spero di poter vincere questa..."

msgctxt "67||rarabai_event_00||ゲーム中の独り言_2"
msgid "What've we got here?"
msgstr "Che abbiamo qui?"

msgctxt "68||rarabai_event_01||ゲーム中の独り言_2"
msgid "Damn!"
msgstr "Maledizione!"

msgctxt "69||rarabai_event_02||ゲーム中の独り言_2"
msgid "I hate to lose..."
msgstr "Odio perdere..."

msgctxt "70||kindai_event_00||ゲーム中の独り言_2"
msgid "Silence. We are locked in battle."
msgstr "Silenzio. Siamo nel mezzo di una battaglia."

msgctxt "71||kindai_event_01||ゲーム中の独り言_2"
msgid "Things're getting good now."
msgstr "Le cose si fanno interessanti."

msgctxt "72||kindai_event_02||ゲーム中の独り言_2"
msgid "I wonder, how is this going to play out?"
msgstr "Mi chiedo, come andrà a finire?"

msgctxt "47||rarabai_weak00||桐生リーチ時_3"
msgid "Oh, I see!"
msgstr "Oh, capisco!"

msgctxt "48||rarabai_weak01||桐生リーチ時_3"
msgid "Huh, already?"
msgstr "Eh, già?"

msgctxt "49||rarabai_weak02||桐生リーチ時_3"
msgid "Now we're talking."
msgstr "Ora si ragiona."

msgctxt "50||rarabai_weak03||桐生リーチ時_3"
msgid "Think you can beat me?"
msgstr "Pensi di potermi battere?"

msgctxt "51||rarabai_weak04||桐生リーチ時_3"
msgid "Come on, relax a little."
msgstr "Dai, rilassati un po'."

msgctxt "52||rarabai_middle00||桐生リーチ時_3"
msgid "So what?"
msgstr "E allora?"

msgctxt "53||rarabai_middle01||桐生リーチ時_3"
msgid "Good move."
msgstr "Buona mossa."

msgctxt "54||rarabai_middle02||桐生リーチ時_3"
msgid "That your move? I see."
msgstr "È la tua mossa? Capisco."

msgctxt "55||rarabai_middle03||桐生リーチ時_3"
msgid "Aha! I see."
msgstr "Aha! Vedo."

msgctxt "56||rarabai_middle04||桐生リーチ時_3"
msgid "Don't be like that."
msgstr "Non fare così."

msgctxt "57||kindai_middle00||桐生リーチ時_3"
msgid "Man, you're lucky."
msgstr "Cavolo, sei fortunato."

msgctxt "58||kindai_middle01||桐生リーチ時_3"
msgid "That's no fair!"
msgstr "Non è giusto!"

msgctxt "59||kindai_middle02||桐生リーチ時_3"
msgid "Whoa, take it easy."
msgstr "Whoa, dacci un taglio."

msgctxt "60||kindai_middle03||桐生リーチ時_3"
msgid "Aren't you aggressive?"
msgstr "Sei aggressivo, eh?"

msgctxt "61||kindai_middle04||桐生リーチ時_3"
msgid "Too easy."
msgstr "Troppo facile."

msgctxt "62||kindai_strong00||桐生リーチ時_3"
msgid "So that's your move..."
msgstr "Così questa è la tua mossa..."

msgctxt "63||kindai_strong01||桐生リーチ時_3"
msgid "Well that's a problem."
msgstr "Beh, questo è un problema."

msgctxt "64||kindai_strong02||桐生リーチ時_3"
msgid "How did you riichi so soon!?"
msgstr "Come hai fatto a chiamare Riichi così presto!?"

msgctxt "65||kindai_strong03||桐生リーチ時_3"
msgid "Oooh, nice riichi!"
msgstr "Oooh, bel Riichi!"

msgctxt "66||kindai_strong04||桐生リーチ時_3"
msgid "My heart's gonna pop!"
msgstr "Mi scoppierà il cuore!"

msgctxt "67||rarabai_event_00||桐生リーチ時_3"
msgid "We're just getting started."
msgstr "Abbiamo appena iniziato."

msgctxt "68||rarabai_event_01||桐生リーチ時_3"
msgid "Don't get cocky."
msgstr "Non montarti la testa."

msgctxt "69||rarabai_event_02||桐生リーチ時_3"
msgid "This is so exciting!"
msgstr "Che emozione!"

msgctxt "70||kindai_event_00||桐生リーチ時_3"
msgid "Enough of your insolence."
msgstr "Basta con questa insolenza."

msgctxt "71||kindai_event_01||桐生リーチ時_3"
msgid "That's a bold move."
msgstr "Una mossa audace."

msgctxt "72||kindai_event_02||桐生リーチ時_3"
msgid "The suspense is tearing me up!"
msgstr "Questa suspense mi sta logorando!"

msgctxt "47||rarabai_weak00||桐生が長考_1"
msgid "Hurry it up."
msgstr "Datti una mossa."

msgctxt "48||rarabai_weak01||桐生が長考_1"
msgid "Don't make me wait."
msgstr "Non farmi aspettare."

msgctxt "49||rarabai_weak02||桐生が長考_1"
msgid "Ahem. I'm waiting."
msgstr "Ahem. Sto aspettando."

msgctxt "50||rarabai_weak03||桐生が長考_1"
msgid "I'll teach you some manners."
msgstr "Ti insegnerò io un po' di buone maniere."

msgctxt "51||rarabai_weak04||桐生が長考_1"
msgid "We don't have all day."
msgstr "Non abbiamo tutto il giorno."

msgctxt "52||rarabai_middle00||桐生が長考_1"
msgid "We're waitin', dumbass."
msgstr "Stiamo aspettando, coglione."

msgctxt "53||rarabai_middle01||桐生が長考_1"
msgid "Hurry up already."
msgstr "Muoviti."

msgctxt "54||rarabai_middle02||桐生が長考_1"
msgid "Time is money, pal."
msgstr "Il tempo è denaro, amico."

msgctxt "55||rarabai_middle03||桐生が長考_1"
msgid "You got that good a hand?"
msgstr "Hai una mano così buona?"

msgctxt "56||rarabai_middle04||桐生が長考_1"
msgid "Hurry it up, will ya?"
msgstr "Ti vuoi sbrigare?"

msgctxt "57||kindai_middle00||桐生が長考_1"
msgid "You don't need to overthink it."
msgstr "Non c'è bisogno di pensarci troppo."

msgctxt "58||kindai_middle01||桐生が長考_1"
msgid "Didja pass out?"
msgstr "Sei svenuto?"

msgctxt "59||kindai_middle02||桐生が長考_1"
msgid "Ho hum..."
msgstr "Uhm..."

msgctxt "60||kindai_middle03||桐生が長考_1"
msgid "I've got a date after this."
msgstr "Ho un appuntamento dopo."

msgctxt "61||kindai_middle04||桐生が長考_1"
msgid "Time is money, you know."
msgstr "Il tempo è denaro, lo sai."

msgctxt "62||kindai_strong00||桐生が長考_1"
msgid "I could eat a horse."
msgstr "Ho una fame da lupi."

msgctxt "63||kindai_strong01||桐生が長考_1"
msgid "You're screwing with my rhythm."
msgstr "Stai sballando il mio ritmo."

msgctxt "64||kindai_strong02||桐生が長考_1"
msgid "I sincerely hope you're still awake."
msgstr "Spero vivamente che tu sia ancora sveglio."

msgctxt "65||kindai_strong03||桐生が長考_1"
msgid "Hey, do I get to go yet?"
msgstr "Ehi, tocca a me o no?"

msgctxt "66||kindai_strong04||桐生が長考_1"
msgid "What a downer."
msgstr "Che barba."

msgctxt "67||rarabai_event_00||桐生が長考_1"
msgid "Get a move on."
msgstr "Muoviti."

msgctxt "68||rarabai_event_01||桐生が長考_1"
msgid "Thinking won't help."
msgstr "Pensare non ti aiuterà."

msgctxt "69||rarabai_event_02||桐生が長考_1"
msgid "Hey, are you asleep?"
msgstr "Ehi, stai dormendo?"

msgctxt "70||kindai_event_00||桐生が長考_1"
msgid "Time is not an infinite resource."
msgstr "Il tempo non è una risorsa infinita."

msgctxt "71||kindai_event_01||桐生が長考_1"
msgid "Thinking won't help you now."
msgstr "Pensare non ti aiuterà ora."

msgctxt "72||kindai_event_02||桐生が長考_1"
msgid "This is pretty annoying."
msgstr "Inizia a essere fastidioso."

msgctxt "47||rarabai_weak00||開始時_3"
msgid "I like a good challenge."
msgstr "Mi piacciono le belle sfide."

msgctxt "48||rarabai_weak01||開始時_3"
msgid "I'll go easy on you."
msgstr "Ci andrò piano con te."

msgctxt "49||rarabai_weak02||開始時_3"
msgid "Time for some fun."
msgstr "Ora ci si diverte."

msgctxt "50||rarabai_weak03||開始時_3"
msgid "I'll show you how it's done."
msgstr "Ti farò vedere io come si gioca."

msgctxt "51||rarabai_weak04||開始時_3"
msgid "I'm so going to enjoy this."
msgstr "Mi divertirò un mondo."

msgctxt "52||rarabai_middle00||開始時_3"
msgid "Imma make ya cry."
msgstr "Ti farò piangere."

msgctxt "53||rarabai_middle01||開始時_3"
msgid "Here I go!"
msgstr "Si comincia!"

msgctxt "54||rarabai_middle02||開始時_3"
msgid "It's all luck in the end."
msgstr "Alla fine è tutta fortuna."

msgctxt "55||rarabai_middle03||開始時_3"
msgid "Gonna win this one."
msgstr "Questa la vinco io."

msgctxt "56||rarabai_middle04||開始時_3"
msgid "My tiles are just peachy!"
msgstr "Le mie tessere sono perfette!"

msgctxt "57||kindai_middle00||開始時_3"
msgid "Hope I can get lucky..."
msgstr "Spero di avere fortuna..."

msgctxt "58||kindai_middle01||開始時_3"
msgid "Uh oh. You got Nine Gates?"
msgstr "Uh oh. Hai un Chuuren Poutou?"

msgctxt "59||kindai_middle02||開始時_3"
msgid "This'll be a long game..."
msgstr "Sarà una partita lunga..."

msgctxt "60||kindai_middle03||開始時_3"
msgid "Think I'm easy? Wrong!"
msgstr "Pensi che sia un bersaglio facile? Sbagliato!"

msgctxt "61||kindai_middle04||開始時_3"
msgid "Getting interesting."
msgstr "Si fa interessante."

msgctxt "62||kindai_strong00||開始時_3"
msgid "I wonder if anyone can stop me."
msgstr "Mi chiedo se qualcuno possa fermarmi."

msgctxt "63||kindai_strong01||開始時_3"
msgid "I don't wanna lose this one."
msgstr "Non voglio perdere questa partita."

msgctxt "64||kindai_strong02||開始時_3"
msgid "The fire of mahjong burns within me."
msgstr "Il fuoco del Mahjong arde in me."

msgctxt "65||kindai_strong03||開始時_3"
msgid "Yayayay, it's time for some fun!"
msgstr "Evviva, è ora di divertirsi!"

msgctxt "66||kindai_strong04||開始時_3"
msgid "Maybe I can win this one!"
msgstr "Forse posso vincerla!"

msgctxt "67||rarabai_event_00||開始時_3"
msgid "I'll destroy you now."
msgstr "Ti distruggerò."

msgctxt "68||rarabai_event_01||開始時_3"
msgid "You're going down."
msgstr "Andrai al tappeto."

msgctxt "69||rarabai_event_02||開始時_3"
msgid "I'll play it safe for now."
msgstr "Per ora giocherò sul sicuro."

msgctxt "70||kindai_event_00||開始時_3"
msgid "Well then, let us commence."
msgstr "Ebbene, iniziamo."

msgctxt "71||kindai_event_01||開始時_3"
msgid "I wonder if you can beat me."
msgstr "Chissà se riuscirai a battermi."

msgctxt "72||kindai_event_02||開始時_3"
msgid "I think this game will be mine."
msgstr "Credo che questa partita sarà mia."

msgctxt "47||rarabai_weak00||桐生がツモ_3"
msgid "Who do you take me for!?"
msgstr "Per chi mi hai preso!?"

msgctxt "48||rarabai_weak01||桐生がツモ_3"
msgid "Good tiles."
msgstr "Belle tessere."

msgctxt "49||rarabai_weak02||桐生がツモ_3"
msgid "That can't be right."
msgstr "Non è possibile."

msgctxt "50||rarabai_weak03||桐生がツモ_3"
msgid "Got to be on my toes..."
msgstr "Devo stare all'erta..."

msgctxt "51||rarabai_weak04||桐生がツモ_3"
msgid "Keep me entertained."
msgstr "Fammi divertire."

msgctxt "52||rarabai_middle00||桐生がツモ_3"
msgid "Learn some tact, dimwit."
msgstr "Impara un po' di tatto, idiota."

msgctxt "53||rarabai_middle01||桐生がツモ_3"
msgid "Hold on a sec!"
msgstr "Aspetta un secondo!"

msgctxt "54||rarabai_middle02||桐生がツモ_3"
msgid "Gimme a share of your luck."
msgstr "Dammi un po' della tua fortuna."

msgctxt "55||rarabai_middle03||桐生がツモ_3"
msgid "Time for tsumo?"
msgstr "Tempo di Tsumo?"

msgctxt "56||rarabai_middle04||桐生がツモ_3"
msgid "Huh?"
msgstr "Huh?"

msgctxt "57||kindai_middle00||桐生がツモ_3"
msgid "Booo."
msgstr "Buuu."

msgctxt "58||kindai_middle01||桐生がツモ_3"
msgid "Almost had a heart attack!"
msgstr "Mi è quasi venuto un infarto!"

msgctxt "59||kindai_middle02||桐生がツモ_3"
msgid "That one, huh?"
msgstr "Quello, eh?"

msgctxt "60||kindai_middle03||桐生がツモ_3"
msgid "That was close..."
msgstr "Ci è mancato poco..."

msgctxt "61||kindai_middle04||桐生がツモ_3"
msgid "Let's see how it goes."
msgstr "Vediamo come va."

msgctxt "62||kindai_strong00||桐生がツモ_3"
msgid "You're unbreakable..."
msgstr "Sei indistruttibile..."

msgctxt "63||kindai_strong01||桐生がツモ_3"
msgid "This has gotta be a fluke..."
msgstr "Deve essere un colpo di fortuna..."

msgctxt "64||kindai_strong02||桐生がツモ_3"
msgid "You are the victor."
msgstr "Tu sei il vincitore."

msgctxt "65||kindai_strong03||桐生がツモ_3"
msgid "Whaaat, you already got a tsumo?"
msgstr "Cooosa, hai già fatto Tsumo?"

msgctxt "66||kindai_strong04||桐生がツモ_3"
msgid "Such a bummer."
msgstr "Che seccatura."

msgctxt "67||rarabai_event_00||桐生がツモ_3"
msgid "You're not that bad."
msgstr "Non sei niente male."

msgctxt "68||rarabai_event_01||桐生がツモ_3"
msgid "Oh, damn it."
msgstr "Oh, maledizione."

msgctxt "69||rarabai_event_02||桐生がツモ_3"
msgid "Got lucky!"
msgstr "Che fortuna!"

msgctxt "70||kindai_event_00||桐生がツモ_3"
msgid "...You are quite strong indeed."
msgstr "...Sei davvero forte."

msgctxt "71||kindai_event_01||桐生がツモ_3"
msgid "Lady Luck is with you now."
msgstr "La Dea Bendata è con te."

msgctxt "72||kindai_event_02||桐生がツモ_3"
msgid "I'll resent you for this..."
msgstr "Te la farò pagare..."

msgctxt "47||rarabai_weak00||振込み時_2"
msgid "Seriously!?"
msgstr "Sul serio!?"

msgctxt "48||rarabai_weak01||振込み時_2"
msgid "Don't be mean."
msgstr "Non essere cattivo."

msgctxt "49||rarabai_weak02||振込み時_2"
msgid "Where'd I go wrong?"
msgstr "Dove ho sbagliato?"

msgctxt "50||rarabai_weak03||振込み時_2"
msgid "Trying to make me look bad!?"
msgstr "Stai cercando di farmi fare una brutta figura!?"

msgctxt "51||rarabai_weak04||振込み時_2"
msgid "No way..."
msgstr "Non è possibile..."

msgctxt "52||rarabai_middle00||振込み時_2"
msgid "Pick on someone else."
msgstr "Prenditela con qualcun altro."

msgctxt "53||rarabai_middle01||振込み時_2"
msgid "For crap's sake..."
msgstr "Porca miseria..."

msgctxt "54||rarabai_middle02||振込み時_2"
msgid "Did my luck run out?"
msgstr "La mia fortuna è finita?"

msgctxt "55||rarabai_middle03||振込み時_2"
msgid "Huh. Not too sharp..."
msgstr "Uhm. Non è stato molto furbo..."

msgctxt "56||rarabai_middle04||振込み時_2"
msgid "Gotta be kiddin' me!"
msgstr "Devi stare scherzando!"

msgctxt "57||kindai_middle00||振込み時_2"
msgid "Ouch..."
msgstr "Ahi..."

msgctxt "58||kindai_middle01||振込み時_2"
msgid "What the<symbol=em_dash_with_outline>!"
msgstr "Ma che<symbol=em_dash_with_outline>!"

msgctxt "59||kindai_middle02||振込み時_2"
