msgid ""
msgstr ""
"Project-Id-Version: Yakuza 6 Translation\n"
"Last-Translator: SavT\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Language: it\n"

msgctxt "0||||4"
msgid "Kiryu-san! Sorry to keep you waiting. <symbol=note_with_outline>"
msgstr "Kiryu-san! Scusa per l'attesa. <symbol=note_with_outline>"

msgctxt "1||||4"
msgid "Sorry! Did I make you wait?"
msgstr "Scusami! Ti ho fatto aspettare?"

msgctxt "2||||4"
msgid "Kiryu-san! I'm excited to see you again. <symbol=note_with_outline>"
msgstr "Kiryu-san! Sono felicissima di rivederti. <symbol=note_with_outline>"

msgctxt "3||||4"
msgid "So, where should we go?"
msgstr "Allora, dove andiamo?"

msgctxt "4||||4"
msgid "Karaoke, huh? Sounds good! <symbol=note_with_outline>"
msgstr "Karaoke, eh? Mi sembra un'ottima idea! <symbol=note_with_outline>"

msgctxt "5||||4"
msgid "I don't normally play darts, but I'm excited!"
msgstr "Di solito non gioco a freccette, ma non vedo l'ora!"

msgctxt "6||||4"
msgid "Okay, let's go! <symbol=note_with_outline>"
msgstr "Okay, andiamo! <symbol=note_with_outline>"

msgctxt "7||||4"
msgid "I wonder what you'll sing... <symbol=heart_with_outline>"
msgstr "Chissà cosa canterai... <symbol=heart_with_outline>"

msgctxt "8||||4"
msgid "What should I sing today? <symbol=note_with_outline>"
msgstr "Cosa dovrei cantare oggi? <symbol=note_with_outline>"

msgctxt "9||||4"
msgid "I'm not so good, so go easy on me! <symbol=heart_with_outline>"
msgstr "Non sono molto brava, quindi vacci piano con me! <symbol=heart_with_outline>"

msgctxt "10||||4"
msgid "Okay, here I go!"
msgstr "Okay, vado!"

msgctxt "11||||4"
msgid "Let's just focus on enjoying the rest, okay? <symbol=note_with_outline>"
msgstr "Concentriamoci solo sul goderci il resto, okay? <symbol=note_with_outline>"

msgctxt "12||||4"
msgid "That was fun! We should come back soon. <symbol=note_with_outline>"
msgstr "È stato divertente! Dovremmo tornarci presto. <symbol=note_with_outline>"

msgctxt "13||||4"
msgid "That was so fun! <symbol=heart_with_outline>\r\nWe should definitely do this again sometime. <symbol=note_with_outline>"
msgstr "È stato divertentissimo! <symbol=heart_with_outline>\r\nDovremmo assolutamente rifarlo qualche volta. <symbol=note_with_outline>"

msgctxt "14||||4"
msgid "Shall we head back to the club?"
msgstr "Torniamo al club?"

msgctxt "15||||4"
msgid "This one's my specialty. <symbol=note_with_outline>"
msgstr "Questa è la mia specialità. <symbol=note_with_outline>"

msgctxt "16||||4"
msgid "Oh, maybe I'll sing this one. <symbol=note_with_outline>"
msgstr "Oh, forse canterò questa. <symbol=note_with_outline>"

msgctxt "17||||4"
msgid "Hmm... I guess that song was too hard."
msgstr "Mhm... Immagino che quella canzone fosse troppo difficile."

msgctxt "18||||4"
msgid "It was kinda hard to sing..."
msgstr "È stato un po' difficile da cantare..."

msgctxt "19||||4"
msgid "It was really fun to sing with you. <symbol=note_with_outline>"
msgstr "È stato davvero divertente cantare con te. <symbol=note_with_outline>"

msgctxt "20||||4"
msgid "That song felt really good!\r\nYou're great at keeping the mood up! <symbol=note_with_outline>"
msgstr "Quella canzone è stata fantastica!\r\nSei bravissimo a tenere alto il morale! <symbol=note_with_outline>"

msgctxt "21||||4"
msgid "I want to hear you sing something, too. <symbol=note_with_outline>"
msgstr "Voglio sentirti cantare qualcosa anch'io. <symbol=note_with_outline>"

msgctxt "22||||4"
msgid "Aww... There's no need to be shy..."
msgstr "Aww... Non c'è bisogno di fare il timido..."

msgctxt "23||||4"
msgid "Oh... Uh... That was good...!"
msgstr "Oh... Ehm... È stato bello...!"

msgctxt "24||||4"
msgid "You're so good, Kiryu-san. <symbol=note_with_outline>"
msgstr "Sei davvero bravo, Kiryu-san. <symbol=note_with_outline>"

msgctxt "25||||4"
msgid "You sing incredibly well. <symbol=note_with_outline> I could listen\r\nto you sing like that for hours on end. <symbol=heart_with_outline>"
msgstr "Canti incredibilmente bene. <symbol=note_with_outline> Potrei ascoltarti\r\ncantare così per ore e ore. <symbol=heart_with_outline>"

msgctxt "26||||4"
msgid "Whoa! You've got deep pockets!"
msgstr "Whoa! Non badi certo a spese!"

msgctxt "27||||4"
msgid "Thank you very much!"
msgstr "Grazie mille!"

msgctxt "28||||4"
msgid "Huh...?"
msgstr "Eh...?"

msgctxt "29||||4"
msgid "Oh, I like that one, too. <symbol=note_with_outline>"
msgstr "Oh, piace un sacco anche a me. <symbol=note_with_outline>"

msgctxt "30||||4"
msgid "Thank you for waiting."
msgstr "Grazie per avermi aspettata."

msgctxt "31||||4"
msgid "It's a pleasure to meet you. I'm Hikaru."
msgstr "È un piacere conoscerti. Sono Hikaru."

msgctxt "32||||4"
msgid "Um, and your name is?"
msgstr "Ehm, e il tuo nome è?"

msgctxt "33||||4"
msgid "Oh. I'm Kiryu."
msgstr "Oh. Sono Kiryu."

msgctxt "34||||4"
msgid "Kiryu-san? Well then, I look forward to spending some\r\ntime with you, Kiryu-san!"
msgstr "Kiryu-san? Bene allora, non vedo l'ora di passare\r\ndel tempo con te, Kiryu-san!"

msgctxt "35||||4"
msgid "Yeah, same here."
msgstr "Sì, lo stesso vale per me."

msgctxt "36||||4"
msgid "Thank you for coming in today, Kiryu-san.\r\nI enjoyed all the different topics! <symbol=note_with_outline>"
msgstr "Grazie per essere venuto oggi, Kiryu-san.\r\nMi sono piaciuti un sacco tutti i nostri discorsi! <symbol=note_with_outline>"

msgctxt "37||||4"
msgid "Come back soon, won't you? <symbol=heart_with_outline>"
msgstr "Torna presto a trovarmi, d'accordo? <symbol=heart_with_outline>"

msgctxt "38||||4"
msgid "Yeah, I'll be back."
msgstr "Sì, tornerò."

msgctxt "39||||4"
msgid "And I'll be waiting. <symbol=heart_with_outline>"
msgstr "E io ti aspetterò. <symbol=heart_with_outline>"

msgctxt "40||||4"
msgid "Thanks for visiting me again, Kiryu-san."
msgstr "Grazie per essere tornato a trovarmi, Kiryu-san."

msgctxt "41||||4"
msgid "Kiryu-san, welcome back.\r\nI've been waiting for you. <symbol=heart_with_outline>"
msgstr "Kiryu-san, bentornato.\r\nTi stavo aspettando. <symbol=heart_with_outline>"

msgctxt "42||||4"
msgid "Kiryu-san, welcome back.\r\nI was hoping you'd come back again... <symbol=heart_with_outline>"
msgstr "Kiryu-san, bentornato.\r\nSperavo che saresti tornato... <symbol=heart_with_outline>"

msgctxt "43||||4"
msgid "I'd like to spend more time\r\nwith you today. <symbol=heart_with_outline>"
msgstr "Mi piacerebbe passare più tempo\r\ncon te oggi. <symbol=heart_with_outline>"

msgctxt "44||||4"
msgid "Right this way."
msgstr "Da questa parte."

msgctxt "45||||4"
msgid "Kiryu-san!"
msgstr "Kiryu-san!"

msgctxt "46||||4"
msgid "Thank you for coming today. <symbol=note_with_outline>\r\nI'll be waiting for your next visit."
msgstr "Grazie per essere venuto oggi. <symbol=note_with_outline>\r\nAspetterò la tua prossima visita."

msgctxt "47||||4"
msgid "Thank you for coming today. <symbol=note_with_outline>\r\nCome back soon. <symbol=heart_with_outline>"
msgstr "Grazie per essere venuto oggi. <symbol=note_with_outline>\r\nTorna presto. <symbol=heart_with_outline>"

msgctxt "48||||4"
msgid "Thank you for coming today. <symbol=note_with_outline>\r\nI hope to see you again soon... <symbol=heart_with_outline>"
msgstr "Grazie per essere venuto oggi. <symbol=note_with_outline>\r\nSpero di rivederti presto... <symbol=heart_with_outline>"

msgctxt "49||||4"
msgid "Let's have some fun today. <symbol=heart_with_outline>"
msgstr "Divertiamoci un po' oggi. <symbol=heart_with_outline>"

msgctxt "50||||4"
msgid "Cheers! <symbol=note_with_outline>"
msgstr "Salute! <symbol=note_with_outline>"

msgctxt "51||||4"
msgid "Um, Kiryu-san!"
msgstr "Ehm, Kiryu-san!"

msgctxt "52||||4"
msgid "Here, you can have my phone number.\r\nCall me anytime you want, okay? <symbol=heart_with_outline>"
msgstr "Tieni, ti lascio il mio numero di telefono.\r\nChiamami quando vuoi, okay? <symbol=heart_with_outline>"

msgctxt "53||||4"
msgid "It looks like our time's up."
msgstr "Sembra che il nostro tempo sia scaduto."

msgctxt "54||||4"
msgid "We're out of time,\r\nbut I'd love to talk more..."
msgstr "Abbiamo finito il tempo,\r\nma mi piacerebbe parlare ancora un po'..."

msgctxt "55||||4"
msgid "I'm so happy! <symbol=note_with_outline>\r\nYou're the best, Kiryu-san. <symbol=heart_with_outline>"
msgstr "Sono così felice! <symbol=note_with_outline>\r\nSei il migliore, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "56||||4"
msgid "Thank you so much for today! <symbol=note_with_outline>"
msgstr "Grazie mille per oggi! <symbol=note_with_outline>"

msgctxt "57||||4"
msgid "Okay, got it! <symbol=note_with_outline>"
msgstr "Okay, ricevuto! <symbol=note_with_outline>"

msgctxt "58||||4"
msgid "Hmm, okay..."
msgstr "Mhm, d'accordo..."

msgctxt "59||||4"
msgid "Yeah!"
msgstr "Sì!"

msgctxt "60||||4"
msgid "If you don't mind... <symbol=heart_with_outline>"
msgstr "Se non ti dispiace... <symbol=heart_with_outline>"

msgctxt "61||||4"
msgid "No way."
msgstr "Assolutamente no."

msgctxt "62||||4"
msgid "That's not right at all!"
msgstr "Non è affatto giusto!"

msgctxt "63||||4"
msgid "What? You think so?"
msgstr "Cosa? Lo pensi davvero?"

msgctxt "64||||4"
msgid "I'll pass. <symbol=note_with_outline>"
msgstr "Passo. <symbol=note_with_outline>"

msgctxt "65||||4"
msgid "Wow, really?"
msgstr "Wow, sul serio?"

msgctxt "66||||4"
msgid "See you later!"
msgstr "A più tardi!"

msgctxt "67||||4"
msgid "Oh, Kiryu-san. <symbol=heart_with_outline>"
msgstr "Oh, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "68||||4"
msgid "That's top secret. <symbol=note_with_outline>"
msgstr "Questo è un segreto. <symbol=note_with_outline>"

msgctxt "69||||4"
msgid "Um... Did you have fun talking\r\nwith me today, Kiryu-san?"
msgstr "Ehm... Ti sei divertito a parlare\r\ncon me oggi, Kiryu-san?"

msgctxt "70||||4"
msgid "What? Where's this coming from?"
msgstr "Cosa? Da dove spunta questa domanda?"

msgctxt "71||||4"
msgid "My customers are always telling me\r\nI'm too quiet, or that I have no energy."
msgstr "I miei clienti continuano a dirmi\r\nche sono troppo silenziosa, o che non ho energia."

msgctxt "72||||4"
msgid "Oh. Well, you do seem pretty calm."
msgstr "Oh. Beh, in effetti sembri piuttosto tranquilla."

msgctxt "73||||4"
msgid "Lately, I've been wondering if a hostess\r\nneeds to be more upbeat and energetic."
msgstr "Ultimamente mi chiedo se una hostess\r\ndebba essere più allegra ed energica."

msgctxt "74||||4"
msgid "I mean, the girls like that get more customers,\r\nand they bring in more profit for the club."
msgstr "Voglio dire, le ragazze così attirano più clienti,\r\ne portano più profitti al club."

msgctxt "75||||4"
msgid "That's what you're worried about?"
msgstr "È questo che ti preoccupa?"

msgctxt "76||||4"
msgid "Then, why don't we practice being energetic?"
msgstr "Allora, perché non provi a fare pratica con l'energia?"

msgctxt "77||||4"
msgid "Huh? Practice?"
msgstr "Eh? Pratica?"

msgctxt "78||||4"
msgid "Yeah, if you want to become your ideal self,\r\nyou have to put in the effort first."
msgstr "Sì, se vuoi diventare la tua versione ideale,\r\ndevi prima di tutto impegnarti."

msgctxt "79||||4"
msgid "You've gotta face the challenge head on, with\r\nthe knowledge that you can become better."
msgstr "Devi affrontare la sfida a testa alta, con\r\nla consapevolezza di poter migliorare."

msgctxt "80||||4"
msgid "I see... I think you're right.\r\nYou mind if we give it a shot?"
msgstr "Capisco... Credo tu abbia ragione.\r\nTi dispiace se facciamo un tentativo?"

msgctxt "81||||4"
msgid "No prob."
msgstr "Nessun problema."

msgctxt "82||||4"
msgid "Yaaaaay!"
msgstr "Evviiiiva!"

msgctxt "83||||4"
msgid "Hmmm..."
msgstr "Uhm..."

msgctxt "84||||4"
msgid "Yahoo!"
msgstr "Yahoo!"

msgctxt "85||||4"
msgid "Nice..."
msgstr "Bene..."

msgctxt "86||||4"
msgid "Kiryu-san... I just can't do it... Wait,\r\ndid you trick me into this to tease me?"
msgstr "Kiryu-san... Non ce la faccio... Aspetta,\r\nmi hai convinto a farlo solo per prendermi in giro?"

msgctxt "87||||4"
msgid "You got me..."
msgstr "Mi hai beccato..."

msgctxt "88||||4"
msgid "Oh come on, Kiryu-san!\r\nAt least try to help me out!"
msgstr "Oh andiamo, Kiryu-san!\r\nAlmeno prova ad aiutarmi!"

msgctxt "89||||4"
msgid "Sorry, sorry. But it got you to be a\r\nlittle more energetic, right?"
msgstr "Scusa, scusa. Però ti ha fatto diventare\r\nun pochino più energica, giusto?"

msgctxt "90||||4"
msgid "You're right... Shoot.\r\nYou're better than I thought."
msgstr "Hai ragione... Caspita.\r\nSei più in gamba di quanto pensassi."

msgctxt "91||||4"
msgid "Well, you're fun to be with just as you\r\nare. I don't think you need to force it."
msgstr "Beh, è divertente stare con te così come\r\nsei. Non credo che tu debba forzarti di cambiare."

msgctxt "92||||4"
msgid "Thank you. You're right.\r\nI'll try to work on it in my own way."
msgstr "Grazie. Hai ragione.\r\nCercherò di lavorarci a modo mio."

msgctxt "93||||4"
msgid "Hikaru, I think you're fine as you are."
msgstr "Hikaru, io credo che tu vada bene così come sei."

msgctxt "94||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "95||||4"
msgid "Not everyone comes to a cabaret club\r\nexpecting a wild party with energetic girls."
msgstr "Non tutti vengono in un cabaret club aspettandosi\r\nuna festa scatenata con ragazze piene di energia."

msgctxt "96||||4"
msgid "Some guys just want to have a drink with a\r\ngirl like you in a place they can relax."
msgstr "Alcuni ragazzi vogliono solo bersi qualcosa con una\r\nragazza come te in un posto in cui potersi rilassare."

msgctxt "97||||4"
msgid "Kind of like... me."
msgstr "Un po' come... me."

msgctxt "98||||4"
msgid "Kiryu-san..."
msgstr "Kiryu-san..."

msgctxt "99||||4"
msgid "So, stay just the way you are."
msgstr "Quindi, resta così come sei."

msgctxt "100||||4"
msgid "There's nothing so wrong with you that you'd\r\nneed to hide who you really are, you know?"
msgstr "Non c'è niente di così sbagliato in te da doverti\r\nnascondere per quella che sei veramente, sai?"

msgctxt "101||||4"
msgid "Kiryu-san... <symbol=heart_with_outline> Thank you so much.\r\nI'm feeling really optimistic all of a sudden."
msgstr "Kiryu-san... <symbol=heart_with_outline> Grazie mille.\r\nMi sento davvero ottimista tutto d'un tratto."

msgctxt "102||||4"
msgid "I'll work hard in my own, relaxed way. I hope\r\nyou'll keep coming to take it easy with me. <symbol=heart_with_outline>"
msgstr "Lavorerò sodo a modo mio, rilassandomi. Spero che\r\ncontinuerai a venire per prendertela comoda con me. <symbol=heart_with_outline>"

msgctxt "103||||4"
msgid "Yeah, of course."
msgstr "Sì, certo."

msgctxt "104||||4"
msgid "If you're worried about something as silly as that,\r\nhow about I spend all my money to make you number one?"
msgstr "Se ti preoccupi per una sciocchezza del genere,\r\nche ne diresti se spendessi tutti i miei soldi per farti diventare la numero uno?"

msgctxt "105||||4"
msgid "Huh!? Oh no, I could never. Please don't\r\nwaste your money on something like that."
msgstr "Eh!? Oh no, non potrei mai. Per favore, non\r\nsprecare i tuoi soldi per una cosa del genere."

msgctxt "106||||4"
msgid "But... then you'd be number one, yeah?"
msgstr "Ma... così diventeresti la numero uno, no?"

msgctxt "107||||4"
msgid "But... that doesn't feel right.\r\nI want to aim for the top in my own way."
msgstr "Ma... non mi sembra la cosa giusta da fare.\r\nVoglio puntare alla vetta a modo mio."

msgctxt "108||||4"
msgid "I thought you might say that.\r\nLooks like you already have your answer."
msgstr "Immaginavo che l'avresti detto.\r\nSembra che tu abbia già la tua risposta."

msgctxt "109||||4"
msgid "Oh..."
msgstr "Oh..."

msgctxt "110||||4"
msgid "I think you've gotta be yourself, Hikaru.\r\nI like that, and that's why I requested you."
msgstr "Credo che tu debba solo essere te stessa, Hikaru.\r\nÈ questo che mi piace, ed è per questo che ti ho richiesta."

msgctxt "111||||4"
msgid "Kiryu-san... Thank you. You're right.\r\nI shouldn't push myself too hard."
msgstr "Kiryu-san... Grazie. Hai ragione.\r\nNon dovrei sforzarmi troppo."

msgctxt "112||||4"
msgid "I'll work hard in my own, relaxed way! I hope\r\nyou'll come back and help me see it through."
msgstr "Lavorerò sodo a modo mio, rilassandomi! Spero\r\nche tornerai per aiutarmi a vederne i risultati."

msgctxt "113||||4"
msgid "Yeah. Give it your best shot."
msgstr "Sì. Dai il massimo."

msgctxt "114||||4"
msgid "Just curious, but, why'd you\r\ndecide to become a hostess?"
msgstr "Semplice curiosità, ma perché hai\r\ndeciso di diventare una hostess?"

msgctxt "115||||4"
msgid "I'm a student, so... I need to pay my tuition.\r\nI'm paying my own way through school."
msgstr "Sono una studentessa, quindi... devo pagarmi le tasse.\r\nMi sto pagando gli studi da sola."

msgctxt "116||||4"
msgid "That's admirable."
msgstr "È una cosa ammirevole."

msgctxt "117||||4"
msgid "Oh, not at all. I'm about to graduate,\r\nso I really oughta be looking for a real job..."
msgstr "Oh, per niente. Sto per laurearmi,\r\nquindi dovrei davvero iniziare a cercare un lavoro vero..."

msgctxt "118||||4"
msgid "So, have you been?"
msgstr "E l'hai fatto?"

msgctxt "119||||4"
msgid "No, actually... I have a dream...\r\nI want to become an idol."
msgstr "No, in realtà... Ho un sogno...\r\nVoglio diventare un'idol."

msgctxt "120||||4"
msgid "An idol?"
msgstr "Un'idol?"

msgctxt "121||||4"
msgid "Yeah... I've been looking into it a little\r\nhere and there, but it's not going anywhere..."
msgstr "Sì... Ho fatto qualche ricerca un po'\r\nqui e un po' lì, ma non sta portando a nulla..."

msgctxt "122||||4"
msgid "I'm already 23... I should probably give\r\nup on that and look for a real job, right?"
msgstr "Ho già 23 anni... Probabilmente dovrei\r\nrinunciarci e cercare un vero lavoro, giusto?"

msgctxt "123||||4"
msgid "I'm behind you all the way.\r\nYou shouldn't give up on your dreams."
msgstr "Io faccio il tifo per te fino in fondo.\r\nNon dovresti rinunciare ai tuoi sogni."

msgctxt "124||||4"
msgid "Really?"
msgstr "Davvero?"

msgctxt "125||||4"
msgid "Yeah. You only live once, so you've\r\ngotta make your time count."
msgstr "Sì. Si vive una volta sola, quindi devi\r\nfare in modo che il tuo tempo valga qualcosa."

msgctxt "126||||4"
msgid "But, if you don't fully commit to it, you may\r\nactually regret not giving up when you could have."
msgstr "Ma se non ti ci dedichi anima e corpo, potresti davvero\r\npentirti di non aver mollato quando ne avevi la possibilità."

msgctxt "127||||4"
msgid "So... decide whether or not you're serious about\r\nthis, and make the call. If you are, I'm behind you."
msgstr "Quindi... decidi se fai sul serio oppure no\r\ne prendi una decisione. Se è così, io ti appoggerò."

msgctxt "128||||4"
msgid "Kiryu-san... Thank you."
msgstr "Kiryu-san... Grazie."

msgctxt "129||||4"
msgid "Your words hit me really hard... Maybe I was\r\nnaive for even worrying over it."
msgstr "Le tue parole mi hanno colpita nel profondo... Forse sono stata\r\ningenua anche solo a preoccuparmene in questo modo."

msgctxt "130||||4"
msgid "I'll have to dig deep and give it some real thought.\r\nIf I do decide to go for it... I hope you'll root for me!"
msgstr "Dovrò guardarmi dentro e pensarci seriamente.\r\nE se decidessi di provarci... Spero farai il tifo per me!"

msgctxt "131||||4"
msgid "Of course. I'll be your first fan."
msgstr "Certo. Sarò il tuo primo fan."

msgctxt "132||||4"
msgid "Yaaay! <symbol=heart_with_outline> I'll work hard at it!"
msgstr "Evviva! <symbol=heart_with_outline> Lavorerò sodo!"

msgctxt "133||||4"
msgid "Shouldn't you at least be looking?"
msgstr "Non dovresti almeno dare un'occhiata in giro?"

msgctxt "134||||4"
msgid "So you think so too, huh?"
msgstr "Quindi lo pensi anche tu, eh?"

msgctxt "135||||4"
msgid "Yeah. But I only feel that way because\r\nI can tell you're being indecisive."
msgstr "Sì. Ma la penso così solo perché\r\nposso capire che sei indecisa."

msgctxt "136||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "137||||4"
msgid "If you really want to make a dream come true,\r\nyou have to be determined to see it happen."
msgstr "Se vuoi davvero che un sogno diventi realtà,\r\ndevi essere determinata a realizzarlo."

msgctxt "138||||4"
msgid "If you're hesitating now, then you may as well\r\ngive it up. Being an idol is no walk in the park."
msgstr "Se esiti adesso, tanto vale lasciar perdere.\r\nFare l'idol non è affatto una passeggiata."

msgctxt "139||||4"
msgid "Kiryu-san..."
msgstr "Kiryu-san..."

msgctxt "140||||4"
msgid "But, if one day you can say from the bottom of\r\nyour heart that you want to be an idol, I'm behind you."
msgstr "Ma, se un giorno potrai dire dal profondo del cuore\r\ndi voler diventare un'idol, farò il tifo per te."

msgctxt "141||||4"
msgid "Everyone looks up to idols, and idols have to\r\nshoulder those dreams. It's no walk in the park."
msgstr "Tutti ammirano le idol, e le idol devono farsi\r\ncarico di quei sogni. Non è affatto una passeggiata."

msgctxt "142||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "143||||4"
msgid "I actually know a former idol, and society and the\r\nmedia can be both a blessing and a curse."
msgstr "In realtà conosco un'ex idol, e la società e i\r\nmedia possono essere sia una benedizione che una maledizione."

msgctxt "144||||4"
msgid "If you mess up, everything can come crashing down\r\nin an instant. It's that strict, and you have to be strong."
msgstr "Se fai un passo falso, tutto può crollarti addosso\r\nin un istante. È un mondo spietato, e devi essere forte."

msgctxt "145||||4"
msgid "So, I can't just casually say, yeah, go for it,\r\nyou have my support."
msgstr "Quindi, non posso limitarmi a dire: «sì, buttati,\r\nhai tutto il mio sostegno»."

msgctxt "146||||4"
msgid "......"
msgstr "......"

msgctxt "147||||4"
msgid "But, it's also the kind of job where your hard work and\r\ndetermination pay off by giving people courage and smiles."
msgstr "Ma è anche quel tipo di lavoro in cui il tuo duro lavoro e la tua\r\ndeterminazione vengono ripagati regalando coraggio e sorrisi alla gente."

msgctxt "148||||4"
msgid "If you're ready to bear that burden...\r\nThen I'm behind you all the way."
msgstr "Se sei pronta a farti carico di un tale fardello...\r\nAllora io faccio il tifo per te fino in fondo."

msgctxt "149||||4"
msgid "Kiryu-san... Thank you."
msgstr "Kiryu-san... Grazie."

msgctxt "150||||4"
msgid "You're actually the first person who's taken it\r\nthat seriously and been honest about it. I'm so happy."
msgstr "In realtà sei la prima persona che ha preso la cosa così\r\nseriamente e che è stata sincera al riguardo. Sono così felice."

msgctxt "151||||4"
msgid "I... may have been a little naive. You can't aim\r\nfor something this hard half-heartedly."
msgstr "Io... forse sono stata un po' ingenua. Non si può puntare\r\na qualcosa di così difficile senza metterci il cuore."

msgctxt "152||||4"
msgid "I think I need to take a long, hard look in the mirror."
msgstr "Credo di aver bisogno di un lungo e profondo esame di coscienza."

msgctxt "153||||4"
msgid "Yeah."
msgstr "Già."

msgctxt "154||||4"
msgid "And I hope that one day I'll be able to tell you\r\nthat I want to become an idol with pride."
msgstr "E spero che un giorno sarò in grado di poterti dire\r\ncon orgoglio che voglio diventare un'idol."

msgctxt "155||||4"
msgid "When you do, I'll be your first fan."
msgstr "Quando lo farai, io sarò il tuo primo fan."

msgctxt "156||||4"
msgid "Okay! <symbol=heart_with_outline> I'll work so hard, you won't be able\r\nto take your eyes off me!"
msgstr "Okay! <symbol=heart_with_outline> Lavorerò così sodo che non riuscirai\r\npiù a staccarmi gli occhi di dosso!"

msgctxt "157||||4"
msgid "So? Did you end up figuring out if you want\r\nto look for a job or get into the idol thing?"
msgstr "Allora? Alla fine hai capito se vuoi cercare\r\nun lavoro vero o buttarti in quella cosa dell'idol?"

msgctxt "158||||4"
msgid "Yes. I was actually thinking about\r\nhow I'd tell you that today."
msgstr "Sì. A dire il vero stavo proprio pensando a\r\ncome dirtelo quest'oggi."

msgctxt "159||||4"
msgid "I, Hikaru Shiota, hereby declare that\r\nI'm going to try to become a top idol!"
msgstr "Io, Hikaru Shiota, dichiaro solennemente che\r\nproverò a diventare una top idol!"

msgctxt "160||||4"
msgid "I thought you might."
msgstr "Immaginavo che l'avresti fatto."

msgctxt "161||||4"
msgid "Yeah! And if I don't seem serious,\r\nI'm telling you, I'm quite serious!"
msgstr "Sì! E anche se non sembro seria al riguardo,\r\nti assicuro che sto facendo maledettamente sul serio!"

msgctxt "162||||4"
msgid "And it's all thanks to your encouragement,\r\nKiryu-san. Thank you!"
msgstr "Ed è tutto merito del tuo incoraggiamento,\r\nKiryu-san. Grazie!"

msgctxt "163||||4"
msgid "Hey, I just say whatever pops into my head.\r\nGood luck with it."
msgstr "Ehi, io dico solo la prima cosa che mi passa per la testa.\r\nIn bocca al lupo."

msgctxt "164||||4"
msgid "Thanks! Though I still need to consider which\r\nof my traits I want to emphasize."
msgstr "Grazie! Anche se devo ancora decidere\r\nquali dei miei pregi voglio mettere in risalto."

msgctxt "165||||4"
msgid "Traits?"
msgstr "Pregi?"

msgctxt "166||||4"
msgid "Yeah. Sorta like a catchphrase. If you don't set\r\nyourself apart, you'll get lost in the crowd."
msgstr "Sì. Qualcosa tipo un tormentone. Se non ti\r\ndistingui dagli altri, finirai per perderti nella folla."

msgctxt "167||||4"
msgid "It's a competitive society we live in..."
msgstr "Viviamo proprio in una società competitiva..."

msgctxt "168||||4"
msgid "Yeah... So, Kiryu-san, do you have any\r\nsuggestions for a catchphrase that would fit me?"
msgstr "Già... Quindi, Kiryu-san, hai per caso qualche\r\nsuggerimento per un tormentone che faccia al caso mio?"

msgctxt "169||||4"
msgid "A catchphrase, huh... Let's see..."
msgstr "Un tormentone, eh... Vediamo un po'..."

msgctxt "170||||4"
msgid "How about, \"Check out my fine butt!\""
msgstr "Che ne dici di: \"Ammirate il mio bel sedere!\""

msgctxt "171||||4"
msgid "Kiryu-san... You really get how this works!"
msgstr "Kiryu-san... Tu sì che hai capito come funziona!"

msgctxt "172||||4"
msgid "I can't deny that my butt is part of my charm.\r\nIt might not be a bad idea to play that up!"
msgstr "Non posso negare che il mio sedere sia parte del mio fascino.\r\nPotrebbe non essere una cattiva idea puntare su quello!"

msgctxt "173||||4"
msgid "That said, I'm impressed that you noticed.\r\nThat means you're staring at my butt a lot, huh?"
msgstr "Detto questo, sono colpita che tu l'abbia notato.\r\nQuesto significa che lo fissi parecchio, eh?"

msgctxt "174||||4"
msgid "No, all it took was a single glance..."
msgstr "No, è bastata un'occhiata fugace..."

msgctxt "175||||4"
msgid "Ohhhh, you. It's written all over your face.\r\nYou're cute when you're embarrassed."
msgstr "Ohhhh, sei fantastico. Ti si legge in faccia.\r\nSei carino quando ti imbarazzi."

msgctxt "176||||4"
msgid "How about, \"I'm such a bright, energetic, and\r\nsunny girl, that you'll need shades!\""
msgstr "Che ne dici di: \"Sono una ragazza così solare, allegra ed\r\nenergica che vi serviranno gli occhiali da sole!\""

msgctxt "177||||4"
msgid "Kiryu-san, you're pretty good at this...\r\nThat does sound like a catchphrase."
msgstr "Kiryu-san, ci sai decisamente fare...\r\nSembra a tutti gli effetti un tormentone."

msgctxt "178||||4"
msgid "But I don't think I'm all that bright or\r\nenergetic, so, do you think that'll work?"
msgstr "Però non credo di essere poi così allegra o\r\nenergica, quindi, pensi davvero possa funzionare?"

msgctxt "179||||4"
msgid "Don't underestimate the power of words. If you\r\nsay you're bright and energetic, they'll believe it."
msgstr "Non sottovalutare il potere delle parole. Se dici\r\ndi essere allegra ed energica, loro ci crederanno."

msgctxt "180||||4"
msgid "I see. So it's kind of like getting out in front of\r\nmy shortcomings? Amazing! You're like my producer."
msgstr "Capisco. Quindi è un po' come giocare in anticipo per coprire\r\ni miei difetti? Fantastico! Sei proprio come il mio produttore."

msgctxt "181||||4"
msgid "It might work. Just keep it in mind."
msgstr "Potrebbe funzionare. Tienilo a mente."

msgctxt "182||||4"
msgid "Okay. <symbol=note_with_outline> Thank you, Producer Kiryu. <symbol=note_with_outline>"
msgstr "D'accordo. <symbol=note_with_outline> Grazie, Produttore Kiryu. <symbol=note_with_outline>"

msgctxt "183||||4"
msgid "How about \"Make way for the Princess of the\r\nHealer Kingdom!\""
msgstr "Che ne dici di: \"Fate largo alla Principessa del\r\nRegno delle Guaritrici!\""

msgctxt "184||||4"
msgid "Kiryu-san, you're so good at this!\r\nI appreciate the serious thought."
msgstr "Kiryu-san, sei davvero bravissimo a farlo!\r\nApprezzo che tu ci abbia pensato seriamente."

msgctxt "185||||4"
msgid "Well, I think your softness is what makes\r\nyou so unique."
msgstr "Beh, credo che la tua delicatezza sia ciò\r\nche ti rende così unica."

msgctxt "186||||4"
msgid "I only came up with it because I think a lot of guys\r\nlike me would be drawn to the promise of healing."
msgstr "L'ho tirato fuori solo perché penso che molti ragazzi\r\ncome me verrebbero attirati dalla prospettiva della cura."

msgctxt "187||||4"
msgid "I'm happy you think of me that way."
msgstr "Sono felice che tu la pensi così su di me."

msgctxt "188||||4"
msgid "And you even called me a princess... <symbol=note_with_outline>\r\nYou'll make me blush."
msgstr "E mi hai persino chiamata principessa... <symbol=note_with_outline>\r\nCosì mi farai arrossire."

msgctxt "189||||4"
msgid "Just food for thought.\r\nI hope you'll find the right approach."
msgstr "Sono solo spunti di riflessione.\r\nSpero che tu riesca a trovare l'approccio giusto."

msgctxt "190||||4"
msgid "Me too! <symbol=note_with_outline>\r\nThank you for your input, Producer Kiryu. <symbol=note_with_outline>"
msgstr "Anch'io! <symbol=note_with_outline>\r\nGrazie per i tuoi suggerimenti, Produttore Kiryu. <symbol=note_with_outline>"

msgctxt "191||||4"
msgid "You know, until now, my only joy in life\r\nwas my daily dose of dried sweet potatoes..."
msgstr "Sai, fino ad ora, la mia unica gioia nella vita\r\nera la mia dose quotidiana di patate dolci essiccate..."

msgctxt "192||||4"
msgid "But I've discovered that talking to you is\r\nsomething I've started looking forward to!"
msgstr "Ma ho scoperto che chiacchierare con te è\r\nuna cosa che ho iniziato ad attendere con ansia!"

msgctxt "193||||4"
msgid "So I'm on the same level\r\nas dried sweet potatoes?"
msgstr "Quindi sono allo stesso livello\r\ndelle patate dolci essiccate?"

msgctxt "194||||4"
msgid "Don't take it so negatively!\r\nI really, <font_kind=yakuza_italic>really</font_kind> like dried sweet potatoes."
msgstr "Non prenderla così negativamente!\r\nA me piacciono davvero, <font_kind=yakuza_italic>davvero</font_kind> tanto le patate dolci essiccate."

msgctxt "195||||4"
msgid "So being on that level means I <font_kind=yakuza_italic>really</font_kind>\r\nlike you too, Kiryu-san."
msgstr "Quindi essere a quel livello significa che mi piaci\r\ndavvero, <font_kind=yakuza_italic>davvero</font_kind> tanto anche tu, Kiryu-san."

msgctxt "196||||4"
msgid "Oh, what am I saying!?"
msgstr "Oh, ma che sto dicendo!?"

msgctxt "197||||4"
msgid "Anyway, I just wanted to say it's been fun\r\ntalking to you... It makes my heart race."
msgstr "Comunque, volevo solo dirti che è stato divertente\r\nparlare con te... Mi fa battere forte il cuore."

msgctxt "198||||4"
msgid "Your heart races, huh? That sounds...\r\n...like you might be a little love sick."
msgstr "Ti batte il cuore, eh? Sembra proprio...\r\n...che tu sia un po' innamorata."

msgctxt "199||||4"
msgid "Huh!?"
msgstr "Eh!?"

msgctxt "200||||4"
msgid "Just messing with you."
msgstr "Ti sto solo stuzzicando."

msgctxt "201||||4"
msgid "Come on, don't tease me.\r\nBesides... I'm not joking."
msgstr "Dai, non prendermi in giro.\r\nE poi... Non sto scherzando."

msgctxt "202||||4"
msgid "Hm? About what?"
msgstr "Mhm? Su cosa?"

msgctxt "203||||4"
msgid "It's nothing! Kiryu-san...\r\nYou're so dense."
msgstr "Niente! Kiryu-san...\r\nSei così tonto."

msgctxt "204||||4"
msgid "Am I?"
msgstr "Dici?"

msgctxt "205||||4"
msgid "Yeah, well... that's actually part of your\r\ncharm, I suppose."
msgstr "Sì, beh... suppongo che in realtà questo faccia\r\nparte del tuo fascino."

msgctxt "206||||4"
msgid "Hm... I'll take that as a compliment."
msgstr "Mhm... Lo prenderò come un complimento."

msgctxt "207||||4"
msgid "What a coincidence. Me too."
msgstr "Che coincidenza. Anch'io."

msgctxt "208||||4"
msgid "Huh!? Does that mean...\r\nYou feel the love too?"
msgstr "Eh!? Questo significa che...\r\nProvi amore anche tu?"

msgctxt "209||||4"
msgid "Yeah. I feel the same way."
msgstr "Sì. Mi sento allo stesso modo."

msgctxt "210||||4"
msgid "Oh no... What should I do?\r\nI'm not ready... and you're so bold..."
msgstr "Oh no... Cosa dovrei fare?\r\nNon sono pronta... e tu sei così sfacciato..."

msgctxt "211||||4"
msgid "But... I'm happy, Kiryu-san...\r\nAs long as it's with you, I..."
msgstr "Ma... sono felice, Kiryu-san...\r\nFinché sono con te, io..."

msgctxt "212||||4"
msgid "Hm? Where are you going with this?\r\nWe're talking about dried sweet potatoes, right?"
msgstr "Mhm? Dove vuoi arrivare con questo discorso?\r\nStiamo parlando di patate dolci essiccate, giusto?"

msgctxt "213||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "214||||4"
msgid "I love dried sweet potatoes, too."
msgstr "Anch'io adoro le patate dolci essiccate."

msgctxt "215||||4"
msgid "Oh, Kiryu-san! Don't be so vague when\r\nyou say such important things!"
msgstr "Oh, Kiryu-san! Non essere così vago quando\r\ndici cose tanto importanti!"

msgctxt "216||||4"
msgid "...Vague?"
msgstr "...Vago?"

msgctxt "217||||4"
msgid "...That's enough of that.\r\nI got all worked up for nothing."
msgstr "...Può bastare così.\r\nMi sono illusa per niente."

msgctxt "218||||4"
msgid "You're weird, Kiryu-san."
msgstr "Sei proprio strano, Kiryu-san."

msgctxt "219||||4"
msgid "You need to lay off the dried sweet potatoes."
msgstr "Devi darti una calmata con le patate dolci essiccate."

msgctxt "220||||4"
msgid "Huh? You think so?"
msgstr "Eh? Dici?"

msgctxt "221||||4"
msgid "You know... starch goes right to the stomach."
msgstr "Sai... L'amido va dritto dritto nello stomaco."

msgctxt "222||||4"
msgid "Besides, everything in moderation, you know?"
msgstr "Inoltre, per ogni cosa ci vuole moderazione, no?"

msgctxt "223||||4"
msgid "Okay. You're weird, Kiryu-san."
msgstr "Okay. Sei proprio strano, Kiryu-san."

msgctxt "224||||4"
msgid "Am I?"
msgstr "Dici?"

msgctxt "225||||4"
msgid "Yes. Of course, I mean that in a good way."
msgstr "Sì. E lo intendo in senso buono, ovviamente."

msgctxt "226||||4"
msgid "Kiryu-san, I actually have something\r\nI want to report!"
msgstr "Kiryu-san, in realtà c'è una cosa\r\nche voglio annunciarti!"

msgctxt "227||||4"
msgid "Oh yeah? What's the occasion?"
msgstr "Ah sì? Qual è l'occasione?"

msgctxt "228||||4"
msgid "I'm... going to sign a contract with a talent\r\nagency to become an idol!"
msgstr "Sto... per firmare un contratto con un'agenzia\r\ndi talenti per diventare un'idol!"

msgctxt "229||||4"
msgid "What? Really?"
msgstr "Cosa? Davvero?"

msgctxt "230||||4"
msgid "Yeah! I auditioned, made it through the test,\r\nand managed to get a call back!"
msgstr "Sì! Ho fatto un provino, ho superato il test\r\ne sono riuscita a ottenere un richiamo!"

msgctxt "231||||4"
msgid "That's great! You're an idol now!"
msgstr "È fantastico! Sei un'idol, adesso!"

msgctxt "232||||4"
msgid "Well, this is only where it starts.\r\nThe real challenge is what comes next."
msgstr "Beh, è solo l'inizio.\r\nLa vera sfida è ciò che verrà dopo."

msgctxt "233||||4"
msgid "But... it's all thanks to you, Kiryu-san.\r\nThank you so much!"
msgstr "Ma... è tutto merito tuo, Kiryu-san.\r\nGrazie infinite!"

msgctxt "234||||4"
msgid "I didn't do anything.\r\nIt was all you."
msgstr "Io non ho fatto niente.\r\nÈ tutta farina del tuo sacco."

msgctxt "235||||4"
msgid "No, this only happened because of\r\nwhat you said to me that one time."
msgstr "No, tutto questo è successo solo grazie a\r\nquello che mi hai detto l'altra volta."

msgctxt "236||||4"
msgid "I was afraid to commit to it, but you made me\r\ncome out of my shell and get serious about it."
msgstr "Avevo paura di impegnarmi, ma tu mi hai fatto\r\nuscire dal guscio e mi hai fatto fare sul serio."

msgctxt "237||||4"
msgid "You do seem more confident than back then.\r\nGive it your best shot, okay?"
msgstr "Sembri molto più sicura di te rispetto ad allora.\r\nDai il massimo, d'accordo?"

msgctxt "238||||4"
msgid "I will! I actually have a meeting with the\r\nagency after this."
msgstr "Lo farò! A dire il vero ho un appuntamento con\r\nl'agenzia subito dopo questo."

msgctxt "239||||4"
msgid "The interview was held at a different location, so\r\nthis'll be my first time going to the office. I'm nervous..."
msgstr "Il colloquio si è tenuto in un altro posto, quindi questa\r\nsarà la mia prima volta in quegli uffici. Sono nervosa..."

msgctxt "240||||4"
msgid "That's okay. There's a lot of different types of people\r\nin the entertainment industry, so just be careful, okay?"
msgstr "Va tutto bene. Ci sono un sacco di persone diverse\r\nnel mondo dello spettacolo, quindi sta' attenta, okay?"

msgctxt "241||||4"
msgid "I will. Thank you. <symbol=note_with_outline>"
msgstr "Lo farò. Grazie. <symbol=note_with_outline>"

msgctxt "242||||4"
msgid "Well, see you later, Kiryu-san. <symbol=note_with_outline>"
msgstr "Beh, ci vediamo dopo, Kiryu-san. <symbol=note_with_outline>"

msgctxt "243||||4"
msgid "Yeah."
msgstr "Sì."

msgctxt "244||||4"
msgid "Let's see... I like tea,\r\nso I go to a lot of tea parties."
msgstr "Vediamo... Mi piace il tè,\r\nquindi vado spesso ai tea party."

msgctxt "245||||4"
msgid "Yeah? Do you make your own tea?"
msgstr "Sì? Te lo prepari da sola il tè?"

msgctxt "246||||4"
msgid "Yes! Of course, I like drinking it, too."
msgstr "Sì! Certo, mi piace anche berlo."

msgctxt "247||||4"
msgid "Oh! Would you like me to make some\r\nfor you too, Kiryu-san?"
msgstr "Oh! Vuoi che ne prepari un po'\r\nanche per te, Kiryu-san?"

msgctxt "248||||4"
msgid "Sure. Looking forward to it."
msgstr "Certo. Non vedo l'ora."

msgctxt "249||||4"
msgid "Hmm... I usually go shopping,\r\nor I'll just wander around outside."
msgstr "Uhm... Di solito vado a fare shopping,\r\no semplicemente me ne vado a zonzo all'aperto."

msgctxt "250||||4"
msgid "I see.\r\nWhat kind of stuff do you shop for?"
msgstr "Capisco.\r\nChe tipo di cose compri di solito?"

msgctxt "251||||4"
msgid "Oh, just the usual women's stuff.\r\nBeauty products, cute clothes, you know."
msgstr "Oh, solo le solite cose da donne.\r\nProdotti di bellezza, vestiti carini, sai."

msgctxt "252||||4"
msgid "Let me buy next time."
msgstr "Lascia che paghi io la prossima volta."

msgctxt "253||||4"
msgid "Wow, really!?\r\nThat makes me happy! <symbol=note_with_outline>"
msgstr "Wow, sul serio!?\r\nQuesto mi rende molto felice! <symbol=note_with_outline>"

msgctxt "254||||4"
msgid "Buy some for me next time."
msgstr "Comprane qualcuno per me la prossima volta."

msgctxt "255||||4"
msgid "Huh...? Beauty products and cute clothes?"
msgstr "Eh...? Prodotti di bellezza e vestiti carini?"

msgctxt "256||||4"
msgid "Kiryu-san... Are you into that kind of thing?"
msgstr "Kiryu-san... Ti piacciono quel tipo di cose?"

msgctxt "257||||4"
msgid "What? N-No, it's not like that..."
msgstr "Cosa? N-No, non è come sembra..."

msgctxt "258||||4"
msgid "Don't worry. I won't tell anyone!"
msgstr "Non preoccuparti. Non lo dirò a nessuno!"

msgctxt "259||||4"
msgid "Besides, I bet you'd be pretty cute\r\nin drag, Kiryu-san."
msgstr "Inoltre, scommetto che saresti molto carino\r\nvestito da donna, Kiryu-san."

msgctxt "260||||4"
msgid "(That came out the wrong way...)"
msgstr "(È suonata nel modo sbagliato...)"

msgctxt "261||||4"
msgid "Hmmm."
msgstr "Mhm."

msgctxt "262||||4"
msgid "Oh... Am I boring you?"
msgstr "Oh... Ti sto annoiando?"

msgctxt "263||||4"
msgid "No, I didn't mean that..."
msgstr "No, non intendevo questo..."

msgctxt "264||||4"
msgid "Come on, Kiryu-san! What am I supposed\r\nto think with a response like that? Hmph!"
msgstr "Andiamo, Kiryu-san! Cosa dovrei pensare\r\ncon una risposta del genere? Umpf!"

msgctxt "265||||4"
msgid "I started here just after I started college,\r\nso this'll be my fourth year."
msgstr "Ho iniziato qui appena dopo aver cominciato il college,\r\nquindi questo sarà il mio quarto anno."

msgctxt "266||||4"
msgid "Four years, huh?\r\nWould you say you're used to the job, then?"
msgstr "Quattro anni, eh?\r\nDiresti che ormai sei abituata al lavoro, quindi?"

msgctxt "267||||4"
msgid "No way! I've got a ways to go. The moment I let my\r\nguard down I make mistakes, so I try to stay focused."
msgstr "Macché! Ho ancora molta strada da fare. Appena abbasso la\r\nguardia commetto degli errori, quindi cerco di restare concentrata."

msgctxt "268||||4"
msgid "I see. I suppose giving it that\r\nkind of attention is a good thing."
msgstr "Capisco. Suppongo che prestare un tale\r\nlivello di attenzione sia una cosa positiva."

msgctxt "269||||4"
msgid "I'm from Kanagawa, near the sea."
msgstr "Vengo da Kanagawa, vicino al mare."

msgctxt "270||||4"
msgid "Huh. So, can you swim?\r\nPeople are into surfing there, right?"
msgstr "Mhm. Quindi sai nuotare?\r\nLa gente va pazza per il surf lì, no?"

msgctxt "271||||4"
msgid "I can't swim at all... Can you, Kiryu-san?"
msgstr "Non so nuotare affatto... E tu, Kiryu-san?"

msgctxt "272||||4"
msgid "I suppose so.\r\nI've gotten into spearfishing lately."
msgstr "Suppongo di sì.\r\nUltimamente mi sono appassionato alla pesca subacquea."

msgctxt "273||||4"
msgid "Oh, that's amazing! Woooow!\r\nYou'll have to teach me that some time!"
msgstr "Oh, ma è fantastico! Woooow!\r\nDovrai insegnarmi come si fa, qualche volta!"

msgctxt "274||||4"
msgid "Dried sweet potatoes and beef jerky!"
msgstr "Patate dolci essiccate e carne di manzo secca!"

msgctxt "275||||4"
msgid "They're kinda tough, and I like how the more\r\nyou chew them, the more flavor you get."
msgstr "Sono un po' dure, e mi piace il fatto che più le\r\nmastichi, più sapore sprigionano."

msgctxt "276||||4"
msgid "Wow. You've got quite a refined palate."
msgstr "Wow. Hai un palato decisamente raffinato."

msgctxt "277||||4"
msgid "Why, thank you. <symbol=note_with_outline>"
msgstr "Oh, ma grazie. <symbol=note_with_outline>"

msgctxt "278||||4"
msgid "I suppose I like a kind man."
msgstr "Suppongo mi piaccia un uomo gentile."

msgctxt "279||||4"
msgid "The kind of guy who helps an old woman\r\ncarry something heavy comes to mind."
msgstr "Mi viene in mente il tipo di ragazzo che aiuta\r\nuna vecchia signora a trasportare qualcosa di pesante."

msgctxt "280||||4"
msgid "Kiryu-san, are you the type to help an\r\nold lady out?"
msgstr "Kiryu-san, tu sei il tipo che aiuterebbe\r\nuna vecchia signora in difficoltà?"

msgctxt "281||||4"
msgid "Isn't it obvious?\r\nOf course I would."
msgstr "Non è ovvio?\r\nCerto che lo farei."

msgctxt "282||||4"
msgid "I knew you were kind.\r\nThat's wonderful. <symbol=note_with_outline>"
msgstr "Sapevo di avere di fronte un uomo gentile.\r\nÈ una cosa meravigliosa. <symbol=note_with_outline>"

msgctxt "283||||4"
msgid "Nope, can't say I'd carry her stuff."
msgstr "No, non posso dire che le porterei la roba."

msgctxt "284||||4"
msgid "Huh? Why not?"
msgstr "Eh? E perché no?"

msgctxt "285||||4"
msgid "These days, old people get mad if you\r\ntry to treat them like senior citizens."
msgstr "Al giorno d'oggi, gli anziani si arrabbiano\r\nse provi a trattarli come anziani."

msgctxt "286||||4"
msgid "Oh, I have heard of that happening.\r\nHmmm... Must be tough."
msgstr "Oh, ho sentito dire che può capitare.\r\nMhm... Deve essere difficile."

msgctxt "287||||4"
msgid "Actually, I'd pick up both the stuff\r\nand the old lady."
msgstr "A dire il vero, solleverei sia la roba\r\nche la vecchia signora."

msgctxt "288||||4"
msgid "What!? You'd carry them both!?"
msgstr "Cosa!? Le porteresti entrambe!?"

msgctxt "289||||4"
msgid "I never thought of that!\r\nYou're so kind! That's wonderful... <symbol=heart_with_outline>"
msgstr "Non ci avevo mai pensato!\r\nSei così gentile! È una cosa meravigliosa... <symbol=heart_with_outline>"

msgctxt "290||||4"
msgid "I don't know if I'd call it kind, but..."
msgstr "Non so se lo definirei gentile, ma..."

msgctxt "291||||4"
msgid "I don't think I'm all that different, but\r\nI guess I'm the type who craves attention."
msgstr "Non penso di essere molto diversa, ma\r\ncredo di essere il tipo in cerca di attenzioni."

msgctxt "292||||4"
msgid "Oho. Attention does it for you?"
msgstr "Oho. Così ti piacciono le attenzioni?"

msgctxt "293||||4"
msgid "Yep. I may-eow even talk like a cat."
msgstr "Sì. Miao-gari potrei persino parlare come un gatto."

msgctxt "294||||4"
msgid "I'll give you as much attention as you want."
msgstr "Ti darò tutte le attenzioni che vuoi."

msgctxt "295||||4"
msgid "Oh, Kiryu-san! <symbol=note_with_outline> I'm so happy right meow. <symbol=note_with_outline>"
msgstr "Oh, Kiryu-san! <symbol=note_with_outline> Sono così felice mi-aora. <symbol=note_with_outline>"

msgctxt "296||||4"
msgid "I don't really like women who beg for attention."
msgstr "Non mi piacciono molto le donne che elemosinano attenzioni."

msgctxt "297||||4"
msgid "Whaaat? You don't like me, Kiryu-san?\r\nMeow I'm all sad... <symbol=note_with_outline> I apawlogize... <symbol=note_with_outline>"
msgstr "Cooosa? Non ti piaccio, Kiryu-san?\r\nMi-aora sono proprio triste... <symbol=note_with_outline> Mi scus-miao... <symbol=note_with_outline>"

msgctxt "298||||4"
msgid "I forgive you."
msgstr "Ti perdono."

msgctxt "299||||4"
msgid "That's cute-meow..."
msgstr "Che cari-miao..."

msgctxt "300||||4"
msgid "Kiryu-san!? Did you just say \"that's cute-meow\"?"
msgstr "Kiryu-san!? Hai appena detto \"che cari-miao\"?"

msgctxt "301||||4"
msgid "N-Nope, forget I said anything."
msgstr "N-No, dimentica tutto quello che ho detto."

msgctxt "302||||4"
msgid "I know what I heard!\r\nYou're so mischievous that it's cute. <symbol=heart_with_outline>"
msgstr "So bene quello che ho sentito!\r\nSei così dispettoso che risulta persino carino. <symbol=heart_with_outline>"

msgctxt "303||||4"
msgid "For a long time, I've dreamt of becoming an idol."
msgstr "Per molto tempo ho sognato di diventare un'idol."

msgctxt "304||||4"
msgid "But I'm not a teenager anymore, and people tell\r\nme to just get a job... I'm keeping my options open."
msgstr "Ma non sono più un'adolescente, e la gente mi dice\r\ndi trovarmi un vero lavoro... Sto valutando le mie opzioni."

msgctxt "305||||4"
msgid "When I was a kid,\r\nI thought I wanted to be a teacher."
msgstr "Quando ero bambina,\r\ncredevo di voler fare l'insegnante."

msgctxt "306||||4"
msgid "A teacher, huh? That's a nice dream.\r\nWhat changed your mind?"
msgstr "L'insegnante, eh? È un bel sogno.\r\nCosa ti ha fatto cambiare idea?"

msgctxt "307||||4"
msgid "Back in school, I started hearing about\r\nthese \"monster parents.\""
msgstr "A scuola ho iniziato a sentir parlare\r\ndi questi \"genitori mostruosi\"."

msgctxt "308||||4"
msgid "I figured I didn't stand a chance against\r\nany monsters, so..."
msgstr "E mi sono detta di non avere alcuna speranza\r\ncontro i mostri, quindi..."

msgctxt "309||||4"
msgid "Monster parents...?"
msgstr "Genitori mostruosi...?"

msgctxt "310||||4"
msgid "Oh, those!"
msgstr "Oh, quelli!"

msgctxt "311||||4"
msgid "Exactly. It'd be tough to deal with them,\r\nyou know?"
msgstr "Esatto. Sarebbe davvero difficile avere a che fare con loro,\r\nsai?"

msgctxt "312||||4"
msgid "Yep. Probably real difficult."
msgstr "Già. Probabilmente molto difficile."

msgctxt "313||||4"
msgid "Kiryu-san... Are you even following?"
msgstr "Kiryu-san... Ma mi stai seguendo?"

msgctxt "314||||4"
msgid "Yeah, the unreasonable types, right? The kind that\r\ncomplain about their kids' teachers to the school..."
msgstr "Sì, i tipi irragionevoli, giusto? Quelli che si\r\nlamentano con la scuola degli insegnanti dei loro figli..."

msgctxt "315||||4"
msgid "Yeah. It's hard for me to be firm with people,\r\nso I'd probably have gotten sick with stress..."
msgstr "Esatto. Faccio molta fatica ad essere severa con le persone,\r\nquindi probabilmente mi sarei ammalata per via dello stress..."

msgctxt "316||||4"
msgid "Teachers have it rough these days...\r\nThough, I bet the kids would all like your class."
msgstr "Gli insegnanti se la passano male al giorno d'oggi...\r\nAnche se scommetto che i bambini adorerebbero le tue lezioni."

msgctxt "317||||4"
msgid "You really think so? I'm happy to hear that. <symbol=note_with_outline>\r\nI love kids."
msgstr "Lo pensi davvero? Sono così felice di sentirlo. <symbol=note_with_outline>\r\nIo adoro i bambini."

msgctxt "318||||4"
msgid "Oh, someone like Kazama-san."
msgstr "Oh, qualcuno come Kazama-san."

msgctxt "319||||4"
msgid "Huh? Kazama-san?"
msgstr "Eh? Kazama-san?"

msgctxt "320||||4"
msgid "Yeah. He was pretty scary when he got mad.\r\nHe was kind of a monster in the underworld."
msgstr "Sì. Faceva parecchia paura quando si arrabbiava.\r\nEra una specie di mostro nel mondo criminale."

msgctxt "321||||4"
msgid "Underworld? Kiryu-san, you're losing me here..."
msgstr "Mondo criminale? Kiryu-san, mi stai perdendo in questo discorso..."

msgctxt "322||||4"
msgid "Oh, I'm good at giving shoulder massages.\r\nMy friends are always telling me that."
msgstr "Oh, sono molto brava a fare massaggi alle spalle.\r\nLe mie amiche me lo dicono sempre."

msgctxt "323||||4"
msgid "I massaged my dad's shoulders a lot when I was\r\nlittle. Does Papa Kiryu want a massage, too?"
msgstr "Ho massaggiato un sacco le spalle di mio padre quando ero\r\npiccola. Anche Papà Kiryu vuole un massaggio?"

msgctxt "324||||4"
msgid "Oh, you don't mind?"
msgstr "Oh, non ti dispiace?"

msgctxt "325||||4"
msgid "Not at all! It'll cost you extra, though. <symbol=note_with_outline>"
msgstr "Assolutamente no! Però ti costerà un extra. <symbol=note_with_outline>"

msgctxt "326||||4"
msgid "Tch... You're pretty devious."
msgstr "Tsk... Sei proprio scaltra."

msgctxt "327||||4"
msgid "I don't know if this counts as interesting,\r\nbut I did some volunteering overseas last month."
msgstr "Non so se si possa considerare interessante,\r\nma il mese scorso ho fatto un po' di volontariato all'estero."

msgctxt "328||||4"
msgid "Huh. Never guessed you'd be into that."
msgstr "Mhm. Non avrei mai immaginato che fosse una cosa che ti interessa."

msgctxt "329||||4"
msgid "I am. I was helping out with some tree planting,\r\nbut physical labor is hard work."
msgstr "E invece sì. Stavo dando una mano a piantare degli alberi,\r\nma il lavoro fisico è davvero duro."

msgctxt "330||||4"
msgid "But in my free time I got to interact with the\r\nlocals, and it was a new and really fun experience."
msgstr "Nel tempo libero, però, ho potuto interagire con la\r\ngente del posto, ed è stata un'esperienza nuova e molto divertente."

msgctxt "331||||4"
msgid "I bet. What country were you in?"
msgstr "Ci scommetto. In quale Paese sei andata?"

msgctxt "332||||4"
msgid "Myanmar."
msgstr "Myanmar."

msgctxt "333||||4"
msgid "(Myanmar...?)"
msgstr "(Myanmar...?)"

msgctxt "334||||4"
msgid "Oh, isn't that in southeast Asia?"
msgstr "Oh, non si trova nel Sud-est asiatico?"

msgctxt "335||||4"
msgid "Yeah! I'm impressed you knew that."
msgstr "Sì! Sono colpita che tu lo sapessi."

msgctxt "336||||4"
msgid "Of course. Common knowledge, right?"
msgstr "Ma certo. Cultura generale, giusto?"

msgctxt "337||||4"
msgid "Anyway, I think it's great that you're getting\r\nthat kind of experience while you're young."
msgstr "Comunque, penso sia fantastico che tu faccia\r\nquesto tipo di esperienze mentre sei giovane."

msgctxt "338||||4"
msgid "Thank you. I hope it ends up being useful\r\nsomehow."
msgstr "Grazie. Spero che si rivelino utili\r\nin qualche modo."

msgctxt "339||||4"
msgid "The place with those famous hot springs\r\nin Kusatsu?"
msgstr "Il posto con quelle famose sorgenti termali\r\na Kusatsu?"

msgctxt "340||||4"
msgid "That's Gunma."
msgstr "Quella è Gunma."

msgctxt "341||||4"
msgid "Isn't that some English word for a tool?"
msgstr "Non è una parola inglese per un attrezzo?"

msgctxt "342||||4"
msgid "That's a \"hammer.\""
msgstr "Quello è un \"hammer\"."

msgctxt "343||||4"
msgid "Not really, but I feel like that's okay.\r\nMy philosophy is to have a few good friends."
msgstr "Non molto a dire il vero, ma per me va bene così.\r\nLa mia filosofia è avere pochi ma buoni amici."

msgctxt "344||||4"
msgid "Did you know you can play games on your\r\nphone these days? I do that a lot lately."
msgstr "Sapevi che oggigiorno puoi fare dei giochi sul tuo\r\ntelefono? Ci gioco spessissimo ultimamente."

msgctxt "345||||4"
msgid "What kind of games do you play, Kiryu-san?"
msgstr "Che genere di giochi fai, Kiryu-san?"

msgctxt "346||||4"
msgid "I hit up the arcades a lot.\r\nSo, arcade games."
msgstr "Frequento spesso le sale giochi.\r\nQuindi, giochi arcade."

msgctxt "347||||4"
msgid "Wow! I haven't been to one in a while.\r\nYou should take me there sometime!"
msgstr "Wow! È da un bel po' che non ci vado.\r\nDovresti portarmici, qualche volta!"

msgctxt "348||||4"
msgid "I'm all about the mobile games."
msgstr "Vado matto per i giochi mobile."

msgctxt "349||||4"
msgid "Really? Which ones do you play?"
msgstr "Davvero? A quali giochi giochi?"

msgctxt "350||||4"
msgid "Huh? Uh, I don't know...\r\nWhatever's popular."
msgstr "Eh? Ehm, non saprei...\r\nI soliti più popolari."

msgctxt "351||||4"
msgid "Kiryu-san... You don't really play, do you?\r\nYou need to learn how to lie better."
msgstr "Kiryu-san... Non giochi a niente di tutto questo, vero?\r\nDevi proprio imparare a mentire meglio."

msgctxt "352||||4"
msgid "You got me... Sorry."
msgstr "Mi hai beccato... Scusami."

msgctxt "353||||4"
msgid "Lately... I'm caught up in the game of love."
msgstr "Ultimamente... Sono preso dal gioco dell'amore."

msgctxt "354||||4"
msgid "Kiryu-san, you try to act so cool sometimes.\r\nYou're a funny guy."
msgstr "Kiryu-san, a volte cerchi proprio di fare il duro.\r\nSei un ragazzo divertente."

msgctxt "355||||4"
msgid "Huh? What secret?"
msgstr "Eh? Che segreto?"

msgctxt "356||||4"
msgid "Well, actually..."
msgstr "Beh, in realtà..."

msgctxt "357||||4"
msgid "I've been to prison before."
msgstr "In passato sono stato in prigione."

msgctxt "358||||4"
msgid "Huh? Really?"
msgstr "Eh? Sul serio?"

msgctxt "359||||4"
msgid "But you don't seem like a bad person\r\nto me, Kiryu-san."
msgstr "Ma a me non sembri affatto una persona\r\ncattiva, Kiryu-san."

msgctxt "360||||4"
msgid "Ah, maybe it was a false charge?\r\nOr were you trying to protect someone else?"
msgstr "Ah, magari sei stato incolpato ingiustamente?\r\nOppure stavi cercando di proteggere qualcun altro?"

msgctxt "361||||4"
msgid "Sometimes I wonder."
msgstr "Me lo chiedo anch'io a volte."

msgctxt "362||||4"
msgid "Well, people have all kinds of circumstances.\r\nI don't believe you're a bad person at all."
msgstr "Beh, le persone hanno un sacco di circostanze diverse.\r\nNon credo proprio che tu sia una cattiva persona."

msgctxt "363||||4"
msgid "People pick fights with me a lot."
msgstr "La gente attacca briga con me molto spesso."

msgctxt "364||||4"
msgid "I bet... You kind of look like the type!\r\nI don't think that's much of a secret, really."
msgstr "Ci scommetto... Hai l'aspetto giusto per il ruolo!\r\nNon credo sia un grande segreto, onestamente."

msgctxt "365||||4"
msgid "I'm 100,024 years old."
msgstr "Ho 100.024 anni."

msgctxt "366||||4"
msgid "Realllllly..."
msgstr "Davveeero..."

msgctxt "367||||4"
msgid "...Never mind."
msgstr "...Lascia perdere."

msgctxt "368||||4"
msgid "A lot of people in other countries seem to have\r\nthem. I don't think they're all that bad, really."
msgstr "Sembri che molte persone in altri Paesi li abbiano.\r\nNon credo siano una cosa poi così brutta, onestamente."

msgctxt "369||||4"
msgid "It seems like such a painful process though...\r\nWait... Do you have one, Kiryu-san?"
msgstr "Mi sembra un procedimento così doloroso però...\r\nAspetta... Tu ne hai uno, Kiryu-san?"

msgctxt "370||||4"
msgid "Yeah, on my back."
msgstr "Sì, sulla schiena."

msgctxt "371||||4"
msgid "Wow, really?\r\nWhat kind of design is it?"
msgstr "Wow, sul serio?\r\nChe tipo di disegno è?"

msgctxt "372||||4"
msgid "A dragon."
msgstr "Un drago."

msgctxt "373||||4"
msgid "Oooh, sounds cool.\r\nI kind of wanna see it..."
msgstr "Oooh, dev'essere fantastico.\r\nMi piacerebbe tanto vederlo..."

msgctxt "374||||4"
msgid "Angel wings."
msgstr "Delle ali da angelo."

msgctxt "375||||4"
msgid "Aww. I hope you use those wings to fly\r\nto the future!"
msgstr "Aww. Spero che tu usi quelle ali per spiccare\r\nil volo verso il futuro!"

msgctxt "376||||4"
msgid "Hikaru... It's you."
msgstr "C'è... Hikaru."

msgctxt "377||||4"
msgid "Huh? Me!? Did you make sure\r\nI turned out cute?"
msgstr "Eh? Io!? Ti sei assicurato\r\nche venissi fuori carina?"

msgctxt "378||||4"
msgid "Yeah, it's really cute... for a dragon."
msgstr "Sì, davvero molto carina... per un drago."

msgctxt "379||||4"
msgid "What, so it's a dragon!?\r\nYou're silly, Kiryu-san."
msgstr "Cosa, quindi è un drago!?\r\nSei proprio buffo, Kiryu-san."

msgctxt "380||||4"
msgid "I do drink, and I think I can hold\r\nit pretty well, too."
msgstr "Sì, bevo e credo anche di saper\r\nreggere bene l'alcol."

msgctxt "381||||4"
msgid "But I'm not a big fan of carbonation,\r\nso I stay away from beers and sours."
msgstr "Ma non sono una grande fan delle bibite gassate,\r\nquindi sto alla larga dalle birre e dai sour."

msgctxt "382||||4"
msgid "But around you, who knows? I might\r\nlet my guard down and get drunk... <symbol=heart_with_outline>"
msgstr "Ma quando ci sei tu, chi lo sa? Potrei abbassare\r\nla guardia e prendere una sbronza... <symbol=heart_with_outline>"

msgctxt "383||||4"
msgid "Oh, I've heard of them. There's a lot of\r\nnaughty guys in there, aren't there?"
msgstr "Oh, ne ho sentito parlare. Ci sono un sacco di\r\ncattivoni da quelle parti, non è vero?"

msgctxt "384||||4"
msgid "Hmm... Well, you're not wrong..."
msgstr "Mhm... Beh, non hai torto..."

msgctxt "385||||4"
msgid "Something new probably happens\r\nevery day there. Might be fun."
msgstr "Probabilmente da quelle parti accade qualcosa di nuovo\r\nogni giorno. Potrebbe essere divertente."

msgctxt "386||||4"
msgid "Oh, that idol that was popular a little\r\nwhile back? She was soooo cute."
msgstr "Oh, quell'idol che andava tanto di moda un\r\npo' di tempo fa? Era coooosì carina."

msgctxt "387||||4"
msgid "I was really disappointed when she retired.\r\nWere you a fan of hers, Kiryu-san?"
msgstr "Ci sono rimasta davvero male quando si è ritirata.\r\nEri un suo fan, Kiryu-san?"

msgctxt "388||||4"
msgid "Well... you could say that.\r\nI'm a pretty big fan."
msgstr "Beh... Si può dire di sì.\r\nSono un suo grandissimo fan."

msgctxt "389||||4"
msgid "Wow, I never would've guessed!\r\nI practically had her CD on repeat."
msgstr "Wow, non l'avrei mai immaginato!\r\nIo ascoltavo il suo CD praticamente a ripetizione."

msgctxt "390||||4"
msgid "Oh! I'd love to hear about your adventures!"
msgstr "Oh! Mi piacerebbe tanto sentire le tue avventure!"

msgctxt "391||||4"
msgid "I have kind of a legendary saga in crime."
msgstr "Ho vissuto una specie di epica saga nel crimine."

msgctxt "392||||4"
msgid "Say what?\r\nYou have legendary sugar sometimes?"
msgstr "Come dici?\r\nHai avuto dello zucchero epico a volte?"

msgctxt "393||||4"
msgid "That's really sweet!\r\nI love brown sugar, myself. <symbol=note_with_outline>"
msgstr "Una cosa molto dolce!\r\nPersonalmente io adoro lo zucchero di canna. <symbol=note_with_outline>"

msgctxt "394||||4"
msgid "A long time ago,\r\nI defeated some tigers with my bare hands."
msgstr "Tanto tempo fa,\r\nho sconfitto delle tigri a mani nude."

msgctxt "395||||4"
msgid "That's a good one."
msgstr "Questa è buona."

msgctxt "396||||4"
msgid "I cook a lot, actually. I like dried sweet potatoes,\r\nso I'm experimenting with them in my dishes."
msgstr "In realtà cucino molto. Mi piacciono un sacco le patate dolci\r\nessiccate, quindi sto sperimentando usandole nei miei piatti."

msgctxt "397||||4"
msgid "Dried sweet potatoes?"
msgstr "Patate dolci essiccate?"

msgctxt "398||||4"
msgid "Yep. Once I get it down,\r\nI'll bring you some, okay?"
msgstr "Sì. Una volta trovata la ricetta giusta,\r\nte ne porterò un po', okay?"

msgctxt "399||||4"
msgid "S-Sure..."
msgstr "C-Certo..."

msgctxt "400||||4"
msgid "I'm type A. What about you?"
msgstr "Il mio è gruppo A. E il tuo?"

msgctxt "401||||4"
msgid "I'm type O."
msgstr "Il mio è gruppo 0."

msgctxt "402||||4"
msgid "Really? A and O are supposed to be pretty\r\ncompatible, you know. <symbol=note_with_outline>"
msgstr "Davvero? Si dice che il gruppo A e lo 0 siano piuttosto\r\ncompatibili tra di loro, sai. <symbol=note_with_outline>"

msgctxt "403||||4"
msgid "Gross, you can't just jump into dirty topics\r\nlike that... I'm not telling!"
msgstr "Che schifo, non puoi saltare a certi argomenti sconci\r\nin questo modo... Non te lo dico!"

msgctxt "404||||4"
msgid "What? You really want to know that much?\r\nWell... I can make an exception just for you."
msgstr "Cosa? Ci tieni così tanto a saperlo?\r\nBeh... Posso fare un'eccezione solo per te."

msgctxt "405||||4"
msgid "Okay..."
msgstr "D'accordo..."

msgctxt "406||||4"
msgid "It's actually... zero."
msgstr "In realtà è... zero."

msgctxt "407||||4"
msgid "You're lying..."
msgstr "Stai mentendo..."

msgctxt "408||||4"
msgid "It's not a lie... <symbol=note_with_outline>\r\nIdols don't do stuff like that. <symbol=note_with_outline>"
msgstr "Non è una bugia... <symbol=note_with_outline>\r\nLe idol non fanno cose del genere. <symbol=note_with_outline>"

msgctxt "409||||4"
msgid "That's pretty cool..."
msgstr "Davvero niente male..."

msgctxt "410||||4"
msgid "Oh... You're into that, Kiryu-san?"
msgstr "Oh... Ti piacciono queste cose, Kiryu-san?"

msgctxt "411||||4"
msgid "Then I'll volunteer to be the first...\r\nKidding, of course."
msgstr "Allora mi offro volontaria per essere la prima...\r\nScherzo, ovviamente."

msgctxt "412||||4"
msgid "Oh, Kiryu-san. I hope you stay in the running. <symbol=heart_with_outline>"
msgstr "Oh, Kiryu-san. Spero che anche tu resterai in gara. <symbol=heart_with_outline>"

msgctxt "413||||4"
msgid "No boyfriend here! Right now I'm focused\r\non my job and my dream."
msgstr "Nessun fidanzato qui! In questo momento sono\r\nconcentrata sul mio lavoro e sul mio sogno."

msgctxt "414||||4"
msgid "Can't say that I do."
msgstr "Non posso dire di esserlo."

msgctxt "415||||4"
msgid "Aren't you lonely?"
msgstr "Non ti senti solo?"

msgctxt "416||||4"
msgid "When I'm lonely, I just think about you,\r\nKiryu-san. <symbol=heart_with_outline>"
msgstr "Quando mi sento sola, mi basta pensare a te,\r\nKiryu-san. <symbol=heart_with_outline>"

msgctxt "417||||4"
msgid "You know how to make me happy."
msgstr "Sai proprio come rendermi felice."

msgctxt "418||||4"
msgid "My dream is to become an idol, so I figured\r\nthis might give me some good experience."
msgstr "Il mio sogno è diventare un'idol, quindi ho pensato\r\nche questo potesse darmi una buona esperienza."

msgctxt "419||||4"
msgid "Huh. I guess idols and hostesses do have sort\r\nof similar traits, like..."
msgstr "Mhm. Immagino che le idol e le hostess abbiano un\r\npo' dei tratti in comune, per esempio..."

msgctxt "420||||4"
msgid "Needing communication skills?"
msgstr "L'avere bisogno di abilità comunicative?"

msgctxt "421||||4"
msgid "Oh, I'm impressed that you see that.\r\nThat's right! <symbol=note_with_outline>"
msgstr "Oh, sono colpita che tu te ne accorga.\r\nÈ esatto! <symbol=note_with_outline>"

msgctxt "422||||4"
msgid "These days, an idol has to do a lot more\r\nthan just be a good singer."
msgstr "Al giorno d'oggi, un'idol deve fare molto di\r\npiù che essere semplicemente una brava cantante."

msgctxt "423||||4"
msgid "I figured I could put some polish on my\r\ncommunication skills as a hostess."
msgstr "Ho pensato che avrei potuto perfezionare le mie abilità\r\ndi comunicazione lavorando come hostess."

msgctxt "424||||4"
msgid "That does seem like it would be good\r\nexperience. Best of luck to you."
msgstr "Questa sì che mi sembra una bella\r\nesperienza per te. Ti auguro il meglio."

msgctxt "425||||4"
msgid "Yep! Thank you!"
msgstr "Sì! Grazie!"

msgctxt "426||||4"
msgid "Guys fawning over you?"
msgstr "Uomini che ti ronzano sempre intorno?"

msgctxt "427||||4"
msgid "Not at all! I meant both jobs rely pretty\r\nheavily on communication skills."
msgstr "Per niente! Intendevo dire che entrambi i lavori fanno un\r\nforte affidamento sulle capacità comunicative."

msgctxt "428||||4"
msgid "Oh, right."
msgstr "Oh, capisco."

msgctxt "429||||4"
msgid "Although, being fawned over isn't so bad,\r\neither... <symbol=note_with_outline>"
msgstr "Sebbene avere degli spasimanti non sia poi\r\ncosì male, dopotutto... <symbol=note_with_outline>"

msgctxt "430||||4"
msgid "Being able to sleep your way to the top?"
msgstr "Poter arrivare al successo portandosi a letto la gente?"

msgctxt "431||||4"
msgid "What? Why would you say that? That's not it at all.\r\nI meant both jobs need strong communication skills."
msgstr "Cosa? Come ti salta in mente di dire una cosa del genere? Non è affatto\r\ncosì. Intendevo dire che per entrambi serve una forte capacità di comunicare."

msgctxt "432||||4"
msgid "And, you can't just sleep with people to get ahead,\r\nokay? At least, I don't!"
msgstr "E, non si può mica portarsi a letto le persone per andare\r\navanti, okay? O perlomeno io non lo faccio!"

msgctxt "433||||4"
msgid "Oh, good idea.\r\nI'll be the princess, then!"
msgstr "Oh, ottima idea.\r\nIo farò la principessa, allora!"

msgctxt "434||||4"
msgid "Uh, do you even know what the king game is?"
msgstr "Uh, hai almeno idea di cosa sia il gioco del re?"

msgctxt "435||||4"
msgid "Kiryu-san, don't get all high and mighty on me!"
msgstr "Kiryu-san, non darti arie di superiorità con me!"

msgctxt "436||||4"
msgid "I listen to a lot of rock, but I like lots of other stuff.\r\nI go to music festivals sometimes, too."
msgstr "Ascolto molto rock, ma mi piacciono un sacco di altri generi.\r\nA volte vado anche a dei festival musicali."

msgctxt "437||||4"
msgid "Yeah! I'm having fun, too. <symbol=note_with_outline>"
msgstr "Sì! Mi sto divertendo anch'io. <symbol=note_with_outline>"

msgctxt "438||||4"
msgid "I know, right? I don't really like the winter...\r\nI just want spring to last aaaaall year."
msgstr "Vero? Non mi piace molto l'inverno...\r\nVorrei che la primavera durasse tuuuutto l'anno."

msgctxt "439||||4"
msgid "Really? I get the warm and fuzzies when\r\nyou're around, Kiryu-san. <symbol=note_with_outline>"
msgstr "Davvero? Sento un bel calduccio rassicurante\r\nquando mi sei vicino, Kiryu-san. <symbol=note_with_outline>"

msgctxt "440||||4"
msgid "What does that even mean?"
msgstr "Che cosa vorrebbe significare?"

msgctxt "441||||4"
msgid "Glad to hear it! <symbol=note_with_outline>"
msgstr "Sono felice di sentirlo! <symbol=note_with_outline>"

msgctxt "442||||4"
msgid "You say that to all the girls, don't you?"
msgstr "Lo dici a tutte le ragazze, vero?"

msgctxt "443||||4"
msgid "Oh gosh, I don't know what to say... <symbol=heart_with_outline>"
msgstr "Santo cielo, non so cosa dire... <symbol=heart_with_outline>"

msgctxt "444||||4"
msgid "Yahoo!"
msgstr "Yahoo!"

msgctxt "445||||4"
msgid "You're like a cute little boy, Kiryu-san. <symbol=note_with_outline>"
msgstr "Sei come un ragazzino carino, Kiryu-san. <symbol=note_with_outline>"

msgctxt "446||||4"
msgid "Hello to you too! Greetings are the\r\nfoundation of human interaction."
msgstr "Salve anche a te! I saluti sono il\r\nfondamento dell'interazione umana."

msgctxt "447||||4"
msgid "What? No way! This isn't that kind of club!"
msgstr "Cosa? Ma non esiste! Non è quel tipo di club questo!"

msgctxt "448||||4"
msgid "...You flatter me. <symbol=note_with_outline>"
msgstr "...Mi lusinghi. <symbol=note_with_outline>"

msgctxt "449||||4"
msgid "You probably say that to everyone, right?"
msgstr "Probabilmente lo dici a tutti, giusto?"

msgctxt "450||||4"
msgid "[Beautiful eyes...]"
msgstr "[Bellissimi occhi...]"

msgctxt "451||||4"
msgid "How nice... <symbol=heart_with_outline>"
msgstr "Che cosa dolce... <symbol=heart_with_outline>"

msgctxt "452||||4"
msgid "Whaaat? But looking at one person all\r\nthe time is pretty boring..."
msgstr "Cooosa? Ma guardare sempre e solo una\r\npersona è un po' noioso..."

msgctxt "453||||4"
msgid "Hmmmm... That's a secret. <symbol=note_with_outline>"
msgstr "Uhm... È un segreto. <symbol=note_with_outline>"

msgctxt "454||||4"
msgid "Hmm, let me think... Yes. <symbol=note_with_outline>"
msgstr "Mhm, fammi pensare... Sì. <symbol=note_with_outline>"

msgctxt "455||||4"
msgid "Oh, is that so? Who?"
msgstr "Oh, davvero? Di chi si tratta?"

msgctxt "456||||4"
msgid "Hmm... I can't tell you... <symbol=heart_with_outline>"
msgstr "Mhm... Non posso dirtelo... <symbol=heart_with_outline>"

msgctxt "457||||4"
msgid "...I see."
msgstr "...Capisco."

msgctxt "458||||4"
msgid "Yes, I do. <symbol=heart_with_outline>"
msgstr "Sì, eccome. <symbol=heart_with_outline>"

msgctxt "459||||4"
msgid "Really? Who?"
msgstr "Davvero? E chi è?"

msgctxt "460||||4"
msgid "Huh?  You're going to make me say it? <symbol=heart_with_outline>"
msgstr "Eh? Mi costringerai a dirlo a voce alta? <symbol=heart_with_outline>"

msgctxt "461||||4"
msgid "Is it someone I know?"
msgstr "È qualcuno che conosco?"

msgctxt "462||||4"
msgid "Hey, don't ask for hints...\r\nIt's... the person you know best. <symbol=heart_with_outline>"
msgstr "Ehi, non chiedermi indizi...\r\nÈ... la persona che conosci meglio in assoluto. <symbol=heart_with_outline>"

msgctxt "463||||4"
msgid "Hm? The person I know best?"
msgstr "Mhm? La persona che conosco meglio?"

msgctxt "464||||4"
msgid "Wait... Is it Date-san!?\r\nYou're in love with Makoto Date!?"
msgstr "Aspetta... È Date-san!?\r\nSei innamorata di Makoto Date!?"

msgctxt "465||||4"
msgid "What? I don't even know who that is!\r\nYou're so dense, Kiryu-san."
msgstr "Cosa? Non so nemmeno chi sia!\r\nSei proprio tonto, Kiryu-san."

msgctxt "466||||4"
msgid "Wait... Is it the Florist!?"
msgstr "Aspetta... È il Fioraio!?"

msgctxt "467||||4"
msgid "Wait... Is it me? No way..."
msgstr "Aspetta... Sono io? Ma no, impossibile..."

msgctxt "468||||4"
msgid "Oh, Kiryu-san... <symbol=heart_with_outline>"
msgstr "Oh, Kiryu-san... <symbol=heart_with_outline>"

msgctxt "469||||4"
msgid "Oh no! I better make sure I don't fall\r\nin love with you, then."
msgstr "Oh no! Farei bene ad assicurarmi di non\r\ninnamorarmi di te, allora."

msgctxt "470||||4"
msgid "Thank you very much. <symbol=note_with_outline>"
msgstr "Ti ringrazio tantissimo. <symbol=note_with_outline>"

msgctxt "471||||4"
msgid "There's a bar I like just down the street\r\nfrom the club. Their fried eggs are sooo good!"
msgstr "C'è un bar che mi piace in fondo alla strada dal club.\r\nLe loro uova fritte sono coooosì buone!"

msgctxt "472||||4"
msgid "No, and I don't even want to talk about it!"
msgstr "No, e non voglio nemmeno parlarne!"

msgctxt "473||||4"
msgid "No, and I wish you wouldn't bring\r\nthat kind of stuff up..."
msgstr "No, e vorrei che tu non tirassi\r\nfuori questi discorsi..."

msgctxt "474||||4"
msgid "Why?"
msgstr "Perché?"

msgctxt "475||||4"
msgid "I mean... it's not really the kind of thing you\r\nwant to hear from someone you like..."
msgstr "Insomma... non è proprio il genere di cosa che vuoi\r\nsentire dalla persona che ti piace..."

msgctxt "476||||4"
msgid "What am I saying!?\r\nI'm sorry, forget I said that!"
msgstr "Ma cosa sto dicendo!?\r\nMi dispiace, dimentica quello che ho detto!"

msgctxt "477||||4"
msgid "Uh... Sure..."
msgstr "Ehm... Certo..."

msgctxt "478||||4"
msgid "What!? You made a mess of a convenience store?\r\nI really feel for the poor employees..."
msgstr "Cosa!? Hai distrutto un minimarket?\r\nMi dispiace tantissimo per i poveri dipendenti..."

msgctxt "479||||4"
msgid "But, you regret doing it, right?"
msgstr "Però ti sei pentito di averlo fatto, vero?"

msgctxt "480||||4"
msgid "Yeah, of course I feel bad about it."
msgstr "Sì, ovviamente mi sento in colpa per questo."

msgctxt "481||||4"
msgid "Yes, yes, good, good. <symbol=note_with_outline>"
msgstr "Sì, sì, bene, bene. <symbol=note_with_outline>"

msgctxt "482||||4"
msgid "Not everyone's capable of reflecting on their\r\nactions. You're a good person, Kazuma-chan. <symbol=note_with_outline>"
msgstr "Non tutti sono in grado di riflettere sulle loro\r\nazioni. Sei una brava persona, Kazuma-chan. <symbol=note_with_outline>"

msgctxt "483||||4"
msgid "I'll take the compliment as an honor."
msgstr "Prenderò il complimento come un onore."

msgctxt "484||||4"
msgid "No, see, it wasn't my fault."
msgstr "No, vedi, non è stata colpa mia."

msgctxt "485||||4"
msgid "Huh? But aren't you the one who messed it up?"
msgstr "Eh? Ma non sei tu quello che ha sfasciato tutto?"

msgctxt "486||||4"
msgid "I think you need to consider that, at the very least.\r\nOpen your eyes to the truth, Kazuma-chan!"
msgstr "Penso che dovresti per lo meno rendertene conto.\r\nApri gli occhi e guarda la verità, Kazuma-chan!"

msgctxt "487||||4"
msgid "Sorry."
msgstr "Scusa."

msgctxt "488||||4"
msgid "It's not healthy to keep that kind\r\nof stuff all bottled up, you know?"
msgstr "Non è salutare tenersi dentro roba\r\ndel genere, sai?"

msgctxt "489||||4"
msgid "If you need a stiff drink to forget the past\r\nevery once in a while, sometimes that's okay, too."
msgstr "Se ogni tanto hai bisogno di bere un drink forte per dimenticare il\r\npassato, non c'è nulla di male. A volte ci sta."

msgctxt "490||||4"
msgid "Yeah... Thanks for that."
msgstr "Sì... Grazie."

msgctxt "491||||4"
msgid "You lost someone important to you, huh?"
msgstr "Hai perso qualcuno di importante per te, eh?"

msgctxt "492||||4"
msgid "Yeah. We... did a lot of stupid stuff together."
msgstr "Già. Insieme... facevamo un sacco di cose stupide."

msgctxt "493||||4"
msgid "But he's probably happy that you remember\r\nhim like this, Kiryu-san."
msgstr "Ma probabilmente lui è felice che tu ti\r\nricordi di lui in questo modo, Kiryu-san."

msgctxt "494||||4"
msgid "I'm sure he's smiling down from heaven."
msgstr "Sono certa che ti stia sorridendo dal paradiso."

msgctxt "495||||4"
msgid "...I hope so."
msgstr "...Lo spero."

msgctxt "496||||4"
msgid "Hmm... Deep topics like this are hard for me...\r\nI don't have a whole lot of friends myself, so..."
msgstr "Uhm... Argomenti profondi come questo sono difficili per me...\r\nNon ho poi così tanti amici, quindi..."

msgctxt "497||||4"
msgid "Wow, really? Now that you mention it,\r\nI think you'd make a great dad, Kiryu-san."
msgstr "Wow, davvero? Ora che mi ci fai pensare,\r\ncredo che saresti un ottimo papà, Kiryu-san."

msgctxt "498||||4"
msgid "Y-You think?"
msgstr "D-Dici?"

msgctxt "499||||4"
msgid "Yeah! If I was going to get married, I'd want\r\na husband who'd be good with babies."
msgstr "Certo! Se dovessi mai sposarmi, vorrei\r\nun marito bravo con i bambini."

msgctxt "500||||4"
msgid "You're a fisherman, Kiryu-san? That's amazing. <symbol=note_with_outline>\r\nI can't swim, so it seems really cool to me."
msgstr "Sei un pescatore, Kiryu-san? È fantastico. <symbol=note_with_outline>\r\nIo non so nuotare, quindi mi sembra una cosa fighissima."

msgctxt "501||||4"
msgid "Whoa... I don't really get it, but I feel bad\r\nfor you. Kiryu-san... Stay strong, please!"
msgstr "Whoa... Non ci capisco molto, ma mi dispiace\r\nper te. Kiryu-san... Tieni duro, ti prego!"

msgctxt "502||||4"
msgid "That's probably because you walk around\r\nwith a constant scowl!"
msgstr "Questo succede probabilmente perché vai in giro\r\ncon un'espressione sempre accigliata!"

msgctxt "503||||4"
msgid "If you strutted down the street with a cute\r\nsmile, I bet you'd get picked on less."
msgstr "Se camminassi per strada con un bel sorriso stampato\r\nin faccia, scommetto che saresti preso di mira molto meno."

msgctxt "504||||4"
msgid "In my case, that might get me into even\r\nmore fights, actually..."
msgstr "Nel mio caso, questo in realtà potrebbe procurarmi\r\nancora più guai..."

msgctxt "505||||4"
msgid "Pocket Circuit...? What's that?"
msgstr "Pocket Circuit...? Che cos'è?"

msgctxt "506||||4"
msgid "Oh, really? I think you're buff enough\r\nas it is, don't you?"
msgstr "Oh, davvero? Penso che tu sia già\r\nabbastanza palestrato, non credi?"

msgctxt "507||||4"
msgid "Me either.\r\nI prefer a relaxed atmosphere much more."
msgstr "Nemmeno io.\r\nPreferisco di gran lunga un'atmosfera più rilassata."

msgctxt "508||||4"
msgid "Oh really? You kinda look like the type to\r\nbe aggressive, though."
msgstr "Ah sì? Sembri un po' il tipo di persona\r\npiuttosto aggressiva, in realtà."

msgctxt "509||||4"
msgid "Really? Same here, actually. Kind of weird\r\nto say that in this job, though, huh? <symbol=note_with_outline>"
msgstr "Davvero? Anche per me è così, a dire il vero. Un po' strano\r\ndire una cosa del genere facendo questo lavoro, eh? <symbol=note_with_outline>"

msgctxt "510||||4"
msgid "Is that so? But maybe the two of us\r\nbeing like that makes us more compatible."
msgstr "Dici davvero? Ma forse il fatto che noi due\r\nsiamo così ci rende più compatibili."

msgctxt "511||||4"
msgid "Yeah! I hope we keep getting\r\nalong like this, Kiryu-san."
msgstr "Già! Spero che continueremo ad andare\r\nd'accordo in questo modo, Kiryu-san."

msgctxt "512||||4"
msgid "You must be pretty loaded, Kiryu-san. But what\r\nI like about a cheap bar is how casual they are."
msgstr "Devi essere piuttosto ricco, Kiryu-san. Ma quello che mi\r\npiace di un bar economico è che si può essere molto informali."

msgctxt "513||||4"
msgid "Hmmmm... Maybe, 40?"
msgstr "Uhm... Forse 40?"

msgctxt "514||||4"
msgid "Close. I'm 48."
msgstr "Ci sei andata vicino. Ne ho 48."

msgctxt "515||||4"
msgid "What!? Really!? You're older than my dad."
msgstr "Cosa!? Davvero!? Sei più grande di mio padre."

msgctxt "516||||4"
msgid "Older... than your dad...?"
msgstr "Più grande... di tuo padre...?"

msgctxt "517||||4"
msgid "......"
msgstr "......"

msgctxt "518||||4"
msgid "Huh? Something wrong, Kiryu-san?\r\nKiryu-saaaan?"
msgstr "Eh? C'è qualcosa che non va, Kiryu-san?\r\nKiryu-saaaan?"

msgctxt "519||||4"
msgid "Let's see... I think you're a good guy. <symbol=note_with_outline>"
msgstr "Vediamo un po'... Credo tu sia un brav'uomo. <symbol=note_with_outline>"

msgctxt "520||||4"
msgid "I think you're a very handsome\r\nand kind of mischievous person... <symbol=heart_with_outline>"
msgstr "Penso tu sia una persona molto bella e\r\nanche piuttosto maliziosa... <symbol=heart_with_outline>"

msgctxt "521||||4"
msgid "If I had to pick, older, I guess.\r\nI prefer a refined, mature man."
msgstr "Se dovessi scegliere, più grandi, immagino.\r\nPreferisco un uomo maturo e raffinato."

msgctxt "522||||4"
msgid "My fetish is secret conversations. I like\r\neavesdropping on people whispering to each other."
msgstr "Il mio feticcio sono le conversazioni segrete. Adoro\r\norigliare le persone che bisbigliano tra loro."

msgctxt "523||||4"
msgid "Huh... That's an unusual fetish."
msgstr "Mhm... È un feticcio inusuale."

msgctxt "524||||4"
msgid "Oh, you're speaking my language, Kiryu-san!\r\nI got kind of excited just now. <symbol=heart_with_outline>"
msgstr "Oh, parliamo la stessa lingua, Kiryu-san!\r\nMi sono un po' eccitata in questo momento. <symbol=heart_with_outline>"

msgctxt "525||||4"
msgid "What I want the most right now? I'm in college,\r\nso I want credits and a completed thesis!"
msgstr "La cosa che desidero di più al momento? Vado al college,\r\nquindi voglio dei crediti e una tesi finita!"

msgctxt "526||||4"
msgid "It was in middle school, I think.\r\nIt ended up unrequited, though."
msgstr "È stato alle medie, credo.\r\nPerò è finito per non essere corrisposto."

msgctxt "527||||4"
msgid "You didn't confess?"
msgstr "Non ti sei dichiarata?"

msgctxt "528||||4"
msgid "I couldn't do it! I used to get butterflies just talking\r\nto him, so I could barely form coherent sentences."
msgstr "Non ce la facevo! Avevo le farfalle nello stomaco solo a parlarci,\r\nriuscivo a malapena a formulare delle frasi di senso compiuto."

msgctxt "529||||4"
msgid "You used to be pretty innocent, huh?"
msgstr "Eri una ragazza parecchio ingenua, eh?"

msgctxt "530||||4"
msgid "I'm still innocent now!"
msgstr "Sono innocente ancora oggi!"

msgctxt "531||||4"
msgid "Gross, you can't just jump into dirty topics\r\nlike that... I'm not telling!"
msgstr "Che schifo, non puoi saltare a certi argomenti sconci\r\nin questo modo... Non te lo dico!"

msgctxt "532||||4"
msgid "Oh, Kiryu-san. I'm only telling because it's\r\nyou, okay? They're white... <symbol=heart_with_outline>"
msgstr "Oh, Kiryu-san. Te lo dico solo perché sei\r\ntu, okay? Sono bianche... <symbol=heart_with_outline>"

msgctxt "533||||4"
msgid "Ooh..."
msgstr "Ooh..."

msgctxt "534||||4"
msgid "Marriage, huh? I'd like to someday, but I don't\r\nfeel like I'm ready where I'm at now."
msgstr "Matrimonio, eh? Mi piacerebbe sposarmi un giorno, ma non\r\nmi sento ancora pronta al punto in cui mi trovo adesso."

msgctxt "535||||4"
msgid "Really? You seem like you'd be popular with\r\nthe guys. You'd have no problem settling down."
msgstr "Davvero? Hai proprio l'aria di avere un sacco di corteggiatori.\r\nNon avresti alcun problema a sistemarti."

msgctxt "536||||4"
msgid "Hm... I'm just still so unsure. Is the guy\r\nfor me out there somewhere?"
msgstr "Uhm... Ne sono ancora così insicura. Ci sarà il ragazzo\r\ngiusto per me da qualche parte là fuori?"

msgctxt "537||||4"
msgid "Huh? Really? Maybe you should propose\r\nthen, Kiryu-san!"
msgstr "Eh? Davvero? Allora forse dovresti fare tu\r\nla proposta, Kiryu-san!"

msgctxt "538||||4"
msgid "Wha<symbol=em_dash_with_outline>What are you trying to say!?"
msgstr "Ma c<symbol=em_dash_with_outline>Cosa stai cercando di dire!?"

msgctxt "539||||4"
msgid "Just kidding. <symbol=note_with_outline>"
msgstr "Stavo scherzando. <symbol=note_with_outline>"

msgctxt "540||||4"
msgid "You don't... want me?"
msgstr "Non mi... vuoi?"

msgctxt "541||||4"
msgid "I-It's not that... There's just a proper\r\norder to these things, and..."
msgstr "N-Non è questo... C'è un ordine\r\ngiusto per queste cose, e..."

msgctxt "542||||4"
msgid "Right... Well even if the timing's wrong,\r\nI won't give up just yet. <symbol=heart_with_outline>"
msgstr "Giusto... Beh, anche se il tempismo è sbagliato,\r\nnon mi arrenderò mica adesso. <symbol=heart_with_outline>"

msgctxt "543||||4"
msgid "Hey, what's that supposed to mean?\r\nYou make it sound like I need it to look good."
msgstr "Ehi, cosa vorrebbe dire?\r\nFai sembrare che io ne abbia bisogno per apparire bella."

msgctxt "544||||4"
msgid "N-No, that's not what I meant..."
msgstr "N-No, non era quello che intendevo..."

msgctxt "545||||4"
msgid "Just kidding. <symbol=note_with_outline> I'm happy to hear it.\r\nThank you. <symbol=note_with_outline>"
msgstr "Sto scherzando. <symbol=note_with_outline> Sono felice di sentirlo.\r\nGrazie. <symbol=note_with_outline>"

msgctxt "546||||4"
msgid "Huh? Umm, I don't think so...\r\nMaybe in our previous lives."
msgstr "Eh? Ehm, non credo proprio...\r\nForse in una delle nostre vite precedenti."

msgctxt "547||||4"
msgid "It's nice to hear, even if you are just trying to\r\nflatter me. I'm pretty proud of my butt, actually!"
msgstr "È bello sentirselo dire, anche se stai solo cercando di\r\nlusingarmi. A dire il vero, vado piuttosto fiera del mio sedere!"

msgctxt "548||||4"
msgid "Cheating? I hear a lot about celebrities\r\ncheating on each other these days..."
msgstr "Tradimento? Ultimamente sento parlare un sacco\r\ndi celebrità che si tradiscono a vicenda..."

msgctxt "549||||4"
msgid "If you got married, would you be\r\nthe type to cheat, Kiryu-san?"
msgstr "Se mai ti sposassi, saresti il\r\ntipo da tradire, Kiryu-san?"

msgctxt "550||||4"
msgid "I would never!"
msgstr "Non lo farei mai!"

msgctxt "551||||4"
msgid "Oh, is that so?"
msgstr "Oh, davvero?"

msgctxt "552||||4"
msgid "Well, maybe if you ever get married,\r\nI'll see if I can seduce you, then. <symbol=note_with_outline>"
msgstr "Beh, se mai ti sposassi, forse allora\r\ncercherò di vedere se riesco a sedurti. <symbol=note_with_outline>"

msgctxt "553||||4"
msgid "I'd want to!"
msgstr "Mi piacerebbe!"

msgctxt "554||||4"
msgid "At least you're honest. Hearing you admit\r\nit so boldly makes it sound a little less taboo."
msgstr "Almeno sei onesto. Sentirtelo ammettere con tanta\r\naudacia lo fa sembrare un po' meno tabù come argomento."

msgctxt "555||||4"
msgid "Hmm... I think I prefer staying in to talk\r\nand relax or watch a movie, maybe."
msgstr "Uhm... Credo di preferire stare in casa a parlare\r\ne rilassarmi o magari guardare un film."

msgctxt "556||||4"
msgid "Yeah, I'm the same way. I like the feeling of\r\nbeing at home in a place just for the two of us."
msgstr "Sì, io la penso allo stesso modo. Mi piace la sensazione\r\ndi stare a casa in un posto solo per noi due."

msgctxt "557||||4"
msgid "I might not look it, but I was actually in the\r\nbasketball club! ...As the team manager."
msgstr "Potrà anche non sembrare, ma facevo parte del\r\nclub di basket! ...Come manager della squadra."

msgctxt "558||||4"
msgid "Huh? The ones you're wearing right now?"
msgstr "Eh? Quelle che indossi in questo momento?"

msgctxt "559||||4"
msgid "I wouldn't mind, but, Kiryu-san...\r\nDid you wet yourself?"
msgstr "Non mi dispiacerebbe, ma Kiryu-san...\r\nTi sei fatto la pipì addosso?"

msgctxt "560||||4"
msgid "Uh... Never mind. Forget it."
msgstr "Ehm... Non importa. Lascia perdere."

msgctxt "561||||4"
msgid "Okay! That comes in the ¥100,000 option! <symbol=note_with_outline>"
msgstr "Okay! È incluso nell'opzione da 100.000 ¥! <symbol=note_with_outline>"

msgctxt "562||||4"
msgid "Oh, Kiryu-san.\r\nMy dad says the same thing. That's cute. <symbol=note_with_outline>"
msgstr "Oh, Kiryu-san.\r\nMio padre dice la stessa identica cosa. Che carino. <symbol=note_with_outline>"

msgctxt "563||||4"
msgid "I pick mostly idol songs,\r\nbut I do hard rock a lot, too."
msgstr "Scegli spesso le canzoni da idol,\r\nma spazio parecchio anche con l'hard rock."

msgctxt "564||||4"
msgid "Rock...? Do you know Machine Gun Kiss?"
msgstr "Rock...? Conosci Machine Gun Kiss?"

msgctxt "565||||4"
msgid "Yeah! The one that goes, \"hyaku oku no KISS wo abisemasu\r\nyo?\" The one all those pretentious old guys like to sing?"
msgstr "Sì! Quella che fa: \"hyaku oku no KISS wo abisemasu\r\nyo?\" Quella che amano cantare tutti quei vecchietti presuntuosi?"

msgctxt "566||||4"
msgid "I don't think only pretentious older guys sing it..."
msgstr "Non credo che la cantino soltanto i vecchietti presuntuosi..."

msgctxt "567||||4"
msgid "Dangerous men? You mean, like, stalker guys?"
msgstr "Uomini pericolosi? Vuoi dire, i tipi da stalker?"

msgctxt "568||||4"
msgid "No, it's more nuanced than that..."
msgstr "No, è una cosa un po' più complessa di così..."

msgctxt "569||||4"
msgid "I don't really get it, but I say safety beats\r\ndanger every time."
msgstr "Non ci arrivo, ma ti dico che la sicurezza vince\r\nsul pericolo in ogni caso."

msgctxt "570||||4"
msgid "Wow... I've never met anyone quite like that."
msgstr "Wow... Non ho mai incontrato nessuno del genere."

msgctxt "571||||4"
msgid "Date-san?"
msgstr "Date-san?"

msgctxt "572||||4"
msgid "Yeah. He's a detective I've known for a long time.\r\nHe's... kind of like a partner to me."
msgstr "Sì. È un detective che conosco da molto tempo.\r\nÈ... una specie di partner per me."

msgctxt "573||||4"
msgid "A partner, huh? <symbol=note_with_outline>\r\nYou must really like him, Kiryu-san."
msgstr "Un partner, eh? <symbol=note_with_outline>\r\nDeve piacerti davvero, Kiryu-san."

msgctxt "574||||4"
msgid "Yeah, I do."
msgstr "Sì, mi piace."

msgctxt "575||||4"
msgid "I'm kind of jealous that you\r\nhave someone so close like that."
msgstr "Sono un po' gelosa che tu\r\nabbia qualcuno di così vicino."

msgctxt "576||||4"
msgid "No, he's a pain in the ass."
msgstr "No, è una vera rottura di scatole."

msgctxt "577||||4"
msgid "Oh you, you don't have to act all tough. <symbol=note_with_outline>"
msgstr "Oh tu, non c'è bisogno che tu faccia il duro. <symbol=note_with_outline>"

msgctxt "578||||4"
msgid "I like you better..."
msgstr "Mi piaci di più tu..."

msgctxt "579||||4"
msgid "Oh, Kiryu-san.\r\nI feel bad for Date-san now. <symbol=note_with_outline>"
msgstr "Oh, Kiryu-san.\r\nMi dispiace un sacco per Date-san adesso. <symbol=note_with_outline>"

msgctxt "580||||4"
msgid "Wow... He sounds like a pretty cool guy."
msgstr "Wow... Sembra un tipo molto in gamba."

msgctxt "581||||4"
msgid "Someone who's bigger than you, Kiryu-san?\r\nThat's something I'd like to see!"
msgstr "Qualcuno che è più grosso di te, Kiryu-san?\r\nÈ una cosa che mi piacerebbe vedere!"

msgctxt "582||||4"
msgid "Wow... You must really trust him, Kiryu-san."
msgstr "Wow... Devi fidarti ciecamente di lui, Kiryu-san."

msgctxt "583||||4"
msgid "That's so nice.\r\nI hope you can trust me like that, too."
msgstr "È una cosa molto bella.\r\nSpero che tu possa fidarti anche di me in quel modo."

msgctxt "584||||4"
msgid "That'd be pretty great."
msgstr "Sarebbe davvero fantastico."

msgctxt "585||||4"
msgid "Ah, it's famous for its ramen, right?\r\nI hope I get a chance to go someday."
msgstr "Ah, è famoso per il suo ramen, vero?\r\nSpero di avere l'opportunità di andarci un giorno."

