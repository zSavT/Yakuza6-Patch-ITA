msgctxt "1||option||name"
msgid "Game Settings"
msgstr "Impostazioni di gioco"

msgctxt "2||save||name"
msgid "Save"
msgstr "Salva"

msgctxt "3||load||name"
msgid "Load"
msgstr "Carica"

msgctxt "4||return_to_title||name"
msgid "Quit Game"
msgstr "Esci dal gioco"

msgctxt "5||audio_option||name"
msgid "Audio Settings"
msgstr "Impostazioni audio"

msgctxt "6||profile||name"
msgid "Character Profiles"
msgstr "Profili dei personaggi"

msgctxt "7||controller_guide||name"
msgid "Controls"
msgstr "Comandi"

