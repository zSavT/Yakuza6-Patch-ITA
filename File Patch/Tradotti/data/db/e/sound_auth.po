msgctxt "1||speech_list_adv_shop_ippan||table||34||||4"
msgid "Get out of here!\nAnd don't come back!"
msgstr "Fuori di qui!\nE non si faccia più vedere!"

msgctxt "1||speech_list_adv_shop_ippan||table||35||||4"
msgid "How could you do that...?\nPlease stay away from my store."
msgstr "Come ha potuto...?\nPer favore, stia lontano dal mio negozio."

msgctxt "1||speech_list_adv_shop_ippan||table||36||||4"
msgid "Wh-What am I supposed to do now?\nPlease, see yourself out this instant."
msgstr "C-Cosa dovrei fare adesso...?\nLa prego, se ne vada all'istante."

msgctxt "1||speech_list_adv_shop_ippan||table||37||||4"
msgid "I'll fix this somehow!\nPlease come again, sir!"
msgstr "Sistemerò tutto in qualche modo!\nLa prego di tornare, signore!"

msgctxt "1||speech_list_adv_shop_ippan||table||38||||4"
msgid "This is kind of a problem...\nbut I hope you come again soon!"
msgstr "Questo è un bel problema...\nma spero tornerà a trovarci presto!"

msgctxt "1||speech_list_adv_shop_ippan||table||39||||4"
msgid "I've got real problems here!\nBut... I guess these things happen."
msgstr "È un vero disastro!\nMa... immagino che queste cose succedano."

msgctxt "1||speech_list_adv_shop_ippan||table||40||||4"
msgid "We don't have much in stock right now,\nbut I hope you find something you want!"
msgstr "Non abbiamo molta merce al momento,\nma spero trovi qualcosa di suo gradimento!"

msgctxt "1||speech_list_adv_shop_ippan||table||41||||4"
msgid "You've got to be kidding me!\nApologize for this, right now!"
msgstr "Starà scherzando, spero!\nChieda scusa per questo, ora!"

