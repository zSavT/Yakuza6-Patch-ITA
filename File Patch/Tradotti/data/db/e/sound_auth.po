msgctxt "88||speech_list_sub_b26||table||125||||4"
msgid "Nope, but there's a useful little\nthing in this world called gambling."
msgstr "No, ma a questo mondo c'è un'utile cosetta\nchiamata gioco d'azzardo."

msgctxt "88||speech_list_sub_b26||table||126||||4"
