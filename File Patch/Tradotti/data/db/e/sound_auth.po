msgstr "Ehi, tu! Cosa stai facendo!?"

msgctxt "12||speech_list_imssn||table||2226||||4"
msgid "Right, then. Don't ever do it again."
msgstr "D'accordo. Non farlo mai più."

msgctxt "12||speech_list_imssn||table||2227||||4"
