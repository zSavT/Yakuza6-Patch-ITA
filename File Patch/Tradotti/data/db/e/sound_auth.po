msgctxt "2||speech_list_adv_shop_sp||table||99||||4"
msgid "T'thank ya fer always usin' my taxi,\nI wanna give ya this ride fer free!"
msgstr "Per ringraziarti che prendi sempre il mio taxi,\nquesta corsa te la offro io!"

msgctxt "2||speech_list_adv_shop_sp||table||100||||4"
msgid "Hello there, Kiryu-san!\nWelcome to the Nyan Nyan Café!"
msgstr "Salve, Kiryu-san!\nBenvenuto al Nyan Nyan Café!"

msgctxt "2||speech_list_adv_shop_sp||table||101||||4"
msgid "Thank you very much!\nPlease come visit our furry friends again soon!"
msgstr "Grazie mille!\nTorna presto a trovare i nostri amici pelosi!"

msgctxt "2||speech_list_adv_shop_sp||table||102||||4"
msgid "I'm sure they'll be happy to see you!"
msgstr "Sono sicura che saranno felici di vederti!"

msgctxt "2||speech_list_adv_shop_sp||table||103||||4"
msgid "Our feline friends were overjoyed!\nNice choice, Kiryu-san!"
msgstr "I nostri amici felini erano felicissimi!\nOttima scelta, Kiryu-san!"

msgctxt "2||speech_list_adv_shop_sp||table||104||||4"
msgid "Our feline friends really loved that food.\nThey're on cloud nine!"
msgstr "I nostri amici felini hanno adorato quel cibo.\nSono al settimo cielo!"

msgctxt "2||speech_list_adv_shop_sp||table||105||||4"
msgid "Our feline friends are full of energy!\nHere, take this as thanks."
msgstr "I nostri amici felini sono pieni di energia!\nEcco, prendi questo come ringraziamento."

msgctxt "2||speech_list_adv_shop_sp||table||106||||4"
msgid "Thank you so much for everything today!\nPlease come visit our furry friends again soon!"
msgstr "Grazie mille per oggi!\nTorna presto a trovare i nostri amici pelosi!"

msgctxt "2||speech_list_adv_shop_sp||table||107||||4"
msgid "Welcome!"
msgstr "Benvenuto!"

msgctxt "2||speech_list_adv_shop_sp||table||108||||4"
msgid "What are you looking for today?"
msgstr "Cosa cercava oggi?"

msgctxt "2||speech_list_adv_shop_sp||table||109||||4"
msgid "Thank you very much!"
msgstr "Grazie mille!"

msgctxt "2||speech_list_adv_shop_sp||table||110||||4"
msgid "I'm sorry, but we're currently closed for today."
msgstr "Mi dispiace, ma abbiamo chiuso per oggi."

msgctxt "2||speech_list_adv_shop_sp||table||111||||4"
msgid "This area's currently closed off\nfor construction. My apologies."
msgstr "Quest'area è momentaneamente chiusa\nper lavori. Mi scuso per il disagio."

msgctxt "2||speech_list_adv_shop_sp||table||112||||4"
msgid "We're restoring this building here back to\nits original state after years of deterioration."
msgstr "Stiamo restaurando questo edificio per riportarlo\nallo stato originale dopo anni di incuria."

msgctxt "2||speech_list_adv_shop_sp||table||113||||4"
msgid "Sorry for the inconvenience."
msgstr "Ci scusiamo per il disagio."

msgctxt "2||speech_list_adv_shop_sp||table||114||||4"
msgid "We're doing some large-scale reconstruction\non the sewer system beyond here."
msgstr "Stiamo effettuando dei lavori di ricostruzione su\nlarga scala nel sistema fognario qui oltre."

msgctxt "2||speech_list_adv_shop_sp||table||115||||4"
msgid "Sorry for the inconvenience,\nbut you'll need to take a detour."
msgstr "Ci scusiamo per il disagio,\nma dovrà prendere una deviazione."

msgctxt "2||speech_list_adv_shop_sp||table||116||||4"
msgid "(I shouldn't leave yet...)"
msgstr "(Non dovrei ancora andarmene...)"

msgctxt "2||speech_list_adv_shop_sp||table||117||||4"
msgid "(I don't have time to be messing around...)"
msgstr "(Non ho tempo da perdere...)"

msgctxt "2||speech_list_adv_shop_sp||table||118||||4"
msgid "(I shouldn't bring Haruto to Little Asia with me...)"
msgstr "(Non dovrei portare Haruto a Little Asia con me...)"

msgctxt "2||speech_list_adv_shop_sp||table||119||||4"
msgid "(I should go somewhere with fewer people...)"
msgstr "(Dovrei andare in un posto con meno gente...)"

msgctxt "2||speech_list_adv_shop_sp||table||120||||4"
msgid "Kiryu-san."
msgstr "Kiryu-san."

msgctxt "2||speech_list_adv_shop_sp||table||121||||4"
msgid "Oh, Kiryu-san."
msgstr "Oh, Kiryu-san."

msgctxt "2||speech_list_adv_shop_sp||table||122||||4"
msgid "Welcome."
msgstr "Benvenuto."

msgctxt "2||speech_list_adv_shop_sp||table||123||||4"
msgid "See you later!"
msgstr "A dopo!"

msgctxt "2||speech_list_adv_shop_sp||table||124||||4"
msgid "Take it easy."
msgstr "Vai con calma."

msgctxt "4||speech_list_btl_hact||table||0||||4"
msgid "Kiryu-aniki!"
msgstr "Kiryu-aniki!"

msgctxt "4||speech_list_btl_hact||table||1||||4"
msgid "We'll help you out, Kiryu-aniki!"
msgstr "Ti diamo una mano noi, Kiryu-aniki!"

msgctxt "4||speech_list_btl_hact||table||2||||4"
msgid "Let's head down there!"
msgstr "Scendiamo laggiù!"

msgctxt "4||speech_list_btl_hact||table||3||||4"
msgid "Y'better not've forgotten 'bout us!"
msgstr "Vedi di non dimenticarti di noi!"

msgctxt "4||speech_list_btl_hact||table||4||||4"
msgid "Get ready for a righteous\nwhoopin'!"
msgstr "Preparati a una bella\nripassata!"

msgctxt "4||speech_list_btl_hact||table||6||||4"
msgid "C'mon, let's do this!"
msgstr "Forza, diamoci dentro!"

msgctxt "4||speech_list_btl_hact||table||8||||4"
msgid "Y'little shit!"
msgstr "Pezzo di merda!"

msgctxt "4||speech_list_btl_hact||table||9||||4"
msgid "I'm gonna kill ya!"
msgstr "Ti ammazzo!"

msgctxt "4||speech_list_btl_hact||table||11||||4"
msgid "Gah, fuck this..."
msgstr "Argh, fanculo..."

msgctxt "4||speech_list_btl_hact||table||12||||4"
msgid "Yo, old man!"
msgstr "Ehi, vecchio!"

msgctxt "4||speech_list_btl_hact||table||13||||4"
msgid "Hurry up and hand over your wallet!"
msgstr "Sbrigati a sganciare il portafoglio!"

msgctxt "4||speech_list_btl_hact||table||14||||4"
msgid "I could use a bit of spendin' money!"
msgstr "Mi farebbe comodo un po' di grana!"

msgctxt "4||speech_list_btl_hact||table||15||||4"
msgid "All right... Let's do this!"
msgstr "D'accordo... Diamoci dentro!"

msgctxt "4||speech_list_btl_hact||table||16||||4"
msgid "Right."
msgstr "Ricevuto."

msgctxt "4||speech_list_btl_hact||table||17||||4"
msgid "Sounds like you need to learn some manners."
msgstr "Sembra ti serva una lezione di buone maniere."

msgctxt "4||speech_list_btl_hact||table||18||||4"
msgid "I need to keep moving."
msgstr "Devo continuare a muovermi."

msgctxt "4||speech_list_btl_hact||table||19||||4"
msgid "This isn't the right way..."
msgstr "Non è la strada giusta..."

msgctxt "4||speech_list_btl_hact||table||20||||4"
msgid "Let's do this!"
msgstr "Diamoci dentro!"

msgctxt "4||speech_list_btl_hact||table||21||||4"
msgid "Don't let your guard down."
msgstr "Non abbassare la guardia."

msgctxt "4||speech_list_btl_hact||table||22||||4"
msgid "Nagumo!?"
msgstr "Nagumo!?"

msgctxt "4||speech_list_btl_hact||table||24||||4"
msgid "Get outta my way!"
msgstr "Togliti di mezzo!"

msgctxt "4||speech_list_btl_hact||table||25||||4"
msgid "Dammit."
msgstr "Maledizione."

msgctxt "4||speech_list_btl_hact||table||27||||4"
msgid "Good luck."
msgstr "Buona fortuna."

msgctxt "4||speech_list_btl_hact||table||28||||4"
msgid "I'll be counting on you."
msgstr "Conto su di te."

msgctxt "4||speech_list_btl_hact||table||29||||4"
msgid "Always with the helicopters...\nWhat a pain in the ass."
msgstr "Sempre con questi elicotteri...\nChe rottura di palle."

msgctxt "4||speech_list_btl_hact||table||30||||4"
msgid "The elevator doesn't go past here..."
msgstr "L'ascensore non va oltre..."

msgctxt "4||speech_list_btl_hact||table||31||||4"
msgid "Looks like we have to fight..."
msgstr "Mi sa che ci tocca combattere..."

msgctxt "4||speech_list_btl_hact||table||32||||4"
msgid "Sorry..."
msgstr "Scusa..."

msgctxt "4||speech_list_btl_hact||table||33||||4"
msgid "Look what we got here. Let's take 'em down!"
msgstr "Guarda un po' chi c'è. Facciamoli fuori!"

msgctxt "4||speech_list_btl_hact||table||34||||4"
msgid "There they are!"
msgstr "Eccoli!"

msgctxt "4||speech_list_btl_hact||table||35||||4"
msgid "[Hey, there they are!]"
msgstr "[Ehi, eccoli!]"

msgctxt "4||speech_list_btl_hact||table||36||||4"
msgid "Is that it?"
msgstr "Tutto qui?"

msgctxt "4||speech_list_btl_hact||table||37||||4"
msgid "I'll tear you apart!"
msgstr "Ti faccio a pezzi!"

msgctxt "4||speech_list_btl_hact||table||38||||4"
msgid "You're finished!"
msgstr "Sei finito!"

msgctxt "4||speech_list_btl_hact||table||40||||4"
msgid "Come here!"
msgstr "Vieni qui!"

msgctxt "4||speech_list_btl_hact||table||48||||4"
msgid "Looks like I'll finally get the workout\nI've been itching for this whole time."
msgstr "Sembra che finalmente potrò sgranchirmi le ossa\ncome volevo da un bel pezzo."

msgctxt "4||speech_list_btl_hact||table||49||||4"
msgid "Is something wrong, Kiryu-san?"
msgstr "Qualcosa non va, Kiryu-san?"

msgctxt "4||speech_list_btl_hact||table||50||||4"
msgid "Goddammit!"
msgstr "Porca puttana!"

msgctxt "4||speech_list_btl_hact||table||62||||4"
msgid "Just my luck!"
msgstr "La mia solita fortuna!"

msgctxt "4||speech_list_btl_hact||table||63||||4"
msgid "Kiryu-san."
msgstr "Kiryu-san."

msgctxt "4||speech_list_btl_hact||table||64||||4"
msgid "When I say your name, come over to me."
msgstr "Quando ti chiamo, vieni da me."

msgctxt "4||speech_list_btl_hact||table||65||||4"
msgid "Kiryu-san. I'll go on ahead and scout it out."
msgstr "Kiryu-san. Vado avanti a dare un'occhiata."

msgctxt "4||speech_list_btl_hact||table||66||||4"
msgid "Good luck."
msgstr "Buona fortuna."

msgctxt "4||speech_list_btl_hact||table||67||||4"
msgid "I'll be counting on you."
msgstr "Conto su di te."

msgctxt "4||speech_list_btl_hact||table||68||||4"
msgid "I need to keep moving."
msgstr "Devo continuare a muovermi."

msgctxt "4||speech_list_btl_hact||table||69||||4"
msgid "This isn't the right way..."
msgstr "Non è la strada giusta..."

msgctxt "5||speech_list_caba_cabacrew||table||0||||4"
msgid "Welcome to Club Shine."
msgstr "Benvenuto al Club Shine."

msgctxt "5||speech_list_caba_cabacrew||table||1||||4"
msgid "We offer a 6,000 yen package with an additional\n2,000 yen service fee."
msgstr "Offriamo un pacchetto da 6.000 yen con l'aggiunta\ndi 2.000 yen per il servizio."

msgctxt "5||speech_list_caba_cabacrew||table||2||||4"
msgid "There is also a separate 2,000 yen request fee."
msgstr "C'è anche una quota di richiesta separata di 2.000 yen."

msgctxt "5||speech_list_caba_cabacrew||table||3||||4"
msgid "Are you interested?"
msgstr "Le interessa?"

msgctxt "5||speech_list_caba_cabacrew||table||4||||4"
msgid "Who would you like to request?"
msgstr "Chi desidera richiedere?"

msgctxt "5||speech_list_caba_cabacrew||table||5||||4"
msgid "Very well.\nWe look forward to your next visit."
msgstr "Molto bene.\nSperiamo di rivederla presto."

msgctxt "5||speech_list_caba_cabacrew||table||6||||4"
msgid "Riona? Just a moment, please."
msgstr "Riona? Un momento, per favore."

msgctxt "5||speech_list_caba_cabacrew||table||7||||4"
msgid "Saki? Just a moment, please."
msgstr "Saki? Un momento, per favore."

msgctxt "5||speech_list_caba_cabacrew||table||8||||4"
msgid "Erina? Just a moment, please."
msgstr "Erina? Un momento, per favore."

msgctxt "5||speech_list_caba_cabacrew||table||9||||4"
msgid "Sora? Just a moment, please."
msgstr "Sora? Un momento, per favore."

msgctxt "5||speech_list_caba_cabacrew||table||10||||4"
msgid "Hikaru? Just a moment, please."
msgstr "Hikaru? Un momento, per favore."

msgctxt "5||speech_list_caba_cabacrew||table||11||||4"
msgid "If you'll excuse me."
msgstr "Con permesso."

msgctxt "5||speech_list_caba_cabacrew||table||12||||4"
msgid "Just a moment, sir."
msgstr "Un momento, signore."

msgctxt "5||speech_list_caba_cabacrew||table||13||||4"
msgid "Your drink, sir."
msgstr "Il suo drink, signore."

msgctxt "5||speech_list_caba_cabacrew||table||14||||4"
msgid "Your order, sir."
msgstr "La sua ordinazione, signore."

msgctxt "5||speech_list_caba_cabacrew||table||15||||4"
msgid "I'm afraid your time is almost up."
msgstr "Temo che il suo tempo sia quasi scaduto."

msgctxt "5||speech_list_caba_cabacrew||table||16||||4"
msgid "What would you like to do?"
msgstr "Cosa desidera fare?"

msgctxt "5||speech_list_caba_cabacrew||table||17||||4"
msgid "Take your time, sir."
msgstr "Faccia con comodo, signore."

msgctxt "5||speech_list_caba_cabacrew||table||18||||4"
msgid "Very well."
msgstr "Molto bene."

msgctxt "5||speech_list_caba_cabacrew||table||19||||4"
msgid "Your bill, sir."
msgstr "Il suo conto, signore."

msgctxt "5||speech_list_caba_cabacrew||table||20||||4"
msgid "Thank you very much."
msgstr "Grazie mille."

msgctxt "5||speech_list_caba_cabacrew||table||21||||4"
msgid "(I'm starting to feel the alcohol.)"
msgstr "(Inizio a sentire l'effetto dell'alcol.)"

msgctxt "5||speech_list_caba_cabacrew||table||22||||4"
msgid "(Seems I'm short on cash...)"
msgstr "(Mi sa che sono a corto di contanti...)"

msgctxt "5||speech_list_caba_cabacrew||table||23||||4"
msgid "Maybe next time."
msgstr "Sarà per un'altra volta."

msgctxt "5||speech_list_caba_cabacrew||table||24||||4"
msgid "(The hostess I requested isn't here today...)"
msgstr "(La hostess che ho richiesto non c'è oggi...)"

msgctxt "5||speech_list_caba_cabacrew||table||25||||4"
msgid "(I'm short on cash. I should check the prices\nbefore I walk into these things.)"
msgstr "(Sono a corto di contanti. Dovrei controllare i prezzi\nprima di entrare in posti del genere.)"

msgctxt "5||speech_list_caba_cabacrew||table||26||||4"
msgid "(I'm really feeling the alcohol...\nI might have to leave soon.)"
msgstr "(Sento davvero l'effetto dell'alcol...\nMi sa che dovrò andarmene presto.)"

msgctxt "5||speech_list_caba_cabacrew||table||27||||4"
msgid "(I'm practically drunk... I should sober\nup a bit before I head out to meet her.)"
msgstr "(Sono praticamente ubriaco... Dovrei smaltire\nun po' prima di andare a incontrarla.)"

msgctxt "6||speech_list_caba_erina||table||0||||4"
msgid "Sorry to keep you waiting! <symbol=note_with_outline>"
msgstr "Scusa per l'attesa! <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||1||||4"
msgid "Sorry... Did you have to wait long?"
msgstr "Scusa... Hai aspettato molto?"

msgctxt "6||speech_list_caba_erina||table||2||||4"
msgid "Kiryu-san! Thanks for coming. <symbol=note_with_outline>"
msgstr "Kiryu-san! Grazie per essere venuto. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||3||||4"
msgid "Where do you want to go?"
msgstr "Dove vuoi andare?"

msgctxt "6||speech_list_caba_erina||table||4||||4"
msgid "Oh, I love karaoke! <symbol=note_with_outline>"
msgstr "Oh, adoro il karaoke! <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||5||||4"
msgid "Darts, huh?\r\nI enjoy a game every now and then."
msgstr "Freccette, eh?\r\nOgni tanto mi piace fare una partita."

msgctxt "6||speech_list_caba_erina||table||6||||4"
msgid "Well, shall we get going? <symbol=note_with_outline>"
msgstr "Bene, andiamo? <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||7||||4"
msgid "What kind of songs do you like?"
msgstr "Che genere di canzoni ti piacciono?"

msgctxt "6||speech_list_caba_erina||table||8||||4"
msgid "What should I sing? <symbol=note_with_outline>"
msgstr "Cosa dovrei cantare? <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||9||||4"
msgid "I'm like a darts machine!"
msgstr "Sono un asso a freccette!"

msgctxt "6||speech_list_caba_erina||table||10||||4"
msgid "Huh? What were the rules again?"
msgstr "Eh? Quali erano le regole?"

msgctxt "6||speech_list_caba_erina||table||11||||4"
msgid "It's so nice to be out with  with you, Kiryu-san! <symbol=note_with_outline>\r\nWhat should I pick?"
msgstr "È così bello uscire con te, Kiryu-san! <symbol=note_with_outline>\r\nCosa dovrei scegliere?"

msgctxt "6||speech_list_caba_erina||table||12||||4"
msgid "That was fun! <symbol=note_with_outline>\r\nLet's hang out again sometime."
msgstr "È stato divertente! <symbol=note_with_outline>\r\nUsciamo di nuovo, qualche volta."

msgctxt "6||speech_list_caba_erina||table||13||||4"
msgid "That was so fun! <symbol=heart_with_outline>\r\nI really enjoyed myself!"
msgstr "È stato divertentissimo! <symbol=heart_with_outline>\r\nMi sono proprio divertita!"

msgctxt "6||speech_list_caba_erina||table||14||||4"
msgid "How'd it get so late?\r\nYou wanna head back to the club?"
msgstr "Ma come ha fatto a farsi già così tardi?\r\nVuoi tornare al club?"

msgctxt "6||speech_list_caba_erina||table||15||||4"
msgid "I love this song!\nI hope you like it too. <symbol=heart_with_outline>"
msgstr "Adoro questa canzone!\nSpero piaccia anche a te. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||16||||4"
msgid "This song's my jam. <symbol=note_with_outline>"
msgstr "Questa è proprio la mia canzone. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||17||||4"
msgid "Hmm... It's kind of hard to sing like that..."
msgstr "Hmm... È un po' difficile cantare così..."

msgctxt "6||speech_list_caba_erina||table||18||||4"
msgid "Kiryu-san! It's hard to sing like this..."
msgstr "Kiryu-san! È difficile cantare così..."

msgctxt "6||speech_list_caba_erina||table||19||||4"
msgid "That was fun!\r\nYou're really good at getting me pumped!"
msgstr "È stato divertente!\r\nSei bravissimo a darmi la carica!"

msgctxt "6||speech_list_caba_erina||table||20||||4"
msgid "That felt great!\r\nYou're good at setting a mood. <symbol=note_with_outline>"
msgstr "È stato fantastico!\r\nSei bravo a creare l'atmosfera giusta. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||21||||4"
msgid "I wanna hear you sing something! <symbol=note_with_outline>"
msgstr "Voglio sentirti cantare qualcosa! <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||22||||4"
msgid "Whaaat? I wanted to see you sing..."
msgstr "Cooosa? Volevo vederti cantare..."

msgctxt "6||speech_list_caba_erina||table||23||||4"
msgid "Th-That was an interesting song..."
msgstr "Q-Quella era una canzone interessante..."

msgctxt "6||speech_list_caba_erina||table||24||||4"
msgid "You're such a good singer!\r\nI was a captive audience the whole time."
msgstr "Sei così bravo a cantare!\r\nMi hai tenuta incollata per tutto il tempo."

msgctxt "6||speech_list_caba_erina||table||25||||4"
msgid "You sounded like a pro!\r\nThat was amazing. <symbol=heart_with_outline>"
msgstr "Sembravi un professionista!\r\nÈ stato fantastico. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||26||||4"
msgid "Huh!? Wow, that's awesome!"
msgstr "Eh!? Wow, è fantastico!"

msgctxt "6||speech_list_caba_erina||table||27||||4"
msgid "Thank you."
msgstr "Grazie."

msgctxt "6||speech_list_caba_erina||table||28||||4"
msgid "Huh...?"
msgstr "Eh...?"

msgctxt "6||speech_list_caba_erina||table||29||||4"
msgid "I love those too!\r\nI can never stop snacking on them."
msgstr "Piacciono tantissimo anche a me!\r\nNon riesco mai a smettere di mangiarli."

msgctxt "6||speech_list_caba_erina||table||30||||4"
msgid "Hi there!"
msgstr "Ciao!"

msgctxt "6||speech_list_caba_erina||table||31||||4"
msgid "It's nice to meet you.\r\nI'm Erina."
msgstr "Piacere di conoscerti.\r\nSono Erina."

msgctxt "6||speech_list_caba_erina||table||32||||4"
msgid "Can I ask your name?"
msgstr "Posso chiederti come ti chiami?"

msgctxt "6||speech_list_caba_erina||table||33||||4"
msgid "Kazuma Kiryu."
msgstr "Kazuma Kiryu."

msgctxt "6||speech_list_caba_erina||table||34||||4"
msgid "Kiryu-san, then? I'm looking forward\r\nto spending some time with you today!"
msgstr "Kiryu-san, allora? Non vedo l'ora\r\ndi passare un po' di tempo con te oggi!"

msgctxt "6||speech_list_caba_erina||table||35||||4"
msgid "Likewise."
msgstr "Altrettanto."

msgctxt "6||speech_list_caba_erina||table||36||||4"
msgid "Today was really fun, Kiryu-san. <symbol=note_with_outline>"
msgstr "Oggi è stato davvero divertente, Kiryu-san. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||37||||4"
msgid "You'll come and hang out with me again, right?"
msgstr "Verrai a trovarmi di nuovo, vero?"

msgctxt "6||speech_list_caba_erina||table||38||||4"
msgid "Yeah, I'll be back."
msgstr "Sì, tornerò."

msgctxt "6||speech_list_caba_erina||table||39||||4"
msgid "I'll be here for you any time. <symbol=heart_with_outline>"
msgstr "Sarò qui per te quando vorrai. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||40||||4"
msgid "Oh, Kiryu-san!\r\nYou came to see me!"
msgstr "Oh, Kiryu-san!\r\nSei venuto a trovarmi!"

msgctxt "6||speech_list_caba_erina||table||41||||4"
msgid "I've been waiting for you, Kiryu-san. <symbol=heart_with_outline>"
msgstr "Ti stavo aspettando, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||42||||4"
msgid "I've waited for you for so long... <symbol=heart_with_outline>"
msgstr "Ti ho aspettato per così tanto tempo... <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||43||||4"
msgid "You're all mine today. <symbol=note_with_outline>"
msgstr "Oggi sei tutto mio. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||44||||4"
msgid "Right this way."
msgstr "Da questa parte."

msgctxt "6||speech_list_caba_erina||table||45||||4"
msgid "Kiryu-san!"
msgstr "Kiryu-san!"

msgctxt "6||speech_list_caba_erina||table||46||||4"
msgid "Thanks for coming today.\r\nHope to see you again!"
msgstr "Grazie per essere venuto oggi.\r\nSpero di rivederti!"

msgctxt "6||speech_list_caba_erina||table||47||||4"
msgid "Thank you so much!\r\nI can't wait to see you again!"
msgstr "Grazie mille!\r\nNon vedo l'ora di rivederti!"

msgctxt "6||speech_list_caba_erina||table||48||||4"
msgid "Time flies when you're having fun.\r\nYou'd better come back again, okay? <symbol=heart_with_outline>"
msgstr "Il tempo vola quando ci si diverte.\r\nVedi di tornare ancora, okay? <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||49||||4"
msgid "Well, Kiryu-san, thanks for coming in today! <symbol=heart_with_outline>"
msgstr "Beh, Kiryu-san, grazie per essere passato oggi! <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||50||||4"
msgid "Cheers!"
msgstr "Salute!"

msgctxt "6||speech_list_caba_erina||table||51||||4"
msgid "Oh, Kiryu-san.\r\nDo you have a second?"
msgstr "Oh, Kiryu-san.\r\nHai un secondo?"

msgctxt "6||speech_list_caba_erina||table||52||||4"
msgid "Here's my phone number.\r\nYou should invite me out sometime, okay? <symbol=heart_with_outline>"
msgstr "Questo è il mio numero di telefono.\r\nDovresti invitarmi a uscire qualche volta, okay? <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||53||||4"
msgid "Time's almost up.\r\nWhat do you want to do?"
msgstr "Il tempo è quasi scaduto.\r\nCosa vuoi fare?"

msgctxt "6||speech_list_caba_erina||table||54||||4"
msgid "It's already so late...\r\nI want to keep talking with you. <symbol=heart_with_outline>"
msgstr "È già così tardi...\r\nVoglio continuare a parlare con te. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||55||||4"
msgid "Yay! Happy to hear it. <symbol=heart_with_outline>"
msgstr "Evviva! Sono felice di sentirtelo dire. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||56||||4"
msgid "Thank you.\r\nLet's do this again sometime, okay? <symbol=note_with_outline>"
msgstr "Grazie.\r\nFacciamolo di nuovo, qualche volta, okay? <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||57||||4"
msgid "It really is true."
msgstr "È proprio vero."

msgctxt "6||speech_list_caba_erina||table||58||||4"
msgid "You're right!"
msgstr "Hai ragione!"

msgctxt "6||speech_list_caba_erina||table||59||||4"
msgid "I see. I didn't know that."
msgstr "Capisco. Non lo sapevo."

msgctxt "6||speech_list_caba_erina||table||60||||4"
msgid "Right!? I think so, too."
msgstr "Vero!? Lo penso anch'io."

msgctxt "6||speech_list_caba_erina||table||61||||4"
msgid "Hm... I wonder?"
msgstr "Mhm... Chissà?"

msgctxt "6||speech_list_caba_erina||table||62||||4"
msgid "Sorry. I don't really understand..."
msgstr "Scusa. Non credo di aver capito..."

msgctxt "6||speech_list_caba_erina||table||63||||4"
msgid "Huh? Really?"
msgstr "Eh? Davvero?"

msgctxt "6||speech_list_caba_erina||table||64||||4"
msgid "I don't think that's right..."
msgstr "Non credo sia giusto..."

msgctxt "6||speech_list_caba_erina||table||65||||4"
msgid "Geez, what are you saying, Kiryu-san?"
msgstr "Cavoli, ma che dici, Kiryu-san?"

msgctxt "6||speech_list_caba_erina||table||66||||4"
msgid "Yeah, that's right. <symbol=note_with_outline>"
msgstr "Sì, esatto. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||67||||4"
msgid "Wow, really?"
msgstr "Wow, sul serio?"

msgctxt "6||speech_list_caba_erina||table||68||||4"
msgid "I wonder..."
msgstr "Chissà..."

msgctxt "6||speech_list_caba_erina||table||69||||4"
msgid "Um... Do you have a lot of male friends,\r\nKiryu-san?"
msgstr "Ehm... Hai molti amici maschi,\r\nKiryu-san?"

msgctxt "6||speech_list_caba_erina||table||70||||4"
msgid "Friends, huh?\r\nYeah, I guess most of my close friends are guys."
msgstr "Amici, eh?\r\nSì, direi che quasi tutti i miei amici più stretti sono uomini."

msgctxt "6||speech_list_caba_erina||table||71||||4"
msgid "Wow, that's nice..."
msgstr "Wow, che bello..."

msgctxt "6||speech_list_caba_erina||table||72||||4"
msgid "Why, are you looking to meet more guys?"
msgstr "Perché, stai cercando di conoscere più ragazzi?"

msgctxt "6||speech_list_caba_erina||table||73||||4"
msgid "No, quite the opposite. I have a tough\r\ntime making female friends, actually."
msgstr "No, tutto il contrario. In realtà faccio molta\r\nfatica a farmi delle amiche."

msgctxt "6||speech_list_caba_erina||table||74||||4"
msgid "The other day, a girl I was getting along with\r\naccused me of trying to seduce her boyfriend..."
msgstr "L'altro giorno, una ragazza con cui andavo d'accordo\r\nmi ha accusata di aver provato a sedurre il suo ragazzo..."

msgctxt "6||speech_list_caba_erina||table||75||||4"
msgid "Were you... giving him the look or anything?"
msgstr "Gli stavi per caso... facendo gli occhi dolci o cose del genere?"

msgctxt "6||speech_list_caba_erina||table||76||||4"
msgid "No! I would never do that."
msgstr "No! Non lo farei mai."

msgctxt "6||speech_list_caba_erina||table||77||||4"
msgid "But she called me \"conniving\" and \"fake...\""
msgstr "Ma lei mi ha dato della \"calcolatrice\" e della \"falsa\"..."

msgctxt "6||speech_list_caba_erina||table||78||||4"
msgid "That's terrible..."
msgstr "È terribile..."

msgctxt "6||speech_list_caba_erina||table||79||||4"
msgid "Kiryu-san... Do I seem like that to you?"
msgstr "Kiryu-san... Ti sembro una tipa del genere?"

msgctxt "6||speech_list_caba_erina||table||80||||4"
msgid "I wouldn't say that."
msgstr "Non direi."

msgctxt "6||speech_list_caba_erina||table||81||||4"
msgid "Right!? I wasn't even thinking about that.\r\nWhy would she say that to me?"
msgstr "Vero!? Non ci stavo nemmeno pensando.\r\nPerché mi ha detto una cosa simile?"

msgctxt "6||speech_list_caba_erina||table||82||||4"
msgid "Maybe you're doing something subconsciously\r\nthat gives people the wrong idea."
msgstr "Forse fai qualcosa inconsciamente\r\nche dà alla gente l'idea sbagliata."

msgctxt "6||speech_list_caba_erina||table||83||||4"
msgid "Subconsciously?"
msgstr "Inconsciamente?"

msgctxt "6||speech_list_caba_erina||table||84||||4"
msgid "Yeah. With me, I seem to subconsciously draw\r\npunks into trying to fight me on the streets."
msgstr "Sì. Nel mio caso, sembra che io attiri inconsciamente\r\nteppisti che vogliono affrontarmi per strada."

msgctxt "6||speech_list_caba_erina||table||85||||4"
msgid "...Setting aside how unique that problem is...\r\nIt's got to be something I don't know I'm doing."
msgstr "...A parte quanto sia particolare il tuo problema...\r\nDeve essere qualcosa che faccio senza rendermene conto."

msgctxt "6||speech_list_caba_erina||table||86||||4"
msgid "Maybe I should give it some thought.\r\nThanks for hearing me out, though."
msgstr "Forse dovrei rifletterci su.\r\nGrazie per avermi ascoltata, comunque."

msgctxt "6||speech_list_caba_erina||table||87||||4"
msgid "Well, that's just the kind of allure you have.\r\nMaybe you're just a natural temptress."
msgstr "Beh, è il tipo di fascino che hai.\r\nForse sei semplicemente una seduttrice nata."

msgctxt "6||speech_list_caba_erina||table||88||||4"
msgid "Oh, stop... I'm not like that at all. <symbol=heart_with_outline>"
msgstr "Oh, dai... Non sono affatto così. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||89||||4"
msgid "Hmph. I guess I need to be more careful about\r\nhow I'm being interpreted."
msgstr "Uff. Immagino di dover stare più attenta a\r\ncome vengo interpretata."

msgctxt "6||speech_list_caba_erina||table||90||||4"
msgid "Well, if the shoe fits..."
msgstr "Beh, se ti calza a pennello..."

msgctxt "6||speech_list_caba_erina||table||91||||4"
msgid "Whaaaaat? You too, Kiryu-san?"
msgstr "Cooosa? Anche tu, Kiryu-san?"

msgctxt "6||speech_list_caba_erina||table||92||||4"
msgid "It's not necessarily a bad thing, though.\r\nIn a job like this, that's one of your weapons."
msgstr "Non è necessariamente un male, però.\r\nIn un lavoro come questo, è una delle tue armi."

msgctxt "6||speech_list_caba_erina||table||93||||4"
msgid "I don't want it to stop me from making friends though...\r\nEspecially if I'm not even trying to be like that..."
msgstr "Non voglio che mi impedisca di farmi delle amiche, però...\r\nSpecialmente se non sto nemmeno cercando di fare la gattamorta..."

msgctxt "6||speech_list_caba_erina||table||94||||4"
msgid "Well, maybe you're doing something subconsciously\r\nthat gives men the wrong impression."
msgstr "Beh, forse fai qualcosa inconsciamente\r\nche dà agli uomini l'impressione sbagliata."

msgctxt "6||speech_list_caba_erina||table||95||||4"
msgid "With me, I seem to subconsciously make punks\r\nwant to fight me on the street. Sorta like that."
msgstr "Nel mio caso, sembra che spinga inconsciamente i teppisti\r\na volermi affrontare per strada. Una cosa del genere."

msgctxt "6||speech_list_caba_erina||table||96||||4"
msgid "I don't know if it's quite like that... but\r\nmaybe you're right about the subconscious thing."
msgstr "Non so se sia esattamente la stessa cosa... ma\r\nforse hai ragione sulla parte dell'inconscio."

msgctxt "6||speech_list_caba_erina||table||97||||4"
msgid "Well, that's just the kind of allure you have.\r\nMaybe you're just a natural temptress."
msgstr "Beh, è il tipo di fascino che hai.\r\nForse sei semplicemente una seduttrice nata."

msgctxt "6||speech_list_caba_erina||table||98||||4"
msgid "Oh, please don't tease me...\r\nI'm not like that at all. <symbol=heart_with_outline>"
msgstr "Oh, ti prego, non prendermi in giro...\r\nNon sono affatto così. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||99||||4"
msgid "I think it's got to be something like that...\r\nBesides, I like those kind of women anyway."
msgstr "Penso debba essere qualcosa del genere...\r\nE poi, a me le donne così piacciono comunque."

msgctxt "6||speech_list_caba_erina||table||100||||4"
msgid "But aren't you actually faking it?\r\nMaybe you're faking it with me too?"
msgstr "Ma non è che in realtà fingi?\r\nForse stai fingendo anche con me?"

msgctxt "6||speech_list_caba_erina||table||101||||4"
msgid "W-Wait, what are you saying!?\r\nI'm not trying to be like that at all!"
msgstr "A-Aspetta, ma che dici!?\r\nNon sto affatto cercando di fare una cosa simile!"

msgctxt "6||speech_list_caba_erina||table||102||||4"
msgid "Really? I was positive everything you've said\r\nwas well-calculated..."
msgstr "Davvero? Ero sicuro che ogni tua parola\r\nfosse ben calcolata..."

msgctxt "6||speech_list_caba_erina||table||103||||4"
msgid "That's not true!\r\nI'm talking to you as I would anybody else!"
msgstr "Non è vero!\r\nSto parlando con te come farei con chiunque altro!"

msgctxt "6||speech_list_caba_erina||table||104||||4"
msgid "Hm... But nobody masks their true intentions\r\nbetter than a woman... Can I trust you?"
msgstr "Hm... Ma nessuno maschera le proprie vere intenzioni\r\nmeglio di una donna... Posso fidarmi di te?"

msgctxt "6||speech_list_caba_erina||table||105||||4"
msgid "Of course! <symbol=heart_with_outline>\r\nI want you to see the true me..."
msgstr "Certo! <symbol=heart_with_outline>\r\nVoglio che tu veda la vera me..."

msgctxt "6||speech_list_caba_erina||table||106||||4"
msgid "(A temptress indeed... Even if this is all\r\none big deception, I just have to roll with it!)"
msgstr "(Una vera seduttrice... Anche se fosse tutta\r\nuna grande finzione, devo solo stare al gioco!)"

msgctxt "6||speech_list_caba_erina||table||107||||4"
msgid "Hey, Kiryu-san. Do you remember when we\r\ntalked about how I get misunderstood a lot?"
msgstr "Ehi, Kiryu-san. Ricordi quando abbiamo\r\nparlato del fatto che vengo spesso fraintesa?"

msgctxt "6||speech_list_caba_erina||table||108||||4"
msgid "Yeah. You mentioned having trouble making friends\r\nand getting accused of being too fake."
msgstr "Sì. Hai detto che hai problemi a farti delle amiche\r\ne che vieni accusata di essere troppo finta."

msgctxt "6||speech_list_caba_erina||table||109||||4"
msgid "I thought about it some more,\r\nand I think men misunderstand me, too..."
msgstr "Ci ho pensato ancora un po',\r\ne credo che anche gli uomini mi fraintendano..."

msgctxt "6||speech_list_caba_erina||table||110||||4"
msgid "Wait, you mean men are calling you fake now, too?\r\nIt must be pretty obvious then, huh?"
msgstr "Aspetta, vuoi dire che ora anche gli uomini ti danno della falsa?\r\nDeve essere piuttosto ovvio allora, eh?"

msgctxt "6||speech_list_caba_erina||table||111||||4"
msgid "Obvious...?\r\nI told you, I'm not fake! Geez!"
msgstr "Ovvio...?\r\nTi ho detto che non sono finta! Uffa!"

msgctxt "6||speech_list_caba_erina||table||112||||4"
msgid "A guy I thought of as just a friend actually\r\nconfessed his feelings for me..."
msgstr "Un ragazzo che consideravo solo un amico mi ha\r\nconfessato di provare dei sentimenti per me..."

msgctxt "6||speech_list_caba_erina||table||113||||4"
msgid "When I turned him down, he got all mad, and he\r\nasked, \"Then why were you leading me on!?\""
msgstr "Quando l'ho respinto, si è arrabbiato tutto, e mi ha\r\nchiesto: \"Allora perché mi stavi illudendo!?\""

msgctxt "6||speech_list_caba_erina||table||114||||4"
msgid "Sorry to hear that happened."
msgstr "Mi dispiace che sia successo."

msgctxt "6||speech_list_caba_erina||table||115||||4"
msgid "I went to an all-girls school, so maybe I don't\r\nknow how much distance to put between a guy."
msgstr "Sono andata in una scuola femminile, quindi forse non\r\nso quanta distanza mettere tra me e un ragazzo."

msgctxt "6||speech_list_caba_erina||table||116||||4"
msgid "Erina, do you approach your male and female\r\nfriends the same way?"
msgstr "Erina, ti approcci ai tuoi amici maschi e femmine\r\nnello stesso modo?"

msgctxt "6||speech_list_caba_erina||table||117||||4"
msgid "Let's see... I've never given it much thought,\r\nand I'll go see movies with them and stuff."
msgstr "Vediamo... Non ci ho mai pensato troppo,\r\ne vado a vedere dei film con loro e cose così."

msgctxt "6||speech_list_caba_erina||table||118||||4"
msgid "Kiryu-san... How do men see women like that?"
msgstr "Kiryu-san... Come vedono gli uomini le donne così?"

msgctxt "6||speech_list_caba_erina||table||119||||4"
msgid "They might misinterpret that. If you go out\r\nalone with them, it could get their hopes up."
msgstr "Potrebbero fraintenderlo. Se esci\r\nda sola con loro, potrebbero illudersi."

msgctxt "6||speech_list_caba_erina||table||120||||4"
msgid "So, that is how it works...\r\nI just wanted to hang out, though."
msgstr "Quindi funziona così...\r\nIo volevo solo passare un po' di tempo insieme, però."

msgctxt "6||speech_list_caba_erina||table||121||||4"
msgid "Men fall into that mindset too easily. A date\r\nlike that almost always leads to the wrong idea."
msgstr "Gli uomini cadono troppo facilmente in questa trappola. Un'uscita\r\ndel genere porta quasi sempre a farsi l'idea sbagliata."

msgctxt "6||speech_list_caba_erina||table||122||||4"
msgid "Next time, try inviting someone else to tag\r\nalong. That should clear up any confusion."
msgstr "La prossima volta, prova a invitare qualcun altro a venire\r\ncon voi. Questo dovrebbe evitare ogni confusione."

msgctxt "6||speech_list_caba_erina||table||123||||4"
msgid "I see.\r\nI'll try to be more careful next time."
msgstr "Capisco.\r\nCercherò di fare più attenzione la prossima volta."

msgctxt "6||speech_list_caba_erina||table||124||||4"
msgid "Yeah, that'd be best for the both of you."
msgstr "Sì, sarebbe la cosa migliore per entrambi."

msgctxt "6||speech_list_caba_erina||table||125||||4"
msgid "I'm glad I asked you, Kiryu-san!\r\nYou're so reliable. That's awesome. <symbol=heart_with_outline>"
msgstr "Sono contenta di avertelo chiesto, Kiryu-san!\r\nSei così affidabile. È fantastico. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||126||||4"
msgid "Th-Thanks..."
msgstr "G-Grazie..."

msgctxt "6||speech_list_caba_erina||table||127||||4"
msgid "(I get it now... I can see how guys could get\r\nthe wrong idea from this...)"
msgstr "(Ora capisco... È facile intuire come i ragazzi\r\npossano farsi un'idea sbagliata in questo modo...)"

msgctxt "6||speech_list_caba_erina||table||128||||4"
msgid "I think treating everyone as equals is one of\r\nyour strengths, Erina. You don't need to change."
msgstr "Credo che trattare tutti allo stesso modo sia uno dei\r\ntuoi punti di forza, Erina. Non c'è bisogno che tu cambi."

msgctxt "6||speech_list_caba_erina||table||129||||4"
msgid "Y-You think so?"
msgstr "L-Lo pensi davvero?"

msgctxt "6||speech_list_caba_erina||table||130||||4"
msgid "Yeah. Men only grow by overcoming misunderstandings\r\nand failures. It's not your job to worry about it."
msgstr "Sì. Gli uomini crescono solo superando fraintendimenti\r\ne fallimenti. Non è compito tuo preoccupartene."

msgctxt "6||speech_list_caba_erina||table||131||||4"
msgid "That's pretty deep, Kiryu-san.\r\nDoes that hit close to home for you?"
msgstr "È un pensiero profondo, Kiryu-san.\r\nParli per esperienza personale?"

msgctxt "6||speech_list_caba_erina||table||132||||4"
msgid "Sure. Misunderstandings, being too late...\r\nA lot of different experiences."
msgstr "Certo. Fraintendimenti, arrivare troppo tardi...\r\nTante esperienze diverse."

msgctxt "6||speech_list_caba_erina||table||133||||4"
msgid "But I don't look back on any of it with regret.\r\nThey're what made me who I am today."
msgstr "Ma non guardo al passato con rimpianto.\r\nÈ tutto ciò che mi ha reso l'uomo che sono oggi."

msgctxt "6||speech_list_caba_erina||table||134||||4"
msgid "Kiryu-san, you're a pretty cool guy."
msgstr "Kiryu-san, sei proprio in gamba."

msgctxt "6||speech_list_caba_erina||table||135||||4"
msgid "If a guy like you says so, then...\r\nI guess I'll stay how I am. <symbol=heart_with_outline>"
msgstr "Se lo dice un uomo come te, allora...\r\ncredo che resterò così come sono. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||136||||4"
msgid "They're the best."
msgstr "Sono le migliori."

msgctxt "6||speech_list_caba_erina||table||137||||4"
msgid "Huh? The... best?"
msgstr "Eh? Le... migliori?"

msgctxt "6||speech_list_caba_erina||table||138||||4"
msgid "Yeah.\r\nMind games like that are the very heart of love."
msgstr "Sì.\r\nI giochetti mentali di questo tipo sono l'essenza dell'amore."

msgctxt "6||speech_list_caba_erina||table||139||||4"
msgid "Besides, a woman with a seductive edge is more\r\nattractive than the cold shoulder for sure."
msgstr "Inoltre, una donna con un lato seducente è molto\r\npiù attraente di una fredda e scostante."

msgctxt "6||speech_list_caba_erina||table||140||||4"
msgid "Mind games, huh? I hadn't thought about\r\nit like that. Is that how men see it?"
msgstr "Giochetti mentali, eh? Non ci avevo mai pensato\r\nin questo modo. È così che la vedono gli uomini?"

msgctxt "6||speech_list_caba_erina||table||141||||4"
msgid "Yeah. It's the guy's fault for misunderstanding,\r\nbut you've got to be confident about that."
msgstr "Sì. È colpa del ragazzo se ha frainteso,\r\nma tu devi essere sicura di te stessa."

msgctxt "6||speech_list_caba_erina||table||142||||4"
msgid "You're right! I wanted to hear a man's opinion,\r\nso that's really refreshing."
msgstr "Hai ragione! Volevo sentire l'opinione di un uomo,\r\nquindi mi rincuora saperlo."

msgctxt "6||speech_list_caba_erina||table||143||||4"
msgid "I'm glad I asked you, Kiryu-san!\r\nYou're such a reliable guy. <symbol=heart_with_outline>"
msgstr "Sono contenta di avertelo chiesto, Kiryu-san!\r\nSei un uomo così affidabile. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||144||||4"
msgid "Kiryu-san, Kiryu-san!"
msgstr "Kiryu-san, Kiryu-san!"

msgctxt "6||speech_list_caba_erina||table||145||||4"
msgid "Hm? What's up? You seem happy."
msgstr "Mhm? Che succede? Sembri felice."

msgctxt "6||speech_list_caba_erina||table||146||||4"
msgid "Guess what? I finally made a friend!"
msgstr "Indovina? Finalmente mi sono fatta un'amica!"

msgctxt "6||speech_list_caba_erina||table||147||||4"
msgid "Erina... You..."
msgstr "Erina... Tu..."

msgctxt "6||speech_list_caba_erina||table||148||||4"
msgid "Oh, please don't look at me with those sad eyes!"
msgstr "Oh, ti prego, non guardarmi con quegli occhi tristi!"

msgctxt "6||speech_list_caba_erina||table||149||||4"
msgid "I worked hard, and I finally achieved my goal\r\nof making a girl friend!"
msgstr "Mi sono impegnata tanto, e alla fine ho raggiunto\r\nil mio obiettivo di farmi un'amica!"

msgctxt "6||speech_list_caba_erina||table||150||||4"
msgid "You were working to make sure nobody called you\r\nfake, conniving, and cold-blooded, right?"
msgstr "Hai lavorato duro per assicurarti che nessuno ti desse\r\ndella falsa, calcolatrice e insensibile, giusto?"

msgctxt "6||speech_list_caba_erina||table||151||||4"
msgid "N-No one's said all <font_kind=yakuza_italic>that</font_kind> yet,\r\nbut... something to that effect!"
msgstr "N-Nessuno mi ha detto <font_kind=yakuza_italic>tutto questo</font_kind>,\r\nma... il senso era quello!"

msgctxt "6||speech_list_caba_erina||table||152||||4"
msgid "I tried to make sure I wasn't coming across as\r\nsarcastic, and I chose my words carefully..."
msgstr "Ho cercato di assicurarmi di non sembrare\r\nsarcastica e ho scelto le parole con attenzione..."

msgctxt "6||speech_list_caba_erina||table||153||||4"
msgid "I was just generally being more conscious of\r\nmyself in my own way!"
msgstr "In generale, sono stata solo molto più attenta\r\nal mio comportamento, a modo mio!"

msgctxt "6||speech_list_caba_erina||table||154||||4"
msgid "That's great.\r\nI'm glad you made a new girl friend."
msgstr "È fantastico.\r\nSono felice che tu ti sia fatta una nuova amica."

msgctxt "6||speech_list_caba_erina||table||155||||4"
msgid "Thank you. If I keep at it, I wonder if I'll\r\nbe able to make even more friends?"
msgstr "Grazie. Chissà se, continuando così, riuscirò\r\na farmi ancora più amiche?"

msgctxt "6||speech_list_caba_erina||table||156||||4"
msgid "Erina..."
msgstr "Erina..."

msgctxt "6||speech_list_caba_erina||table||157||||4"
msgid "I feel the loneliness setting in already.\r\nDon't forget me, okay?"
msgstr "Sento già la solitudine farsi strada.\r\nNon dimenticarti di me, okay?"

msgctxt "6||speech_list_caba_erina||table||158||||4"
msgid "Of course not.\r\nYou're... very important to me, Kiryu-san."
msgstr "Certo che no.\r\nTu sei... molto importante per me, Kiryu-san."

msgctxt "6||speech_list_caba_erina||table||159||||4"
msgid "Thanks. I was just kidding, anyway.\r\nI do hope you can get closer to more people."
msgstr "Grazie. Stavo solo scherzando, comunque.\r\nSpero davvero che tu riesca a legare con più persone."

msgctxt "6||speech_list_caba_erina||table||160||||4"
msgid "I will, thank you!\r\nI'm gonna see if I can make a hundred friends!"
msgstr "Lo farò, grazie!\r\nVedrò se riesco a farmi cento amiche!"

msgctxt "6||speech_list_caba_erina||table||161||||4"
msgid "I'm rooting for you."
msgstr "Faccio il tifo per te."

msgctxt "6||speech_list_caba_erina||table||162||||4"
msgid "Don't overdo it though, okay?"
msgstr "Non esagerare, però, okay?"

msgctxt "6||speech_list_caba_erina||table||163||||4"
msgid "Huh? Overdo it how?"
msgstr "Eh? Esagerare in che senso?"

msgctxt "6||speech_list_caba_erina||table||164||||4"
msgid "Well, self-awareness is a good thing to have,\r\nbut you shouldn't change who you are, either."
msgstr "Beh, l'autoconsapevolezza è un'ottima cosa,\r\nma non dovresti nemmeno cambiare chi sei veramente."

msgctxt "6||speech_list_caba_erina||table||165||||4"
msgid "I... don't want you to become someone whose life\r\nis dictated by what other people think of you."
msgstr "Io... non voglio che tu diventi una persona la cui vita\r\nè dettata da ciò che gli altri pensano di lei."

msgctxt "6||speech_list_caba_erina||table||166||||4"
msgid "Kiryu-san... Thank you! I'm okay.\r\nI won't let myself suffocate under it."
msgstr "Kiryu-san... Grazie! Sto bene.\r\nNon mi lascerò soffocare da questa cosa."

msgctxt "6||speech_list_caba_erina||table||167||||4"
msgid "Good. Then that's fine.\r\nWhat's most important is being true to yourself."
msgstr "Bene. Allora va bene così.\r\nLa cosa più importante è rimanere fedele a se stessi."

msgctxt "6||speech_list_caba_erina||table||168||||4"
msgid "Kiryu-san...\r\nThank you for thinking about me so seriously..."
msgstr "Kiryu-san...\r\nGrazie per preoccuparti per me così seriamente..."

msgctxt "6||speech_list_caba_erina||table||169||||4"
msgid "No matter how many friends I make...\r\nYou'll be different. Someone special. <symbol=heart_with_outline>"
msgstr "Non importa quante amicizie farò...\r\nTu sarai diverso. Una persona speciale. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||170||||4"
msgid "I'm honored."
msgstr "Ne sono onorato."

msgctxt "6||speech_list_caba_erina||table||171||||4"
msgid "I'll work hard to make friends, too!"
msgstr "Mi impegnerò per farmi degli amici anch'io!"

msgctxt "6||speech_list_caba_erina||table||172||||4"
msgid "Huh? You too?"
msgstr "Eh? Anche tu?"

msgctxt "6||speech_list_caba_erina||table||173||||4"
msgid "Yeah. Seeing you so happy makes me want to\r\ntry harder at the friendship thing, too."
msgstr "Sì. Vederti così felice fa venire voglia anche a me\r\ndi impegnarmi un po' di più con le amicizie."

msgctxt "6||speech_list_caba_erina||table||174||||4"
msgid "When I thought about it, I realized I\r\ndon't have a lot of decent friends right now..."
msgstr "Quando ci ho pensato, ho realizzato di non\r\navere molti amici decenti, di questi tempi..."

msgctxt "6||speech_list_caba_erina||table||175||||4"
msgid "O-Oh, really...?\r\nThen, you and I should make tons of new friends!"
msgstr "O-Oh, davvero...?\r\nAllora, noi due dovremmo farci un sacco di nuovi amici!"

msgctxt "6||speech_list_caba_erina||table||176||||4"
msgid "But no matter what, no matter how many friends\r\nI make... you'll be different. Someone special. <symbol=heart_with_outline>"
msgstr "Ma qualsiasi cosa accada, non importa quante amicizie\r\nfarò... tu sarai diverso. Una persona speciale. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||177||||4"
msgid "I'm honored."
msgstr "Ne sono onorato."

msgctxt "6||speech_list_caba_erina||table||178||||4"
msgid "Hmm..."
msgstr "Mhm..."

msgctxt "6||speech_list_caba_erina||table||179||||4"
msgid "You seem a little down. Did your new friend\r\nfinally see through your fake exterior?"
msgstr "Sembri un po' giù. La tua nuova amica\r\nha finalmente smascherato la tua facciata?"

msgctxt "6||speech_list_caba_erina||table||180||||4"
msgid "Th-There's nothing to be seen through!\r\nI'm not fake to begin with!"
msgstr "N-Non c'è niente da smascherare!\r\nTanto per cominciare, non sono affatto falsa!"

msgctxt "6||speech_list_caba_erina||table||181||||4"
msgid "But, there have been some weird things happening\r\nrecently..."
msgstr "Però... sono successe delle cose un po' strane\r\ndi recente..."

msgctxt "6||speech_list_caba_erina||table||182||||4"
msgid "Weird things?"
msgstr "Cose strane?"

msgctxt "6||speech_list_caba_erina||table||183||||4"
msgid "Maybe I'm overthinking it,\r\nbut I feel like someone's always watching me."
msgstr "Forse ci sto pensando troppo,\r\nma mi sento come se qualcuno mi stesse sempre a guardare."

msgctxt "6||speech_list_caba_erina||table||184||||4"
msgid "Like someone's following me around at night..."
msgstr "Come se qualcuno mi seguisse di notte..."

msgctxt "6||speech_list_caba_erina||table||185||||4"
msgid "Wait, you mean like a stalker?"
msgstr "Aspetta, intendi una specie di stalker?"

msgctxt "6||speech_list_caba_erina||table||186||||4"
msgid "You think that's it?\r\nUgh, it's such a creepy feeling..."
msgstr "Pensi che sia così?\r\nUgh, è una sensazione così inquietante..."

msgctxt "6||speech_list_caba_erina||table||187||||4"
msgid "Any ideas about who it might be?"
msgstr "Hai idea di chi possa essere?"

msgctxt "6||speech_list_caba_erina||table||188||||4"
msgid "Not really...\r\nI'm a little scared."
msgstr "Non proprio...\r\nHo un po' di paura."

msgctxt "6||speech_list_caba_erina||table||189||||4"
msgid "Erina..."
msgstr "Erina..."

msgctxt "6||speech_list_caba_erina||table||190||||4"
msgid "Don't worry. No matter what kind of guy this is,\r\nI'll protect you."
msgstr "Non preoccuparti. Non importa chi sia questo tizio,\r\nti proteggerò io."

msgctxt "6||speech_list_caba_erina||table||191||||4"
msgid "Kiryu-san...!"
msgstr "Kiryu-san...!"

msgctxt "6||speech_list_caba_erina||table||192||||4"
msgid "If you're scared something's going to happen,\r\nyou get in touch with me right away."
msgstr "Se hai paura che stia per succedere qualcosa,\r\ncontattami immediatamente."

msgctxt "6||speech_list_caba_erina||table||193||||4"
msgid "Th-Thank you so much...!"
msgstr "G-Grazie infinite...!"

msgctxt "6||speech_list_caba_erina||table||194||||4"
msgid "It makes me so happy to hear you say that..."
msgstr "Mi rende così felice sentirtelo dire..."

msgctxt "6||speech_list_caba_erina||table||195||||4"
msgid "I didn't know what I'd do before,\r\nbut I feel much better now!"
msgstr "Prima non sapevo che cosa avrei fatto,\r\nma ora mi sento molto meglio!"

msgctxt "6||speech_list_caba_erina||table||196||||4"
msgid "Well, the important part is your safety.\r\nJust be careful, okay?"
msgstr "Beh, la cosa più importante è la tua sicurezza.\r\nCerca solo di stare attenta, d'accordo?"

msgctxt "6||speech_list_caba_erina||table||197||||4"
msgid "Don't worry. No matter what happens,\r\nthe law will protect you!"
msgstr "Non preoccuparti. Qualsiasi cosa succeda,\r\nla legge ti proteggerà!"

msgctxt "6||speech_list_caba_erina||table||198||||4"
msgid "The... law?"
msgstr "La... legge?"

msgctxt "6||speech_list_caba_erina||table||199||||4"
msgid "Yeah. I saw on TV that they're tightening\r\nthe laws surrounding stalkers."
msgstr "Sì. Ho visto in TV che stanno inasprendo\r\nle leggi sugli stalker."

msgctxt "6||speech_list_caba_erina||table||200||||4"
msgid "Anyone who'd go that far will be punished\r\nto the full extent of the law."
msgstr "Chiunque si spinga a tanto verrà punito\r\ncon tutto il rigore della legge."

msgctxt "6||speech_list_caba_erina||table||201||||4"
msgid "I-I see... But I don't know who it could be, and\r\nI'd rather it didn't happen in the first place..."
msgstr "C-Capisco... Ma non so chi possa essere, e in ogni caso\r\npreferirei che non succedesse proprio niente del genere..."

msgctxt "6||speech_list_caba_erina||table||202||||4"
msgid "That's true... Well, just try to be careful."
msgstr "È vero... Beh, cerca solo di stare attenta."

msgctxt "6||speech_list_caba_erina||table||203||||4"
msgid "Yeah. Thanks for the info.\r\nYou sure know a lot, Kiryu-san."
msgstr "Sì. Grazie per l'informazione.\r\nSai un sacco di cose, Kiryu-san."

msgctxt "6||speech_list_caba_erina||table||204||||4"
msgid "I just got lucky."
msgstr "È solo che ho avuto fortuna."

msgctxt "6||speech_list_caba_erina||table||205||||4"
msgid "I'll take him down right now!"
msgstr "Lo sistemerò io, in questo istante!"

msgctxt "6||speech_list_caba_erina||table||206||||4"
msgid "What!? Take him down!?"
msgstr "Eh!? Sistemarlo tu!?"

msgctxt "6||speech_list_caba_erina||table||207||||4"
msgid "Yeah. Warnings have no effect on guys that\r\nresort to cowardly tactics like stalking."
msgstr "Sì. Gli avvertimenti non hanno alcun effetto su quelli\r\nche ricorrono a tattiche codarde come lo stalking."

msgctxt "6||speech_list_caba_erina||table||208||||4"
msgid "The only way to convince them to change\r\nis with the power of your fists!"
msgstr "Il solo modo per convincerli a cambiare\r\nè a suon di pugni!"

msgctxt "6||speech_list_caba_erina||table||209||||4"
msgid "B-But, it could still be a misunderstanding,\r\nso I probably don't need to go that far...!"
msgstr "M-Ma potrebbe comunque essere un malinteso,\r\nquindi forse non c'è bisogno di arrivare a tanto...!"

msgctxt "6||speech_list_caba_erina||table||210||||4"
msgid "R-Really? Well, if you say so..."
msgstr "D-Davvero? Beh, se lo dici tu..."

msgctxt "6||speech_list_caba_erina||table||211||||4"
msgid "You're a life-saver though, Kiryu-san.\r\nYou would go that far for me?"
msgstr "Però sei un vero salvatore, Kiryu-san.\r\nTi spingeresti a tanto per me?"

msgctxt "6||speech_list_caba_erina||table||212||||4"
msgid "I just don't want anything to happen to you."
msgstr "È che non voglio che ti succeda niente."

msgctxt "6||speech_list_caba_erina||table||213||||4"
msgid "Your concern for me makes me so happy, Kiryu-san!\r\nI'll try to be careful."
msgstr "Il fatto che ti preoccupi per me mi rende così felice, Kiryu-san!\r\nCercherò di fare attenzione."

msgctxt "6||speech_list_caba_erina||table||214||||4"
msgid "Um, Kiryu-san... Are you free after this?\r\nI was thinking we could go grab a bite..."
msgstr "Ehm, Kiryu-san... Sei libero dopo il lavoro?\r\nPensavo che potremmo andare a mangiare qualcosa..."

msgctxt "6||speech_list_caba_erina||table||215||||4"
msgid "Sounds good. You're a big eater, right?\r\nHow about I treat you to something you like?"
msgstr "Sembra un'ottima idea. Sei una mangiona, vero?\r\nChe ne dici se ti offro qualcosa che ti piace?"

msgctxt "6||speech_list_caba_erina||table||216||||4"
msgid "Huh!? Really? I'd feel bad, though..."
msgstr "Eh!? Sul serio? Mi sentirei un po' in colpa, però..."

msgctxt "6||speech_list_caba_erina||table||217||||4"
msgid "Don't sweat it.\r\nI'm actually curious to see you in action."
msgstr "Non preoccuparti.\r\nA dire il vero sono curioso di vederti all'opera."

msgctxt "6||speech_list_caba_erina||table||218||||4"
msgid "Yay! Eating together with Kiryu-san! <symbol=note_with_outline>"
msgstr "Evviva! A cena insieme a Kiryu-san! <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||219||||4"
msgid "Don't get too excited."
msgstr "Non entusiasmarti troppo."

msgctxt "6||speech_list_caba_erina||table||220||||4"
msgid "I'll need to get ready,\r\nso can you meet me at Theater Square?"
msgstr "Avrò bisogno di un attimo per prepararmi,\r\nquindi puoi incontrarmi in Piazza del Teatro?"

msgctxt "6||speech_list_caba_erina||table||221||||4"
msgid "Theater Square. Got it."
msgstr "Piazza del Teatro. Ricevuto."

msgctxt "6||speech_list_caba_erina||table||222||||4"
msgid "I can't wait. <symbol=note_with_outline>"
msgstr "Non vedo l'ora. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||223||||4"
msgid "I like watching movies.\r\nWhat kind of movies do you like, Kiryu-san?"
msgstr "Mi piace guardare i film.\r\nChe genere di film ti piacciono, Kiryu-san?"

msgctxt "6||speech_list_caba_erina||table||224||||4"
msgid "I like mystery movies, myself."
msgstr "Personalmente, mi piacciono i gialli."

msgctxt "6||speech_list_caba_erina||table||225||||4"
msgid "Oh, I love a good mystery! You like them too,\r\nKiryu-san? I'm happy to hear that."
msgstr "Oh, adoro i bei gialli! Piacciono anche a te,\r\nKiryu-san? Sono felice di sentirlo."

msgctxt "6||speech_list_caba_erina||table||226||||4"
msgid "Yeah, I like seeing the payoff for all\r\nthe foreshadowing at the beginning."
msgstr "Sì, mi piace vedere come tutti gli indizi\r\niniziali portino a una conclusione inaspettata."

msgctxt "6||speech_list_caba_erina||table||227||||4"
msgid "Exactly! I'm always like, \"Oh, so that's how they\r\ndid it!\" Maybe I'll rent a DVD on my way home."
msgstr "Esatto! Faccio sempre: \"Oh, è così che hanno fatto!\".\r\nForse noleggerò un DVD sulla via del ritorno."

msgctxt "6||speech_list_caba_erina||table||228||||4"
msgid "Gory horror movies are my thing. Like the ones\r\nwhere they have to kill a bunch of zombies."
msgstr "I film horror splatter sono la mia passione. Come quelli\r\nin cui devono ammazzare un mucchio di zombie."

msgctxt "6||speech_list_caba_erina||table||229||||4"
msgid "Oh really... I don't do well with blood,\r\nso the horror genre is kind of hard for me..."
msgstr "Oh, davvero... Non sopporto la vista del sangue,\r\nquindi il genere horror è un po' pesante per me..."

msgctxt "6||speech_list_caba_erina||table||230||||4"
msgid "I see...\r\nWell, that's pretty common among women."
msgstr "Capisco...\r\nBeh, è una cosa piuttosto comune tra le donne."

msgctxt "6||speech_list_caba_erina||table||231||||4"
msgid "There are plenty of women who like gory movies,\r\nbut I just can't get into them."
msgstr "Ci sono un sacco di donne a cui piacciono i film violenti,\r\nma io proprio non riesco a farmeli piacere."

msgctxt "6||speech_list_caba_erina||table||232||||4"
msgid "Well, it's not exactly \"watching,\" but...\r\nI've actually been in an action movie."
msgstr "Beh, non si tratta esattamente di \"guardare\", ma...\r\nIn realtà ho recitato in un film d'azione."

msgctxt "6||speech_list_caba_erina||table||233||||4"
msgid "Really!? Kiryu-san, are you an actor!?"
msgstr "Davvero!? Kiryu-san, sei un attore!?"

msgctxt "6||speech_list_caba_erina||table||234||||4"
msgid "Nah, I just got roped in off the street to fill\r\nin for someone. It was nothing too big."
msgstr "Macché, sono solo stato preso dalla strada per\r\nsostituire qualcuno. Niente di che."

msgctxt "6||speech_list_caba_erina||table||235||||4"
msgid "How cool! I used to make videos just for the fun\r\nof it as a kid. I wanna see your movie now!"
msgstr "Che figata! Da piccola facevo dei video solo\r\nper divertimento. Adesso voglio vedere il tuo film!"

msgctxt "6||speech_list_caba_erina||table||236||||4"
msgid "I've been going to a lot of concerts lately."
msgstr "Ultimamente vado a un sacco di concerti."

msgctxt "6||speech_list_caba_erina||table||237||||4"
msgid "The audience feels so close to the artist in\r\nthese small venues, it's amazing!"
msgstr "In questi piccoli locali il pubblico si sente\r\ncosì vicino all'artista, è fantastico!"

msgctxt "6||speech_list_caba_erina||table||238||||4"
msgid "Oh, really? I hit the karaoke bars from time to\r\ntime, but I don't see too many concerts."
msgstr "Oh, davvero? Ogni tanto vado al karaoke, ma non\r\nseguo molti concerti."

msgctxt "6||speech_list_caba_erina||table||239||||4"
msgid "Karaoke doesn't have quite the same appeal as a\r\nconcert. Want to go to one together some time?"
msgstr "Il karaoke non ha lo stesso fascino di un\r\nconcerto vero. Ti va di andarci insieme qualche volta?"

msgctxt "6||speech_list_caba_erina||table||240||||4"
msgid "Looking forward to it."
msgstr "Non vedo l'ora."

msgctxt "6||speech_list_caba_erina||table||241||||4"
msgid "It's been about a year since I started."
msgstr "È passato circa un anno da quando ho iniziato."

msgctxt "6||speech_list_caba_erina||table||242||||4"
msgid "Really? I hear a lot of girls quit jobs like\r\nthis after about a year."
msgstr "Davvero? Sento dire che molte ragazze lasciano\r\nlavori come questo dopo circa un anno."

msgctxt "6||speech_list_caba_erina||table||243||||4"
msgid "You think you'll keep at it?"
msgstr "Pensi che andrai avanti?"

msgctxt "6||speech_list_caba_erina||table||244||||4"
msgid "Yeah. I've got some stuff to figure out still,\r\nbut I don't want to up and quit."
msgstr "Sì. Ho ancora un bel po' di cose da capire,\r\nma non voglio mollare tutto all'improvviso."

msgctxt "6||speech_list_caba_erina||table||245||||4"
msgid "I like talking to people, and it's nice to\r\nmeet wonderful guys like you, Kiryu-san. <symbol=note_with_outline>"
msgstr "Mi piace parlare con le persone, ed è bello incontrare\r\nuomini meravigliosi come te, Kiryu-san. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||246||||4"
msgid "You're good."
msgstr "Ci sai fare."

msgctxt "6||speech_list_caba_erina||table||247||||4"
msgid "I'm from Kanagawa."
msgstr "Vengo da Kanagawa."

msgctxt "6||speech_list_caba_erina||table||248||||4"
msgid "What a coincidence.\r\nI'm from around there, too."
msgstr "Che coincidenza.\r\nAnch'io vengo da quelle parti."

msgctxt "6||speech_list_caba_erina||table||249||||4"
msgid "Wow, really!? I knew I felt a connection with you!\r\nWe're the Kanagawa Alliance now. <symbol=heart_with_outline>"
msgstr "Wow, sul serio!? Sapevo di sentire una certa connessione con te!\r\nOra siamo l'Alleanza di Kanagawa. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||250||||4"
msgid "Hm... I'll eat anything, but lately I've been\r\nhooked on ramen with extra meat and veggies."
msgstr "Hm... Mangio di tutto, ma ultimamente vado matta\r\nper il ramen con porzioni extra di carne e verdure."

msgctxt "6||speech_list_caba_erina||table||251||||4"
msgid "The place I've been going to offers an extra large\r\nsize... I think I'm gonna go for it next time."
msgstr "Il posto in cui vado offre una porzione extra large...\r\nPenso che la prossima volta proverò quella."

msgctxt "6||speech_list_caba_erina||table||252||||4"
msgid "Impressive. You could really finish it?"
msgstr "Notevole. Riusciresti davvero a finirlo tutto?"

msgctxt "6||speech_list_caba_erina||table||253||||4"
msgid "I don't look it, but I'm a big eater.\r\nThere's nothing I can't eat!"
msgstr "Non sembrerà, ma sono una gran mangiona.\r\nNon c'è niente che non riesca a mangiare!"

msgctxt "6||speech_list_caba_erina||table||254||||4"
msgid "Oh really? We should go out sometime, then.\r\nMy treat."
msgstr "Ah, sì? Allora dovremmo uscire insieme, prima o poi.\r\nOffro io."

msgctxt "6||speech_list_caba_erina||table||255||||4"
msgid "You mean it? That'd be great! Just don't get\r\nmad at me if I order the whole menu, okay? <symbol=heart_with_outline>"
msgstr "Dici sul serio? Sarebbe fantastico! Però non arrabbiarti\r\ncon me se ordino tutto il menu, okay? <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||256||||4"
msgid "I like a quiet, intelligent man.\r\nMen who read a lot are the best."
msgstr "Mi piacciono gli uomini silenziosi e intelligenti.\r\nQuelli che leggono molto sono i migliori."

msgctxt "6||speech_list_caba_erina||table||257||||4"
msgid "Have you read anything lately, Kiryu-san?"
msgstr "Hai letto qualcosa di recente, Kiryu-san?"

msgctxt "6||speech_list_caba_erina||table||258||||4"
msgid "Does... manga count?"
msgstr "I... manga contano?"

msgctxt "6||speech_list_caba_erina||table||259||||4"
msgid "Wow, you read manga, Kiryu-san?\r\nNot what I was expecting."
msgstr "Wow, leggi i manga, Kiryu-san?\r\nNon me l'aspettavo da te."

msgctxt "6||speech_list_caba_erina||table||260||||4"
msgid "Novels, I guess?"
msgstr "Romanzi, direi?"

msgctxt "6||speech_list_caba_erina||table||261||||4"
msgid "Wow, that's exactly my idea of a quiet,\r\nintelligent man! Color me impressed!"
msgstr "Wow, incarni esattamente la mia idea di uomo silenzioso\r\ne intelligente! Sono davvero colpita!"

msgctxt "6||speech_list_caba_erina||table||262||||4"
msgid "Good to know."
msgstr "Buono a sapersi."

msgctxt "6||speech_list_caba_erina||table||263||||4"
msgid "I read... the mood."
msgstr "Leggo... l'atmosfera."

msgctxt "6||speech_list_caba_erina||table||264||||4"
msgid "Kiryu-san...! You're so silly!"
msgstr "Kiryu-san...! Sei proprio buffo!"

msgctxt "6||speech_list_caba_erina||table||265||||4"
msgid "Guess I misread it this time..."
msgstr "Mi sa che stavolta l'ho letta male..."

msgctxt "6||speech_list_caba_erina||table||266||||4"
msgid "I'm the kind of girl who goes all in on the\r\nhousework and stuff. Wanna make me an offer? <symbol=heart_with_outline>"
msgstr "Sono il tipo di ragazza che si dà da fare con le\r\nfaccende domestiche e simili. Vuoi farmi un'offerta? <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||267||||4"
msgid "I'd consider it."
msgstr "Potrei prenderlo in considerazione."

msgctxt "6||speech_list_caba_erina||table||268||||4"
msgid "Actually, I want to be in a movie!"
msgstr "In realtà, vorrei recitare in un film!"

msgctxt "6||speech_list_caba_erina||table||269||||4"
msgid "Wow, the movies, huh?\r\nI think you'd be good in..."
msgstr "Wow, il cinema, eh?\r\nPenso che saresti brava in..."

msgctxt "6||speech_list_caba_erina||table||270||||4"
msgid "I think you'd be good in a fantasy film."
msgstr "Penso che saresti brava in un film fantasy."

msgctxt "6||speech_list_caba_erina||table||271||||4"
msgid "Oh, that'd be cool! I've love to cast some\r\nspells, so I'd totally audition for that!"
msgstr "Oh, sarebbe fantastico! Mi piacerebbe un sacco\r\nlanciare incantesimi, andrei di corsa a fare l'audizione!"

msgctxt "6||speech_list_caba_erina||table||272||||4"
msgid "I think you'd be good in a romance film."
msgstr "Penso che saresti brava in un film romantico."

msgctxt "6||speech_list_caba_erina||table||273||||4"
msgid "But the leads in those movies always seem so\r\nmature... I wonder if I could pull it off."
msgstr "Ma i protagonisti di quei film sembrano sempre così\r\nmaturi... chissà se ne sarei all'altezza."

msgctxt "6||speech_list_caba_erina||table||274||||4"
msgid "I'm sure you'd be fine."
msgstr "Sono sicuro che te la caveresti benissimo."

msgctxt "6||speech_list_caba_erina||table||275||||4"
msgid "You'd help me practice if I ever landed a role\r\nlike that, right? You could be the love interest."
msgstr "Mi aiuteresti a fare pratica se mai ottenessi un ruolo\r\ndel genere, vero? Potresti fare la mia dolce metà."

msgctxt "6||speech_list_caba_erina||table||276||||4"
msgid "Sure, no problem."
msgstr "Certo, nessun problema."

msgctxt "6||speech_list_caba_erina||table||277||||4"
msgid "I think you'd be good in a comedy film."
msgstr "Penso che saresti brava in un film comico."

msgctxt "6||speech_list_caba_erina||table||278||||4"
msgid "Comedy? What makes you say that?"
msgstr "Commedia? Cosa te lo fa dire?"

msgctxt "6||speech_list_caba_erina||table||279||||4"
msgid "You're fun to talk to, so I think you have a\r\nnatural talent for entertaining people."
msgstr "È divertente parlare con te, quindi penso che tu abbia un\r\ntalento naturale per intrattenere la gente."

msgctxt "6||speech_list_caba_erina||table||280||||4"
msgid "Aww, thanks.\r\nI enjoy talking to you too, Kiryu-san."
msgstr "Oh, grazie.\r\nAnche a me piace molto parlare con te, Kiryu-san."

msgctxt "6||speech_list_caba_erina||table||281||||4"
msgid "I wanted to be a film director."
msgstr "Volevo fare il regista."

msgctxt "6||speech_list_caba_erina||table||282||||4"
msgid "Oh really? That's unusual."
msgstr "Oh, davvero? È piuttosto insolito."

msgctxt "6||speech_list_caba_erina||table||283||||4"
msgid "I shot some videos on my own back in school,\r\nbut making a real film is such hard work..."
msgstr "A scuola ho girato dei video per conto mio,\r\nma fare un vero film è un lavoro durissimo..."

msgctxt "6||speech_list_caba_erina||table||284||||4"
msgid "So at some point my dream changed from wanting\r\nto be behind the camera to in front of it!"
msgstr "Quindi, a un certo punto, il mio sogno è cambiato dal\r\nvoler stare dietro la macchina da presa al volerci stare davanti!"

msgctxt "6||speech_list_caba_erina||table||285||||4"
msgid "You really love movies, don't you?\r\nI'd like to see those old videos of yours."
msgstr "Ami davvero i film, vero?\r\nMi piacerebbe vedere quei tuoi vecchi video."

msgctxt "6||speech_list_caba_erina||table||286||||4"
msgid "N-No way! Those were like the embodiment of\r\nbeing a dumb kid. I'd die of shame."
msgstr "N-Non se ne parla! Erano la perfetta incarnazione\r\ndi una ragazzina stupida. Morirei di vergogna."

msgctxt "6||speech_list_caba_erina||table||287||||4"
msgid "Being a big eater. But I also change clothes like\r\nthe wind. I can try on a new outfit in 10 seconds!"
msgstr "L'essere una mangiona. Ma mi cambio anche i vestiti alla\r\nvelocità del vento. Posso infilarmi un nuovo outfit in 10 secondi!"

msgctxt "6||speech_list_caba_erina||table||288||||4"
msgid "Okay, you've got 10 seconds."
msgstr "Va bene, hai 10 secondi."

msgctxt "6||speech_list_caba_erina||table||289||||4"
msgid "H-Hey, wait a sec!\r\nI don't have anything to change into!"
msgstr "E-Ehi, aspetta un momento!\r\nNon ho niente da mettermi!"

msgctxt "6||speech_list_caba_erina||table||290||||4"
msgid "Hm? So I see. That's a shame."
msgstr "Hm? Già. Che peccato."

msgctxt "6||speech_list_caba_erina||table||291||||4"
msgid "Maybe if we weren't here, though..."
msgstr "Però, magari se non fossimo qui..."

msgctxt "6||speech_list_caba_erina||table||292||||4"
msgid "Hm?"
msgstr "Mhm?"

msgctxt "6||speech_list_caba_erina||table||293||||4"
msgid "N-Never mind!"
msgstr "N-Niente, lascia perdere!"

msgctxt "6||speech_list_caba_erina||table||294||||4"
msgid "Putting clothes on is one thing, but...\r\nNobody strips off a shirt faster than me!"
msgstr "Mettersi i vestiti è un conto, ma...\r\nNessuno si sfila la maglietta più in fretta di me!"

msgctxt "6||speech_list_caba_erina||table||295||||4"
msgid "Huh!? Really?\r\nCan I have a demo of this speed stripping?"
msgstr "Eh!? Sul serio?\r\nPosso avere una dimostrazione di questo spogliarello veloce?"

msgctxt "6||speech_list_caba_erina||table||296||||4"
msgid "I probably shouldn't do that in here..."
msgstr "Probabilmente non dovrei farlo qui dentro..."

msgctxt "6||speech_list_caba_erina||table||297||||4"
msgid "Aww, that's too bad.\r\nBut if we were somewhere else, you'd show me?"
msgstr "Oh, che disdetta.\r\nMa se fossimo da qualche altra parte, me lo faresti vedere?"

msgctxt "6||speech_list_caba_erina||table||298||||4"
msgid "S-Sure..."
msgstr "C-Certo..."

msgctxt "6||speech_list_caba_erina||table||299||||4"
msgid "It wasn't much fun for me, but I got laughed at \r\nwhen I told everyone I'd almost gotten arrested..."
msgstr "Per me non è stato per niente divertente, ma tutti si sono\r\nmessi a ridere quando ho raccontato che stavo per essere arrestata..."

msgctxt "6||speech_list_caba_erina||table||300||||4"
msgid "Arrested? What happened?"
msgstr "Arrestata? Cos'è successo?"

msgctxt "6||speech_list_caba_erina||table||301||||4"
msgid "I left the club one night, and a cop thought I was\r\na high school delinquent... I had to prove my age..."
msgstr "Una sera stavo uscendo dal club, e un poliziotto mi ha\r\npreso per una liceale ribelle... ho dovuto dimostrare la mia età..."

msgctxt "6||speech_list_caba_erina||table||302||||4"
msgid "Not much you can do about that.\r\nThey only stopped you because you look so young."
msgstr "C'è poco che tu possa farci.\r\nTi hanno fermata solo perché sembri molto giovane."

msgctxt "6||speech_list_caba_erina||table||303||||4"
msgid "Hmm... But I want to look more mature..."
msgstr "Uff... Però io vorrei sembrare più matura..."

msgctxt "6||speech_list_caba_erina||table||304||||4"
msgid "Look on the bright side. A lot of guys prefer\r\nyounger girls, so you probably get more requests."
msgstr "Guarda il lato positivo. Un sacco di ragazzi preferiscono\r\nle ragazze più giovani, quindi probabilmente avrai più richieste."

msgctxt "6||speech_list_caba_erina||table||305||||4"
msgid "Maybe you're right. <symbol=heart_with_outline>\r\nIs that why you requested me, Kiryu-san?"
msgstr "Forse hai ragione. <symbol=heart_with_outline>\r\nÈ per questo che mi hai scelta, Kiryu-san?"

msgctxt "6||speech_list_caba_erina||table||306||||4"
msgid "Who can say?"
msgstr "Chi può dirlo?"

msgctxt "6||speech_list_caba_erina||table||307||||4"
msgid "What? Aren't you a minor!?"
msgstr "Cosa? Non sei minorenne!?"

msgctxt "6||speech_list_caba_erina||table||308||||4"
msgid "Oh, not you too Kiryu-san... I'm 23 years old!\r\nI want to be a mature woman already..."
msgstr "Oh, non ti ci mettere anche tu, Kiryu-san... Ho 23 anni!\r\nVoglio diventare subito una donna matura..."

msgctxt "6||speech_list_caba_erina||table||309||||4"
msgid "Wish I knew what it was like to have your age\r\nchecked. I haven't looked young a day in my life."
msgstr "Mi piacerebbe sapere cosa si prova a farsi controllare\r\nl'età. Non ho mai avuto l'aspetto di un ragazzino in vita mia."

msgctxt "6||speech_list_caba_erina||table||310||||4"
msgid "Well, you do have a calm demeanor about you...\r\nBut, maybe they'd take you in for questioning!"
msgstr "Beh, in effetti hai un atteggiamento molto calmo...\r\nPerò, chissà, magari ti porterebbero dentro per interrogarti!"

msgctxt "6||speech_list_caba_erina||table||311||||4"
msgid "...Who'd want that to happen?"
msgstr "...Chi vorrebbe mai che succedesse una cosa del genere?"

msgctxt "6||speech_list_caba_erina||table||312||||4"
msgid "Not at all. How do you make friends?"
msgstr "Niente affatto. Come si fa a stringere amicizia?"

msgctxt "6||speech_list_caba_erina||table||313||||4"
msgid "That's a tough question. Normally you'd just\r\nsmile and try to spark a conversation, right?"
msgstr "È una domanda difficile. Di solito basterebbe\r\nsorridere e cercare di attaccare bottone, vero?"

msgctxt "6||speech_list_caba_erina||table||314||||4"
msgid "But would you ever make it past the acquaintance\r\nstage like that? That doesn't feel like friendship."
msgstr "Ma riusciresti mai ad andare oltre la fase del\r\nsemplice conoscente in quel modo? Non sembra vera amicizia."

msgctxt "6||speech_list_caba_erina||table||315||||4"
msgid "I guess it's a question of how you even\r\ndefine a \"friend\" to begin with."
msgstr "Immagino sia una questione di come si intenda definire\r\nun \"amico\", tanto per cominciare."

msgctxt "6||speech_list_caba_erina||table||316||||4"
msgid "Hmmm... Maybe you're overcomplicating things?\r\nIt's supposed to happen naturally."
msgstr "Mhm... Forse stai complicando troppo le cose?\r\nDovrebbe nascere tutto in modo naturale."

msgctxt "6||speech_list_caba_erina||table||317||||4"
msgid "Is that really how it works?\r\nIt's harder than it seems..."
msgstr "Funziona davvero così?\r\nÈ più difficile di quanto sembri..."

msgctxt "6||speech_list_caba_erina||table||318||||4"
msgid "I play a lot of video games.\r\nI actually bought a new console the other day!"
msgstr "Gioco un sacco ai videogiochi.\r\nIn realtà ho comprato una nuova console l'altro giorno!"

msgctxt "6||speech_list_caba_erina||table||319||||4"
msgid "Oh, really?"
msgstr "Oh, davvero?"

msgctxt "6||speech_list_caba_erina||table||320||||4"
msgid "I got so excited I bought two controllers!\r\nBut then I realized I have no one to play with..."
msgstr "Ero così elettrizzata che ho comprato due controller!\r\nMa poi ho realizzato di non avere nessuno con cui giocare..."

msgctxt "6||speech_list_caba_erina||table||321||||4"
msgid "Erina..."
msgstr "Erina..."

msgctxt "6||speech_list_caba_erina||table||322||||4"
msgid "Would you like to play against me sometime?\r\nYou can be my first opponent!"
msgstr "Ti andrebbe di giocare contro di me, qualche volta?\r\nPotresti essere il mio primo avversario!"

msgctxt "6||speech_list_caba_erina||table||323||||4"
msgid "Hmm, sure.\r\nI'm game to take you on."
msgstr "Mhm, certo.\r\nAccetto la sfida."

msgctxt "6||speech_list_caba_erina||table||324||||4"
msgid "Really!? I can't wait! <symbol=note_with_outline>"
msgstr "Davvero!? Non vedo l'ora! <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||325||||4"
msgid "You have a secret, Kiryu-san?"
msgstr "Hai un segreto, Kiryu-san?"

msgctxt "6||speech_list_caba_erina||table||326||||4"
msgid "Yeah. Actually..."
msgstr "Sì. In realtà..."

msgctxt "6||speech_list_caba_erina||table||327||||4"
msgid "I used to write in to this radio show."
msgstr "Scrivevo per una trasmissione radiofonica."

msgctxt "6||speech_list_caba_erina||table||328||||4"
msgid "Huh!? You did!? I never imagined you'd\r\nbe so diligent about something."
msgstr "Eh!? Lo facevi davvero!? Non avrei mai immaginato\r\nche fossi così costante in certe cose."

msgctxt "6||speech_list_caba_erina||table||329||||4"
msgid "I don't look like the type?"
msgstr "Non sembro il tipo?"

msgctxt "6||speech_list_caba_erina||table||330||||4"
msgid "Hmm... I guess I could see that.\r\nYou do seem like a guy who's experienced a lot."
msgstr "Mhm... Immagino di sì, a pensarci bene.\r\nSembri proprio un uomo con molta esperienza."

msgctxt "6||speech_list_caba_erina||table||331||||4"
msgid "I'm sure you had a bunch of interesting stories\r\nto tell them. <symbol=note_with_outline>"
msgstr "Sono certa che tu abbia avuto un sacco di storie\r\ninteressanti da raccontargli. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||332||||4"
msgid "Thanks."
msgstr "Grazie."

msgctxt "6||speech_list_caba_erina||table||333||||4"
msgid "I've been a host before.\r\nNot by choice, mind you."
msgstr "Ho fatto l'host in passato.\r\nMa non per scelta, sia chiaro."

msgctxt "6||speech_list_caba_erina||table||334||||4"
msgid "Whoa, really?\r\nI want to see you do a champagne call!"
msgstr "Uau, davvero?\r\nVoglio vederti fare una chiamata per lo champagne!"

msgctxt "6||speech_list_caba_erina||table||335||||4"
msgid "I'm actually your father...!"
msgstr "In realtà sono tuo padre...!"

msgctxt "6||speech_list_caba_erina||table||336||||4"
msgid "You're just the type to make a dad joke,\r\nKiryu-san. Very funny!"
msgstr "Sei proprio il tipo da battuta da papà,\r\nKiryu-san. Molto divertente!"

msgctxt "6||speech_list_caba_erina||table||337||||4"
msgid "Whenever I think of tattoos, all I see are cherry\r\nblossoms. You know, from that one old movie?"
msgstr "Ogni volta che penso ai tatuaggi, mi vengono in mente i fiori\r\ndi ciliegio. Hai presente, in quel vecchio film?"

msgctxt "6||speech_list_caba_erina||table||338||||4"
msgid "Oh, you mean that one where the magistrate reveals\r\nhis tattoo right before he exposes the villain?"
msgstr "Oh, intendi quello in cui il magistrato rivela il suo\r\ntatuaggio un attimo prima di smascherare il cattivo?"

msgctxt "6||speech_list_caba_erina||table||339||||4"
msgid "That's the one! I remember wanting to tear off\r\nmy clothes and resolve a crisis after I saw it!"
msgstr "Esatto, quello! Ricordo di aver voluto strapparmi\r\ni vestiti per sistemare le cose dopo averlo visto!"

msgctxt "6||speech_list_caba_erina||table||340||||4"
msgid "Tear off your clothes... and resolve a..."
msgstr "Strapparti i vestiti... e sistemare le..."

msgctxt "6||speech_list_caba_erina||table||341||||4"
msgid "Oh, Kiryu-san.\r\nDid your mind just go straight into the gutter?"
msgstr "Oh, Kiryu-san.\r\nHai subito pensato male, per caso?"

msgctxt "6||speech_list_caba_erina||table||342||||4"
msgid "N-No, it's not that..."
msgstr "N-No, non è quello..."

msgctxt "6||speech_list_caba_erina||table||343||||4"
msgid "You can't fool me. <symbol=heart_with_outline>"
msgstr "Non puoi ingannarmi. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||344||||4"
msgid "I like drinking, but I always get flushed really\r\nquick. I turn beet red from just a drop! It's sad!"
msgstr "Mi piace bere, ma divento subito rossa per\r\nun niente. Divento un peperone con una sola goccia! Che tristezza!"

msgctxt "6||speech_list_caba_erina||table||345||||4"
msgid "The news seems to talk about them all the time.\r\nSomething about a war... I don't wanna get shot..."
msgstr "I telegiornali sembrano parlarne in continuazione.\r\nQualcosa su una guerra... Non vorrei beccarmi una pallottola..."

msgctxt "6||speech_list_caba_erina||table||346||||4"
msgid "She was a really cute idol.\r\nI've sung her songs in karaoke."
msgstr "Era un'idol davvero adorabile.\r\nHo cantato le sue canzoni al karaoke."

msgctxt "6||speech_list_caba_erina||table||347||||4"
msgid "Oh, did you?"
msgstr "Oh, davvero?"

msgctxt "6||speech_list_caba_erina||table||348||||4"
msgid "A lot of bands have been getting back together,\r\nso I wonder if Haruka-chan will come back, too."
msgstr "Un sacco di gruppi si stanno riunendo ultimamente,\r\nchissà se tornerà anche Haruka-chan."

msgctxt "6||speech_list_caba_erina||table||349||||4"
msgid "I wonder..."
msgstr "Chissà..."

msgctxt "6||speech_list_caba_erina||table||350||||4"
msgid "The adventures of Kiryu-san?\r\nI bet this is going to be an amazing journey!"
msgstr "Le avventure di Kiryu-san?\r\nScommetto che sarà un viaggio incredibile!"

msgctxt "6||speech_list_caba_erina||table||351||||4"
msgid "Thinking back on it, I took down a tiger once..."
msgstr "Pensandoci bene, una volta ho steso una tigre..."

msgctxt "6||speech_list_caba_erina||table||352||||4"
msgid "What!? A tiger!? That's so amazing,\r\nI don't even know what to say..."
msgstr "Cosa!? Una tigre!? È incredibile,\r\nnon so nemmeno cosa dire..."

msgctxt "6||speech_list_caba_erina||table||353||||4"
msgid "One time I fought a hundred yakuza by myself."
msgstr "Una volta ho combattuto da solo contro cento yakuza."

msgctxt "6||speech_list_caba_erina||table||354||||4"
msgid "A-A hundred? By yourself!?\r\nI'm amazed you even survived...!"
msgstr "C-Cento? Da solo!?\r\nMi sorprende che tu sia sopravvissuto...!"

msgctxt "6||speech_list_caba_erina||table||355||||4"
msgid "I was a taxi driver for a little while."
msgstr "Per un po' ho fatto il tassista."

msgctxt "6||speech_list_caba_erina||table||356||||4"
msgid "Wow, you were?\r\nBut does that really qualify as an adventure?"
msgstr "Wow, davvero?\r\nMa si può davvero definire un'avventura?"

msgctxt "6||speech_list_caba_erina||table||357||||4"
msgid "And... I became the fastest man in Fukuoka."
msgstr "E... sono diventato l'uomo più veloce di Fukuoka."

msgctxt "6||speech_list_caba_erina||table||358||||4"
msgid "Huh? I-In a taxi? What do you mean?\r\nMore details, please!"
msgstr "Eh? I-In taxi? Cosa intendi dire?\r\nVoglio più dettagli, dai!"

msgctxt "6||speech_list_caba_erina||table||359||||4"
msgid "I make a lot of sweets.\r\nI'm thinking I'll make a cherry pie next."
msgstr "Preparo molti dolci.\r\nPensavo di preparare una torta di ciliegie, la prossima volta."

msgctxt "6||speech_list_caba_erina||table||360||||4"
msgid "Wow, that sounds good."
msgstr "Wow, sembra ottima."

msgctxt "6||speech_list_caba_erina||table||361||||4"
msgid "If you keep requesting me,\r\nI'll make one for you."
msgstr "Se continui a richiedermi,\r\nne farò una per te."

msgctxt "6||speech_list_caba_erina||table||362||||4"
msgid "Guess I don't have much choice."
msgstr "Immagino di non avere molta scelta."

msgctxt "6||speech_list_caba_erina||table||363||||4"
msgid "I don't actually know my blood type...\r\nSo, I can't use it for compatibility tests..."
msgstr "In realtà non conosco il mio gruppo sanguigno...\r\nQuindi non posso usarlo per i test di compatibilità..."

msgctxt "6||speech_list_caba_erina||table||364||||4"
msgid "No comment!\r\nI'll leave it up to your imagination. <symbol=note_with_outline>"
msgstr "No comment!\r\nLo lascio alla tua immaginazione. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||365||||4"
msgid "Nope, no boyfriend."
msgstr "Nope, nessun fidanzato."

msgctxt "6||speech_list_caba_erina||table||366||||4"
msgid "Really...? Seems like you'd have a lot\r\nof men vying for your attention."
msgstr "Davvero...? Mi sembra che tu abbia un mucchio\r\ndi uomini che fanno a gara per le tue attenzioni."

msgctxt "6||speech_list_caba_erina||table||367||||4"
msgid "Hmm, actually, it feels like most of the\r\nguys who talk to me already have girlfriends."
msgstr "Uhm, a dire il vero, mi sembra che la maggior parte dei\r\nragazzi che mi parlano abbiano già la ragazza."

msgctxt "6||speech_list_caba_erina||table||368||||4"
msgid "But, I'll wait patiently for my wonderful prince.\r\nMaybe there's one closer than I think?"
msgstr "Ma aspetterò pazientemente il mio principe azzurro.\r\nMagari ce n'è uno più vicino di quanto io creda?"

msgctxt "6||speech_list_caba_erina||table||369||||4"
msgid "You never know."
msgstr "Non si sa mai."

msgctxt "6||speech_list_caba_erina||table||370||||4"
msgid "Originally I did it to save money for\r\nacting classes, since I want to be an actress."
msgstr "All'inizio l'ho fatto per mettere da parte dei soldi per\r\nle lezioni di recitazione, dato che voglio fare l'attrice."

msgctxt "6||speech_list_caba_erina||table||371||||4"
msgid "I've learned a lot from this job about how to\r\ntalk and convey the right emotions, though."
msgstr "Tuttavia, da questo lavoro ho imparato molto su come\r\nparlare e trasmettere le emozioni giuste."

msgctxt "6||speech_list_caba_erina||table||372||||4"
msgid "So it's like taking a class all day long."
msgstr "Quindi è come prendere lezioni per tutto il giorno."

msgctxt "6||speech_list_caba_erina||table||373||||4"
msgid "Except I actually get paid at night, so maybe\r\nthese classes are better! Kidding, of course! <symbol=note_with_outline>"
msgstr "Solo che in realtà vengo pagata di notte, quindi forse\r\nqueste lezioni sono anche meglio! Scherzo, ovviamente! <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||374||||4"
msgid "Hey, you can't just decide that!\r\nBut that's just your style, huh? So silly."
msgstr "Ehi, non puoi decidere tu per me!\r\nMa immagino sia proprio nel tuo stile, eh? Sei buffo."

msgctxt "6||speech_list_caba_erina||table||375||||4"
msgid "I like a lot of different genres."
msgstr "Mi piacciono un sacco di generi diversi."

msgctxt "6||speech_list_caba_erina||table||376||||4"
msgid "Oh yeah? Then..."
msgstr "Ah sì? Allora..."

msgctxt "6||speech_list_caba_erina||table||377||||4"
msgid "How about rock?"
msgstr "Che ne dici del rock?"

msgctxt "6||speech_list_caba_erina||table||378||||4"
msgid "I've been listening to more rock than anything\r\nlately! I went to a festival last summer. It was so fun!"
msgstr "Ultimamente ascolto quasi solo rock!\r\nSono andata a un festival l'estate scorsa. È stato divertentissimo!"

msgctxt "6||speech_list_caba_erina||table||379||||4"
msgid "How about classical?"
msgstr "Che ne dici della musica classica?"

msgctxt "6||speech_list_caba_erina||table||380||||4"
msgid "I want to get more into classical music,\r\nbut whenever I try, I just fall right asleep."
msgstr "Vorrei ascoltare più musica classica,\r\nma ogni volta che ci provo mi addormento subito."

msgctxt "6||speech_list_caba_erina||table||381||||4"
msgid "How about enka?"
msgstr "E dell'enka che mi dici?"

msgctxt "6||speech_list_caba_erina||table||382||||4"
msgid "I don't know too much about it, but I've got\r\nsome customers who are really into it."
msgstr "Non ne so molto, ma ho\r\nalcuni clienti a cui piace un sacco."

msgctxt "6||speech_list_caba_erina||table||383||||4"
msgid "I like the song, \"Pure Love In Kamurocho.\""
msgstr "Mi piace la canzone \"Pure Love in Kamurocho\"."

msgctxt "6||speech_list_caba_erina||table||384||||4"
msgid "Back in the day,\r\nthat was one of my go-to karaoke songs."
msgstr "Ai vecchi tempi,\r\nera uno dei miei cavalli di battaglia al karaoke."

msgctxt "6||speech_list_caba_erina||table||385||||4"
msgid "Really!? Talk about a coincidence!\r\nWe should do a duet of it sometime. <symbol=note_with_outline>"
msgstr "Davvero!? Che coincidenza!\r\nDovremmo cantarla in duetto qualche volta. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||386||||4"
msgid "And we're gonna keep having more fun!"
msgstr "E ci divertiremo ancora di più!"

msgctxt "6||speech_list_caba_erina||table||387||||4"
msgid "I'm just happy you're having fun, Kiryu-san. <symbol=note_with_outline>"
msgstr "Sono solo felice che ti stia divertendo, Kiryu-san. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||388||||4"
msgid "I'm having fun, too! I wish this never had to\r\nend... Just kidding."
msgstr "Mi sto divertendo anch'io! Vorrei che non finisse\r\nmai... Scherzo."

msgctxt "6||speech_list_caba_erina||table||389||||4"
msgid "Yeah. I actually like the cold, though."
msgstr "Sì. Anche se, a dire il vero, a me piace il freddo."

msgctxt "6||speech_list_caba_erina||table||390||||4"
msgid "You can layer your clothes,\r\nand you have more options for outfits. <symbol=note_with_outline>"
msgstr "Puoi vestirti a strati,\r\ne hai molta più scelta per gli abbinamenti. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||391||||4"
msgid "I see. That's the kind of logic only\r\na girl could have."
msgstr "Capisco. È una logica che solo\r\nuna ragazza potrebbe avere."

msgctxt "6||speech_list_caba_erina||table||392||||4"
msgid "But it's no different for men!\r\nHow about I coordinate an outfit for you?"
msgstr "Ma vale anche per gli uomini!\r\nChe ne dici se ti scelgo io un outfit?"

msgctxt "6||speech_list_caba_erina||table||393||||4"
msgid "I like the suit I've got on, so I'm good."
msgstr "Mi piace il completo che indosso, quindi sto bene così."

msgctxt "6||speech_list_caba_erina||table||394||||4"
msgid "Awww, too bad."
msgstr "Awww, peccato."

msgctxt "6||speech_list_caba_erina||table||395||||4"
msgid "I think the taste improves with you around, too."
msgstr "Credo che anche il sapore migliori con te nei paraggi."

msgctxt "6||speech_list_caba_erina||table||396||||4"
msgid "You're drunk, aren't you, Kiryu-san?\r\nTell me again when you're sober. <symbol=heart_with_outline>"
msgstr "Sei ubriaco, vero, Kiryu-san?\r\nRipetimelo quando sarai sobrio. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||397||||4"
msgid "A-Are you okay, Kiryu-san!?\r\nWere there some weird mushrooms in the food...!?"
msgstr "T-Tutto bene, Kiryu-san!?\r\nC'erano per caso dei funghi strani nel cibo...!?"

msgctxt "6||speech_list_caba_erina||table||398||||4"
msgid "Well, that's polite. Hello, Kiryu-san. <symbol=note_with_outline>\r\nThis is kind of awkward."
msgstr "Beh, che modi educati. Ciao, Kiryu-san. <symbol=note_with_outline>\r\nÈ un po' imbarazzante."

msgctxt "6||speech_list_caba_erina||table||399||||4"
msgid "Really? If you want to do some touching... <symbol=heart_with_outline>"
msgstr "Davvero? Se hai voglia di allungare le mani... <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||400||||4"
msgid "...Then go to a different club."
msgstr "...Allora vai in un altro club."

msgctxt "6||speech_list_caba_erina||table||401||||4"
msgid "Ergh..."
msgstr "Argh..."

msgctxt "6||speech_list_caba_erina||table||402||||4"
msgid "You're quite handsome, too!"
msgstr "Anche tu sei un bell'uomo!"

msgctxt "6||speech_list_caba_erina||table||403||||4"
msgid "You mean it? Thanks. <symbol=note_with_outline>"
msgstr "Dici davvero? Grazie. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||404||||4"
msgid "Wh-What's gotten in you?"
msgstr "Ch-Che ti prende?"

msgctxt "6||speech_list_caba_erina||table||405||||4"
msgid "Uh, I was just thinking about\r\nhow beautiful your eyes are."
msgstr "Ehm, stavo solo pensando a\r\nquanto siano belli i tuoi occhi."

msgctxt "6||speech_list_caba_erina||table||406||||4"
msgid "I just wasn't expecting you to break out\r\nin English all of a sudden. You're silly."
msgstr "Non mi aspettavo che te ne uscissi all'improvviso\r\ncon l'inglese. Sei proprio buffo."

msgctxt "6||speech_list_caba_erina||table||407||||4"
msgid "Come on, I bet you say that to every girl."
msgstr "Dai, scommetto che lo dici a tutte le ragazze."

msgctxt "6||speech_list_caba_erina||table||408||||4"
msgid "If you agree to only look at me, then sure."
msgstr "Se prometti di guardare solo me, allora d'accordo."

msgctxt "6||speech_list_caba_erina||table||409||||4"
msgid "Think you can only request me from now on...?"
msgstr "Pensi di poter richiedere solo me, d'ora in poi...?"

msgctxt "6||speech_list_caba_erina||table||410||||4"
msgid "That's fine."
msgstr "Va bene."

msgctxt "6||speech_list_caba_erina||table||411||||4"
msgid "Really?\r\nThen, maybe I'll only look at you, too. <symbol=note_with_outline>"
msgstr "Davvero?\r\nAllora, forse guarderò anch'io solo te. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||412||||4"
msgid "Oh c'mon, don't you know\r\nyou're the only one I look at?"
msgstr "Oh andiamo, non lo sai\r\nche guardo solo te?"

msgctxt "6||speech_list_caba_erina||table||413||||4"
msgid "You'd better only look at me too, okay?"
msgstr "Sarà meglio che anche tu guardi solo me, intesi?"

msgctxt "6||speech_list_caba_erina||table||414||||4"
msgid "Yeah..."
msgstr "Sì..."

msgctxt "6||speech_list_caba_erina||table||415||||4"
msgid "I don't have a boyfriend or\r\nanyone I like right now."
msgstr "Al momento non ho un fidanzato o\r\nqualcuno che mi piace."

msgctxt "6||speech_list_caba_erina||table||416||||4"
msgid "Oh, you don't?"
msgstr "Ah, no?"

msgctxt "6||speech_list_caba_erina||table||417||||4"
msgid "I do think it'd be nice, though.\r\nBut first I have to work hard at my job!"
msgstr "Però penso che sarebbe bello averlo.\r\nMa prima devo impegnarmi col lavoro!"

msgctxt "6||speech_list_caba_erina||table||418||||4"
msgid "Hmm... It's a secret."
msgstr "Mhm... È un segreto."

msgctxt "6||speech_list_caba_erina||table||419||||4"
msgid "That just makes me even more curious..."
msgstr "Questo mi incuriosisce ancora di più..."

msgctxt "6||speech_list_caba_erina||table||420||||4"
msgid "Well, it's embarrassing! I mean,\r\nthere is someone I'm a bit interested in..."
msgstr "Beh, è imbarazzante! Cioè,\r\nc'è qualcuno che mi interessa un po'..."

msgctxt "6||speech_list_caba_erina||table||421||||4"
msgid "You don't mean me, do you?"
msgstr "Non intendi me, vero?"

msgctxt "6||speech_list_caba_erina||table||422||||4"
msgid "And what if I did? <symbol=note_with_outline>"
msgstr "E se fosse così? <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||423||||4"
msgid "There's... someone, I guess?"
msgstr "C'è... qualcuno, credo?"

msgctxt "6||speech_list_caba_erina||table||424||||4"
msgid "I see..."
msgstr "Capisco..."

msgctxt "6||speech_list_caba_erina||table||425||||4"
msgid "But I'm sure it's unrequited. He seems dense,\r\nand it might be hard to make it work out..."
msgstr "Ma sono certa che non sia corrisposto. Sembra un po' tardo,\r\ne potrebbe essere difficile far funzionare le cose..."

msgctxt "6||speech_list_caba_erina||table||426||||4"
msgid "He's dense?\r\nHe doesn't know what he's missing."
msgstr "È tardo?\r\nNon sa cosa si perde."

msgctxt "6||speech_list_caba_erina||table||428||||4"
msgid "That's the first I've actually heard a line like\r\nthat! Kiryu-san, you're silly."
msgstr "È la prima volta che sento una frase\r\ndel genere! Kiryu-san, sei proprio buffo."

msgctxt "6||speech_list_caba_erina||table||429||||4"
msgid "Then I think I'm about to get some\r\nsecond-degree burns... <symbol=heart_with_outline>"
msgstr "Allora mi sa che sto per farmi venire\r\ndelle ustioni di secondo grado... <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||430||||4"
msgid "I'm ready for you any time!"
msgstr "Sono pronta per te in qualsiasi momento!"

msgctxt "6||speech_list_caba_erina||table||431||||4"
msgid "I don't actually eat out in Kamurocho very often."
msgstr "In realtà non mangio spesso fuori a Kamurocho."

msgctxt "6||speech_list_caba_erina||table||432||||4"
msgid "I'm a big eater,\r\nso it actually costs a lot if I go out to eat..."
msgstr "Sono una gran mangiona,\r\nquindi mi costa un sacco se vado a mangiare fuori..."

msgctxt "6||speech_list_caba_erina||table||433||||4"
msgid "Must be rough..."
msgstr "Dev'essere dura..."

msgctxt "6||speech_list_caba_erina||table||434||||4"
msgid "Yeah. At least I can make all I want at home.\r\nIt's made me a better cook."
msgstr "Sì. Almeno a casa posso prepararmi quello che voglio.\r\nMi ha reso una cuoca migliore."

msgctxt "6||speech_list_caba_erina||table||435||||4"
msgid "Wow, that's pretty amazing."
msgstr "Wow, è fantastico."

msgctxt "6||speech_list_caba_erina||table||436||||4"
msgid "Then I should cook for you sometime,\r\nKiryu-san. <symbol=heart_with_outline>"
msgstr "Allora dovrei cucinare per te, qualche volta,\r\nKiryu-san. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||437||||4"
msgid "Kiryu-san, you go to places like that?\r\nThat's kind of surprising."
msgstr "Kiryu-san, vai in posti del genere?\r\nÈ piuttosto sorprendente."

msgctxt "6||speech_list_caba_erina||table||438||||4"
msgid "Hmm... I'd rather you didn't\r\ngo to those kind of places..."
msgstr "Mhm... Preferirei che tu non\r\nandassi in posti del genere..."

msgctxt "6||speech_list_caba_erina||table||439||||4"
msgid "Oh? Why's that?"
msgstr "Oh? E perché mai?"

msgctxt "6||speech_list_caba_erina||table||440||||4"
msgid "Well, I don't know of too many girls who'd want\r\na guy they like to be in those places."
msgstr "Beh, non conosco molte ragazze che vorrebbero che il\r\nragazzo che piace loro frequentasse posti simili."

msgctxt "6||speech_list_caba_erina||table||441||||4"
msgid "Wait, what am I saying...?\r\nN-Never mind!"
msgstr "Aspetta, ma che sto dicendo...?\r\nN-Niente, lascia perdere!"

msgctxt "6||speech_list_caba_erina||table||442||||4"
msgid "Huh? You destroyed a convenience store? \r\nHow does something like that even happen!?"
msgstr "Eh? Hai distrutto un minimarket?\r\nCome diamine può succedere una cosa del genere!?"

msgctxt "6||speech_list_caba_erina||table||443||||4"
msgid "It's kind of complicated..."
msgstr "È un po' complicato..."

msgctxt "6||speech_list_caba_erina||table||444||||4"
msgid "I guess... Just don't destroy our club, okay?"
msgstr "Immagino... Cerca solo di non distruggere il nostro club, okay?"

msgctxt "6||speech_list_caba_erina||table||445||||4"
msgid "Yeah. It'll be fine... probably."
msgstr "Sì. Andrà tutto bene... probabilmente."

msgctxt "6||speech_list_caba_erina||table||446||||4"
msgid "Kiryu-san... If you have something you need\r\nto confess, I'll listen."
msgstr "Kiryu-san... Se hai qualcosa che hai bisogno\r\ndi confessare, ti ascolto."

msgctxt "6||speech_list_caba_erina||table||447||||4"
msgid "Just know that if it's something I can't forgive,\r\nyou might find yourself in a bucket of hot water."
msgstr "Sappi solo che se è qualcosa che non posso perdonarti,\r\npotresti finire in un mare di guai."

msgctxt "6||speech_list_caba_erina||table||448||||4"
msgid "That's a pretty old expression...\r\nYou sure you aren't lying about your age?"
msgstr "È un'espressione piuttosto antiquata...\r\nSicura di non mentire sulla tua età?"

msgctxt "6||speech_list_caba_erina||table||449||||4"
msgid "Was he a friend of yours?"
msgstr "Era un tuo amico?"

msgctxt "6||speech_list_caba_erina||table||450||||4"
msgid "Yeah. He was like a brother to me. Even now, I find\r\nmyself thinking back to when we just messed around."
msgstr "Sì. Era come un fratello per me. Ancora adesso mi ritrovo\r\na ripensare a quando facevamo solo cazzate insieme."

msgctxt "6||speech_list_caba_erina||table||451||||4"
msgid "Oh, I see.\r\nWhat kind of memories do you have of him?"
msgstr "Oh, capisco.\r\nChe tipo di ricordi hai di lui?"

msgctxt "6||speech_list_caba_erina||table||452||||4"
msgid "We sang karaoke together a lot. There was a\r\npopular band at the time that we really liked."
msgstr "Cantavamo spesso al karaoke insieme. C'era una\r\nband molto popolare all'epoca che ci piaceva un sacco."

msgctxt "6||speech_list_caba_erina||table||453||||4"
msgid "He was the type to hog the mic, so most of the\r\ntime he forced me to sing back-up for him."
msgstr "Era il tipo che monopolizzava il microfono, quindi la maggior\r\nparte delle volte mi costringeva a fargli i cori."

msgctxt "6||speech_list_caba_erina||table||454||||4"
msgid "Wow. Singing together like that...\r\nSounds like you two were really close."
msgstr "Wow. Cantare insieme in quel modo...\r\nSembra proprio che voi due foste molto uniti."

msgctxt "6||speech_list_caba_erina||table||455||||4"
msgid "Yeah. But now I can never do\r\nthose dumb interjections again..."
msgstr "Sì. Ma ora non potrò mai più fargli\r\nquegli stupidi cori..."

msgctxt "6||speech_list_caba_erina||table||456||||4"
msgid "Kiryu-san..."
msgstr "Kiryu-san..."

msgctxt "6||speech_list_caba_erina||table||457||||4"
msgid "Ah, sorry.\r\nI shouldn't have brought up something so dark."
msgstr "Ah, scusa.\r\nNon avrei dovuto tirare fuori un argomento così triste."

msgctxt "6||speech_list_caba_erina||table||458||||4"
msgid "No... You can talk about whatever\r\nyou want if it helps ease your burden."
msgstr "No... Puoi parlare di quello che vuoi\r\nse ti aiuta ad alleggerirti il cuore."

msgctxt "6||speech_list_caba_erina||table||459||||4"
msgid "We used to just drink and shoot the breeze\r\nat this bar we really loved."
msgstr "Andavamo sempre a bere e a sparare cazzate\r\nin questo bar che ci piaceva un sacco."

msgctxt "6||speech_list_caba_erina||table||460||||4"
msgid "Sounds like you two made a lot\r\nof memories at this bar."
msgstr "Sembra che abbiate costruito un sacco\r\ndi ricordi in quel bar."

msgctxt "6||speech_list_caba_erina||table||461||||4"
msgid "Yeah. Even now, when I walk by it, I feel like\r\nI could go in and he'd still be sitting there."
msgstr "Già. Ancora oggi, quando ci passo davanti, mi sento come se\r\npotessi entrare e trovarlo ancora seduto lì."

msgctxt "6||speech_list_caba_erina||table||462||||4"
msgid "Pretty stupid, right?\r\nI know he's gone, but..."
msgstr "Abbastanza stupido, vero?\r\nSo che se n'è andato, ma..."

msgctxt "6||speech_list_caba_erina||table||463||||4"
msgid "A lot happened...\r\nAnd in the end, it had to come to blows."
msgstr "Sono successe tante cose...\r\nE alla fine, siamo dovuti arrivare alle mani."

msgctxt "6||speech_list_caba_erina||table||464||||4"
msgid "More and more... I wonder if there was\r\nsome way things could have ended better."
msgstr "Sempre più spesso... mi chiedo se ci fosse un modo\r\nper far finire le cose diversamente."

msgctxt "6||speech_list_caba_erina||table||465||||4"
msgid "Someone you can share your secrets with, I guess?\r\nI just want a friend before I find a true friend..."
msgstr "Qualcuno con cui condividere i tuoi segreti, immagino?\r\nIo vorrei solo farmi un'amica prima di trovare una vera amica..."

msgctxt "6||speech_list_caba_erina||table||466||||4"
msgid "Ohh, I could see that!\r\nI bet you're good at taking care of someone!"
msgstr "Ohh, ce la vedo proprio!\r\nScommetto che sei bravo a prenderti cura degli altri!"

msgctxt "6||speech_list_caba_erina||table||467||||4"
msgid "Is that how I look?"
msgstr "Ti do questa impressione?"

msgctxt "6||speech_list_caba_erina||table||468||||4"
msgid "Yeah. Any baby would be thrilled to be lifted\r\ninto the air in your arms! You'd be a good dad."
msgstr "Sì. Qualsiasi bambino sarebbe felicissimo di farsi sollevare\r\nin aria dalle tue braccia! Saresti un ottimo papà."

msgctxt "6||speech_list_caba_erina||table||469||||4"
msgid "You know so much about it! You should let\r\nme taste some of the fish you catch."
msgstr "Ne sai davvero un sacco! Dovresti farmi\r\nassaggiare un po' del pesce che peschi."

msgctxt "6||speech_list_caba_erina||table||470||||4"
msgid "Huh? How does one even become a target of\r\nan organization like that?"
msgstr "Eh? Come si fa a diventare il bersaglio di\r\nun'organizzazione del genere?"

msgctxt "6||speech_list_caba_erina||table||471||||4"
msgid "Good question..."
msgstr "Bella domanda..."

msgctxt "6||speech_list_caba_erina||table||472||||4"
msgid "Maybe that's just the card fate dealt you.\r\nBut I'm on your side, okay?"
msgstr "Forse è solo la carta che ti ha riservato il destino.\r\nMa io sono dalla tua parte, okay?"

msgctxt "6||speech_list_caba_erina||table||473||||4"
msgid "Honestly, you have to wonder what's going on\r\nin the minds of people like that."
msgstr "Sinceramente, c'è da chiedersi cosa passi per\r\nla testa a certa gente."

msgctxt "6||speech_list_caba_erina||table||474||||4"
msgid "I used to go all the time! Pocket Circuit\r\nStadium, right? My machine was pretty fast."
msgstr "Ci andavo sempre! Al Pocket Circuit Stadium,\r\ngiusto? La mia macchinina era piuttosto veloce."

msgctxt "6||speech_list_caba_erina||table||475||||4"
msgid "Wow. Never imagined you were into it."
msgstr "Wow. Non avrei mai immaginato che ti piacesse."

msgctxt "6||speech_list_caba_erina||table||476||||4"
msgid "Oh yeah! Have you heard, Kiryu-san? About the\r\nguy called \"The Fastest Man in Kamurocho?\""
msgstr "Oh, già! Ne hai mai sentito parlare, Kiryu-san? Del\r\ntizio chiamato \"L'uomo più veloce di Kamurocho\"?"

msgctxt "6||speech_list_caba_erina||table||477||||4"
msgid "He's a legend who'd show up whenever there was a\r\nPocket Circuit boom, win every race, then disappear."
msgstr "È una leggenda che si faceva vivo a ogni boom del Pocket\r\nCircuit, vinceva tutte le gare e poi spariva nel nulla."

msgctxt "6||speech_list_caba_erina||table||478||||4"
msgid "If it comes back again, maybe he'll reappear..."
msgstr "Se dovesse tornare di moda, magari riapparirà..."

msgctxt "6||speech_list_caba_erina||table||479||||4"
msgid "I've even heard rumors that he took one of\r\nthe Pocket Circuit staffers as his wife..."
msgstr "Ho persino sentito voci sul fatto che abbia preso in moglie\r\nuna ragazza dello staff del Pocket Circuit..."

msgctxt "6||speech_list_caba_erina||table||480||||4"
msgid "H-Huh... There were rumors like that?"
msgstr "E-Eh... Giravano voci del genere?"

msgctxt "6||speech_list_caba_erina||table||481||||4"
msgid "(Is she talking about me? Couldn't be...)"
msgstr "(Sta parlando di me? Impossibile...)"

msgctxt "6||speech_list_caba_erina||table||482||||4"
msgid "But Kiryu-san, you seem pretty strong already.\r\nYou're still training?"
msgstr "Ma Kiryu-san, mi sembri già bello forte.\r\nTi alleni ancora?"

msgctxt "6||speech_list_caba_erina||table||483||||4"
msgid "Strength has no ceiling.\r\nI'm going to keep aiming higher."
msgstr "La forza non ha limiti.\r\nContinuerò a puntare sempre più in alto."

msgctxt "6||speech_list_caba_erina||table||484||||4"
msgid "Then I hope you'll be there to help me out\r\nif I ever find myself in a pinch."
msgstr "Allora spero che sarai lì ad aiutarmi\r\nse mai dovessi trovarmi nei guai."

msgctxt "6||speech_list_caba_erina||table||485||||4"
msgid "Sure. Leave it to me."
msgstr "Certo. Lascia fare a me."

msgctxt "6||speech_list_caba_erina||table||486||||4"
msgid "That's encouraging. <symbol=heart_with_outline>"
msgstr "È rassicurante. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||487||||4"
msgid "Me too. I'm no good in a crowd."
msgstr "Anch'io. Non mi trovo bene in mezzo alla folla."

msgctxt "6||speech_list_caba_erina||table||488||||4"
msgid "Huh!? I would have thought the opposite!"
msgstr "Eh!? Avrei detto il contrario!"

msgctxt "6||speech_list_caba_erina||table||489||||4"
msgid "I tend to like people who take the lead, but...\r\nif it was you, I wouldn't mind you being passive."
msgstr "Di solito mi piacciono i tipi che prendono l'iniziativa, ma...\r\nse si trattasse di te, non mi dispiacerebbe la passività."

msgctxt "6||speech_list_caba_erina||table||490||||4"
msgid "Thanks for the support..."
msgstr "Grazie per l'appoggio..."

msgctxt "6||speech_list_caba_erina||table||491||||4"
msgid "You never gave me that impression, Kiryu-san.\r\nI can talk to pretty much anybody!"
msgstr "Non mi hai mai dato quest'impressione, Kiryu-san.\r\nIo riesco a parlare praticamente con chiunque!"

msgctxt "6||speech_list_caba_erina||table||492||||4"
msgid "Oh? Any tips you can share?"
msgstr "Oh? Hai qualche consiglio da darmi?"

msgctxt "6||speech_list_caba_erina||table||493||||4"
msgid "Just smiling and nodding go a long way.\r\nYou should give it a shot, Kiryu-san!"
msgstr "Sorridere e annuire fanno già molto.\r\nDovresti provare, Kiryu-san!"

msgctxt "6||speech_list_caba_erina||table||494||||4"
msgid "Smiling and nodding, huh?"
msgstr "Sorridere e annuire, eh?"

msgctxt "6||speech_list_caba_erina||table||496||||4"
msgid "Well... There's nothing wrong with being shy\r\neither, so you don't have to force it..."
msgstr "Beh... Non c'è neanche nulla di male nell'essere timidi,\r\nquindi non devi forzarti..."

msgctxt "6||speech_list_caba_erina||table||497||||4"
msgid "I don't worry about that stuff... Of course,\r\nI'd be happy if you took me somewhere like that."
msgstr "Non bado a queste cose... Certo,\r\nsarei felice se mi portassi in un posto del genere."

msgctxt "6||speech_list_caba_erina||table||498||||4"
msgid "Oh, you would?"
msgstr "Oh, davvero?"

msgctxt "6||speech_list_caba_erina||table||499||||4"
msgid "For me, the company is more important than the\r\nvenue. If I like him, I'm fine going anywhere."
msgstr "Per me la compagnia è più importante del posto.\r\nSe un ragazzo mi piace, mi sta bene andare ovunque."

msgctxt "6||speech_list_caba_erina||table||500||||4"
msgid "Hmm... Around 48?"
msgstr "Mhm... Sui 48?"

msgctxt "6||speech_list_caba_erina||table||501||||4"
msgid "That's right. I didn't think you'd\r\nget it on the dot, though..."
msgstr "Esatto. Non pensavo che ci avresti\r\npreso in pieno, però..."

msgctxt "6||speech_list_caba_erina||table||502||||4"
msgid "Wow, I nailed it!\r\nHow old do I look?"
msgstr "Wow, ci ho azzeccato!\r\nIo quanti anni ti sembro avere?"

msgctxt "6||speech_list_caba_erina||table||503||||4"
msgid "Hmm. 18?"
msgstr "Mhm. 18?"

msgctxt "6||speech_list_caba_erina||table||504||||4"
msgid "Nope. I'm actually 23! But it's great that you\r\nknew guessing low was the safest bet with a woman."
msgstr "Sbagliato. In realtà ne ho 23! Ma è fantastico che tu\r\nsappia che puntare al ribasso è la mossa più sicura con una donna."

msgctxt "6||speech_list_caba_erina||table||505||||4"
msgid "Nah, I just said what I thought."
msgstr "Nah, ho solo detto quello che pensavo."

msgctxt "6||speech_list_caba_erina||table||506||||4"
msgid "Thank you. <symbol=note_with_outline>"
msgstr "Grazie. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||507||||4"
msgid "Hmm. 23?"
msgstr "Mhm. 23?"

msgctxt "6||speech_list_caba_erina||table||508||||4"
msgid "Oh! You're right! I'm impressed.\r\nGood job, Kiryu-san!"
msgstr "Oh! Hai indovinato! Sono impressionata.\r\nOttimo lavoro, Kiryu-san!"

msgctxt "6||speech_list_caba_erina||table||509||||4"
msgid "Hmm. 28?"
msgstr "Mhm. 28?"

msgctxt "6||speech_list_caba_erina||table||510||||4"
msgid "Kiryu-san... Better luck next time."
msgstr "Kiryu-san... Ritenta, sarai più fortunato."

msgctxt "6||speech_list_caba_erina||table||511||||4"
msgid "I was wrong? Sorry..."
msgstr "Ho sbagliato? Scusa..."

msgctxt "6||speech_list_caba_erina||table||512||||4"
msgid "Geez. I'm still 23.\r\nDo I look that old?"
msgstr "Cavoli. Ho ancora 23 anni.\r\nSembro così vecchia?"

msgctxt "6||speech_list_caba_erina||table||513||||4"
msgid "No, I was just misled by the refined\r\ncharm you have about you."
msgstr "No, mi sono solo lasciato ingannare dal fascino\r\nraffinato che emani."

msgctxt "6||speech_list_caba_erina||table||514||||4"
msgid "Nice save.\r\nI'll let you off the hook this time. <symbol=note_with_outline>"
msgstr "Bel salvataggio.\r\nTe la lascio passare, per stavolta. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||515||||4"
msgid "I think you're a fun customer!\r\nTime flies when I'm with you, Kiryu-san."
msgstr "Credo che tu sia un cliente divertente!\r\nIl tempo vola quando sto con te, Kiryu-san."

msgctxt "6||speech_list_caba_erina||table||516||||4"
msgid "I'm having fun, too."
msgstr "Mi sto divertendo anch'io."

msgctxt "6||speech_list_caba_erina||table||517||||4"
msgid "You're a special customer.\r\nI get all happy whenever you walk in."
msgstr "Sei un cliente speciale.\r\nDivento felicissima ogni volta che entri nel club."

msgctxt "6||speech_list_caba_erina||table||518||||4"
msgid "It's nice to hear that."
msgstr "Mi fa piacere sentirlo."

msgctxt "6||speech_list_caba_erina||table||519||||4"
msgid "I'm always waiting for you. <symbol=note_with_outline>"
msgstr "Ti aspetto sempre. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||520||||4"
msgid "Y-You're... someone I'm interested in, I guess."
msgstr "T-Tu sei... qualcuno che mi interessa, credo."

msgctxt "6||speech_list_caba_erina||table||521||||4"
msgid "Sometimes I find myself wondering\r\nwhat you're doing... Oh, what am I saying!?"
msgstr "A volte mi ritrovo a chiedermi\r\ncosa tu stia facendo... Oh, ma che sto dicendo!?"

msgctxt "6||speech_list_caba_erina||table||522||||4"
msgid "I see... I came to this club because\r\nI was interested in you, too."
msgstr "Capisco... Sono venuto in questo club perché\r\nanch'io ero interessato a te."

msgctxt "6||speech_list_caba_erina||table||523||||4"
msgid "Kiryu-san...! I'm glad, though. <symbol=heart_with_outline>"
msgstr "Kiryu-san...! Ne sono felice, però. <symbol=heart_with_outline>"

msgctxt "6||speech_list_caba_erina||table||524||||4"
msgid "I have no preference when it comes to age. Even\r\na guy as old as my dad could be in the strike zone."
msgstr "Non ho preferenze quando si tratta di età. Anche\r\nun uomo dell'età di mio padre potrebbe rientrare nei miei gusti."

msgctxt "6||speech_list_caba_erina||table||525||||4"
msgid "So... I have a chance, then."
msgstr "Quindi... ho una possibilità, allora."

msgctxt "6||speech_list_caba_erina||table||526||||4"
msgid "Of course! Guys in your age range are actually\r\nthe sexiest. I bet you're popular with the girls."
msgstr "Certo! Gli uomini della tua età sono in assoluto\r\ni più sexy. Scommetto che sei popolare tra le ragazze."

msgctxt "6||speech_list_caba_erina||table||527||||4"
msgid "I have a finger fetish.\r\nI love a man with long, rugged fingers...!"
msgstr "Ho un feticismo per le dita.\r\nAdoro gli uomini con dita lunghe e vissute...!"

msgctxt "6||speech_list_caba_erina||table||528||||4"
msgid "Yeah? What do you think about mine?"
msgstr "Ah sì? Che ne pensi delle mie?"

msgctxt "6||speech_list_caba_erina||table||529||||4"
msgid "They're actually really my type!\r\nI've been stealing glances at them... <symbol=note_with_outline>"
msgstr "In realtà sono proprio il mio tipo!\r\nGli stavo lanciando delle occhiatine... <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||530||||4"
msgid "I'd like a home theater system. I want to watch\r\nmovies on a big screen with powerful sound!"
msgstr "Mi piacerebbe un impianto home theater. Voglio guardare\r\ni film su un grande schermo con un suono potente!"

msgctxt "6||speech_list_caba_erina||table||531||||4"
msgid "I met my first love at a class reunion the\r\nother day, but now he's the father of two kids."
msgstr "L'altro giorno ho rincontrato il mio primo amore a una\r\nrimpatriata di classe, ma ora è padre di due figli."

msgctxt "6||speech_list_caba_erina||table||532||||4"
msgid "Well, a lot can happen by that age."
msgstr "Beh, ne possono succedere di cose a quell'età."

msgctxt "6||speech_list_caba_erina||table||533||||4"
msgid "How did your first love go, Kiryu-san?"
msgstr "E il tuo primo amore com'è andato, Kiryu-san?"

msgctxt "6||speech_list_caba_erina||table||534||||4"
msgid "Me? I..."
msgstr "Il mio? Io..."

msgctxt "6||speech_list_caba_erina||table||536||||4"
msgid "L-Let's just drink the night away then,\r\nKiryu-san!"
msgstr "A-Allora beviamoci su tutta la notte,\r\nKiryu-san!"

msgctxt "6||speech_list_caba_erina||table||537||||4"
msgid "We went to a bread factory on a field trip.\r\nI think that was my first real job experience."
msgstr "Siamo andati in un panificio in gita scolastica.\r\nPenso che sia stata la mia prima vera esperienza lavorativa."

msgctxt "6||speech_list_caba_erina||table||538||||4"
msgid "Uh, not that kind of first time."
msgstr "Ehm, non intendevo quel tipo di prima volta."

msgctxt "6||speech_list_caba_erina||table||539||||4"
msgid "Huh? What do you mean, then?"
msgstr "Eh? Che cosa intendevi, allora?"

msgctxt "6||speech_list_caba_erina||table||540||||4"
msgid "Er, never mind..."
msgstr "Ehm, lascia perdere..."

msgctxt "6||speech_list_caba_erina||table||541||||4"
msgid "Kiryu-san, that's sexual harassment.\r\nI'm not telling you."
msgstr "Kiryu-san, queste sono molestie sessuali.\r\nNon te lo dico."

msgctxt "6||speech_list_caba_erina||table||542||||4"
msgid "What? Well, what color do you think they are...?"
msgstr "Cosa? Beh, di che colore pensi che siano...?"

msgctxt "6||speech_list_caba_erina||table||543||||4"
msgid "Hm, let's see... White?"
msgstr "Mhm, vediamo... Bianche?"

msgctxt "6||speech_list_caba_erina||table||544||||4"
msgid "Then they're white. <symbol=note_with_outline>"
msgstr "Allora sono bianche. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||545||||4"
msgid "Ngh..."
msgstr "Ngh..."

msgctxt "6||speech_list_caba_erina||table||546||||4"
msgid "Oh, Kiryu-san. You're such a perv... I'll tell\r\nyou, but... it's a secret, okay?"
msgstr "Oh, Kiryu-san. Sei proprio un pervertito... Te lo\r\ndirò, ma... è un segreto, okay?"

msgctxt "6||speech_list_caba_erina||table||547||||4"
msgid "...They're black."
msgstr "...Sono nere."

msgctxt "6||speech_list_caba_erina||table||548||||4"
msgid "Oho..."
msgstr "Oho..."

msgctxt "6||speech_list_caba_erina||table||549||||4"
msgid "I'd like to get married sooner than later.\r\nI want kids."
msgstr "Mi piacerebbe sposarmi il prima possibile.\r\nVoglio avere dei bambini."

msgctxt "6||speech_list_caba_erina||table||550||||4"
msgid "Think you'll ever settle down, Kiryu-san?"
msgstr "Pensi che ti sistemerai mai, Kiryu-san?"

msgctxt "6||speech_list_caba_erina||table||551||||4"
msgid "Hmm. I have things I need to do before then."
msgstr "Mhm. Ho delle cose da fare prima."

msgctxt "6||speech_list_caba_erina||table||552||||4"
msgid "If you keep putting it off, all the cute girls\r\nare going to get snatched up, though. Like me."
msgstr "Se continui a rimandare, però, tutte le ragazze carine\r\nverranno prese. Tipo me."

msgctxt "6||speech_list_caba_erina||table||553||||4"
msgid "I'll have to be careful about that."
msgstr "Dovrò stare attento a questo."

msgctxt "6||speech_list_caba_erina||table||554||||4"
msgid "Um... What about you, Kiryu-san?\r\nDo you think you... want to get married?"
msgstr "Ehm... E tu, Kiryu-san?\r\nPensi... di volerti sposare?"

msgctxt "6||speech_list_caba_erina||table||555||||4"
msgid "I've got a lot going on right now. But part\r\nof me would like that to happen some day."
msgstr "Ho un sacco di cose per la testa al momento. Ma a una\r\nparte di me piacerebbe che succedesse, un giorno."

msgctxt "6||speech_list_caba_erina||table||556||||4"
msgid "Oh, really!? I'm glad."
msgstr "Oh, davvero!? Mi fa piacere."

msgctxt "6||speech_list_caba_erina||table||557||||4"
msgid "Hm? Why's that?"
msgstr "Mhm? E come mai?"

msgctxt "6||speech_list_caba_erina||table||558||||4"
msgid "...It's nothing."
msgstr "...Niente di che."

msgctxt "6||speech_list_caba_erina||table||559||||4"
msgid "Really? I don't actually wear that much makeup."
msgstr "Davvero? In realtà non mi trucco poi così tanto."

msgctxt "6||speech_list_caba_erina||table||560||||4"
msgid "Oh, you don't?"
msgstr "Oh, no?"

msgctxt "6||speech_list_caba_erina||table||561||||4"
msgid "Oh, also, you probably shouldn't say that\r\nto a woman."
msgstr "Ah, comunque, probabilmente non dovresti\r\ndire una cosa del genere a una donna."

msgctxt "6||speech_list_caba_erina||table||562||||4"
msgid "They might take it as you think they're ugly\r\nwithout their make-up on."
msgstr "Potrebbero pensare che tu le reputi brutte senza trucco."

msgctxt "6||speech_list_caba_erina||table||563||||4"
msgid "I meant it as a compliment...\r\nA woman's mind is so complex."
msgstr "Nelle mie intenzioni era un complimento...\r\nLa mente femminile è così complessa."

msgctxt "6||speech_list_caba_erina||table||564||||4"
msgid "Huh? You think we've seen each other somewhere?"
msgstr "Eh? Pensi che ci siamo già visti da qualche parte?"

msgctxt "6||speech_list_caba_erina||table||565||||4"
msgid "I feel like I saw you at a movie theater..."
msgstr "Ho come l'impressione di averti visto in un cinema..."

msgctxt "6||speech_list_caba_erina||table||566||||4"
msgid "Oh, I go to the theater a lot, so it might have\r\nbeen me! Let me know next time you go, would you? <symbol=note_with_outline>"
msgstr "Oh, vado spesso al cinema, quindi potevo\r\nessere io! Fammi sapere la prossima volta che ci vai, d'accordo? <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||567||||4"
msgid "Was that you I saw fishing on the pier?"
msgstr "Eri tu quello che ho visto pescare sul molo?"

msgctxt "6||speech_list_caba_erina||table||568||||4"
msgid "No, I wasn't there.\r\nProbably wasn't me..."
msgstr "No, non ero lì.\r\nProbabilmente non ero io..."

msgctxt "6||speech_list_caba_erina||table||569||||4"
msgid "I thought so... Sorry."
msgstr "Lo immaginavo... Scusa."

msgctxt "6||speech_list_caba_erina||table||570||||4"
msgid "Did we meet in a previous life?"
msgstr "Ci siamo incontrati in una vita precedente?"

msgctxt "6||speech_list_caba_erina||table||571||||4"
msgid "Kiryu-san, I didn't know you were capable of\r\nanything that cheesy. I wasn't expecting that!"
msgstr "Kiryu-san, non sapevo fossi capace di dire cose\r\ncosì sdolcinate. Questa non me l'aspettavo!"

msgctxt "6||speech_list_caba_erina||table||572||||4"
msgid "...But, maybe we did. I feel like maybe\r\nfate guided us here."
msgstr "...Ma chissà, forse sì. Sento che, forse,\r\nil destino ci ha guidato fin qui."

msgctxt "6||speech_list_caba_erina||table||573||||4"
msgid "Thank you! My figure is the one thing\r\nI'm confident about. Even though I'm a big eater."
msgstr "Grazie! Il mio fisico è l'unica cosa di cui\r\nsono sicura. Anche se sono una gran mangiona."

msgctxt "6||speech_list_caba_erina||table||574||||4"
msgid "I'm amazed you can keep a body like that despite\r\nhow much you eat. Do you do anything special?"
msgstr "Mi sorprende che tu riesca a mantenere un corpo simile nonostante\r\ntutto quello che mangi. Fai qualcosa in particolare?"

msgctxt "6||speech_list_caba_erina||table||575||||4"
msgid "Not really. In fact, it makes the other girls\r\nkind of jealous of me sometimes..."
msgstr "Non proprio. Anzi, a volte la cosa rende le altre ragazze\r\nun po' invidiose di me..."

msgctxt "6||speech_list_caba_erina||table||576||||4"
msgid "Having a good figure is a crime, huh?"
msgstr "Avere un bel fisico è un crimine, eh?"

msgctxt "6||speech_list_caba_erina||table||577||||4"
msgid "Some people say that cheating\r\nis a sign of a successful man."
msgstr "C'è chi dice che tradire sia\r\nil segno di un uomo di successo."

msgctxt "6||speech_list_caba_erina||table||578||||4"
msgid "Would you forgive me?"
msgstr "Tu mi perdoneresti?"

msgctxt "6||speech_list_caba_erina||table||579||||4"
msgid "Not in a million years! Would you forgive your\r\ngirlfriend if she cheated on you?"
msgstr "Nemmeno tra un milione di anni! Tu perdoneresti la\r\ntua ragazza se ti tradisse?"

msgctxt "6||speech_list_caba_erina||table||580||||4"
msgid "Well, if she cheated, it might have been my\r\nfault anyway, so... I might forgive her."
msgstr "Beh, se mi tradisse, potrebbe comunque essere colpa\r\nmia, quindi... potrei perdonarla."

msgctxt "6||speech_list_caba_erina||table||581||||4"
msgid "Wow, you're very open-minded about it, Kiryu-san.\r\nI wouldn't be able to forgive them."
msgstr "Wow, sei molto aperto al riguardo, Kiryu-san.\r\nIo non ci riuscirei mai."

msgctxt "6||speech_list_caba_erina||table||582||||4"
msgid "I'd never forgive her.\r\nI'd curse her descendants."
msgstr "Non la perdonerei mai.\r\nMaledirei tutta la sua discendenza."

msgctxt "6||speech_list_caba_erina||table||583||||4"
msgid "True, true, true!\r\nCheaters should burn in the fires of hell! Yep."
msgstr "Vero, vero, vero!\r\nI traditori dovrebbero bruciare tra le fiamme dell'inferno! Esatto."

msgctxt "6||speech_list_caba_erina||table||584||||4"
msgid "Good. If we dated, I wouldn't\r\nhave to worry about you cheating on me..."
msgstr "Bene. Se uscissimo insieme, non dovrei\r\npreoccuparmi che tu mi tradisca..."

msgctxt "6||speech_list_caba_erina||table||585||||4"
msgid "Right..."
msgstr "Già..."

msgctxt "6||speech_list_caba_erina||table||586||||4"
msgid "Oh, I like going outdoors too!\r\nWhat kinds of places do you go, Kiryu-san?"
msgstr "Oh, anche a me piace stare all'aperto!\r\nIn che genere di posti vai, Kiryu-san?"

msgctxt "6||speech_list_caba_erina||table||587||||4"
msgid "It's got to be the ocean."
msgstr "Non può che essere il mare."

msgctxt "6||speech_list_caba_erina||table||588||||4"
msgid "I love the ocean! Yakisoba, fried squid,\r\nand shaved ice! I love them all!"
msgstr "Adoro il mare! Yakisoba, calamari fritti\r\ne granita! Mi piacciono un sacco!"

msgctxt "6||speech_list_caba_erina||table||589||||4"
msgid "Um... Is eating all you think about?"
msgstr "Ehm... Pensi solo a mangiare?"

msgctxt "6||speech_list_caba_erina||table||590||||4"
msgid "Eating something at the beach makes it way more\r\ntasty! That's the joy of the outdoors for you."
msgstr "Mangiare qualcosa in spiaggia lo rende molto più\r\nbuono! Questa è la vera gioia della vita all'aperto."

msgctxt "6||speech_list_caba_erina||table||591||||4"
msgid "Maybe you've got a point."
msgstr "Forse hai ragione."

msgctxt "6||speech_list_caba_erina||table||592||||4"
msgid "It's got to be the mountains."
msgstr "Non possono che essere le montagne."

msgctxt "6||speech_list_caba_erina||table||593||||4"
msgid "Mountains! Nice! Angelica shoots, fiddleheads,\r\nand akebia! I love them all."
msgstr "Le montagne! Che bello! Germogli di angelica, felci\r\ne akebia! Mi piacciono un sacco."

msgctxt "6||speech_list_caba_erina||table||594||||4"
msgid "Those are all vegetables..."
msgstr "Sono tutti ortaggi..."

msgctxt "6||speech_list_caba_erina||table||595||||4"
msgid "Cooking with ingredients you gathered yourself\r\nis just one of the joys of the great outdoors."
msgstr "Cucinare con gli ingredienti che hai raccolto da solo\r\nè solo una delle gioie della vita all'aria aperta."

msgctxt "6||speech_list_caba_erina||table||596||||4"
msgid "Maybe you've got a point."
msgstr "Forse hai ragione."

msgctxt "6||speech_list_caba_erina||table||597||||4"
msgid "It's got to be a pond."
msgstr "Non può che essere un laghetto."

msgctxt "6||speech_list_caba_erina||table||598||||4"
msgid "Going outdoors to a pond?\r\nKind of plain, isn't it?"
msgstr "Stare all'aperto in un laghetto?\r\nUn po' noioso, non trovi?"

msgctxt "6||speech_list_caba_erina||table||599||||4"
msgid "That's not true. It's nice to get out on a boat,\r\nfeed the birds, and just relax."
msgstr "Non è vero. È bello uscire in barca,\r\ndare da mangiare agli uccelli e rilassarsi."

msgctxt "6||speech_list_caba_erina||table||600||||4"
msgid "I see... A boat could be nice. You wouldn't even\r\nhave to go out too far. I never thought about it."
msgstr "Capisco... Una barca potrebbe essere carina. Non dovresti nemmeno\r\nspingerti troppo al largo. Non ci avevo mai pensato."

msgctxt "6||speech_list_caba_erina||table||601||||4"
msgid "Relaxing is nice, but I prefer to get out\r\nthere and do something..."
msgstr "Rilassarsi è bello, ma preferisco uscire\r\ne fare qualcosa di più..."

msgctxt "6||speech_list_caba_erina||table||602||||4"
msgid "Although, it's not like I have anyone to take\r\nme out right now..."
msgstr "Anche se, al momento, non c'è nessuno che possa\r\nportarmi fuori..."

msgctxt "6||speech_list_caba_erina||table||603||||4"
msgid "Nope! I was in other clubs, though. <symbol=note_with_outline>"
msgstr "Nope! Però partecipavo ad altri club scolastici. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||604||||4"
msgid "I like movies a lot, so I was in the film club.\r\nThat really takes me back. <symbol=note_with_outline>"
msgstr "Mi piacciono molto i film, quindi ero nel club di cinema.\r\nChe ricordi. <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||605||||4"
msgid "Huh? Your Kazumundies? But I bet\r\nthey're all big and hard to wash."
msgstr "Eh? I tuoi Kazumutandoni? Ma scommetto\r\nche sono enormi e difficili da lavare."

msgctxt "6||speech_list_caba_erina||table||606||||4"
msgid "I'd prefer it if you didn't\r\ngive my underwear strange nicknames."
msgstr "Preferirei che tu non affibbiassi\r\nstrani nomignoli alla mia biancheria."

msgctxt "6||speech_list_caba_erina||table||607||||4"
msgid "Only if you help me, Kiryu-san."
msgstr "Solo se mi dai una mano, Kiryu-san."

msgctxt "6||speech_list_caba_erina||table||608||||4"
msgid "You can boil the water, make the soup stock,\r\nput in the miso, and cut the tofu."
msgstr "Tu puoi bollire l'acqua, preparare il brodo,\r\naggiungere il miso e tagliare il tofu."

msgctxt "6||speech_list_caba_erina||table||609||||4"
msgid "What are you going to do, then?"
msgstr "E tu cosa farai, scusa?"

msgctxt "6||speech_list_caba_erina||table||610||||4"
msgid "I'll pour it!"
msgstr "Io la verso!"

msgctxt "6||speech_list_caba_erina||table||611||||4"
msgid "Hey... Then it's just me making the soup."
msgstr "Ehi... Allora sono praticamente io a fare la zuppa."

msgctxt "6||speech_list_caba_erina||table||612||||4"
msgid "<symbol=heart_with_outline> Did you catch me?"
msgstr "<symbol=heart_with_outline> Mi hai beccata?"

msgctxt "6||speech_list_caba_erina||table||613||||4"
msgid "Whoa! You sounded like an old man all of a sudden!"
msgstr "Whoa! Sembravi un vecchietto, tutto all'improvviso!"

msgctxt "6||speech_list_caba_erina||table||614||||4"
msgid "I sing a lot of oldies, like stuff from the '70s.\r\nHard to sing them with a crowd my own age, though."
msgstr "Canto un sacco di vecchi successi, tipo roba degli anni '70.\r\nÈ difficile cantarli con gente della mia età, però."

msgctxt "6||speech_list_caba_erina||table||615||||4"
msgid "Huh. How about going with me, then?"
msgstr "Ah. Che ne dici di andarci con me, allora?"

msgctxt "6||speech_list_caba_erina||table||616||||4"
msgid "Really? It does seem like you'd be in a better\r\nage range for that. I'm excited now! <symbol=note_with_outline>"
msgstr "Davvero? In effetti sembra che tu abbia l'età\r\ngiusta per queste cose. Ora non vedo l'ora! <symbol=note_with_outline>"

msgctxt "6||speech_list_caba_erina||table||617||||4"
msgid "Dangerous men? I think I prefer people who\r\nare more peaceful..."
msgstr "Uomini pericolosi? Credo di preferire persone\r\nun po' più tranquille..."

msgctxt "6||speech_list_caba_erina||table||618||||4"
msgid "Wow, you hang around someone that crazy?\r\nHe sounds like a character out of a movie!"
msgstr "Wow, frequenti qualcuno di così pazzo?\r\nSembra il personaggio di un film!"

msgctxt "6||speech_list_caba_erina||table||619||||4"
msgid "I'd like to meet him...\r\nYou should bring him by sometime."
msgstr "Mi piacerebbe conoscerlo...\r\nDovresti portarlo qui, qualche volta."

msgctxt "6||speech_list_caba_erina||table||620||||4"
msgid "You don't really want me to do that..."
msgstr "Non vuoi davvero che io lo faccia..."

msgctxt "6||speech_list_caba_erina||table||621||||4"
msgid "Wow, he gave you your first cell phone?\r\nWhat a sweet guy."
msgstr "Wow, ti ha regalato lui il tuo primo cellulare?\r\nChe tipo dolce."

msgctxt "6||speech_list_caba_erina||table||622||||4"
msgid "Wow. This Akiyama-san ran a cabaret club, too?"
msgstr "Wow. Questo Akiyama-san gestiva un cabaret club?"

msgctxt "6||speech_list_caba_erina||table||623||||4"
msgid "You know all kinds of different people. If I ever\r\nmeet him, I'll have a ton of questions to ask."
msgstr "Conosci davvero tutti i tipi di persone. Se mai lo\r\nincontrassi, avrei un sacco di domande da fargli."

msgctxt "6||speech_list_caba_erina||table||624||||4"
msgid "Wow! He took down a bear!? We'll have to give\r\nhim a call if we ever get a bear in the club."
msgstr "Wow! Ha abbattuto un orso!? Dovremo chiamarlo\r\nse mai entrasse un orso nel club."

msgctxt "6||speech_list_caba_erina||table||625||||4"
msgid "...I wouldn't worry about any bears waltzing in."
msgstr "...Non mi preoccuperei troppo degli orsi."

msgctxt "6||speech_list_caba_erina||table||626||||4"
msgid "Wow, you know someone like that?"
msgstr "Wow, conosci un tipo del genere?"

msgctxt "6||speech_list_caba_erina||table||627||||4"
msgid "Yeah. I've known him since he was a kid."
msgstr "Sì. Lo conosco da quando era un ragazzino."

msgctxt "6||speech_list_caba_erina||table||628||||4"
msgid "We've been through a lot, but if we ever meet on\r\neven ground, I'm sure the drinks would be great."
msgstr "Ne abbiamo passate tante, ma se mai ci incontrassimo alla\r\npari, sono sicuro che finiremmo per farci una bella bevuta."

msgctxt "6||speech_list_caba_erina||table||629||||4"
msgid "Male friendship is so wonderful...! When that day\r\ncomes, I'll get you a bottle of something nice."
msgstr "L'amicizia maschile è così meravigliosa...! Quando arriverà\r\nquel giorno, vi prenderò una buona bottiglia."

msgctxt "6||speech_list_caba_erina||table||630||||4"
msgid "I want to see Onomichi sometime.\r\nOnomichi ramen... The fish are tasty, too."
msgstr "Mi piacerebbe visitare Onomichi, un giorno.\r\nIl ramen di Onomichi... Anche il pesce è molto buono."

msgctxt "6||speech_list_caba_erina||table||631||||4"
msgid "Food really is all you think about, huh?"
msgstr "Pensi solo al cibo, eh?"

msgctxt "7||speech_list_caba_hikaru||table||0||||4"
msgid "Kiryu-san! Sorry to keep you waiting. <symbol=note_with_outline>"
msgstr "Kiryu-san! Scusa per l'attesa. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||1||||4"
msgid "Sorry! Did I make you wait?"
msgstr "Scusa! Ti ho fatto aspettare?"

msgctxt "7||speech_list_caba_hikaru||table||2||||4"
msgid "Kiryu-san! I'm excited to see you again. <symbol=note_with_outline>"
msgstr "Kiryu-san! Sono felice di rivederti. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||3||||4"
msgid "So, where should we go?"
msgstr "Allora, dove andiamo?"

msgctxt "7||speech_list_caba_hikaru||table||4||||4"
msgid "Karaoke, huh? Sounds good! <symbol=note_with_outline>"
msgstr "Karaoke, eh? Sembra fantastico! <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||5||||4"
msgid "I don't normally play darts, but I'm excited!"
msgstr "Di solito non gioco a freccette, ma sono entusiasta!"

msgctxt "7||speech_list_caba_hikaru||table||6||||4"
msgid "Okay, let's go! <symbol=note_with_outline>"
msgstr "Ok, andiamo! <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||7||||4"
msgid "I wonder what you'll sing... <symbol=heart_with_outline>"
msgstr "Chissà cosa canterai... <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||8||||4"
msgid "What should I sing today? <symbol=note_with_outline>"
msgstr "Cosa dovrei cantare oggi? <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||9||||4"
msgid "I'm not so good, so go easy on me! <symbol=heart_with_outline>"
msgstr "Non sono molto brava, quindi vacci piano! <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||10||||4"
msgid "Okay, here I go!"
msgstr "Okay, vado!"

msgctxt "7||speech_list_caba_hikaru||table||11||||4"
msgid "Let's just focus on enjoying the rest, okay? <symbol=note_with_outline>"
msgstr "Cerchiamo solo di goderci il resto, d'accordo? <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||12||||4"
msgid "That was fun! We should come back soon. <symbol=note_with_outline>"
msgstr "È stato divertente! Dovremmo tornarci presto. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||13||||4"
msgid "That was so fun! <symbol=heart_with_outline>\nWe should definitely do this again sometime. <symbol=note_with_outline>"
msgstr "È stato divertentissimo! <symbol=heart_with_outline>\nDobbiamo assolutamente rifarlo qualche volta. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||14||||4"
msgid "Shall we head back to the club?"
msgstr "Torniamo al club?"

msgctxt "7||speech_list_caba_hikaru||table||15||||4"
msgid "This one's my specialty. <symbol=note_with_outline>"
msgstr "Questa è la mia specialità. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||16||||4"
msgid "Oh, maybe I'll sing this one. <symbol=note_with_outline>"
msgstr "Oh, forse canterò questa. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||17||||4"
msgid "Hmm... I guess that song was too hard."
msgstr "Mhm... Mi sa che quella canzone era troppo difficile."

msgctxt "7||speech_list_caba_hikaru||table||18||||4"
msgid "It was kinda hard to sing..."
msgstr "È stato un po' difficile cantarla..."

msgctxt "7||speech_list_caba_hikaru||table||19||||4"
msgid "It was really fun to sing with you. <symbol=note_with_outline>"
msgstr "È stato davvero divertente cantare con te. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||20||||4"
msgid "That song felt really good!\nYou're great at keeping the mood up! <symbol=note_with_outline>"
msgstr "È stata una bella cantata!\nSei fantastico a mantenere viva l'atmosfera! <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||21||||4"
msgid "I want to hear you sing something, too. <symbol=note_with_outline>"
msgstr "Anch'io voglio sentirti cantare qualcosa. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||22||||4"
msgid "Aww... There's no need to be shy..."
msgstr "Aww... Non c'è bisogno di fare il timido..."

msgctxt "7||speech_list_caba_hikaru||table||23||||4"
msgid "Oh... Uh... That was good...!"
msgstr "Oh... Uhm... Sei stato bravo...!"

msgctxt "7||speech_list_caba_hikaru||table||24||||4"
msgid "You're so good, Kiryu-san. <symbol=note_with_outline>"
msgstr "Sei così bravo, Kiryu-san. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||25||||4"
msgid "You sing incredibly well. <symbol=note_with_outline> I could listen\nto you sing like that for hours on end. <symbol=heart_with_outline>"
msgstr "Canti incredibilmente bene. <symbol=note_with_outline> Potrei ascoltarti\ncantare così per ore e ore. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||26||||4"
msgid "Whoa! You've got deep pockets!"
msgstr "Whoa! Non badi a spese!"

msgctxt "7||speech_list_caba_hikaru||table||27||||4"
msgid "Thank you very much!"
msgstr "Grazie infinite!"

msgctxt "7||speech_list_caba_hikaru||table||28||||4"
msgid "Huh...?"
msgstr "Eh...?"

msgctxt "7||speech_list_caba_hikaru||table||29||||4"
msgid "Oh, I like that one, too. <symbol=note_with_outline>"
msgstr "Oh, piace molto anche a me. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||30||||4"
msgid "Thank you for waiting."
msgstr "Grazie per l'attesa."

msgctxt "7||speech_list_caba_hikaru||table||31||||4"
msgid "It's a pleasure to meet you. I'm Hikaru."
msgstr "Piacere di conoscerti. Sono Hikaru."

msgctxt "7||speech_list_caba_hikaru||table||32||||4"
msgid "Um, and your name is?"
msgstr "Ehm, e il tuo nome è?"

msgctxt "7||speech_list_caba_hikaru||table||33||||4"
msgid "Oh. I'm Kiryu."
msgstr "Oh. Sono Kiryu."

msgctxt "7||speech_list_caba_hikaru||table||34||||4"
msgid "Kiryu-san? Well then, I look forward to spending some\ntime with you, Kiryu-san!"
msgstr "Kiryu-san? Bene, allora non vedo l'ora di passare\nun po' di tempo con te, Kiryu-san!"

msgctxt "7||speech_list_caba_hikaru||table||35||||4"
msgid "Yeah, same here."
msgstr "Sì, altrettanto."

msgctxt "7||speech_list_caba_hikaru||table||36||||4"
msgid "Thank you for coming in today, Kiryu-san.\nI enjoyed all the different topics! <symbol=note_with_outline>"
msgstr "Grazie per essere venuto oggi, Kiryu-san.\nMi è piaciuto parlare di tante cose diverse! <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||37||||4"
msgid "Come back soon, won't you? <symbol=heart_with_outline>"
msgstr "Torna presto, va bene? <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||38||||4"
msgid "Yeah, I'll be back."
msgstr "Sì, tornerò."

msgctxt "7||speech_list_caba_hikaru||table||39||||4"
msgid "And I'll be waiting. <symbol=heart_with_outline>"
msgstr "E io ti aspetterò. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||40||||4"
msgid "Thanks for visiting me again, Kiryu-san."
msgstr "Grazie per essere tornato a trovarmi, Kiryu-san."

msgctxt "7||speech_list_caba_hikaru||table||41||||4"
msgid "Kiryu-san, welcome back.\nI've been waiting for you. <symbol=heart_with_outline>"
msgstr "Kiryu-san, bentornato.\nTi stavo aspettando. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||42||||4"
msgid "Kiryu-san, welcome back.\nI was hoping you'd come back again... <symbol=heart_with_outline>"
msgstr "Kiryu-san, bentornato.\nSperavo tornassi a trovarmi... <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||43||||4"
msgid "I'd like to spend more time\nwith you today. <symbol=heart_with_outline>"
msgstr "Oggi mi piacerebbe passare più tempo\ncon te. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||44||||4"
msgid "Right this way."
msgstr "Da questa parte."

msgctxt "7||speech_list_caba_hikaru||table||45||||4"
msgid "Kiryu-san!"
msgstr "Kiryu-san!"

msgctxt "7||speech_list_caba_hikaru||table||46||||4"
msgid "Thank you for coming today. <symbol=note_with_outline>\nI'll be waiting for your next visit."
msgstr "Grazie per essere venuto oggi. <symbol=note_with_outline>\nAspetterò la tua prossima visita."

msgctxt "7||speech_list_caba_hikaru||table||47||||4"
msgid "Thank you for coming today. <symbol=note_with_outline>\nCome back soon. <symbol=heart_with_outline>"
msgstr "Grazie per essere venuto oggi. <symbol=note_with_outline>\nTorna presto. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||48||||4"
msgid "Thank you for coming today. <symbol=note_with_outline>\nI hope to see you again soon... <symbol=heart_with_outline>"
msgstr "Grazie per essere venuto oggi. <symbol=note_with_outline>\nSpero di rivederti presto... <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||49||||4"
msgid "Let's have some fun today. <symbol=heart_with_outline>"
msgstr "Divertiamoci un po' oggi. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||50||||4"
msgid "Cheers! <symbol=note_with_outline>"
msgstr "Salute! <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||51||||4"
msgid "Um, Kiryu-san!"
msgstr "Ehm, Kiryu-san!"

msgctxt "7||speech_list_caba_hikaru||table||52||||4"
msgid "Here, you can have my phone number.\nCall me anytime you want, okay? <symbol=heart_with_outline>"
msgstr "Tieni, ti do il mio numero di telefono.\nChiamami quando vuoi, okay? <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||53||||4"
msgid "It looks like our time's up."
msgstr "Sembra che il nostro tempo sia scaduto."

msgctxt "7||speech_list_caba_hikaru||table||54||||4"
msgid "We're out of time,\nbut I'd love to talk more..."
msgstr "Abbiamo finito il tempo a disposizione,\nma mi piacerebbe continuare a parlare..."

msgctxt "7||speech_list_caba_hikaru||table||55||||4"
msgid "I'm so happy! <symbol=note_with_outline>\nYou're the best, Kiryu-san. <symbol=heart_with_outline>"
msgstr "Sono così felice! <symbol=note_with_outline>\nSei il migliore, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||56||||4"
msgid "Thank you so much for today! <symbol=note_with_outline>"
msgstr "Grazie infinite per la giornata di oggi! <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||57||||4"
msgid "Okay, got it! <symbol=note_with_outline>"
msgstr "Okay, ho capito! <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||58||||4"
msgid "Hmm, okay..."
msgstr "Mhm, okay..."

msgctxt "7||speech_list_caba_hikaru||table||59||||4"
msgid "Yeah!"
msgstr "Sì!"

msgctxt "7||speech_list_caba_hikaru||table||60||||4"
msgid "If you don't mind... <symbol=heart_with_outline>"
msgstr "Se non ti dispiace... <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||61||||4"
msgid "No way."
msgstr "Non se ne parla."

msgctxt "7||speech_list_caba_hikaru||table||62||||4"
msgid "That's not right at all!"
msgstr "Non è affatto vero!"

msgctxt "7||speech_list_caba_hikaru||table||63||||4"
msgid "What? You think so?"
msgstr "Cosa? Lo pensi davvero?"

msgctxt "7||speech_list_caba_hikaru||table||64||||4"
msgid "I'll pass. <symbol=note_with_outline>"
msgstr "Passo. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||65||||4"
msgid "Wow, really?"
msgstr "Wow, sul serio?"

msgctxt "7||speech_list_caba_hikaru||table||66||||4"
msgid "See you later!"
msgstr "A dopo!"

msgctxt "7||speech_list_caba_hikaru||table||67||||4"
msgid "Oh, Kiryu-san. <symbol=heart_with_outline>"
msgstr "Oh, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||68||||4"
msgid "That's top secret. <symbol=note_with_outline>"
msgstr "Questo è un segreto. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||69||||4"
msgid "Um... Did you have fun talking\nwith me today, Kiryu-san?"
msgstr "Ehm... Ti sei divertito a parlare\ncon me oggi, Kiryu-san?"

msgctxt "7||speech_list_caba_hikaru||table||70||||4"
msgid "What? Where's this coming from?"
msgstr "Come mai questa domanda?"

msgctxt "7||speech_list_caba_hikaru||table||71||||4"
msgid "My customers are always telling me\nI'm too quiet, or that I have no energy."
msgstr "I miei clienti mi dicono sempre che sono\ntroppo silenziosa, o che non ho energia."

msgctxt "7||speech_list_caba_hikaru||table||72||||4"
msgid "Oh. Well, you do seem pretty calm."
msgstr "Oh. Beh, in effetti sembri una tipa tranquilla."

msgctxt "7||speech_list_caba_hikaru||table||73||||4"
msgid "Lately, I've been wondering if a hostess\nneeds to be more upbeat and energetic."
msgstr "Ultimamente, mi chiedo se una hostess non debba\nessere più allegra ed energica."

msgctxt "7||speech_list_caba_hikaru||table||74||||4"
msgid "I mean, the girls like that get more customers,\nand they bring in more profit for the club."
msgstr "Insomma, le ragazze così attirano più clienti,\ne portano più profitti al club."

msgctxt "7||speech_list_caba_hikaru||table||75||||4"
msgid "That's what you're worried about?"
msgstr "È di questo che ti preoccupi?"

msgctxt "7||speech_list_caba_hikaru||table||76||||4"
msgid "Then, why don't we practice being energetic?"
msgstr "Allora, perché non ti alleni a essere più energica?"

msgctxt "7||speech_list_caba_hikaru||table||77||||4"
msgid "Huh? Practice?"
msgstr "Eh? Pratica?"

msgctxt "7||speech_list_caba_hikaru||table||78||||4"
msgid "Yeah, if you want to become your ideal self,\nyou have to put in the effort first."
msgstr "Sì, se vuoi diventare la versione ideale di te stessa,\ndevi prima metterci dell'impegno."

msgctxt "7||speech_list_caba_hikaru||table||79||||4"
msgid "You've gotta face the challenge head on, with\nthe knowledge that you can become better."
msgstr "Devi affrontare la sfida a testa alta, con la\nconsapevolezza che puoi migliorare."

msgctxt "7||speech_list_caba_hikaru||table||80||||4"
msgid "I see... I think you're right.\nYou mind if we give it a shot?"
msgstr "Capisco... Credo che tu abbia ragione.\nTi dispiace se facciamo un tentativo?"

msgctxt "7||speech_list_caba_hikaru||table||81||||4"
msgid "No prob."
msgstr "Nessun problema."

msgctxt "7||speech_list_caba_hikaru||table||82||||4"
msgid "Yaaaaay!"
msgstr "Evvivaaa!"

msgctxt "7||speech_list_caba_hikaru||table||83||||4"
msgid "Hmmm..."
msgstr "Mhm..."

msgctxt "7||speech_list_caba_hikaru||table||84||||4"
msgid "Yahoo!"
msgstr "Yahoo!"

msgctxt "7||speech_list_caba_hikaru||table||85||||4"
msgid "Nice..."
msgstr "Bene..."

msgctxt "7||speech_list_caba_hikaru||table||86||||4"
msgid "Kiryu-san... I just can't do it... Wait,\ndid you trick me into this to tease me?"
msgstr "Kiryu-san... Proprio non ce la faccio... Aspetta,\nmi hai spinta a farlo per prendermi in giro?"

msgctxt "7||speech_list_caba_hikaru||table||87||||4"
msgid "You got me..."
msgstr "Mi hai beccato..."

msgctxt "7||speech_list_caba_hikaru||table||88||||4"
msgid "Oh come on, Kiryu-san!\nAt least try to help me out!"
msgstr "Oh, andiamo, Kiryu-san!\nCerca almeno di aiutarmi!"

msgctxt "7||speech_list_caba_hikaru||table||89||||4"
msgid "Sorry, sorry. But it got you to be a\nlittle more energetic, right?"
msgstr "Scusa, scusa. Ma ti ha fatto diventare\nun po' più energica, non è vero?"

msgctxt "7||speech_list_caba_hikaru||table||90||||4"
msgid "You're right... Shoot.\nYou're better than I thought."
msgstr "Hai ragione... Accipicchia.\nSei più in gamba di quanto pensassi."

msgctxt "7||speech_list_caba_hikaru||table||91||||4"
msgid "Well, you're fun to be with just as you\nare. I don't think you need to force it."
msgstr "Beh, è piacevole stare con te per quella che\nsei. Non penso che tu debba forzarti."

msgctxt "7||speech_list_caba_hikaru||table||92||||4"
msgid "Thank you. You're right.\nI'll try to work on it in my own way."
msgstr "Grazie. Hai ragione.\nCercherò di lavorarci su a modo mio."

msgctxt "7||speech_list_caba_hikaru||table||93||||4"
msgid "Hikaru, I think you're fine as you are."
msgstr "Hikaru, penso che tu vada bene così come sei."

msgctxt "7||speech_list_caba_hikaru||table||94||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "7||speech_list_caba_hikaru||table||95||||4"
msgid "Not everyone comes to a cabaret club\nexpecting a wild party with energetic girls."
msgstr "Non tutti quelli che vengono in un cabaret club si\naspettano una festa sfrenata con ragazze esuberanti."

msgctxt "7||speech_list_caba_hikaru||table||96||||4"
msgid "Some guys just want to have a drink with a\ngirl like you in a place they can relax."
msgstr "Alcuni uomini vogliono solo bere qualcosa con una\nragazza come te in un posto in cui potersi rilassare."

msgctxt "7||speech_list_caba_hikaru||table||97||||4"
msgid "Kind of like... me."
msgstr "Un po' come... me."

msgctxt "7||speech_list_caba_hikaru||table||98||||4"
msgid "Kiryu-san..."
msgstr "Kiryu-san..."

msgctxt "7||speech_list_caba_hikaru||table||99||||4"
msgid "So, stay just the way you are."
msgstr "Quindi, resta esattamente come sei."

msgctxt "7||speech_list_caba_hikaru||table||100||||4"
msgid "There's nothing so wrong with you that you'd\nneed to hide who you really are, you know?"
msgstr "Non c'è niente di così sbagliato in te da dover\nnascondere chi sei veramente, lo sai, vero?"

msgctxt "7||speech_list_caba_hikaru||table||101||||4"
msgid "Kiryu-san... <symbol=heart_with_outline> Thank you so much.\nI'm feeling really optimistic all of a sudden."
msgstr "Kiryu-san... <symbol=heart_with_outline> Grazie mille.\nMi sento davvero ottimista all'improvviso."

msgctxt "7||speech_list_caba_hikaru||table||102||||4"
msgid "I'll work hard in my own, relaxed way. I hope\nyou'll keep coming to take it easy with me. <symbol=heart_with_outline>"
msgstr "Lavorerò sodo alla mia maniera, in modo rilassato. Spero che\ncontinuerai a venire a rilassarti in mia compagnia. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||103||||4"
msgid "Yeah, of course."
msgstr "Certo, senza dubbio."

msgctxt "7||speech_list_caba_hikaru||table||104||||4"
msgid "If you're worried about something as silly as that,\nhow about I spend all my money to make you number one?"
msgstr "Se ti preoccupi per una sciocchezza simile, che ne\ndici se spendessi tutti i miei soldi per farti diventare la numero uno?"

msgctxt "7||speech_list_caba_hikaru||table||105||||4"
msgid "Huh!? Oh no, I could never. Please don't\nwaste your money on something like that."
msgstr "Eh!? Oh no, non potrei mai. Per favore, non\nsprecare i tuoi soldi per una cosa del genere."

msgctxt "7||speech_list_caba_hikaru||table||106||||4"
msgid "But... then you'd be number one, yeah?"
msgstr "Ma... così diventeresti la numero uno, no?"

msgctxt "7||speech_list_caba_hikaru||table||107||||4"
msgid "But... that doesn't feel right.\nI want to aim for the top in my own way."
msgstr "Sì, ma... non mi sembrerebbe giusto.\nVoglio puntare alla vetta con le mie forze."

msgctxt "7||speech_list_caba_hikaru||table||108||||4"
msgid "I thought you might say that.\nLooks like you already have your answer."
msgstr "Immaginavo che avresti detto così.\nSembra che tu abbia già la tua risposta."

msgctxt "7||speech_list_caba_hikaru||table||109||||4"
msgid "Oh..."
msgstr "Oh..."

msgctxt "7||speech_list_caba_hikaru||table||110||||4"
msgid "I think you've gotta be yourself, Hikaru.\nI like that, and that's why I requested you."
msgstr "Credo che tu debba essere te stessa, Hikaru.\nMi piace il tuo modo di fare, per questo ti ho richiesta."

msgctxt "7||speech_list_caba_hikaru||table||111||||4"
msgid "Kiryu-san... Thank you. You're right.\nI shouldn't push myself too hard."
msgstr "Kiryu-san... Grazie. Hai ragione.\nNon dovrei sforzarmi troppo."

msgctxt "7||speech_list_caba_hikaru||table||112||||4"
msgid "I'll work hard in my own, relaxed way! I hope\nyou'll come back and help me see it through."
msgstr "Mi impegnerò a modo mio, rilassata! Spero che\ntornerai per aiutarmi a portare a termine il mio obiettivo."

msgctxt "7||speech_list_caba_hikaru||table||113||||4"
msgid "Yeah. Give it your best shot."
msgstr "Sì. Metticela tutta."

msgctxt "7||speech_list_caba_hikaru||table||114||||4"
msgid "Just curious, but, why'd you\ndecide to become a hostess?"
msgstr "Per curiosità, come mai hai\ndeciso di diventare una hostess?"

msgctxt "7||speech_list_caba_hikaru||table||115||||4"
msgid "I'm a student, so... I need to pay my tuition.\nI'm paying my own way through school."
msgstr "Sono una studentessa, quindi... devo pagarmi le tasse.\nMi pago gli studi da sola."

msgctxt "7||speech_list_caba_hikaru||table||116||||4"
msgid "That's admirable."
msgstr "È ammirevole."

msgctxt "7||speech_list_caba_hikaru||table||117||||4"
msgid "Oh, not at all. I'm about to graduate,\nso I really oughta be looking for a real job..."
msgstr "Oh, per niente. Sto per laurearmi,\nquindi dovrei davvero cercarmi un lavoro vero..."

msgctxt "7||speech_list_caba_hikaru||table||118||||4"
msgid "So, have you been?"
msgstr "Quindi, lo stai cercando?"

msgctxt "7||speech_list_caba_hikaru||table||119||||4"
msgid "No, actually... I have a dream...\nI want to become an idol."
msgstr "No, in realtà... ho un sogno...\nVoglio diventare un'idol."

msgctxt "7||speech_list_caba_hikaru||table||120||||4"
msgid "An idol?"
msgstr "Un'idol?"

msgctxt "7||speech_list_caba_hikaru||table||121||||4"
msgid "Yeah... I've been looking into it a little\nhere and there, but it's not going anywhere..."
msgstr "Sì... Mi sono guardata un po' intorno, ma\nnon sto andando da nessuna parte..."

msgctxt "7||speech_list_caba_hikaru||table||122||||4"
msgid "I'm already 23... I should probably give\nup on that and look for a real job, right?"
msgstr "Ho già 23 anni... Probabilmente dovrei lasciar\nperdere e cercare un lavoro vero, non credi?"

msgctxt "7||speech_list_caba_hikaru||table||123||||4"
msgid "I'm behind you all the way.\nYou shouldn't give up on your dreams."
msgstr "Sono dalla tua parte, qualsiasi cosa succeda.\nNon dovresti rinunciare ai tuoi sogni."

msgctxt "7||speech_list_caba_hikaru||table||124||||4"
msgid "Really?"
msgstr "Davvero?"

msgctxt "7||speech_list_caba_hikaru||table||125||||4"
msgid "Yeah. You only live once, so you've\ngotta make your time count."
msgstr "Sì. Si vive una volta sola, quindi devi\nfar fruttare al meglio il tuo tempo."

msgctxt "7||speech_list_caba_hikaru||table||126||||4"
msgid "But, if you don't fully commit to it, you may\nactually regret not giving up when you could have."
msgstr "Però, se non ti ci dedichi anima e corpo, potresti anche\nfinire a rimpiangere di non aver mollato quando potevi."

msgctxt "7||speech_list_caba_hikaru||table||127||||4"
msgid "So... decide whether or not you're serious about\nthis, and make the call. If you are, I'm behind you."
msgstr "Perciò... decidi se fai sul serio con questa cosa\ne fai la tua scelta. Se fai sul serio, io sono con te."

msgctxt "7||speech_list_caba_hikaru||table||128||||4"
msgid "Kiryu-san... Thank you."
msgstr "Kiryu-san... Grazie."

msgctxt "7||speech_list_caba_hikaru||table||129||||4"
msgid "Your words hit me really hard... Maybe I was\nnaive for even worrying over it."
msgstr "Le tue parole mi hanno colpita nel profondo... Forse sono\nstata ingenua anche solo a preoccuparmene."

msgctxt "7||speech_list_caba_hikaru||table||130||||4"
msgid "I'll have to dig deep and give it some real thought.\nIf I do decide to go for it... I hope you'll root for me!"
msgstr "Dovrò guardarmi dentro e pensarci seriamente.\nSe dovessi decidere di provarci... Spero che farai il tifo per me!"

msgctxt "7||speech_list_caba_hikaru||table||131||||4"
msgid "Of course. I'll be your first fan."
msgstr "Certo. Sarò il tuo primo fan."

msgctxt "7||speech_list_caba_hikaru||table||132||||4"
msgid "Yaaay! <symbol=heart_with_outline> I'll work hard at it!"
msgstr "Evviva! <symbol=heart_with_outline> Lavorerò sodo!"

msgctxt "7||speech_list_caba_hikaru||table||133||||4"
msgid "Shouldn't you at least be looking?"
msgstr "Non dovresti almeno cominciare a cercarlo?"

msgctxt "7||speech_list_caba_hikaru||table||134||||4"
msgid "So you think so too, huh?"
msgstr "Quindi lo pensi anche tu, eh?"

msgctxt "7||speech_list_caba_hikaru||table||135||||4"
msgid "Yeah. But I only feel that way because\nI can tell you're being indecisive."
msgstr "Sì. Ma mi sento così solo perché\nvedo che sei indecisa."

msgctxt "7||speech_list_caba_hikaru||table||136||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "7||speech_list_caba_hikaru||table||137||||4"
msgid "If you really want to make a dream come true,\nyou have to be determined to see it happen."
msgstr "Se vuoi davvero che un sogno diventi realtà,\ndevi essere determinata a vederlo realizzarsi."

msgctxt "7||speech_list_caba_hikaru||table||138||||4"
msgid "If you're hesitating now, then you may as well\ngive it up. Being an idol is no walk in the park."
msgstr "Se esiti adesso, tanto vale lasciar\nperdere. Fare l'idol non è una passeggiata."

msgctxt "7||speech_list_caba_hikaru||table||139||||4"
msgid "Kiryu-san..."
msgstr "Kiryu-san..."

msgctxt "7||speech_list_caba_hikaru||table||140||||4"
msgid "But, if one day you can say from the bottom of\nyour heart that you want to be an idol, I'm behind you."
msgstr "Ma, se un giorno potrai dire dal profondo del tuo\ncuore di voler diventare un'idol, io sarò dalla tua parte."

msgctxt "7||speech_list_caba_hikaru||table||141||||4"
msgid "Everyone looks up to idols, and idols have to\nshoulder those dreams. It's no walk in the park."
msgstr "Tutti ammirano le idol, e le idol devono farsi\ncarico di quei sogni. Non è una passeggiata."

msgctxt "7||speech_list_caba_hikaru||table||142||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "7||speech_list_caba_hikaru||table||143||||4"
msgid "I actually know a former idol, and society and the\nmedia can be both a blessing and a curse."
msgstr "In realtà conosco un'ex idol, e la società e i\nmedia possono essere sia una benedizione che una maledizione."

msgctxt "7||speech_list_caba_hikaru||table||144||||4"
msgid "If you mess up, everything can come crashing down\nin an instant. It's that strict, and you have to be strong."
msgstr "Se fai un passo falso, tutto può crollare in\nun istante. È un mondo severo, e devi essere forte."

msgctxt "7||speech_list_caba_hikaru||table||145||||4"
msgid "So, I can't just casually say, yeah, go for it,\nyou have my support."
msgstr "Perciò, non posso semplicemente dirti: 'Sì, vai, provaci,\nhai il mio appoggio'."

msgctxt "7||speech_list_caba_hikaru||table||146||||4"
msgid "......"
msgstr "......"

msgctxt "7||speech_list_caba_hikaru||table||147||||4"
msgid "But, it's also the kind of job where your hard work and\ndetermination pay off by giving people courage and smiles."
msgstr "Ma è anche quel tipo di lavoro in cui il duro lavoro e la\ndeterminazione ripagano regalando sorrisi e coraggio alla gente."

msgctxt "7||speech_list_caba_hikaru||table||148||||4"
msgid "If you're ready to bear that burden...\nThen I'm behind you all the way."
msgstr "Se sei pronta a farti carico di questo peso...\nAllora io sarò con te, fino in fondo."

msgctxt "7||speech_list_caba_hikaru||table||149||||4"
msgid "Kiryu-san... Thank you."
msgstr "Kiryu-san... Grazie."

msgctxt "7||speech_list_caba_hikaru||table||150||||4"
msgid "You're actually the first person who's taken it\nthat seriously and been honest about it. I'm so happy."
msgstr "Sei davvero la prima persona che l'ha presa così\nseriamente e che è stata onesta. Sono molto felice."

msgctxt "7||speech_list_caba_hikaru||table||151||||4"
msgid "I... may have been a little naive. You can't aim\nfor something this hard half-heartedly."
msgstr "Io... forse sono stata un po' ingenua. Non si può puntare\na qualcosa di così difficile senza metterci il cuore."

msgctxt "7||speech_list_caba_hikaru||table||152||||4"
msgid "I think I need to take a long, hard look in the mirror."
msgstr "Credo di dovermi guardare a lungo, e attentamente, allo specchio."

msgctxt "7||speech_list_caba_hikaru||table||153||||4"
msgid "Yeah."
msgstr "Sì."

msgctxt "7||speech_list_caba_hikaru||table||154||||4"
msgid "And I hope that one day I'll be able to tell you\nthat I want to become an idol with pride."
msgstr "E spero che un giorno sarò in grado di dirti\ncon orgoglio che voglio diventare un'idol."

msgctxt "7||speech_list_caba_hikaru||table||155||||4"
msgid "When you do, I'll be your first fan."
msgstr "Quando lo farai, sarò il tuo primo fan."

msgctxt "7||speech_list_caba_hikaru||table||156||||4"
msgid "Okay! <symbol=heart_with_outline> I'll work so hard, you won't be able\nto take your eyes off me!"
msgstr "Va bene! <symbol=heart_with_outline> Lavorerò così sodo che non riuscirai\na togliermi gli occhi di dosso!"

msgctxt "7||speech_list_caba_hikaru||table||157||||4"
msgid "So? Did you end up figuring out if you want\nto look for a job or get into the idol thing?"
msgstr "Allora? Hai poi deciso se vuoi cercarti\nun lavoro o lanciarti nella faccenda dell'idol?"

msgctxt "7||speech_list_caba_hikaru||table||158||||4"
msgid "Yes. I was actually thinking about\nhow I'd tell you that today."
msgstr "Sì. In realtà stavo proprio pensando a\ncome dirtelo, oggi."

msgctxt "7||speech_list_caba_hikaru||table||159||||4"
msgid "I, Hikaru Shiota, hereby declare that\nI'm going to try to become a top idol!"
msgstr "Io, Hikaru Shiota, dichiaro solennemente che\ncercherò di diventare una top idol!"

msgctxt "7||speech_list_caba_hikaru||table||160||||4"
msgid "I thought you might."
msgstr "Me lo immaginavo."

msgctxt "7||speech_list_caba_hikaru||table||161||||4"
msgid "Yeah! And if I don't seem serious,\nI'm telling you, I'm quite serious!"
msgstr "Sì! E se non ti sembro seria,\nti assicuro che sono serissima!"

msgctxt "7||speech_list_caba_hikaru||table||162||||4"
msgid "And it's all thanks to your encouragement,\nKiryu-san. Thank you!"
msgstr "Ed è tutto grazie al tuo incoraggiamento,\nKiryu-san. Grazie!"

msgctxt "7||speech_list_caba_hikaru||table||163||||4"
msgid "Hey, I just say whatever pops into my head.\nGood luck with it."
msgstr "Ehi, io dico solo la prima cosa che mi passa per la testa.\nBuona fortuna."

msgctxt "7||speech_list_caba_hikaru||table||164||||4"
msgid "Thanks! Though I still need to consider which\nof my traits I want to emphasize."
msgstr "Grazie! Anche se devo ancora capire quali\ndei miei lati voglio mettere in risalto."

msgctxt "7||speech_list_caba_hikaru||table||165||||4"
msgid "Traits?"
msgstr "Lati?"

msgctxt "7||speech_list_caba_hikaru||table||166||||4"
msgid "Yeah. Sorta like a catchphrase. If you don't set\nyourself apart, you'll get lost in the crowd."
msgstr "Sì. Una specie di tormentone. Se non ti\ndistingui, finirai per perderti tra la folla."

msgctxt "7||speech_list_caba_hikaru||table||167||||4"
msgid "It's a competitive society we live in..."
msgstr "Viviamo in una società competitiva..."

msgctxt "7||speech_list_caba_hikaru||table||168||||4"
msgid "Yeah... So, Kiryu-san, do you have any\nsuggestions for a catchphrase that would fit me?"
msgstr "Già... Senti, Kiryu-san, avresti qualche\nsuggerimento per una frase che mi si addica?"

msgctxt "7||speech_list_caba_hikaru||table||169||||4"
msgid "A catchphrase, huh... Let's see..."
msgstr "Una frase a effetto, eh... Vediamo..."

msgctxt "7||speech_list_caba_hikaru||table||170||||4"
msgid "How about, \"Check out my fine butt!\""
msgstr "Che ne dici di: \"Ammirate il mio bel sedere!\""

msgctxt "7||speech_list_caba_hikaru||table||171||||4"
msgid "Kiryu-san... You really get how this works!"
msgstr "Kiryu-san... Hai proprio capito come funziona!"

msgctxt "7||speech_list_caba_hikaru||table||172||||4"
msgid "I can't deny that my butt is part of my charm.\nIt might not be a bad idea to play that up!"
msgstr "Non posso negare che il mio sedere faccia parte del mio fascino.\nPotrebbe non essere una cattiva idea puntare su quello!"

msgctxt "7||speech_list_caba_hikaru||table||173||||4"
msgid "That said, I'm impressed that you noticed.\nThat means you're staring at my butt a lot, huh?"
msgstr "Detto questo, sono colpita che tu l'abbia notato.\nSignifica che mi guardi spesso il sedere, eh?"

msgctxt "7||speech_list_caba_hikaru||table||174||||4"
msgid "No, all it took was a single glance..."
msgstr "No, è bastata una singola occhiata..."

msgctxt "7||speech_list_caba_hikaru||table||175||||4"
msgid "Ohhhh, you. It's written all over your face.\nYou're cute when you're embarrassed."
msgstr "Ohhhh, tu. Ce l'hai scritto in faccia.\nSei carino quando ti imbarazzi."

msgctxt "7||speech_list_caba_hikaru||table||176||||4"
msgid "How about, \"I'm such a bright, energetic, and\nsunny girl, that you'll need shades!\""
msgstr "Che ne dici di: \"Sono una ragazza così allegra, energica\ne solare, che avrete bisogno degli occhiali da sole!\""

msgctxt "7||speech_list_caba_hikaru||table||177||||4"
msgid "Kiryu-san, you're pretty good at this...\nThat does sound like a catchphrase."
msgstr "Kiryu-san, ci sai fare...\nSembra proprio un bel tormentone."

msgctxt "7||speech_list_caba_hikaru||table||178||||4"
msgid "But I don't think I'm all that bright or\nenergetic, so, do you think that'll work?"
msgstr "Ma non credo di essere così allegra o\nenergica, quindi, pensi che funzionerà?"

msgctxt "7||speech_list_caba_hikaru||table||179||||4"
msgid "Don't underestimate the power of words. If you\nsay you're bright and energetic, they'll believe it."
msgstr "Non sottovalutare il potere delle parole. Se tu\ndici di essere allegra ed energica, loro ci crederanno."

msgctxt "7||speech_list_caba_hikaru||table||180||||4"
msgid "I see. So it's kind of like getting out in front of\nmy shortcomings? Amazing! You're like my producer."
msgstr "Capisco. Quindi è un po' come anticipare\ni miei difetti? Incredibile! Sei come il mio produttore."

msgctxt "7||speech_list_caba_hikaru||table||181||||4"
msgid "It might work. Just keep it in mind."
msgstr "Potrebbe funzionare. Tienilo a mente."

msgctxt "7||speech_list_caba_hikaru||table||182||||4"
msgid "Okay. <symbol=note_with_outline> Thank you, Producer Kiryu. <symbol=note_with_outline>"
msgstr "D'accordo. <symbol=note_with_outline> Grazie, Produttore Kiryu. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||183||||4"
msgid "How about \"Make way for the Princess of the\nHealer Kingdom!\""
msgstr "Che ne dici di: \"Fate largo alla Principessa\ndel Regno Guaritore!\""

msgctxt "7||speech_list_caba_hikaru||table||184||||4"
msgid "Kiryu-san, you're so good at this!\nI appreciate the serious thought."
msgstr "Kiryu-san, sei bravissimo!\nApprezzo che tu ci abbia pensato seriamente."

msgctxt "7||speech_list_caba_hikaru||table||185||||4"
msgid "Well, I think your softness is what makes\nyou so unique."
msgstr "Beh, credo che la tua dolcezza sia ciò\nche ti rende così unica."

msgctxt "7||speech_list_caba_hikaru||table||186||||4"
msgid "I only came up with it because I think a lot of guys\nlike me would be drawn to the promise of healing."
msgstr "Mi è venuto in mente solo perché penso che molti ragazzi\ncome me sarebbero attratti dalla promessa di essere rassicurati."

msgctxt "7||speech_list_caba_hikaru||table||187||||4"
msgid "I'm happy you think of me that way."
msgstr "Sono felice che tu mi veda in questo modo."

msgctxt "7||speech_list_caba_hikaru||table||188||||4"
msgid "And you even called me a princess... <symbol=note_with_outline>\nYou'll make me blush."
msgstr "E mi hai persino chiamata principessa... <symbol=note_with_outline>\nMi farai arrossire."

msgctxt "7||speech_list_caba_hikaru||table||189||||4"
msgid "Just food for thought.\nI hope you'll find the right approach."
msgstr "È solo uno spunto di riflessione.\nSpero tu riesca a trovare l'approccio giusto."

msgctxt "7||speech_list_caba_hikaru||table||190||||4"
msgid "Me too! <symbol=note_with_outline>\nThank you for your input, Producer Kiryu. <symbol=note_with_outline>"
msgstr "Anch'io! <symbol=note_with_outline>\nGrazie per il tuo contributo, Produttore Kiryu. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||191||||4"
msgid "You know, until now, my only joy in life\nwas my daily dose of dried sweet potatoes..."
msgstr "Sai, fino ad oggi la mia unica gioia nella vita\nera la mia dose quotidiana di patate dolci essiccate..."

msgctxt "7||speech_list_caba_hikaru||table||192||||4"
msgid "But I've discovered that talking to you is\nsomething I've started looking forward to!"
msgstr "Ma ho scoperto che parlare con te è una\ndi quelle cose che aspetto con impazienza!"

msgctxt "7||speech_list_caba_hikaru||table||193||||4"
msgid "So I'm on the same level\nas dried sweet potatoes?"
msgstr "Quindi sono allo stesso livello\ndelle patate dolci essiccate?"

msgctxt "7||speech_list_caba_hikaru||table||194||||4"
msgid "Don't take it so negatively!\nI really, <font_kind=yakuza_italic>really</font_kind> like dried sweet potatoes."
msgstr "Non prenderla così male!\nA me piacciono <font_kind=yakuza_italic>davvero</font_kind> tantissimo le patate dolci essiccate."

msgctxt "7||speech_list_caba_hikaru||table||195||||4"
msgid "So being on that level means I <font_kind=yakuza_italic>really</font_kind>\nlike you too, Kiryu-san."
msgstr "Quindi essere a quel livello significa che anche tu\nmi piaci <font_kind=yakuza_italic>davvero</font_kind> tantissimo, Kiryu-san."

msgctxt "7||speech_list_caba_hikaru||table||196||||4"
msgid "Oh, what am I saying!?"
msgstr "Oh, ma che sto dicendo!?"

msgctxt "7||speech_list_caba_hikaru||table||197||||4"
msgid "Anyway, I just wanted to say it's been fun\ntalking to you... It makes my heart race."
msgstr "Comunque, volevo solo dirti che è stato divertente\nparlare con te... Mi fa battere forte il cuore."

msgctxt "7||speech_list_caba_hikaru||table||198||||4"
msgid "Your heart races, huh? That sounds...\n...like you might be a little love sick."
msgstr "Ti fa battere forte il cuore, eh? Sembra...\n...che tu sia un po' malata d'amore."

msgctxt "7||speech_list_caba_hikaru||table||199||||4"
msgid "Huh!?"
msgstr "Eh!?"

msgctxt "7||speech_list_caba_hikaru||table||200||||4"
msgid "Just messing with you."
msgstr "Ti sto solo prendendo in giro."

msgctxt "7||speech_list_caba_hikaru||table||201||||4"
msgid "Come on, don't tease me.\nBesides... I'm not joking."
msgstr "Dai, non prendermi in giro.\nE poi... io non stavo scherzando."

msgctxt "7||speech_list_caba_hikaru||table||202||||4"
msgid "Hm? About what?"
msgstr "Mhm? Su cosa?"

msgctxt "7||speech_list_caba_hikaru||table||203||||4"
msgid "It's nothing! Kiryu-san...\nYou're so dense."
msgstr "Non è niente! Kiryu-san...\nSei proprio di coccio."

msgctxt "7||speech_list_caba_hikaru||table||204||||4"
msgid "Am I?"
msgstr "Lo sono?"

msgctxt "7||speech_list_caba_hikaru||table||205||||4"
msgid "Yeah, well... that's actually part of your\ncharm, I suppose."
msgstr "Sì, beh... immagino che anche questo\nfaccia parte del tuo fascino."

msgctxt "7||speech_list_caba_hikaru||table||206||||4"
msgid "Hm... I'll take that as a compliment."
msgstr "Mhm... Lo prenderò come un complimento."

msgctxt "7||speech_list_caba_hikaru||table||207||||4"
msgid "What a coincidence. Me too."
msgstr "Che coincidenza. Anch'io."

msgctxt "7||speech_list_caba_hikaru||table||208||||4"
msgid "Huh!? Does that mean...\nYou feel the love too?"
msgstr "Eh!? Questo significa che...\nAnche tu sei malato d'amore?"

msgctxt "7||speech_list_caba_hikaru||table||209||||4"
msgid "Yeah. I feel the same way."
msgstr "Sì. Provo la stessa cosa."

msgctxt "7||speech_list_caba_hikaru||table||210||||4"
msgid "Oh no... What should I do?\nI'm not ready... and you're so bold..."
msgstr "Oh no... Cosa dovrei fare?\nNon sono pronta... e tu sei così audace..."

msgctxt "7||speech_list_caba_hikaru||table||211||||4"
msgid "But... I'm happy, Kiryu-san...\nAs long as it's with you, I..."
msgstr "Però... sono felice, Kiryu-san...\nFinché è con te, io..."

msgctxt "7||speech_list_caba_hikaru||table||212||||4"
msgid "Hm? Where are you going with this?\nWe're talking about dried sweet potatoes, right?"
msgstr "Mhm? Dove vuoi arrivare?\nStiamo parlando di patate dolci essiccate, giusto?"

msgctxt "7||speech_list_caba_hikaru||table||213||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "7||speech_list_caba_hikaru||table||214||||4"
msgid "I love dried sweet potatoes, too."
msgstr "Amo le patate dolci essiccate anch'io."

msgctxt "7||speech_list_caba_hikaru||table||215||||4"
msgid "Oh, Kiryu-san! Don't be so vague when\nyou say such important things!"
msgstr "Oh, Kiryu-san! Non essere così ambiguo quando\ndici cose tanto importanti!"

msgctxt "7||speech_list_caba_hikaru||table||216||||4"
msgid "...Vague?"
msgstr "...Ambiguo?"

msgctxt "7||speech_list_caba_hikaru||table||217||||4"
msgid "...That's enough of that.\nI got all worked up for nothing."
msgstr "...E con questo basta.\nMi sono agitata per niente."

msgctxt "7||speech_list_caba_hikaru||table||218||||4"
msgid "You're weird, Kiryu-san."
msgstr "Sei proprio strano, Kiryu-san."

msgctxt "7||speech_list_caba_hikaru||table||219||||4"
msgid "You need to lay off the dried sweet potatoes."
msgstr "Devi darti una calmata con le patate dolci essiccate."

msgctxt "7||speech_list_caba_hikaru||table||220||||4"
msgid "Huh? You think so?"
msgstr "Eh? Pensi di sì?"

msgctxt "7||speech_list_caba_hikaru||table||221||||4"
msgid "You know... starch goes right to the stomach."
msgstr "Sai com'è... gli amidi vanno dritti sullo stomaco."

msgctxt "7||speech_list_caba_hikaru||table||222||||4"
msgid "Besides, everything in moderation, you know?"
msgstr "E poi, tutto è meglio con moderazione, no?"

msgctxt "7||speech_list_caba_hikaru||table||223||||4"
msgid "Okay. You're weird, Kiryu-san."
msgstr "Va bene. Sei strano, Kiryu-san."

msgctxt "7||speech_list_caba_hikaru||table||224||||4"
msgid "Am I?"
msgstr "Lo sono?"

msgctxt "7||speech_list_caba_hikaru||table||225||||4"
msgid "Yes. Of course, I mean that in a good way."
msgstr "Sì. Ovviamente, lo dico in senso buono."

msgctxt "7||speech_list_caba_hikaru||table||226||||4"
msgid "Kiryu-san, I actually have something\nI want to report!"
msgstr "Kiryu-san, in realtà avrei una cosa\nda comunicarti!"

msgctxt "7||speech_list_caba_hikaru||table||227||||4"
msgid "Oh yeah? What's the occasion?"
msgstr "Ah sì? Qual è l'occasione?"

msgctxt "7||speech_list_caba_hikaru||table||228||||4"
msgid "I'm... going to sign a contract with a talent\nagency to become an idol!"
msgstr "Sto... per firmare un contratto con un'agenzia\ndi talenti per diventare un'idol!"

msgctxt "7||speech_list_caba_hikaru||table||229||||4"
msgid "What? Really?"
msgstr "Cosa? Davvero?"

msgctxt "7||speech_list_caba_hikaru||table||230||||4"
msgid "Yeah! I auditioned, made it through the test,\nand managed to get a call back!"
msgstr "Sì! Ho fatto un provino, ho superato il test\ne sono riuscita a farmi richiamare!"

msgctxt "7||speech_list_caba_hikaru||table||231||||4"
msgid "That's great! You're an idol now!"
msgstr "È fantastico! Adesso sei un'idol!"

msgctxt "7||speech_list_caba_hikaru||table||232||||4"
msgid "Well, this is only where it starts.\nThe real challenge is what comes next."
msgstr "Beh, questo è solo l'inizio.\nLa vera sfida è ciò che verrà dopo."

msgctxt "7||speech_list_caba_hikaru||table||233||||4"
msgid "But... it's all thanks to you, Kiryu-san.\nThank you so much!"
msgstr "Ma... è tutto merito tuo, Kiryu-san.\nGrazie infinite!"

msgctxt "7||speech_list_caba_hikaru||table||234||||4"
msgid "I didn't do anything.\nIt was all you."
msgstr "Io non ho fatto niente.\nHai fatto tutto tu."

msgctxt "7||speech_list_caba_hikaru||table||235||||4"
msgid "No, this only happened because of\nwhat you said to me that one time."
msgstr "No, questo è successo solo grazie a\nquello che mi hai detto quella volta."

msgctxt "7||speech_list_caba_hikaru||table||236||||4"
msgid "I was afraid to commit to it, but you made me\ncome out of my shell and get serious about it."
msgstr "Avevo paura di impegnarmi, ma tu mi hai fatto\nuscire dal guscio e mi hai spinta a fare sul serio."

msgctxt "7||speech_list_caba_hikaru||table||237||||4"
msgid "You do seem more confident than back then.\nGive it your best shot, okay?"
msgstr "In effetti sembri molto più sicura di allora.\nMetticela tutta, d'accordo?"

msgctxt "7||speech_list_caba_hikaru||table||238||||4"
msgid "I will! I actually have a meeting with the\nagency after this."
msgstr "Lo farò! In realtà, dopo questo, ho un incontro\ncon l'agenzia."

msgctxt "7||speech_list_caba_hikaru||table||239||||4"
msgid "The interview was held at a different location, so\nthis'll be my first time going to the office. I'm nervous..."
msgstr "Il colloquio si è tenuto in un altro posto, quindi\nsarà la prima volta che vado nei loro uffici. Sono nervosa..."

msgctxt "7||speech_list_caba_hikaru||table||240||||4"
msgid "That's okay. There's a lot of different types of people\nin the entertainment industry, so just be careful, okay?"
msgstr "Andrà tutto bene. Ci sono tanti tipi di persone diverse nel\nmondo dello spettacolo, quindi cerca solo di stare attenta, okay?"

msgctxt "7||speech_list_caba_hikaru||table||241||||4"
msgid "I will. Thank you. <symbol=note_with_outline>"
msgstr "Lo farò. Grazie. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||242||||4"
msgid "Well, see you later, Kiryu-san. <symbol=note_with_outline>"
msgstr "Bene, a dopo, Kiryu-san. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||243||||4"
msgid "Yeah."
msgstr "A dopo."

msgctxt "7||speech_list_caba_hikaru||table||244||||4"
msgid "Let's see... I like tea,\nso I go to a lot of tea parties."
msgstr "Vediamo... Mi piace il tè,\nquindi vado spesso a dei tea party."

msgctxt "7||speech_list_caba_hikaru||table||245||||4"
msgid "Yeah? Do you make your own tea?"
msgstr "Ah sì? Ti prepari il tè da sola?"

msgctxt "7||speech_list_caba_hikaru||table||246||||4"
msgid "Yes! Of course, I like drinking it, too."
msgstr "Sì! Ma ovviamente, mi piace anche berlo."

msgctxt "7||speech_list_caba_hikaru||table||247||||4"
msgid "Oh! Would you like me to make some\nfor you too, Kiryu-san?"
msgstr "Oh! Vorresti che ne preparassi\nun po' anche per te, Kiryu-san?"

msgctxt "7||speech_list_caba_hikaru||table||248||||4"
msgid "Sure. Looking forward to it."
msgstr "Certo. Non vedo l'ora."

msgctxt "7||speech_list_caba_hikaru||table||249||||4"
msgid "Hmm... I usually go shopping,\nor I'll just wander around outside."
msgstr "Mhm... Di solito vado a fare shopping,\noppure gironzolo qua e là."

msgctxt "7||speech_list_caba_hikaru||table||250||||4"
msgid "I see.\nWhat kind of stuff do you shop for?"
msgstr "Capisco.\nChe genere di cose compri?"

msgctxt "7||speech_list_caba_hikaru||table||251||||4"
msgid "Oh, just the usual women's stuff.\nBeauty products, cute clothes, you know."
msgstr "Oh, le solite cose da donne.\nProdotti di bellezza, vestiti carini, sai com'è."

msgctxt "7||speech_list_caba_hikaru||table||252||||4"
msgid "Let me buy next time."
msgstr "Offro io, la prossima volta."

msgctxt "7||speech_list_caba_hikaru||table||253||||4"
msgid "Wow, really!?\nThat makes me happy! <symbol=note_with_outline>"
msgstr "Wow, sul serio!?\nLa cosa mi rende felice! <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||254||||4"
msgid "Buy some for me next time."
msgstr "Comprane un po' per me la prossima volta."

msgctxt "7||speech_list_caba_hikaru||table||255||||4"
msgid "Huh...? Beauty products and cute clothes?"
msgstr "Eh...? Prodotti di bellezza e vestiti carini?"

msgctxt "7||speech_list_caba_hikaru||table||256||||4"
msgid "Kiryu-san... Are you into that kind of thing?"
msgstr "Kiryu-san... Sei appassionato di questo genere di cose?"

msgctxt "7||speech_list_caba_hikaru||table||257||||4"
msgid "What? N-No, it's not like that..."
msgstr "Cosa? N-No, non è affatto così..."

msgctxt "7||speech_list_caba_hikaru||table||258||||4"
msgid "Don't worry. I won't tell anyone!"
msgstr "Non preoccuparti. Non lo dirò a nessuno!"

msgctxt "7||speech_list_caba_hikaru||table||259||||4"
msgid "Besides, I bet you'd be pretty cute\nin drag, Kiryu-san."
msgstr "Inoltre, scommetto che saresti molto carino\nvestito da donna, Kiryu-san."

msgctxt "7||speech_list_caba_hikaru||table||260||||4"
msgid "(That came out the wrong way...)"
msgstr "(Forse mi sono espresso male...)"

msgctxt "7||speech_list_caba_hikaru||table||261||||4"
msgid "Hmmm."
msgstr "Mhm."

msgctxt "7||speech_list_caba_hikaru||table||262||||4"
msgid "Oh... Am I boring you?"
msgstr "Oh... Ti sto annoiando?"

msgctxt "7||speech_list_caba_hikaru||table||263||||4"
msgid "No, I didn't mean that..."
msgstr "No, non intendevo dire quello..."

msgctxt "7||speech_list_caba_hikaru||table||264||||4"
msgid "Come on, Kiryu-san! What am I supposed\nto think with a response like that? Hmph!"
msgstr "Andiamo, Kiryu-san! Cosa dovrei pensare\ndi una reazione del genere? Uff!"

msgctxt "7||speech_list_caba_hikaru||table||265||||4"
msgid "I started here just after I started college,\nso this'll be my fourth year."
msgstr "Ho iniziato qui subito dopo l'università,\nquindi questo sarà il mio quarto anno."

msgctxt "7||speech_list_caba_hikaru||table||266||||4"
msgid "Four years, huh?\nWould you say you're used to the job, then?"
msgstr "Quattro anni, eh?\nQuindi diresti che ormai ti sei abituata al lavoro?"

msgctxt "7||speech_list_caba_hikaru||table||267||||4"
msgid "No way! I've got a ways to go. The moment I let my\nguard down I make mistakes, so I try to stay focused."
msgstr "Assolutamente no! Ne ho ancora di strada da fare. Un attimo\ndi distrazione e commetto errori, quindi cerco di stare attenta."

msgctxt "7||speech_list_caba_hikaru||table||268||||4"
msgid "I see. I suppose giving it that\nkind of attention is a good thing."
msgstr "Capisco. Immagino che metterci quel tipo\ndi attenzione sia una buona cosa."

msgctxt "7||speech_list_caba_hikaru||table||269||||4"
msgid "I'm from Kanagawa, near the sea."
msgstr "Vengo da Kanagawa, vicino al mare."

msgctxt "7||speech_list_caba_hikaru||table||270||||4"
msgid "Huh. So, can you swim?\nPeople are into surfing there, right?"
msgstr "Mhm. Allora, sai nuotare?\nLì alla gente piace fare surf, giusto?"

msgctxt "7||speech_list_caba_hikaru||table||271||||4"
msgid "I can't swim at all... Can you, Kiryu-san?"
msgstr "Non so nuotare affatto... E tu, Kiryu-san?"

msgctxt "7||speech_list_caba_hikaru||table||272||||4"
msgid "I suppose so.\nI've gotten into spearfishing lately."
msgstr "Immagino di sì.\nUltimamente mi sono appassionato alla pesca subacquea."

msgctxt "7||speech_list_caba_hikaru||table||273||||4"
msgid "Oh, that's amazing! Woooow!\nYou'll have to teach me that some time!"
msgstr "Oh, è fantastico! Uaoooo!\nDovrai insegnarmi come si fa, prima o poi!"

msgctxt "7||speech_list_caba_hikaru||table||274||||4"
msgid "Dried sweet potatoes and beef jerky!"
msgstr "Patate dolci essiccate e carne secca!"

msgctxt "7||speech_list_caba_hikaru||table||275||||4"
msgid "They're kinda tough, and I like how the more\nyou chew them, the more flavor you get."
msgstr "Sono un po' dure, e mi piace il fatto che più\nle mastichi, più sapore rilasciano."

msgctxt "7||speech_list_caba_hikaru||table||276||||4"
msgid "Wow. You've got quite a refined palate."
msgstr "Wow. Hai un palato decisamente raffinato."

msgctxt "7||speech_list_caba_hikaru||table||277||||4"
msgid "Why, thank you. <symbol=note_with_outline>"
msgstr "Ma grazie mille. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||278||||4"
msgid "I suppose I like a kind man."
msgstr "Credo mi piacciano gli uomini gentili."

msgctxt "7||speech_list_caba_hikaru||table||279||||4"
msgid "The kind of guy who helps an old woman\ncarry something heavy comes to mind."
msgstr "Il tipo di ragazzo che aiuta una vecchietta a\nportare le borse pesanti, tanto per capirci."

msgctxt "7||speech_list_caba_hikaru||table||280||||4"
msgid "Kiryu-san, are you the type to help an\nold lady out?"
msgstr "Kiryu-san, sei il tipo che aiuterebbe\nuna vecchia signora?"

msgctxt "7||speech_list_caba_hikaru||table||281||||4"
msgid "Isn't it obvious?\nOf course I would."
msgstr "Non è ovvio?\nCerto che lo farei."

msgctxt "7||speech_list_caba_hikaru||table||282||||4"
msgid "I knew you were kind.\nThat's wonderful. <symbol=note_with_outline>"
msgstr "Sapevo che eri un tipo gentile.\nÈ meraviglioso. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||283||||4"
msgid "Nope, can't say I'd carry her stuff."
msgstr "No, non porterei le sue cose."

msgctxt "7||speech_list_caba_hikaru||table||284||||4"
msgid "Huh? Why not?"
msgstr "Eh? E perché no?"

msgctxt "7||speech_list_caba_hikaru||table||285||||4"
msgid "These days, old people get mad if you\ntry to treat them like senior citizens."
msgstr "Al giorno d'oggi, gli anziani si arrabbiano\nse li tratti come tali."

msgctxt "7||speech_list_caba_hikaru||table||286||||4"
msgid "Oh, I have heard of that happening.\nHmmm... Must be tough."
msgstr "Oh, in effetti ho sentito di casi simili.\nMhm... Dev'essere dura."

msgctxt "7||speech_list_caba_hikaru||table||287||||4"
msgid "Actually, I'd pick up both the stuff\nand the old lady."
msgstr "A dirla tutta, prenderei in braccio sia\nle cose che la vecchia signora."

msgctxt "7||speech_list_caba_hikaru||table||288||||4"
msgid "What!? You'd carry them both!?"
msgstr "Cosa!? Porteresti entrambi!?"

msgctxt "7||speech_list_caba_hikaru||table||289||||4"
msgid "I never thought of that!\nYou're so kind! That's wonderful... <symbol=heart_with_outline>"
msgstr "Non ci avevo mai pensato!\nSei così gentile! È meraviglioso... <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||290||||4"
msgid "I don't know if I'd call it kind, but..."
msgstr "Non so se lo definirei gentile, ma..."

msgctxt "7||speech_list_caba_hikaru||table||291||||4"
msgid "I don't think I'm all that different, but\nI guess I'm the type who craves attention."
msgstr "Non credo di essere tanto diversa, ma immagino\ndi essere il tipo che ha bisogno di attenzioni."

msgctxt "7||speech_list_caba_hikaru||table||292||||4"
msgid "Oho. Attention does it for you?"
msgstr "Oho. Ti piacciono le attenzioni?"

msgctxt "7||speech_list_caba_hikaru||table||293||||4"
msgid "Yep. I may-eow even talk like a cat."
msgstr "Già. Mi-a-volte mi metto persino a parlare come un gatto."

msgctxt "7||speech_list_caba_hikaru||table||294||||4"
msgid "I'll give you as much attention as you want."
msgstr "Ti darò tutte le attenzioni che vuoi."

msgctxt "7||speech_list_caba_hikaru||table||295||||4"
msgid "Oh, Kiryu-san! <symbol=note_with_outline> I'm so happy right meow. <symbol=note_with_outline>"
msgstr "Oh, Kiryu-san! <symbol=note_with_outline> Sono così felice in questo mi-a-omento. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||296||||4"
msgid "I don't really like women who beg for attention."
msgstr "Non mi piacciono molto le donne che implorano attenzioni."

msgctxt "7||speech_list_caba_hikaru||table||297||||4"
msgid "Whaaat? You don't like me, Kiryu-san?\nMeow I'm all sad... <symbol=note_with_outline> I apawlogize... <symbol=note_with_outline>"
msgstr "Cooosa? Non ti piaccio, Kiryu-san?\nMi-a-o mi sento così triste... <symbol=note_with_outline> Chiedo purr-dono... <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||298||||4"
msgid "I forgive you."
msgstr "Ti perdono."

msgctxt "7||speech_list_caba_hikaru||table||299||||4"
msgid "That's cute-meow..."
msgstr "Sei così mi-a-o-carina..."

msgctxt "7||speech_list_caba_hikaru||table||300||||4"
msgid "Kiryu-san!? Did you just say \"that's cute-meow\"?"
msgstr "Kiryu-san!? Hai appena detto \"mi-a-o-carina\"?"

msgctxt "7||speech_list_caba_hikaru||table||301||||4"
msgid "N-Nope, forget I said anything."
msgstr "N-No, dimentica quello che ho detto."

msgctxt "7||speech_list_caba_hikaru||table||302||||4"
msgid "I know what I heard!\nYou're so mischievous that it's cute. <symbol=heart_with_outline>"
msgstr "So bene quello che ho sentito!\nSei così dispettoso, è carino. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||303||||4"
msgid "For a long time, I've dreamt of becoming an idol."
msgstr "Per molto tempo ho sognato di diventare un'idol."

msgctxt "7||speech_list_caba_hikaru||table||304||||4"
msgid "But I'm not a teenager anymore, and people tell\nme to just get a job... I'm keeping my options open."
msgstr "Ma non sono più un'adolescente e la gente mi dice\ndi trovarmi un lavoro... Tengo aperte le mie opzioni."

msgctxt "7||speech_list_caba_hikaru||table||305||||4"
msgid "When I was a kid,\nI thought I wanted to be a teacher."
msgstr "Quando ero bambina,\npensavo di voler fare l'insegnante."

msgctxt "7||speech_list_caba_hikaru||table||306||||4"
msgid "A teacher, huh? That's a nice dream.\nWhat changed your mind?"
msgstr "Un'insegnante, eh? È un bel sogno.\nCos'è che ti ha fatto cambiare idea?"

msgctxt "7||speech_list_caba_hikaru||table||307||||4"
msgid "Back in school, I started hearing about\nthese \"monster parents.\""
msgstr "A scuola ho iniziato a sentir parlare\ndi questi \"genitori mostro\"."

msgctxt "7||speech_list_caba_hikaru||table||308||||4"
msgid "I figured I didn't stand a chance against\nany monsters, so..."
msgstr "Ho pensato di non avere la minima possibilità\ncontro dei mostri, per cui..."

msgctxt "7||speech_list_caba_hikaru||table||309||||4"
msgid "Monster parents...?"
msgstr "Genitori mostro...?"

msgctxt "7||speech_list_caba_hikaru||table||310||||4"
msgid "Oh, those!"
msgstr "Ah, loro!"

msgctxt "7||speech_list_caba_hikaru||table||311||||4"
msgid "Exactly. It'd be tough to deal with them,\nyou know?"
msgstr "Esatto. Sarebbe difficile averci a che fare,\nnon credi?"

msgctxt "7||speech_list_caba_hikaru||table||312||||4"
msgid "Yep. Probably real difficult."
msgstr "Sì. Probabilmente molto difficile."

msgctxt "7||speech_list_caba_hikaru||table||313||||4"
msgid "Kiryu-san... Are you even following?"
msgstr "Kiryu-san... Stai almeno prestando attenzione?"

msgctxt "7||speech_list_caba_hikaru||table||314||||4"
msgid "Yeah, the unreasonable types, right? The kind that\ncomplain about their kids' teachers to the school..."
msgstr "Sì, i tipi irragionevoli, no? Quelli che si lamentano\ndegli insegnanti dei figli con la scuola..."

msgctxt "7||speech_list_caba_hikaru||table||315||||4"
msgid "Yeah. It's hard for me to be firm with people,\nso I'd probably have gotten sick with stress..."
msgstr "Sì. Mi è difficile essere severa con le persone,\nquindi probabilmente mi sarei ammalata per lo stress..."

msgctxt "7||speech_list_caba_hikaru||table||316||||4"
msgid "Teachers have it rough these days...\nThough, I bet the kids would all like your class."
msgstr "Gli insegnanti hanno vita dura, oggigiorno...\nAnche se, scommetto che ai bambini piacerebbe la tua lezione."

msgctxt "7||speech_list_caba_hikaru||table||317||||4"
msgid "You really think so? I'm happy to hear that. <symbol=note_with_outline>\nI love kids."
msgstr "Dici davvero? Mi fa piacere sentirlo. <symbol=note_with_outline>\nIo adoro i bambini."

msgctxt "7||speech_list_caba_hikaru||table||318||||4"
msgid "Oh, someone like Kazama-san."
msgstr "Oh, uno come Kazama-san."

msgctxt "7||speech_list_caba_hikaru||table||319||||4"
msgid "Huh? Kazama-san?"
msgstr "Eh? Kazama-san?"

msgctxt "7||speech_list_caba_hikaru||table||320||||4"
msgid "Yeah. He was pretty scary when he got mad.\nHe was kind of a monster in the underworld."
msgstr "Sì. Faceva molta paura quando si arrabbiava.\nEra una specie di mostro nel mondo criminale."

msgctxt "7||speech_list_caba_hikaru||table||321||||4"
msgid "Underworld? Kiryu-san, you're losing me here..."
msgstr "Mondo criminale? Kiryu-san, mi sono persa..."

msgctxt "7||speech_list_caba_hikaru||table||322||||4"
msgid "Oh, I'm good at giving shoulder massages.\nMy friends are always telling me that."
msgstr "Oh, sono brava a fare i massaggi alle spalle.\nLe mie amiche me lo dicono sempre."

msgctxt "7||speech_list_caba_hikaru||table||323||||4"
msgid "I massaged my dad's shoulders a lot when I was\nlittle. Does Papa Kiryu want a massage, too?"
msgstr "Massaggiavo spesso le spalle di papà quando ero\npiccola. Papà Kiryu vuole un massaggio?"

msgctxt "7||speech_list_caba_hikaru||table||324||||4"
msgid "Oh, you don't mind?"
msgstr "Oh, non ti dispiace?"

msgctxt "7||speech_list_caba_hikaru||table||325||||4"
msgid "Not at all! It'll cost you extra, though. <symbol=note_with_outline>"
msgstr "Niente affatto! Ti costerà un extra, però. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||326||||4"
msgid "Tch... You're pretty devious."
msgstr "Tsk... Sei piuttosto infida."

msgctxt "7||speech_list_caba_hikaru||table||327||||4"
msgid "I don't know if this counts as interesting,\nbut I did some volunteering overseas last month."
msgstr "Non so se si possa definire interessante,\nma il mese scorso ho fatto volontariato all'estero."

msgctxt "7||speech_list_caba_hikaru||table||328||||4"
msgid "Huh. Never guessed you'd be into that."
msgstr "Mhm. Non avrei mai detto che facesse per te."

msgctxt "7||speech_list_caba_hikaru||table||329||||4"
msgid "I am. I was helping out with some tree planting,\nbut physical labor is hard work."
msgstr "Sì, invece. Stavo dando una mano a piantare degli alberi,\nma il lavoro fisico è faticoso."

msgctxt "7||speech_list_caba_hikaru||table||330||||4"
msgid "But in my free time I got to interact with the\nlocals, and it was a new and really fun experience."
msgstr "Ma nel tempo libero ho potuto interagire con la\ngente del posto, ed è stata un'esperienza nuova e divertente."

msgctxt "7||speech_list_caba_hikaru||table||331||||4"
msgid "I bet. What country were you in?"
msgstr "Ci scommetto. In quale paese eri?"

msgctxt "7||speech_list_caba_hikaru||table||332||||4"
msgid "Myanmar."
msgstr "In Birmania."

msgctxt "7||speech_list_caba_hikaru||table||333||||4"
msgid "(Myanmar...?)"
msgstr "(In Birmania...?)"

msgctxt "7||speech_list_caba_hikaru||table||334||||4"
msgid "Oh, isn't that in southeast Asia?"
msgstr "Oh, non si trova nel sud-est asiatico?"

msgctxt "7||speech_list_caba_hikaru||table||335||||4"
msgid "Yeah! I'm impressed you knew that."
msgstr "Sì! Sono colpita che tu lo sapessi."

msgctxt "7||speech_list_caba_hikaru||table||336||||4"
msgid "Of course. Common knowledge, right?"
msgstr "Certo. Conoscenza comune, no?"

msgctxt "7||speech_list_caba_hikaru||table||337||||4"
msgid "Anyway, I think it's great that you're getting\nthat kind of experience while you're young."
msgstr "Comunque, credo sia fantastico che tu faccia\nquesto tipo di esperienze finché sei giovane."

msgctxt "7||speech_list_caba_hikaru||table||338||||4"
msgid "Thank you. I hope it ends up being useful\nsomehow."
msgstr "Grazie. Spero che alla fine si rivelerà\nutile in qualche modo."

msgctxt "7||speech_list_caba_hikaru||table||339||||4"
msgid "The place with those famous hot springs\nin Kusatsu?"
msgstr "Il posto con le famose sorgenti termali\ndi Kusatsu?"

msgctxt "7||speech_list_caba_hikaru||table||340||||4"
msgid "That's Gunma."
msgstr "Quella è Gunma."

msgctxt "7||speech_list_caba_hikaru||table||341||||4"
msgid "Isn't that some English word for a tool?"
msgstr "Non è una parola inglese per un qualche strumento?"

msgctxt "7||speech_list_caba_hikaru||table||342||||4"
msgid "That's a \"hammer.\""
msgstr "Quello è un \"hammer\"."

msgctxt "7||speech_list_caba_hikaru||table||343||||4"
msgid "Not really, but I feel like that's okay.\nMy philosophy is to have a few good friends."
msgstr "Non proprio, ma mi sta bene così.\nLa mia filosofia è avere pochi ma buoni amici."

msgctxt "7||speech_list_caba_hikaru||table||344||||4"
msgid "Did you know you can play games on your\nphone these days? I do that a lot lately."
msgstr "Sapevi che oggigiorno puoi giocare ai\nvideogiochi sul telefono? Io ci gioco un sacco ultimamente."

msgctxt "7||speech_list_caba_hikaru||table||345||||4"
msgid "What kind of games do you play, Kiryu-san?"
msgstr "Che genere di giochi ti piacciono, Kiryu-san?"

msgctxt "7||speech_list_caba_hikaru||table||346||||4"
msgid "I hit up the arcades a lot.\nSo, arcade games."
msgstr "Vado spesso in sala giochi.\nQuindi i cabinati arcade."

msgctxt "7||speech_list_caba_hikaru||table||347||||4"
msgid "Wow! I haven't been to one in a while.\nYou should take me there sometime!"
msgstr "Wow! È da un po' che non ci vado.\nDovresti portarmici, qualche volta!"

msgctxt "7||speech_list_caba_hikaru||table||348||||4"
msgid "I'm all about the mobile games."
msgstr "Gioco tutto il tempo col cellulare."

msgctxt "7||speech_list_caba_hikaru||table||349||||4"
msgid "Really? Which ones do you play?"
msgstr "Davvero? A cosa giochi?"

msgctxt "7||speech_list_caba_hikaru||table||350||||4"
msgid "Huh? Uh, I don't know...\nWhatever's popular."
msgstr "Eh? Ehm, non saprei...\nA quello che va di moda."

msgctxt "7||speech_list_caba_hikaru||table||351||||4"
msgid "Kiryu-san... You don't really play, do you?\nYou need to learn how to lie better."
msgstr "Kiryu-san... In realtà non ci giochi affatto, vero?\nDevi imparare a mentire meglio."

msgctxt "7||speech_list_caba_hikaru||table||352||||4"
msgid "You got me... Sorry."
msgstr "Mi hai beccata... Scusa."

msgctxt "7||speech_list_caba_hikaru||table||353||||4"
msgid "Lately... I'm caught up in the game of love."
msgstr "Ultimamente... sono preso dal gioco dell'amore."

msgctxt "7||speech_list_caba_hikaru||table||354||||4"
msgid "Kiryu-san, you try to act so cool sometimes.\nYou're a funny guy."
msgstr "Kiryu-san, a volte cerchi di darti un sacco di arie.\nSei un tipo buffo."

msgctxt "7||speech_list_caba_hikaru||table||355||||4"
msgid "Huh? What secret?"
msgstr "Eh? Quale segreto?"

msgctxt "7||speech_list_caba_hikaru||table||356||||4"
msgid "Well, actually..."
msgstr "Beh, in realtà..."

msgctxt "7||speech_list_caba_hikaru||table||357||||4"
msgid "I've been to prison before."
msgstr "Sono stato in prigione, in passato."

msgctxt "7||speech_list_caba_hikaru||table||358||||4"
msgid "Huh? Really?"
msgstr "Eh? Davvero?"

msgctxt "7||speech_list_caba_hikaru||table||359||||4"
msgid "But you don't seem like a bad person\nto me, Kiryu-san."
msgstr "Però a me non sembri una cattiva\npersona, Kiryu-san."

msgctxt "7||speech_list_caba_hikaru||table||360||||4"
msgid "Ah, maybe it was a false charge?\nOr were you trying to protect someone else?"
msgstr "Ah, magari sei stato accusato ingiustamente?\nO stavi cercando di proteggere qualcun altro?"

msgctxt "7||speech_list_caba_hikaru||table||361||||4"
msgid "Sometimes I wonder."
msgstr "A volte me lo chiedo."

msgctxt "7||speech_list_caba_hikaru||table||362||||4"
msgid "Well, people have all kinds of circumstances.\nI don't believe you're a bad person at all."
msgstr "Beh, le persone si ritrovano in ogni genere di situazione.\nIo non credo affatto che tu sia una cattiva persona."

msgctxt "7||speech_list_caba_hikaru||table||363||||4"
msgid "People pick fights with me a lot."
msgstr "La gente attacca briga con me molto spesso."

msgctxt "7||speech_list_caba_hikaru||table||364||||4"
msgid "I bet... You kind of look like the type!\nI don't think that's much of a secret, really."
msgstr "Ci scommetto... Hai l'aria di esserlo!\nIn realtà, non credo sia molto un segreto."

msgctxt "7||speech_list_caba_hikaru||table||365||||4"
msgid "I'm 100,024 years old."
msgstr "Ho 100.024 anni."

msgctxt "7||speech_list_caba_hikaru||table||366||||4"
msgid "Realllllly..."
msgstr "Davveeeero..."

msgctxt "7||speech_list_caba_hikaru||table||367||||4"
msgid "...Never mind."
msgstr "...Lascia perdere."

msgctxt "7||speech_list_caba_hikaru||table||368||||4"
msgid "A lot of people in other countries seem to have\nthem. I don't think they're all that bad, really."
msgstr "A quanto pare molte persone in altri paesi ne\nhanno. In realtà non penso che siano un male."

msgctxt "7||speech_list_caba_hikaru||table||369||||4"
msgid "It seems like such a painful process though...\nWait... Do you have one, Kiryu-san?"
msgstr "Sembra un processo così doloroso però...\nAspetta... Tu ce l'hai, Kiryu-san?"

msgctxt "7||speech_list_caba_hikaru||table||370||||4"
msgid "Yeah, on my back."
msgstr "Sì, sulla schiena."

msgctxt "7||speech_list_caba_hikaru||table||371||||4"
msgid "Wow, really?\nWhat kind of design is it?"
msgstr "Wow, sul serio?\nChe tipo di disegno è?"

msgctxt "7||speech_list_caba_hikaru||table||372||||4"
msgid "A dragon."
msgstr "Un drago."

msgctxt "7||speech_list_caba_hikaru||table||373||||4"
msgid "Oooh, sounds cool.\nI kind of wanna see it..."
msgstr "Oooh, sembra fantastico.\nMi piacerebbe vederlo..."

msgctxt "7||speech_list_caba_hikaru||table||374||||4"
msgid "Angel wings."
msgstr "Delle ali d'angelo."

msgctxt "7||speech_list_caba_hikaru||table||375||||4"
msgid "Aww. I hope you use those wings to fly\nto the future!"
msgstr "Aww. Spero che tu usi quelle ali per volare\nverso il futuro!"

msgctxt "7||speech_list_caba_hikaru||table||376||||4"
msgid "Hikaru... It's you."
msgstr "Hikaru... Sei tu."

msgctxt "7||speech_list_caba_hikaru||table||377||||4"
msgid "Huh? Me!? Did you make sure\nI turned out cute?"
msgstr "Eh? Io!? Ti sei assicurato\nche venissi carina?"

msgctxt "7||speech_list_caba_hikaru||table||378||||4"
msgid "Yeah, it's really cute... for a dragon."
msgstr "Sì, è davvero carino... per essere un drago."

msgctxt "7||speech_list_caba_hikaru||table||379||||4"
msgid "What, so it's a dragon!?\nYou're silly, Kiryu-san."
msgstr "Cosa, quindi è un drago!?\nSei buffo, Kiryu-san."

msgctxt "7||speech_list_caba_hikaru||table||380||||4"
msgid "I do drink, and I think I can hold\nit pretty well, too."
msgstr "Sì, bevo, e penso anche di reggere\nl'alcol abbastanza bene."

msgctxt "7||speech_list_caba_hikaru||table||381||||4"
msgid "But I'm not a big fan of carbonation,\nso I stay away from beers and sours."
msgstr "Ma non vado matta per le bevande gassate,\nquindi evito la birra e i sour."

msgctxt "7||speech_list_caba_hikaru||table||382||||4"
msgid "But around you, who knows? I might\nlet my guard down and get drunk... <symbol=heart_with_outline>"
msgstr "Ma in tua compagnia, chissà? Potrei anche\nabbassare la guardia e ubriacarmi... <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||383||||4"
msgid "Oh, I've heard of them. There's a lot of\nnaughty guys in there, aren't there?"
msgstr "Oh, ne ho sentito parlare. Ci sono un sacco\ndi ragazzi un po' vivaci lì dentro, non è vero?"

msgctxt "7||speech_list_caba_hikaru||table||384||||4"
msgid "Hmm... Well, you're not wrong..."
msgstr "Mhm... Beh, non hai tutti i torti..."

msgctxt "7||speech_list_caba_hikaru||table||385||||4"
msgid "Something new probably happens\nevery day there. Might be fun."
msgstr "Lì probabilmente succede qualcosa di\nnuovo ogni giorno. Potrebbe essere divertente."

msgctxt "7||speech_list_caba_hikaru||table||386||||4"
msgid "Oh, that idol that was popular a little\nwhile back? She was soooo cute."
msgstr "Oh, quell'idol che era così popolare qualche\ntempo fa? Era davveeeeero carina."

msgctxt "7||speech_list_caba_hikaru||table||387||||4"
msgid "I was really disappointed when she retired.\nWere you a fan of hers, Kiryu-san?"
msgstr "Ci sono rimasta malissimo quando si è ritirata.\nEri un suo fan, Kiryu-san?"

msgctxt "7||speech_list_caba_hikaru||table||388||||4"
msgid "Well... you could say that.\nI'm a pretty big fan."
msgstr "Beh... si potrebbe dire così.\nSono un suo grande fan."

msgctxt "7||speech_list_caba_hikaru||table||389||||4"
msgid "Wow, I never would've guessed!\nI practically had her CD on repeat."
msgstr "Wow, non l'avrei mai detto!\nIo ascoltavo il suo CD praticamente in loop."

msgctxt "7||speech_list_caba_hikaru||table||390||||4"
msgid "Oh! I'd love to hear about your adventures!"
msgstr "Oh! Mi piacerebbe tanto sentire le tue avventure!"

msgctxt "7||speech_list_caba_hikaru||table||391||||4"
msgid "I have kind of a legendary saga in crime."
msgstr "Ho un passato leggendario da criminale."

msgctxt "7||speech_list_caba_hikaru||table||392||||4"
msgid "Say what?\nYou have legendary sugar sometimes?"
msgstr "Cosa dici?\nUn passato leggendario con lo zucchero di canna integrale?"

msgctxt "7||speech_list_caba_hikaru||table||393||||4"
msgid "That's really sweet!\nI love brown sugar, myself. <symbol=note_with_outline>"
msgstr "È dolcissimo!\nIo adoro lo zucchero di canna. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||394||||4"
msgid "A long time ago,\nI defeated some tigers with my bare hands."
msgstr "Tanto tempo fa,\nho sconfitto delle tigri a mani nude."

msgctxt "7||speech_list_caba_hikaru||table||395||||4"
msgid "That's a good one."
msgstr "Questa è bella."

msgctxt "7||speech_list_caba_hikaru||table||396||||4"
msgid "I cook a lot, actually. I like dried sweet potatoes,\nso I'm experimenting with them in my dishes."
msgstr "In realtà cucino spesso. Mi piacciono le patate dolci\nessiccate, quindi ci sto sperimentando un po' nei miei piatti."

msgctxt "7||speech_list_caba_hikaru||table||397||||4"
msgid "Dried sweet potatoes?"
msgstr "Patate dolci essiccate?"

msgctxt "7||speech_list_caba_hikaru||table||398||||4"
msgid "Yep. Once I get it down,\nI'll bring you some, okay?"
msgstr "Sì. Una volta trovata la ricetta giusta,\nte ne porterò un po', okay?"

msgctxt "7||speech_list_caba_hikaru||table||399||||4"
msgid "S-Sure..."
msgstr "C-Certo..."

msgctxt "7||speech_list_caba_hikaru||table||400||||4"
msgid "I'm type A. What about you?"
msgstr "Io sono di gruppo A. E tu?"

msgctxt "7||speech_list_caba_hikaru||table||401||||4"
msgid "I'm type O."
msgstr "Io sono di gruppo zero."

msgctxt "7||speech_list_caba_hikaru||table||402||||4"
msgid "Really? A and O are supposed to be pretty\ncompatible, you know. <symbol=note_with_outline>"
msgstr "Davvero? Si dice che il gruppo A e quello zero siano\npiuttosto compatibili, sai. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||403||||4"
msgid "Gross, you can't just jump into dirty topics\nlike that... I'm not telling!"
msgstr "Che schifo, non puoi saltare fuori con argomenti sconci\nin questo modo... Non te lo dico!"

msgctxt "7||speech_list_caba_hikaru||table||404||||4"
msgid "What? You really want to know that much?\nWell... I can make an exception just for you."
msgstr "Cosa? Vuoi davvero saperlo così tanto?\nBeh... Posso fare un'eccezione solo per te."

msgctxt "7||speech_list_caba_hikaru||table||405||||4"
msgid "Okay..."
msgstr "Va bene..."

msgctxt "7||speech_list_caba_hikaru||table||406||||4"
msgid "It's actually... zero."
msgstr "In realtà... è zero."

msgctxt "7||speech_list_caba_hikaru||table||407||||4"
msgid "You're lying..."
msgstr "Stai mentendo..."

msgctxt "7||speech_list_caba_hikaru||table||408||||4"
msgid "It's not a lie... <symbol=note_with_outline>\nIdols don't do stuff like that. <symbol=note_with_outline>"
msgstr "Non è una bugia... <symbol=note_with_outline>\nLe idol non fanno quel genere di cose. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||409||||4"
msgid "That's pretty cool..."
msgstr "È molto figo..."

msgctxt "7||speech_list_caba_hikaru||table||410||||4"
msgid "Oh... You're into that, Kiryu-san?"
msgstr "Oh... Ti piacciono queste cose, Kiryu-san?"

msgctxt "7||speech_list_caba_hikaru||table||411||||4"
msgid "Then I'll volunteer to be the first...\nKidding, of course."
msgstr "Allora mi offro volontaria per essere la prima...\nScherzo, ovviamente."

msgctxt "7||speech_list_caba_hikaru||table||412||||4"
msgid "Oh, Kiryu-san. I hope you stay in the running. <symbol=heart_with_outline>"
msgstr "Oh, Kiryu-san. Spero che resterai in lizza. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||413||||4"
msgid "No boyfriend here! Right now I'm focused\non my job and my dream."
msgstr "Nessun fidanzato qui! In questo momento sono concentrata\nsul mio lavoro e sul mio sogno."

msgctxt "7||speech_list_caba_hikaru||table||414||||4"
msgid "Can't say that I do."
msgstr "Non si può dire che io ce l'abbia."

msgctxt "7||speech_list_caba_hikaru||table||415||||4"
msgid "Aren't you lonely?"
msgstr "Non ti senti solo?"

msgctxt "7||speech_list_caba_hikaru||table||416||||4"
msgid "When I'm lonely, I just think about you,\nKiryu-san. <symbol=heart_with_outline>"
msgstr "Quando mi sento sola, penso semplicemente a te,\nKiryu-san. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||417||||4"
msgid "You know how to make me happy."
msgstr "Sai proprio come farmi felice."

msgctxt "7||speech_list_caba_hikaru||table||418||||4"
msgid "My dream is to become an idol, so I figured\nthis might give me some good experience."
msgstr "Il mio sogno è diventare un'idol, quindi ho pensato\nche questo mi avrebbe dato un po' di buona esperienza."

msgctxt "7||speech_list_caba_hikaru||table||419||||4"
msgid "Huh. I guess idols and hostesses do have sort\nof similar traits, like..."
msgstr "Mhm. Immagino che idol e hostess abbiano in\neffetti dei tratti simili, ad esempio..."

msgctxt "7||speech_list_caba_hikaru||table||420||||4"
msgid "Needing communication skills?"
msgstr "Le doti comunicative?"

msgctxt "7||speech_list_caba_hikaru||table||421||||4"
msgid "Oh, I'm impressed that you see that.\nThat's right! <symbol=note_with_outline>"
msgstr "Oh, sono colpita che tu l'abbia capito.\nEsatto! <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||422||||4"
msgid "These days, an idol has to do a lot more\nthan just be a good singer."
msgstr "Al giorno d'oggi, un'idol deve saper fare molto\ndi più che cantare bene."

msgctxt "7||speech_list_caba_hikaru||table||423||||4"
msgid "I figured I could put some polish on my\ncommunication skills as a hostess."
msgstr "Ho pensato che avrei potuto affinare le\nmie doti comunicative facendo la hostess."

msgctxt "7||speech_list_caba_hikaru||table||424||||4"
msgid "That does seem like it would be good\nexperience. Best of luck to you."
msgstr "Sembra proprio un'ottima esperienza\nformativa. In bocca al lupo."

msgctxt "7||speech_list_caba_hikaru||table||425||||4"
msgid "Yep! Thank you!"
msgstr "Sì! Grazie mille!"

msgctxt "7||speech_list_caba_hikaru||table||426||||4"
msgid "Guys fawning over you?"
msgstr "Gli uomini che ti sbavano dietro?"

msgctxt "7||speech_list_caba_hikaru||table||427||||4"
msgid "Not at all! I meant both jobs rely pretty\nheavily on communication skills."
msgstr "Niente affatto! Intendevo dire che entrambi i lavori fanno\nun forte affidamento sulle doti comunicative."

msgctxt "7||speech_list_caba_hikaru||table||428||||4"
msgid "Oh, right."
msgstr "Oh, giusto."

msgctxt "7||speech_list_caba_hikaru||table||429||||4"
msgid "Although, being fawned over isn't so bad,\neither... <symbol=note_with_outline>"
msgstr "Anche se, avere uomini che ti sbavano dietro non è poi così\nmale... <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||430||||4"
msgid "Being able to sleep your way to the top?"
msgstr "Poter andare a letto con la gente per fare carriera?"

msgctxt "7||speech_list_caba_hikaru||table||431||||4"
msgid "What? Why would you say that? That's not it at all.\nI meant both jobs need strong communication skills."
msgstr "Cosa? Perché dici una cosa simile? Non è affatto così.\nIntendevo che entrambi i lavori richiedono ottime doti comunicative."

msgctxt "7||speech_list_caba_hikaru||table||432||||4"
msgid "And, you can't just sleep with people to get ahead,\nokay? At least, I don't!"
msgstr "E poi, non si può fare carriera andando a letto con la gente,\nokay? O, per lo meno, io non lo faccio!"

msgctxt "7||speech_list_caba_hikaru||table||433||||4"
msgid "Oh, good idea.\nI'll be the princess, then!"
msgstr "Oh, buona idea.\nAllora io farò la principessa!"

msgctxt "7||speech_list_caba_hikaru||table||434||||4"
msgid "Uh, do you even know what the king game is?"
msgstr "Ehm, sai almeno in cosa consiste il gioco del re?"

msgctxt "7||speech_list_caba_hikaru||table||435||||4"
msgid "Kiryu-san, don't get all high and mighty on me!"
msgstr "Kiryu-san, non darti arie con me!"

msgctxt "7||speech_list_caba_hikaru||table||436||||4"
msgid "I listen to a lot of rock, but I like lots of other stuff.\nI go to music festivals sometimes, too."
msgstr "Ascolto molto rock, ma mi piacciono anche tante altre cose.\nA volte vado anche ai festival musicali."

msgctxt "7||speech_list_caba_hikaru||table||437||||4"
msgid "Yeah! I'm having fun, too. <symbol=note_with_outline>"
msgstr "Sì! Mi sto divertendo anch'io. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||438||||4"
msgid "I know, right? I don't really like the winter...\nI just want spring to last aaaaall year."
msgstr "Vero? A me non piace molto l'inverno...\nVorrei che la primavera durasse per tuuuuutto l'anno."

msgctxt "7||speech_list_caba_hikaru||table||439||||4"
msgid "Really? I get the warm and fuzzies when\nyou're around, Kiryu-san. <symbol=note_with_outline>"
msgstr "Davvero? Io sento un certo calduccio quando sei\nnei paraggi, Kiryu-san. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||440||||4"
msgid "What does that even mean?"
msgstr "Che cosa dovrebbe significare?"

msgctxt "7||speech_list_caba_hikaru||table||441||||4"
msgid "Glad to hear it! <symbol=note_with_outline>"
msgstr "Sono contenta di sentirlo! <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||442||||4"
msgid "You say that to all the girls, don't you?"
msgstr "Lo dici a tutte le ragazze, non è vero?"

msgctxt "7||speech_list_caba_hikaru||table||443||||4"
msgid "Oh gosh, I don't know what to say... <symbol=heart_with_outline>"
msgstr "Oh cielo, non so cosa dire... <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||444||||4"
msgid "Yahoo!"
msgstr "Yahoo!"

msgctxt "7||speech_list_caba_hikaru||table||445||||4"
msgid "You're like a cute little boy, Kiryu-san. <symbol=note_with_outline>"
msgstr "Sembri un ragazzino adorabile, Kiryu-san. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||446||||4"
msgid "Hello to you too! Greetings are the\nfoundation of human interaction."
msgstr "Ciao anche a te! I saluti sono la base delle\ninterazioni umane."

msgctxt "7||speech_list_caba_hikaru||table||447||||4"
msgid "What? No way! This isn't that kind of club!"
msgstr "Cosa? Non se ne parla! Questo non è quel genere di club!"

msgctxt "7||speech_list_caba_hikaru||table||448||||4"
msgid "...You flatter me. <symbol=note_with_outline>"
msgstr "...Mi lusinghi. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||449||||4"
msgid "You probably say that to everyone, right?"
msgstr "Probabilmente lo dici a tutte, non è vero?"

msgctxt "7||speech_list_caba_hikaru||table||450||||4"
msgid "[Beautiful eyes...]"
msgstr "[Begli occhi...]"

msgctxt "7||speech_list_caba_hikaru||table||451||||4"
msgid "How nice... <symbol=heart_with_outline>"
msgstr "Che bello... <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||452||||4"
msgid "Whaaat? But looking at one person all\nthe time is pretty boring..."
msgstr "Cooosa? Ma guardare sempre e solo una\npersona è piuttosto noioso..."

msgctxt "7||speech_list_caba_hikaru||table||453||||4"
msgid "Hmmmm... That's a secret. <symbol=note_with_outline>"
msgstr "Mhm... Questo è un segreto. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||454||||4"
msgid "Hmm, let me think... Yes. <symbol=note_with_outline>"
msgstr "Mhm, fammici pensare... Sì. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||455||||4"
msgid "Oh, is that so? Who?"
msgstr "Ah, davvero? Chi?"

msgctxt "7||speech_list_caba_hikaru||table||456||||4"
msgid "Hmm... I can't tell you... <symbol=heart_with_outline>"
msgstr "Mhm... Non posso dirtelo... <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||457||||4"
msgid "...I see."
msgstr "...Capisco."

msgctxt "7||speech_list_caba_hikaru||table||458||||4"
msgid "Yes, I do. <symbol=heart_with_outline>"
msgstr "Sì, ce l'ho. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||459||||4"
msgid "Really? Who?"
msgstr "Davvero? E chi è?"

msgctxt "7||speech_list_caba_hikaru||table||460||||4"
msgid "Huh?  You're going to make me say it? <symbol=heart_with_outline>"
msgstr "Eh?  Vuoi costringermi a dirlo? <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||461||||4"
msgid "Is it someone I know?"
msgstr "È qualcuno che conosco?"

msgctxt "7||speech_list_caba_hikaru||table||462||||4"
msgid "Hey, don't ask for hints...\nIt's... the person you know best. <symbol=heart_with_outline>"
msgstr "Ehi, non chiedermi indizi...\nÈ... la persona che conosci meglio. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||463||||4"
msgid "Hm? The person I know best?"
msgstr "Mhm? La persona che conosco meglio?"

msgctxt "7||speech_list_caba_hikaru||table||464||||4"
msgid "Wait... Is it Date-san!?\nYou're in love with Makoto Date!?"
msgstr "Aspetta... È Date-san!?\nSei innamorata di Makoto Date!?"

msgctxt "7||speech_list_caba_hikaru||table||465||||4"
msgid "What? I don't even know who that is!\nYou're so dense, Kiryu-san."
msgstr "Cosa? Non so nemmeno chi sia!\nSei proprio di coccio, Kiryu-san."

msgctxt "7||speech_list_caba_hikaru||table||466||||4"
msgid "Wait... Is it the Florist!?"
msgstr "Aspetta... È il Fioraio!?"

msgctxt "7||speech_list_caba_hikaru||table||467||||4"
msgid "Wait... Is it me? No way..."
msgstr "Aspetta... Sono io? Impossibile..."

msgctxt "7||speech_list_caba_hikaru||table||468||||4"
msgid "Oh, Kiryu-san... <symbol=heart_with_outline>"
msgstr "Oh, Kiryu-san... <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||469||||4"
msgid "Oh no! I better make sure I don't fall\nin love with you, then."
msgstr "Oh no! Allora sarà meglio assicurarmi\ndi non innamorarmi di te."

msgctxt "7||speech_list_caba_hikaru||table||470||||4"
msgid "Thank you very much. <symbol=note_with_outline>"
msgstr "Grazie mille. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||471||||4"
msgid "There's a bar I like just down the street\nfrom the club. Their fried eggs are sooo good!"
msgstr "C'è un bar che mi piace proprio in fondo alla strada,\nuscendo dal club. Le loro uova fritte sono buoooonissime!"

msgctxt "7||speech_list_caba_hikaru||table||472||||4"
msgid "No, and I don't even want to talk about it!"
msgstr "No, e non ne voglio nemmeno parlare!"

msgctxt "7||speech_list_caba_hikaru||table||473||||4"
msgid "No, and I wish you wouldn't bring\nthat kind of stuff up..."
msgstr "No, e vorrei che non tirassi fuori\nquel genere di cose..."

msgctxt "7||speech_list_caba_hikaru||table||474||||4"
msgid "Why?"
msgstr "Perché?"

msgctxt "7||speech_list_caba_hikaru||table||475||||4"
msgid "I mean... it's not really the kind of thing you\nwant to hear from someone you like..."
msgstr "Voglio dire... non è esattamente il tipo di cosa che\nvorresti sentire dalla persona che ti piace..."

msgctxt "7||speech_list_caba_hikaru||table||476||||4"
msgid "What am I saying!?\nI'm sorry, forget I said that!"
msgstr "Cosa sto dicendo!?\nScusami, dimentica che l'ho detto!"

msgctxt "7||speech_list_caba_hikaru||table||477||||4"
msgid "Uh... Sure..."
msgstr "Ehm... Certo..."

msgctxt "7||speech_list_caba_hikaru||table||478||||4"
msgid "What!? You made a mess of a convenience store?\nI really feel for the poor employees..."
msgstr "Cosa!? Hai distrutto un minimarket?\nMi dispiace davvero per i poveri dipendenti..."

msgctxt "7||speech_list_caba_hikaru||table||479||||4"
msgid "But, you regret doing it, right?"
msgstr "Ma, te ne sei pentito, vero?"

msgctxt "7||speech_list_caba_hikaru||table||480||||4"
msgid "Yeah, of course I feel bad about it."
msgstr "Sì, certo che mi dispiace."

msgctxt "7||speech_list_caba_hikaru||table||481||||4"
msgid "Yes, yes, good, good. <symbol=note_with_outline>"
msgstr "Sì, sì, bene, bene. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||482||||4"
msgid "Not everyone's capable of reflecting on their\nactions. You're a good person, Kazuma-chan. <symbol=note_with_outline>"
msgstr "Non tutti sono capaci di riflettere sulle proprie\nazioni. Sei una brava persona, Kazuma-chan. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||483||||4"
msgid "I'll take the compliment as an honor."
msgstr "Prenderò il complimento come un onore."

msgctxt "7||speech_list_caba_hikaru||table||484||||4"
msgid "No, see, it wasn't my fault."
msgstr "No, vedi, non è stata colpa mia."

msgctxt "7||speech_list_caba_hikaru||table||485||||4"
msgid "Huh? But aren't you the one who messed it up?"
msgstr "Eh? Ma non sei tu quello che ha fatto il casino?"

msgctxt "7||speech_list_caba_hikaru||table||486||||4"
msgid "I think you need to consider that, at the very least.\nOpen your eyes to the truth, Kazuma-chan!"
msgstr "Come minimo dovresti tenerne conto.\nApri gli occhi alla verità, Kazuma-chan!"

msgctxt "7||speech_list_caba_hikaru||table||487||||4"
msgid "Sorry."
msgstr "Scusa."

msgctxt "7||speech_list_caba_hikaru||table||488||||4"
msgid "It's not healthy to keep that kind\nof stuff all bottled up, you know?"
msgstr "Non fa bene tenersi tutto dentro\nin questo modo, sai?"

msgctxt "7||speech_list_caba_hikaru||table||489||||4"
msgid "If you need a stiff drink to forget the past\nevery once in a while, sometimes that's okay, too."
msgstr "Se ogni tanto hai bisogno di bere forte per\ndimenticare il passato, a volte va bene anche così."

msgctxt "7||speech_list_caba_hikaru||table||490||||4"
msgid "Yeah... Thanks for that."
msgstr "Sì... Grazie."

msgctxt "7||speech_list_caba_hikaru||table||491||||4"
msgid "You lost someone important to you, huh?"
msgstr "Hai perso una persona importante per te, eh?"

msgctxt "7||speech_list_caba_hikaru||table||492||||4"
msgid "Yeah. We... did a lot of stupid stuff together."
msgstr "Sì. Ne abbiamo... fatte di stupidaggini insieme."

msgctxt "7||speech_list_caba_hikaru||table||493||||4"
msgid "But he's probably happy that you remember\nhim like this, Kiryu-san."
msgstr "Ma probabilmente lui è felice che tu lo\nricordi in questo modo, Kiryu-san."

msgctxt "7||speech_list_caba_hikaru||table||494||||4"
msgid "I'm sure he's smiling down from heaven."
msgstr "Sono certa che ti stia sorridendo dal paradiso."

msgctxt "7||speech_list_caba_hikaru||table||495||||4"
msgid "...I hope so."
msgstr "...Lo spero."

msgctxt "7||speech_list_caba_hikaru||table||496||||4"
msgid "Hmm... Deep topics like this are hard for me...\nI don't have a whole lot of friends myself, so..."
msgstr "Mhm... Discorsi profondi come questo sono difficili per me...\nNemmeno io ho un sacco di amici, quindi..."

msgctxt "7||speech_list_caba_hikaru||table||497||||4"
msgid "Wow, really? Now that you mention it,\nI think you'd make a great dad, Kiryu-san."
msgstr "Wow, sul serio? Ora che mi ci fai pensare,\ncredo che saresti un papà fantastico, Kiryu-san."

msgctxt "7||speech_list_caba_hikaru||table||498||||4"
msgid "Y-You think?"
msgstr "D-Dici?"

msgctxt "7||speech_list_caba_hikaru||table||499||||4"
msgid "Yeah! If I was going to get married, I'd want\na husband who'd be good with babies."
msgstr "Sì! Se mai dovessi sposarmi, vorrei un\nmarito che ci sappia fare con i bambini."

msgctxt "7||speech_list_caba_hikaru||table||500||||4"
msgid "You're a fisherman, Kiryu-san? That's amazing. <symbol=note_with_outline>\nI can't swim, so it seems really cool to me."
msgstr "Sei un pescatore, Kiryu-san? È incredibile. <symbol=note_with_outline>\nIo non so nuotare, quindi mi sembra una cosa fighissima."

msgctxt "7||speech_list_caba_hikaru||table||501||||4"
msgid "Whoa... I don't really get it, but I feel bad\nfor you. Kiryu-san... Stay strong, please!"
msgstr "Whoa... Non l'ho capito del tutto, ma mi dispiace\nper te. Kiryu-san... Sii forte, mi raccomando!"

msgctxt "7||speech_list_caba_hikaru||table||502||||4"
msgid "That's probably because you walk around\nwith a constant scowl!"
msgstr "Probabilmente è perché vai sempre in giro\ncon lo sguardo perennemente accigliato!"

msgctxt "7||speech_list_caba_hikaru||table||503||||4"
msgid "If you strutted down the street with a cute\nsmile, I bet you'd get picked on less."
msgstr "Se ti facessi una passeggiata sfoggiando un bel\nsorriso, scommetto che ti prenderebbero meno di mira."

msgctxt "7||speech_list_caba_hikaru||table||504||||4"
msgid "In my case, that might get me into even\nmore fights, actually..."
msgstr "Nel mio caso, potrebbe farmi finire\nin ancora più risse, a dirla tutta..."

msgctxt "7||speech_list_caba_hikaru||table||505||||4"
msgid "Pocket Circuit...? What's that?"
msgstr "Pocket Circuit...? Cos'è?"

msgctxt "7||speech_list_caba_hikaru||table||506||||4"
msgid "Oh, really? I think you're buff enough\nas it is, don't you?"
msgstr "Ah, davvero? Credo che tu sia già\nabbastanza muscoloso così, non ti pare?"

msgctxt "7||speech_list_caba_hikaru||table||507||||4"
msgid "Me either.\nI prefer a relaxed atmosphere much more."
msgstr "Nemmeno io.\nPreferisco di gran lunga un'atmosfera rilassata."

msgctxt "7||speech_list_caba_hikaru||table||508||||4"
msgid "Oh really? You kinda look like the type to\nbe aggressive, though."
msgstr "Ah, davvero? Eppure sembri il tipo che\nprende sempre l'iniziativa."

msgctxt "7||speech_list_caba_hikaru||table||509||||4"
msgid "Really? Same here, actually. Kind of weird\nto say that in this job, though, huh? <symbol=note_with_outline>"
msgstr "Davvero? Anche per me è così, in effetti. Però è un po' strano\ndirlo, considerando il lavoro che faccio, eh? <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||510||||4"
msgid "Is that so? But maybe the two of us\nbeing like that makes us more compatible."
msgstr "Ah sì? Ma forse il fatto che siamo entrambi\ncosì ci rende più compatibili."

msgctxt "7||speech_list_caba_hikaru||table||511||||4"
msgid "Yeah! I hope we keep getting\nalong like this, Kiryu-san."
msgstr "Sì! Spero che continueremo ad andare\nd'accordo in questo modo, Kiryu-san."

msgctxt "7||speech_list_caba_hikaru||table||512||||4"
msgid "You must be pretty loaded, Kiryu-san. But what\nI like about a cheap bar is how casual they are."
msgstr "Devi essere pieno di soldi, Kiryu-san. Ma ciò che a me\npiace dei bar economici è l'atmosfera alla mano."

msgctxt "7||speech_list_caba_hikaru||table||513||||4"
msgid "Hmmmm... Maybe, 40?"
msgstr "Mhm... Forse 40?"

msgctxt "7||speech_list_caba_hikaru||table||514||||4"
msgid "Close. I'm 48."
msgstr "Ci sei andata vicina. Ho 48 anni."

msgctxt "7||speech_list_caba_hikaru||table||515||||4"
msgid "What!? Really!? You're older than my dad."
msgstr "Cosa!? Davvero!? Sei più vecchio di mio padre."

msgctxt "7||speech_list_caba_hikaru||table||516||||4"
msgid "Older... than your dad...?"
msgstr "Più vecchio... di tuo padre...?"

msgctxt "7||speech_list_caba_hikaru||table||517||||4"
msgid "......"
msgstr "......"

msgctxt "7||speech_list_caba_hikaru||table||518||||4"
msgid "Huh? Something wrong, Kiryu-san?\nKiryu-saaaan?"
msgstr "Eh? Qualcosa non va, Kiryu-san?\nKiryu-saaaan?"

msgctxt "7||speech_list_caba_hikaru||table||519||||4"
msgid "Let's see... I think you're a good guy. <symbol=note_with_outline>"
msgstr "Vediamo... Penso che tu sia un brav'uomo. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||520||||4"
msgid "I think you're a very handsome\nand kind of mischievous person... <symbol=heart_with_outline>"
msgstr "Penso che tu sia molto affascinante\ne un tipo un po' dispettoso... <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||521||||4"
msgid "If I had to pick, older, I guess.\nI prefer a refined, mature man."
msgstr "Se dovessi scegliere, direi i più grandi.\nPreferisco gli uomini maturi e raffinati."

msgctxt "7||speech_list_caba_hikaru||table||522||||4"
msgid "My fetish is secret conversations. I like\neavesdropping on people whispering to each other."
msgstr "Il mio feticismo sono le conversazioni segrete. Mi piace\norigliare le persone che sussurrano tra loro."

msgctxt "7||speech_list_caba_hikaru||table||523||||4"
msgid "Huh... That's an unusual fetish."
msgstr "Mhm... È un feticismo piuttosto insolito."

msgctxt "7||speech_list_caba_hikaru||table||524||||4"
msgid "Oh, you're speaking my language, Kiryu-san!\nI got kind of excited just now. <symbol=heart_with_outline>"
msgstr "Oh, parli proprio la mia lingua, Kiryu-san!\nMi sono appena emozionata un bel po'. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||525||||4"
msgid "What I want the most right now? I'm in college,\nso I want credits and a completed thesis!"
msgstr "Cosa desidero di più in questo momento? Sono all'università,\nquindi voglio i crediti e una tesi finita!"

msgctxt "7||speech_list_caba_hikaru||table||526||||4"
msgid "It was in middle school, I think.\nIt ended up unrequited, though."
msgstr "Credo sia stato alle scuole medie.\nAnche se alla fine non sono stata ricambiata."

msgctxt "7||speech_list_caba_hikaru||table||527||||4"
msgid "You didn't confess?"
msgstr "Non ti sei dichiarata?"

msgctxt "7||speech_list_caba_hikaru||table||528||||4"
msgid "I couldn't do it! I used to get butterflies just talking\nto him, so I could barely form coherent sentences."
msgstr "Non ci sono riuscita! Mi sentivo le farfalle nello stomaco solo\na parlargli, perciò riuscivo a malapena a mettere in fila due parole."

msgctxt "7||speech_list_caba_hikaru||table||529||||4"
msgid "You used to be pretty innocent, huh?"
msgstr "Eri piuttosto innocente, eh?"

msgctxt "7||speech_list_caba_hikaru||table||530||||4"
msgid "I'm still innocent now!"
msgstr "Sono innocente anche adesso!"

msgctxt "7||speech_list_caba_hikaru||table||531||||4"
msgid "Gross, you can't just jump into dirty topics\nlike that... I'm not telling!"
msgstr "Che schifo, non puoi saltare fuori con argomenti sconci\nin questo modo... Non te lo dico!"

msgctxt "7||speech_list_caba_hikaru||table||532||||4"
msgid "Oh, Kiryu-san. I'm only telling because it's\nyou, okay? They're white... <symbol=heart_with_outline>"
msgstr "Oh, Kiryu-san. Te lo dico solo perché sei\ntu, d'accordo? Sono bianchi... <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||533||||4"
msgid "Ooh..."
msgstr "Ooh..."

msgctxt "7||speech_list_caba_hikaru||table||534||||4"
msgid "Marriage, huh? I'd like to someday, but I don't\nfeel like I'm ready where I'm at now."
msgstr "Il matrimonio, eh? Mi piacerebbe un giorno, ma non credo\ndi essere pronta, vista la situazione in cui mi trovo adesso."

msgctxt "7||speech_list_caba_hikaru||table||535||||4"
msgid "Really? You seem like you'd be popular with\nthe guys. You'd have no problem settling down."
msgstr "Davvero? Sembri il tipo popolare tra i ragazzi.\nNon avresti alcun problema a sistemarti."

msgctxt "7||speech_list_caba_hikaru||table||536||||4"
msgid "Hm... I'm just still so unsure. Is the guy\nfor me out there somewhere?"
msgstr "Mhm... Sono solo ancora così insicura. Il ragazzo\nche fa per me sarà là fuori, da qualche parte?"

msgctxt "7||speech_list_caba_hikaru||table||537||||4"
msgid "Huh? Really? Maybe you should propose\nthen, Kiryu-san!"
msgstr "Eh? Davvero? Forse allora dovresti fare tu\nla proposta, Kiryu-san!"

msgctxt "7||speech_list_caba_hikaru||table||538||||4"
msgid "Wha<symbol=em_dash_with_outline>What are you trying to say!?"
msgstr "Co<symbol=em_dash_with_outline>Cosa stai cercando di dire!?"

msgctxt "7||speech_list_caba_hikaru||table||539||||4"
msgid "Just kidding. <symbol=note_with_outline>"
msgstr "Scherzavo. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||540||||4"
msgid "You don't... want me?"
msgstr "Non mi... vuoi?"

msgctxt "7||speech_list_caba_hikaru||table||541||||4"
msgid "I-It's not that... There's just a proper\norder to these things, and..."
msgstr "N-Non è quello... C'è un ordine preciso per\nfare queste cose, e..."

msgctxt "7||speech_list_caba_hikaru||table||542||||4"
msgid "Right... Well even if the timing's wrong,\nI won't give up just yet. <symbol=heart_with_outline>"
msgstr "Certo... Beh, anche se il tempismo è sbagliato,\nnon mi arrenderò tanto facilmente. <symbol=heart_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||543||||4"
msgid "Hey, what's that supposed to mean?\nYou make it sound like I need it to look good."
msgstr "Ehi, che cosa dovrebbe significare?\nSembra che io abbia bisogno del trucco per essere carina."

msgctxt "7||speech_list_caba_hikaru||table||544||||4"
msgid "N-No, that's not what I meant..."
msgstr "N-No, non è quello che intendevo..."

msgctxt "7||speech_list_caba_hikaru||table||545||||4"
msgid "Just kidding. <symbol=note_with_outline> I'm happy to hear it.\nThank you. <symbol=note_with_outline>"
msgstr "Scherzavo. <symbol=note_with_outline> Mi fa piacere sentirlo.\nGrazie. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||546||||4"
msgid "Huh? Umm, I don't think so...\nMaybe in our previous lives."
msgstr "Eh? Ehm, non credo proprio...\nForse nelle nostre vite precedenti."

msgctxt "7||speech_list_caba_hikaru||table||547||||4"
msgid "It's nice to hear, even if you are just trying to\nflatter me. I'm pretty proud of my butt, actually!"
msgstr "È bello da sentire, anche se stai solo cercando di adularmi.\nIn realtà, sono piuttosto fiera del mio fondoschiena!"

msgctxt "7||speech_list_caba_hikaru||table||548||||4"
msgid "Cheating? I hear a lot about celebrities\ncheating on each other these days..."
msgstr "Tradimento? Sento spesso parlare di celebrità che\nsi tradiscono a vicenda di questi tempi..."

msgctxt "7||speech_list_caba_hikaru||table||549||||4"
msgid "If you got married, would you be\nthe type to cheat, Kiryu-san?"
msgstr "Se ti sposassi, saresti il\ntipo che tradisce, Kiryu-san?"

msgctxt "7||speech_list_caba_hikaru||table||550||||4"
msgid "I would never!"
msgstr "Non lo farei mai!"

msgctxt "7||speech_list_caba_hikaru||table||551||||4"
msgid "Oh, is that so?"
msgstr "Ah, è così?"

msgctxt "7||speech_list_caba_hikaru||table||552||||4"
msgid "Well, maybe if you ever get married,\nI'll see if I can seduce you, then. <symbol=note_with_outline>"
msgstr "Beh, allora magari, se mai dovessi sposarti,\nvedrò se riesco a sedurti. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||553||||4"
msgid "I'd want to!"
msgstr "Ne avrei voglia!"

msgctxt "7||speech_list_caba_hikaru||table||554||||4"
msgid "At least you're honest. Hearing you admit\nit so boldly makes it sound a little less taboo."
msgstr "Se non altro sei sincero. Sentirtelo ammettere con così tanta\nsfrontatezza lo fa sembrare un tabù leggermente meno grave."

msgctxt "7||speech_list_caba_hikaru||table||555||||4"
msgid "Hmm... I think I prefer staying in to talk\nand relax or watch a movie, maybe."
msgstr "Mhm... Credo di preferire stare in casa a chiacchierare\ne rilassarmi, o magari guardare un film."

msgctxt "7||speech_list_caba_hikaru||table||556||||4"
msgid "Yeah, I'm the same way. I like the feeling of\nbeing at home in a place just for the two of us."
msgstr "Sì, anch'io. Mi piace quella sensazione di sentirsi\na casa, in un posto solo per noi due."

msgctxt "7||speech_list_caba_hikaru||table||557||||4"
msgid "I might not look it, but I was actually in the\nbasketball club! ...As the team manager."
msgstr "Magari non sembrerà, ma in realtà ero nel club\ndi basket! ...Come manager della squadra."

msgctxt "7||speech_list_caba_hikaru||table||558||||4"
msgid "Huh? The ones you're wearing right now?"
msgstr "Eh? Quelli che stai indossando in questo momento?"

msgctxt "7||speech_list_caba_hikaru||table||559||||4"
msgid "I wouldn't mind, but, Kiryu-san...\nDid you wet yourself?"
msgstr "A me non dispiacerebbe, ma, Kiryu-san...\nTi sei per caso fatto la pipì addosso?"

msgctxt "7||speech_list_caba_hikaru||table||560||||4"
msgid "Uh... Never mind. Forget it."
msgstr "Ehm... Lascia perdere. Dimenticalo."

msgctxt "7||speech_list_caba_hikaru||table||561||||4"
msgid "Okay! That comes in the ¥100,000 option! <symbol=note_with_outline>"
msgstr "Ricevuto! Ma fa parte del pacchetto da ¥100.000! <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||562||||4"
msgid "Oh, Kiryu-san.\nMy dad says the same thing. That's cute. <symbol=note_with_outline>"
msgstr "Oh, Kiryu-san.\nMio padre dice la stessa cosa. È adorabile. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||563||||4"
msgid "I pick mostly idol songs,\nbut I do hard rock a lot, too."
msgstr "Scelgo per lo più canzoni da idol,\nma canto spesso anche canzoni hard rock."

msgctxt "7||speech_list_caba_hikaru||table||564||||4"
msgid "Rock...? Do you know Machine Gun Kiss?"
msgstr "Rock...? Conosci Machine Gun Kiss?"

msgctxt "7||speech_list_caba_hikaru||table||565||||4"
msgid "Yeah! The one that goes, \"hyaku oku no KISS wo abisemasu\nyo?\" The one all those pretentious old guys like to sing?"
msgstr "Sì! Quella che fa: \"hyaku oku no KISS wo abisemasu\nyo?\" Quella che cantano tutti quei vecchi presuntuosi?"

msgctxt "7||speech_list_caba_hikaru||table||566||||4"
msgid "I don't think only pretentious older guys sing it..."
msgstr "Non credo che la cantino solo i vecchi presuntuosi..."

msgctxt "7||speech_list_caba_hikaru||table||567||||4"
msgid "Dangerous men? You mean, like, stalker guys?"
msgstr "Uomini pericolosi? Intendi, tipo degli stalker?"

msgctxt "7||speech_list_caba_hikaru||table||568||||4"
msgid "No, it's more nuanced than that..."
msgstr "No, ci sono più sfumature della cosa..."

msgctxt "7||speech_list_caba_hikaru||table||569||||4"
msgid "I don't really get it, but I say safety beats\ndanger every time."
msgstr "Non ho capito bene, ma dico che la sicurezza\nè meglio del pericolo, senza alcun dubbio."

msgctxt "7||speech_list_caba_hikaru||table||570||||4"
msgid "Wow... I've never met anyone quite like that."
msgstr "Wow... Non ho mai incontrato nessuno di simile."

msgctxt "7||speech_list_caba_hikaru||table||571||||4"
msgid "Date-san?"
msgstr "Date-san?"

msgctxt "7||speech_list_caba_hikaru||table||572||||4"
msgid "Yeah. He's a detective I've known for a long time.\nHe's... kind of like a partner to me."
msgstr "Sì. È un detective che conosco da molto tempo.\nÈ... una specie di partner per me."

msgctxt "7||speech_list_caba_hikaru||table||573||||4"
msgid "A partner, huh? <symbol=note_with_outline>\nYou must really like him, Kiryu-san."
msgstr "Un partner, eh? <symbol=note_with_outline>\nDeve piacerti proprio tanto, Kiryu-san."

msgctxt "7||speech_list_caba_hikaru||table||574||||4"
msgid "Yeah, I do."
msgstr "Sì, mi piace."

msgctxt "7||speech_list_caba_hikaru||table||575||||4"
msgid "I'm kind of jealous that you\nhave someone so close like that."
msgstr "Sono un po' gelosa che tu abbia\nuna persona così vicina a te."

msgctxt "7||speech_list_caba_hikaru||table||576||||4"
msgid "No, he's a pain in the ass."
msgstr "No, è solo una rottura di scatole."

msgctxt "7||speech_list_caba_hikaru||table||577||||4"
msgid "Oh you, you don't have to act all tough. <symbol=note_with_outline>"
msgstr "Oh dai, non c'è bisogno di fare sempre il duro. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||578||||4"
msgid "I like you better..."
msgstr "A me piaci di più tu..."

msgctxt "7||speech_list_caba_hikaru||table||579||||4"
msgid "Oh, Kiryu-san.\nI feel bad for Date-san now. <symbol=note_with_outline>"
msgstr "Oh, Kiryu-san.\nAdesso mi dispiace per Date-san. <symbol=note_with_outline>"

msgctxt "7||speech_list_caba_hikaru||table||580||||4"
msgid "Wow... He sounds like a pretty cool guy."
msgstr "Wow... Sembra proprio un tipo in gamba."

msgctxt "7||speech_list_caba_hikaru||table||581||||4"
msgid "Someone who's bigger than you, Kiryu-san?\nThat's something I'd like to see!"
msgstr "Qualcuno più grosso di te, Kiryu-san?\nÈ una cosa che vorrei proprio vedere!"

msgctxt "7||speech_list_caba_hikaru||table||582||||4"
msgid "Wow... You must really trust him, Kiryu-san."
msgstr "Wow... Devi fidarti proprio tanto di lui, Kiryu-san."

msgctxt "7||speech_list_caba_hikaru||table||583||||4"
msgid "That's so nice.\nI hope you can trust me like that, too."
msgstr "È una cosa bellissima.\nSpero che tu possa fidarti di me allo stesso modo."

msgctxt "7||speech_list_caba_hikaru||table||584||||4"
msgid "That'd be pretty great."
msgstr "Sarebbe davvero fantastico."

msgctxt "7||speech_list_caba_hikaru||table||585||||4"
msgid "Ah, it's famous for its ramen, right?\nI hope I get a chance to go someday."
msgstr "Ah, è famoso per il suo ramen, giusto?\nSpero di avere l'occasione di andarci, un giorno."

msgctxt "8||speech_list_caba_riona||table||0||||4"
msgid "Kiryu-san! Sorry to keep you waiting. <symbol=note_with_outline>"
msgstr "Kiryu-san! Scusami per l'attesa. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||1||||4"
msgid "Did I keep ya waiting...?"
msgstr "Ti ho fatto aspettare tanto...?"

msgctxt "8||speech_list_caba_riona||table||2||||4"
msgid "Kiryu-san!\nI was hopin' you'd come. <symbol=note_with_outline>"
msgstr "Kiryu-san!\nSperavo che saresti venuto. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||3||||4"
msgid "Where should we go?"
msgstr "Dove andiamo?"

msgctxt "8||speech_list_caba_riona||table||4||||4"
msgid "Karaoke, huh?\nSounds good. <symbol=note_with_outline>"
msgstr "Karaoke, eh?\nMi sta bene. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||5||||4"
msgid "I don't play darts much,\nso I'm looking forward to it!"
msgstr "Non gioco molto a freccette,\nquindi non vedo l'ora!"

msgctxt "8||speech_list_caba_riona||table||6||||4"
msgid "Let's get goin', shall we? <symbol=note_with_outline>"
msgstr "Ci incamminiamo, allora? <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||7||||4"
msgid "I'm curious about what song you'll sing. <symbol=heart_with_outline>"
msgstr "Sono curiosa di sentire cosa canterai. <symbol=heart_with_outline>"

msgctxt "8||speech_list_caba_riona||table||8||||4"
msgid "Hmm, what should I sing today? <symbol=note_with_outline>"
msgstr "Mhm, cosa dovrei cantare oggi? <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||9||||4"
msgid "I'm not that great,\nso go easy on me. <symbol=heart_with_outline>"
msgstr "Non sono bravissima,\nquindi vacci piano. <symbol=heart_with_outline>"

msgctxt "8||speech_list_caba_riona||table||10||||4"
msgid "Alright!\nI'll do my best!"
msgstr "D'accordo!\nFarò del mio meglio!"

msgctxt "8||speech_list_caba_riona||table||11||||4"
msgid "W-We're just getting started,\nso we can still have some fun...!"
msgstr "A-Abbiamo appena iniziato,\npossiamo ancora divertirci un po'...!"

msgctxt "8||speech_list_caba_riona||table||12||||4"
msgid "That was fun. <symbol=note_with_outline>\nTake me again sometime, hm?"
msgstr "È stato divertente. <symbol=note_with_outline>\nPortami di nuovo con te qualche volta, eh?"

msgctxt "8||speech_list_caba_riona||table||13||||4"
msgid "That was so fun! <symbol=heart_with_outline> It's tough to find a\ncustomer who's fun out on a date!"
msgstr "È stato divertentissimo! <symbol=heart_with_outline> È raro trovare un\ncliente con cui ci si diverta a uscire!"

msgctxt "8||speech_list_caba_riona||table||14||||4"
msgid "Well, it's about that time.\nWanna head back to the club?"
msgstr "Beh, si è fatta una certa.\nVuoi tornare al club?"

msgctxt "8||speech_list_caba_riona||table||15||||4"
msgid "Oh, I like this song. <symbol=heart_with_outline>\nI want you to hear it. <symbol=note_with_outline>"
msgstr "Oh, mi piace questa canzone. <symbol=heart_with_outline>\nVoglio fartela sentire. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||16||||4"
msgid "Oh, they have this song at karaoke? <symbol=note_with_outline>\nThat settles what I'm singin' then."
msgstr "Oh, hanno questa canzone al karaoke? <symbol=note_with_outline>\nAllora ho deciso cosa cantare."

msgctxt "8||speech_list_caba_riona||table||17||||4"
msgid "Hm... I can't seem to get into it today..."
msgstr "Mhm... Oggi non riesco a entrare nel mood..."

msgctxt "8||speech_list_caba_riona||table||18||||4"
msgid "Kiryu-san!\nIt's hard to sing with you like that..."
msgstr "Kiryu-san!\nÈ difficile cantare con te che fai così..."

msgctxt "8||speech_list_caba_riona||table||19||||4"
msgid "That was fun!\nYou've got this mood thing down. <symbol=heart_with_outline>"
msgstr "È stato divertente!\nSai proprio come creare l'atmosfera. <symbol=heart_with_outline>"

msgctxt "8||speech_list_caba_riona||table||20||||4"
msgid "That felt really good! <symbol=heart_with_outline>\nYou're so good at settin' the mood."
msgstr "È stato davvero bello! <symbol=heart_with_outline>\nSei bravissima a creare l'atmosfera giusta."

msgctxt "8||speech_list_caba_riona||table||21||||4"
msgid "Hey, you're gonna sing too, aren't you? <symbol=note_with_outline>"
msgstr "Ehi, canterai anche tu, vero? <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||22||||4"
msgid "Aww... I wanted to hear you sing..."
msgstr "Aww... Io volevo sentirti cantare..."

msgctxt "8||speech_list_caba_riona||table||23||||4"
msgid "Well, um... I got what you were going for!"
msgstr "Beh, uhm... Ho capito cosa volevi fare!"

msgctxt "8||speech_list_caba_riona||table||24||||4"
msgid "Your song was good, too. <symbol=note_with_outline>\nI was totally absorbed in it. <symbol=heart_with_outline>"
msgstr "Anche la tua canzone era bella. <symbol=note_with_outline>\nEro totalmente rapita. <symbol=heart_with_outline>"

msgctxt "8||speech_list_caba_riona||table||25||||4"
msgid "You're such a good singer!\nI could listen to you forever... <symbol=heart_with_outline>"
msgstr "Sei davvero bravo a cantare!\nPotrei ascoltarti all'infinito... <symbol=heart_with_outline>"

msgctxt "8||speech_list_caba_riona||table||26||||4"
msgid "Huh!? Really?\nDon't go too hard, okay?"
msgstr "Eh!? Davvero?\nNon esagerare, okay?"

msgctxt "8||speech_list_caba_riona||table||27||||4"
msgid "Thank you."
msgstr "Grazie."

msgctxt "8||speech_list_caba_riona||table||28||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "8||speech_list_caba_riona||table||29||||4"
msgid "Oh, that's tasty. <symbol=note_with_outline>\nI love this. <symbol=note_with_outline>"
msgstr "Oh, che buono. <symbol=note_with_outline>\nLo adoro. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||30||||4"
msgid "Excuse me."
msgstr "Permesso."

msgctxt "8||speech_list_caba_riona||table||31||||4"
msgid "Nice to meet you.\nI'm Riona."
msgstr "Piacere di conoscerti.\nSono Riona."

msgctxt "8||speech_list_caba_riona||table||32||||4"
msgid "May I ask your name, sir?"
msgstr "Posso chiederti come ti chiami?"

msgctxt "8||speech_list_caba_riona||table||33||||4"
msgid "Right. I'm Kiryu."
msgstr "Certo. Sono Kiryu."

msgctxt "8||speech_list_caba_riona||table||34||||4"
msgid "Kiryu-san, then? I'm looking forward to\nspending some time with ya today."
msgstr "Kiryu-san, quindi? Non vedo l'ora di\npassare un po' di tempo con te, oggi."

msgctxt "8||speech_list_caba_riona||table||35||||4"
msgid "Yeah. Me too."
msgstr "Sì. Anch'io."

msgctxt "8||speech_list_caba_riona||table||36||||4"
msgid "Thanks, Kiryu-san. Today was fun."
msgstr "Grazie, Kiryu-san. Oggi mi sono divertita."

msgctxt "8||speech_list_caba_riona||table||37||||4"
msgid "If you'd like, come back again."
msgstr "Se ti fa piacere, torna a trovarmi."

msgctxt "8||speech_list_caba_riona||table||38||||4"
msgid "Yeah, I'll be back."
msgstr "Sì, tornerò."

msgctxt "8||speech_list_caba_riona||table||39||||4"
msgid "I'll be looking forward to it."
msgstr "Ti aspetterò."

msgctxt "8||speech_list_caba_riona||table||40||||4"
msgid "Come on in, Kiryu-san.\nI'm so glad you came back."
msgstr "Vieni pure, Kiryu-san.\nSono così felice che tu sia tornato."

msgctxt "8||speech_list_caba_riona||table||41||||4"
msgid "Come on in, Kiryu-san.\nI've been waiting for you...<symbol=heart_with_outline>"
msgstr "Vieni pure, Kiryu-san.\nTi stavo aspettando...<symbol=heart_with_outline>"

msgctxt "8||speech_list_caba_riona||table||42||||4"
msgid "Welcome back, Kiryu-san.\nI'm so happy you're here. <symbol=heart_with_outline>"
msgstr "Bentornato, Kiryu-san.\nSono felice che tu sia qui. <symbol=heart_with_outline>"

msgctxt "8||speech_list_caba_riona||table||43||||4"
msgid "I'm glad we got to spend more time\nthan usual with each other today. <symbol=heart_with_outline>"
msgstr "Sono felice che oggi abbiamo potuto passare\npiù tempo del solito insieme. <symbol=heart_with_outline>"

msgctxt "8||speech_list_caba_riona||table||44||||4"
msgid "Come on over here."
msgstr "Vieni qui."

msgctxt "8||speech_list_caba_riona||table||45||||4"
msgid "Kiryu-san!"
msgstr "Kiryu-san!"

msgctxt "8||speech_list_caba_riona||table||46||||4"
msgid "Thanks for coming in today.\nSee you soon?"
msgstr "Grazie per essere venuto oggi.\nCi vediamo presto?"

msgctxt "8||speech_list_caba_riona||table||47||||4"
msgid "Thanks for comin' today. <symbol=note_with_outline>\nYou'd better come back, okay? <symbol=heart_with_outline>"
msgstr "Grazie per essere venuto oggi. <symbol=note_with_outline>\nVedi di tornare ancora, intesi? <symbol=heart_with_outline>"

msgctxt "8||speech_list_caba_riona||table||48||||4"
msgid "Thanks. <symbol=note_with_outline>\nI want to see you again soon...<symbol=heart_with_outline>"
msgstr "Grazie. <symbol=note_with_outline>\nVoglio rivederti presto...<symbol=heart_with_outline>"

msgctxt "8||speech_list_caba_riona||table||49||||4"
msgid "See you later, Kiryu-san. <symbol=heart_with_outline>"
msgstr "A dopo, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "8||speech_list_caba_riona||table||50||||4"
msgid "Cheers!"
msgstr "Salute!"

msgctxt "8||speech_list_caba_riona||table||51||||4"
msgid "Oh, Kiryu-san.\nCan I give ya something?"
msgstr "Oh, Kiryu-san.\nPosso darti una cosa?"

msgctxt "8||speech_list_caba_riona||table||52||||4"
msgid "This is my phone number.\nCall me sometime, okay? <symbol=heart_with_outline>"
msgstr "Questo è il mio numero di telefono.\nChiamami qualche volta, d'accordo? <symbol=heart_with_outline>"

msgctxt "8||speech_list_caba_riona||table||53||||4"
msgid "It's almost time.\nWhat do you want to do?"
msgstr "È quasi ora.\nCosa vuoi fare?"

msgctxt "8||speech_list_caba_riona||table||54||||4"
msgid "It's time to go...\nI was having so much fun, time just flew on by."
msgstr "È ora di andare...\nMi stavo divertendo un mondo, il tempo è volato."

msgctxt "8||speech_list_caba_riona||table||55||||4"
msgid "Thanks, Kiryu-san. <symbol=heart_with_outline>"
msgstr "Grazie, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "8||speech_list_caba_riona||table||56||||4"
msgid "Thanks for today."
msgstr "Grazie per oggi."

msgctxt "8||speech_list_caba_riona||table||57||||4"
msgid "Oh, I see."
msgstr "Oh, capisco."

msgctxt "8||speech_list_caba_riona||table||58||||4"
msgid "Oh, that's true!"
msgstr "Oh, è vero!"

msgctxt "8||speech_list_caba_riona||table||59||||4"
msgid "Yeah, I think so too."
msgstr "Sì, lo penso anch'io."

msgctxt "8||speech_list_caba_riona||table||60||||4"
msgid "Yeah! You're right!"
msgstr "Sì! Hai ragione!"

msgctxt "8||speech_list_caba_riona||table||61||||4"
msgid "Huh? Really?"
msgstr "Eh? Sul serio?"

msgctxt "8||speech_list_caba_riona||table||62||||4"
msgid "I don't think so..."
msgstr "Non direi..."

msgctxt "8||speech_list_caba_riona||table||63||||4"
msgid "I don't think that's right..."
msgstr "Non credo sia esatto..."

msgctxt "8||speech_list_caba_riona||table||64||||4"
msgid "Hm... I wonder."
msgstr "Mhm... Mi domando."

msgctxt "8||speech_list_caba_riona||table||65||||4"
msgid "Oh, Kiryu-san."
msgstr "Oh, Kiryu-san."

msgctxt "8||speech_list_caba_riona||table||66||||4"
msgid "I wonder..."
msgstr "Chissà..."

msgctxt "8||speech_list_caba_riona||table||67||||4"
msgid "Wow, really?"
msgstr "Wow, sul serio?"

msgctxt "8||speech_list_caba_riona||table||68||||4"
msgid "Um, how was it?"
msgstr "Ehm, com'è andata?"

msgctxt "8||speech_list_caba_riona||table||69||||4"
msgid "It seems like you've been doing this for\na while. Do you have any tricks of the trade?"
msgstr "Sembra che tu faccia questo lavoro da\nun bel po'. Hai qualche trucco del mestiere?"

msgctxt "8||speech_list_caba_riona||table||70||||4"
msgid "I wouldn't say I have any tricks...\nBut I do try to be an upstanding hostess."
msgstr "Non direi di avere dei trucchi...\nMa cerco di essere una hostess onesta."

msgctxt "8||speech_list_caba_riona||table||71||||4"
msgid "An upstanding hostess?"
msgstr "Una hostess onesta?"

msgctxt "8||speech_list_caba_riona||table||72||||4"
msgid "Yeah. I try not to make my customers spend any\nmore than they have to, and I don't push the drinks."
msgstr "Sì. Cerco di non far spendere ai clienti\npiù del dovuto, e non forzo le consumazioni."

msgctxt "8||speech_list_caba_riona||table||73||||4"
msgid "Is that okay, though? Isn't the hostess trade\nall about making customers spend big?"
msgstr "E ti va bene così? Il lavoro da hostess non si basa\ntutto sul far spendere un sacco ai clienti?"

msgctxt "8||speech_list_caba_riona||table||74||||4"
msgid "That's true enough, but...\nI can't really get behind that."
msgstr "In parte è vero, ma...\nnon riesco proprio a condividerlo."

msgctxt "8||speech_list_caba_riona||table||75||||4"
msgid "Not every customer's gonna be loaded, and if I\npushed them to spend, they'd end up suffering..."
msgstr "Non tutti i clienti sono pieni di soldi, e se li\nspingessi a spendere, finirebbero per rimetterci..."

msgctxt "8||speech_list_caba_riona||table||76||||4"
msgid "I don't think of my job as making them pay, but\nmore of givin' them the service they pay for."
msgstr "Non vedo il mio lavoro come farli pagare, ma\npiuttosto come offrire loro il servizio per cui pagano."

msgctxt "8||speech_list_caba_riona||table||77||||4"
msgid "If they go home satisfied, they'll request me\nagain, and everyone's happy, aren't they?"
msgstr "Se tornano a casa soddisfatti, mi chiederanno\ndi nuovo, e tutti saranno felici, no?"

msgctxt "8||speech_list_caba_riona||table||78||||4"
msgid "But sales are everything to a hostess, aren't\nthey? Aren't you being too considerate of them?"
msgstr "Ma gli incassi sono tutto per una hostess,\nno? Non sei un po' troppo accomodante?"

msgctxt "8||speech_list_caba_riona||table||79||||4"
msgid "I get that a lot.\nBut, I just want my customers to be happy."
msgstr "Me lo dicono spesso.\nMa voglio solo che i miei clienti siano felici."

msgctxt "8||speech_list_caba_riona||table||80||||4"
msgid "So, I don't want them to stretch themselves so thin.\nI want them here, and if they do, they'll stop coming."
msgstr "Quindi, non voglio che si prosciughino il portafoglio. Li voglio\nqui, e se si svenano, smetteranno di venire."

msgctxt "8||speech_list_caba_riona||table||81||||4"
msgid "I get it. I guess if you're looking at it in the\nlong term, that's not such a bad strategy."
msgstr "Ho capito. Immagino che, se la si guarda a\nlungo termine, non sia una cattiva strategia."

msgctxt "8||speech_list_caba_riona||table||82||||4"
msgid "Yeah. And the same goes for you, Kiryu-san.\nSo come back and see me again, okay?"
msgstr "Sì. E lo stesso vale per te, Kiryu-san.\nPerciò torna a trovarmi, d'accordo?"

msgctxt "8||speech_list_caba_riona||table||83||||4"
msgid "Sure."
msgstr "Certo."

msgctxt "8||speech_list_caba_riona||table||84||||4"
msgid "I think that's great.\nYou're really thinking about your customers."
msgstr "Penso che sia un'ottima cosa.\nPensi davvero ai tuoi clienti."

msgctxt "8||speech_list_caba_riona||table||85||||4"
msgid "Kiryu-san... That's wonderful.\nThank you."
msgstr "Kiryu-san... È meraviglioso.\nGrazie."

msgctxt "8||speech_list_caba_riona||table||86||||4"
msgid "If I can just relax and have fun here without\nworrying about money, I'm more likely to return."
msgstr "Se posso rilassarmi e divertirmi qui senza dovermi\npreoccupare dei soldi, è più probabile che ritorni."

msgctxt "8||speech_list_caba_riona||table||87||||4"
msgid "Glad to hear it. Havin' you back\nhere is what would make me happiest."
msgstr "Mi fa piacere sentirlo. Averti di nuovo\nqui è ciò che mi renderebbe più felice."

msgctxt "8||speech_list_caba_riona||table||88||||4"
msgid "I'm not exactly rich, myself.\nI'm glad you think that way."
msgstr "Neanch'io sono esattamente un riccone.\nSono felice che la pensi così."

msgctxt "8||speech_list_caba_riona||table||89||||4"
msgid "If I can just relax and have fun here without\nworrying about money, I'm more likely to come back."
msgstr "Se posso rilassarmi e divertirmi qui senza dovermi\npreoccupare dei soldi, è più probabile che ritorni."

msgctxt "8||speech_list_caba_riona||table||90||||4"
msgid "Glad to hear it. Havin' you back\nhere is what would make me happiest."
msgstr "Mi fa piacere sentirlo. Averti di nuovo\nqui è ciò che mi renderebbe più felice."

msgctxt "8||speech_list_caba_riona||table||91||||4"
msgid "All the hostesses at this club seem really good\nat the job. Are you guys given training?"
msgstr "Tutte le hostess in questo club sembrano davvero\nbrave nel loro lavoro. Ricevete una qualche formazione?"

msgctxt "8||speech_list_caba_riona||table||92||||4"
msgid "Not from the club... but I do give some\ninstruction to the younger girls myself."
msgstr "Non dal club... ma sono io stessa a dare\nqualche dritta alle ragazze più giovani."

msgctxt "8||speech_list_caba_riona||table||93||||4"
msgid "Oh, really? Well, you've certainly got the\nexperience. Did your boss ask you to?"
msgstr "Oh, davvero? Beh, l'esperienza di certo non\nti manca. Te lo ha chiesto il capo?"

msgctxt "8||speech_list_caba_riona||table||94||||4"
msgid "Nah, I do it just to do it.\nI try to point stuff out when I notice it."
msgstr "Nah, lo faccio e basta.\nCerco di far notare le cose quando me ne accorgo."

msgctxt "8||speech_list_caba_riona||table||95||||4"
msgid "I see. Well, it seems like it's working."
msgstr "Capisco. Beh, sembra che stia funzionando."

msgctxt "8||speech_list_caba_riona||table||96||||4"
msgid "Thanks. But, I'm sure some of them\nthink it's just a nuisance."
msgstr "Grazie. Ma sono sicura che alcune di loro\npensino che sia solo una seccatura."

msgctxt "8||speech_list_caba_riona||table||97||||4"
msgid "Does it bother you to be thought of that way?"
msgstr "Ti dà fastidio che possano pensarlo?"

msgctxt "8||speech_list_caba_riona||table||98||||4"
msgid "It does... but I'm okay with it if it\nmeans it helps them grow."
msgstr "Un po'... ma mi sta bene, se\nserve ad aiutarle a crescere."

msgctxt "8||speech_list_caba_riona||table||99||||4"
msgid "That's mature of you. I think that'll get\nthrough to them at some point or another."
msgstr "È molto maturo da parte tua. Penso che,\nprima o poi, lo capiranno anche loro."

msgctxt "8||speech_list_caba_riona||table||100||||4"
msgid "I hope so."
msgstr "Lo spero."

msgctxt "8||speech_list_caba_riona||table||101||||4"
msgid "Wow, you've got real confidence. Don't you worry\nabout your rivals surpassing you at this?"
msgstr "Wow, sei molto sicura di te. Non hai paura\nche le tue rivali possano superarti, così?"

msgctxt "8||speech_list_caba_riona||table||102||||4"
msgid "Well, it's in the club's best interest\nfor the hostesses to improve."
msgstr "Beh, che le hostess migliorino\nè nel miglior interesse del club."

msgctxt "8||speech_list_caba_riona||table||103||||4"
msgid "Besides, having rivals gets me fired up.\nI may not seem it, but I'm super competitive."
msgstr "Inoltre, avere delle rivali mi accende.\nMagari non sembrerà, ma sono molto competitiva."

msgctxt "8||speech_list_caba_riona||table||104||||4"
msgid "I figured as much. With how you think about\nthe business, I'm sure you're a tough opponent."
msgstr "Me lo immaginavo. Con la tua visione degli\naffari, sono certo che sei un'avversaria tosta."

msgctxt "8||speech_list_caba_riona||table||105||||4"
msgid "Kiryu-san... Thank you. You're the only\none that's ever had that kinda praise for me."
msgstr "Kiryu-san... Grazie. Sei l'unico\nche mi abbia mai elogiato in questo modo."

msgctxt "8||speech_list_caba_riona||table||106||||4"
msgid "I'm sure that must rub\nsome people the wrong way."
msgstr "Sono sicuro che a qualcuno\npossa dare fastidio."

msgctxt "8||speech_list_caba_riona||table||107||||4"
msgid "Come on, don't say that.\nBut some of them probably do feel that way."
msgstr "Andiamo, non dire così.\nMa, in effetti, probabilmente qualcuna la pensa così."

msgctxt "8||speech_list_caba_riona||table||108||||4"
msgid "Doesn't it bother you to be thought of that way?"
msgstr "Non ti dà fastidio che possano pensarlo?"

msgctxt "8||speech_list_caba_riona||table||109||||4"
msgid "It does... but I'm okay with it if it\nmeans it helps them grow."
msgstr "Un po'... ma mi sta bene, se\nserve ad aiutarle a crescere."

msgctxt "8||speech_list_caba_riona||table||110||||4"
msgid "That's mature of you. I think that'll get\nthrough to them, at some point or another."
msgstr "È molto maturo da parte tua. Penso che,\nprima o poi, lo capiranno anche loro."

msgctxt "8||speech_list_caba_riona||table||111||||4"
msgid "I sure hope so."
msgstr "Spero proprio di sì."

msgctxt "8||speech_list_caba_riona||table||112||||4"
msgid "Hmm..."
msgstr "Mhm..."

msgctxt "8||speech_list_caba_riona||table||113||||4"
msgid "What's wrong?\nSomething happen?"
msgstr "Che c'è?\nÈ successo qualcosa?"

msgctxt "8||speech_list_caba_riona||table||114||||4"
msgid "Actually, one of my regulars was asking me how long\nI'll stay a hostess, and it got me thinkin'."
msgstr "A dire il vero, uno dei miei clienti abituali mi ha chiesto\nper quanto tempo farò la hostess, e la cosa mi ha fatto riflettere."

msgctxt "8||speech_list_caba_riona||table||115||||4"
msgid "Hm. It's not the kind of job you can do forever,\nsure. But it must be tough to know when to quit."
msgstr "Mhm. Certo, non è un lavoro che si può fare per\nsempre. Ma deve essere difficile capire quando smettere."

msgctxt "8||speech_list_caba_riona||table||116||||4"
msgid "What would you do, Kiryu-san?\nWhen do you think it's time to quit?"
msgstr "Tu cosa faresti, Kiryu-san?\nQuand'è che capisci che è arrivato il momento di smettere?"

msgctxt "8||speech_list_caba_riona||table||117||||4"
msgid "When you feel you've\nreached your limit, maybe."
msgstr "Forse quando senti di\naver raggiunto il tuo limite."

msgctxt "8||speech_list_caba_riona||table||118||||4"
msgid "I see. My limit, huh?\nBut what's the limit for this job, I wonder..."
msgstr "Capisco. Il mio limite, eh?\nMi chiedo quale sia il limite per questo lavoro..."

msgctxt "8||speech_list_caba_riona||table||119||||4"
msgid "Maybe, if you find it difficult to speak clearly,\nor you can't sit too long without hip pain. Maybe?"
msgstr "Magari quando inizi ad avere difficoltà a parlare chiaramente,\no non riesci a stare seduta troppo a lungo senza che ti venga mal di schiena."

msgctxt "8||speech_list_caba_riona||table||120||||4"
msgid "That would most certainly be a limit,\nalright. I'd quit for sure if that happened."
msgstr "Questo sarebbe sicuramente un limite,\nnon c'è dubbio. Smetterei senza pensarci due volte."

msgctxt "8||speech_list_caba_riona||table||121||||4"
msgid "Then it sounds like you won't be\nretiring any time soon."
msgstr "In tal caso, mi sa che non andrai\nin pensione tanto presto."

msgctxt "8||speech_list_caba_riona||table||122||||4"
msgid "Maybe when the younger girls start getting a\nhandle on it and you're sure it's in good hands."
msgstr "Magari quando le ragazze più giovani iniziano a prenderci\nla mano e sei sicura che le cose siano in buone mani."

msgctxt "8||speech_list_caba_riona||table||123||||4"
msgid "You think so too, Kiryu-san?\nGreat minds think alike!"
msgstr "Lo pensi anche tu, Kiryu-san?\nLe grandi menti pensano allo stesso modo!"

msgctxt "8||speech_list_caba_riona||table||124||||4"
msgid "I feel like I could leave satisfied if\nthe girls I'm helping out can surpass me."
msgstr "Sento che potrei andarmene soddisfatta se\nle ragazze che sto aiutando riuscissero a superarmi."

msgctxt "8||speech_list_caba_riona||table||125||||4"
msgid "Nice. Although, it's a little too early for that.\nI still need you to be here for me."
msgstr "Bello. Anche se è un po' troppo presto per questo.\nHo ancora bisogno che tu ci sia per me."

msgctxt "8||speech_list_caba_riona||table||126||||4"
msgid "I know. I'm not getting surpassed without a fight.\nI'll keep working at it, okay, Kiryu-san? <symbol=note_with_outline>"
msgstr "Lo so. Non mi lascerò superare senza lottare.\nContinuerò a lavorarci su, okay, Kiryu-san? <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||127||||4"
msgid "Maybe when you get tired of it. When you do,\nit'll be clear that it's time to quit."
msgstr "Forse quando ne sarai stanca. Quando accadrà,\nsarà chiaro che è arrivato il momento di smettere."

msgctxt "8||speech_list_caba_riona||table||128||||4"
msgid "I-I see... That's true."
msgstr "C-Capisco... È vero."

msgctxt "8||speech_list_caba_riona||table||129||||4"
msgid "Have you ever felt tired of doing this?"
msgstr "Ti sei mai sentita stanca di tutto questo?"

msgctxt "8||speech_list_caba_riona||table||130||||4"
msgid "Not yet."
msgstr "Non ancora."

msgctxt "8||speech_list_caba_riona||table||131||||4"
msgid "Then you should keep doing it. Don't worry about\nwhat other people think. It's your choice to make."
msgstr "Allora dovresti continuare. Non preoccuparti di ciò\nche pensa la gente. È una tua scelta."

msgctxt "8||speech_list_caba_riona||table||132||||4"
msgid "Kiryu-san, that's exactly right.\nI think I should be more honest with myself."
msgstr "Kiryu-san, hai perfettamente ragione.\nCredo di dover essere più sincera con me stessa."

msgctxt "8||speech_list_caba_riona||table||133||||4"
msgid "Sounds like you're getting\neven more popular recently."
msgstr "A quanto pare stai diventando\nancora più popolare di recente."

msgctxt "8||speech_list_caba_riona||table||134||||4"
msgid "Thanks to customers like you, I get a lot of\nrequests. See, being an upstanding hostess works!"
msgstr "Grazie a clienti come te, ricevo un sacco di\nrichieste. Vedi, essere una hostess onesta funziona!"

msgctxt "8||speech_list_caba_riona||table||135||||4"
msgid "So that's where being considerate takes you, huh?\nBut isn't it tough being requested so often?"
msgstr "Quindi è qui che ti porta l'essere premurosa, eh?\nMa non è faticoso essere richieste così spesso?"

msgctxt "8||speech_list_caba_riona||table||136||||4"
msgid "Hmm... In my case, it's an issue of volume,\nso... I am pretty busy."
msgstr "Mhm... Nel mio caso è una questione di volume,\nquindi... sono piuttosto impegnata."

msgctxt "8||speech_list_caba_riona||table||137||||4"
msgid "I don't like taking time off when there's someone\nrequesting me, so I haven't had much of a break..."
msgstr "Non mi piace prendermi dei giorni liberi quando c'è\nqualcuno che mi richiede, perciò non ho avuto molte pause..."

msgctxt "8||speech_list_caba_riona||table||138||||4"
msgid "(She does look a little tired... Makes me worry.\nWhat can I say to her?)"
msgstr "(In effetti sembra un po' stanca... La cosa mi\npreoccupa. Cosa potrei dirle?)"

msgctxt "8||speech_list_caba_riona||table||139||||4"
msgid "Riona. You need to get some rest."
msgstr "Riona. Devi riposarti."

msgctxt "8||speech_list_caba_riona||table||140||||4"
msgid "Huh? I'm fine.\nI'm tougher than I look."
msgstr "Eh? Ma io sto bene.\nSono più tosta di quanto sembri."

msgctxt "8||speech_list_caba_riona||table||141||||4"
msgid "You have a strong sense of responsibility, so I think\nthat's translated into a bad habit of overworking yourself."
msgstr "Hai un forte senso di responsabilità, perciò penso che questo si\nsia tradotto nella cattiva abitudine di lavorare troppo."

msgctxt "8||speech_list_caba_riona||table||142||||4"
msgid "If you work yourself sick, the customers who've\nbeen requesting you might feel responsible."
msgstr "Se ti ammalassi per il troppo lavoro, i clienti che\nti hanno richiesta potrebbero sentirsene responsabili."

msgctxt "8||speech_list_caba_riona||table||143||||4"
msgid "If this was really about the customers, wouldn't\ntaking some time off be in their best interest?"
msgstr "Se ti importasse davvero dei clienti, prenderti un\npo' di tempo per riposare non sarebbe nel loro interesse?"

msgctxt "8||speech_list_caba_riona||table||144||||4"
msgid "Kiryu-san... You're right.\nMaybe I wasn't thinking."
msgstr "Kiryu-san... Hai ragione.\nForse ho agito senza riflettere."

msgctxt "8||speech_list_caba_riona||table||145||||4"
msgid "You really are a great guy.\nYou seem to see everything."
msgstr "Sei davvero un grand'uomo.\nSembra che non ti sfugga proprio niente."

msgctxt "8||speech_list_caba_riona||table||146||||4"
msgid "Not at all."
msgstr "Niente affatto."

msgctxt "8||speech_list_caba_riona||table||147||||4"
msgid "No, it's true. You know me better than anyone.\nI value your advice."
msgstr "No, invece. Mi conosci meglio di chiunque altro.\nFaccio tesoro dei tuoi consigli."

msgctxt "8||speech_list_caba_riona||table||148||||4"
msgid "Then, maybe I should\nhold off on requesting you."
msgstr "Allora, forse dovrei\nevitare di richiederti."

msgctxt "8||speech_list_caba_riona||table||149||||4"
msgid "Huh? Why?"
msgstr "Eh? Perché?"

msgctxt "8||speech_list_caba_riona||table||150||||4"
msgid "I'm just another request in your pile. If you end\nup getting sick, then it's all been for nothing."
msgstr "Sono solo un'altra richiesta da aggiungere alla lista. Se\nfinisci per ammalarti, tutto questo non sarà servito a nulla."

msgctxt "8||speech_list_caba_riona||table||151||||4"
msgid "Kiryu-san... Thanks for worryin' about me."
msgstr "Kiryu-san... Grazie per esserti preoccupato per me."

msgctxt "8||speech_list_caba_riona||table||152||||4"
msgid "You're right, I might be working a\nlittle too hard recently."
msgstr "Hai ragione, forse sto lavorando\nun po' troppo ultimamente."

msgctxt "8||speech_list_caba_riona||table||153||||4"
msgid "If you work yourself sick, the customers who've\nbeen requesting you might feel responsible."
msgstr "Se ti ammalassi per il troppo lavoro, i clienti che\nti hanno richiesta potrebbero sentirsene responsabili."

msgctxt "8||speech_list_caba_riona||table||154||||4"
msgid "If this was really about the customers, wouldn't\ntaking some time off be in their best interest?"
msgstr "Se ti importasse davvero dei clienti, prenderti un\npo' di tempo per riposare non sarebbe nel loro interesse?"

msgctxt "8||speech_list_caba_riona||table||155||||4"
msgid "You're right...\nYou see everything, don't you?"
msgstr "Hai ragione...\nNon ti sfugge proprio niente, eh?"

msgctxt "8||speech_list_caba_riona||table||156||||4"
msgid "I'll try to get some rest.\nSo... come back and see me, okay?"
msgstr "Cercherò di riposarmi un po'.\nQuindi... torna a trovarmi, okay?"

msgctxt "8||speech_list_caba_riona||table||157||||4"
msgid "If I couldn't see you anymore, I'd..."
msgstr "Se non potessi più vederti, ne..."

msgctxt "8||speech_list_caba_riona||table||158||||4"
msgid "Hey, I'll be there."
msgstr "Ehi, io ci sarò."

msgctxt "8||speech_list_caba_riona||table||159||||4"
msgid "I'm glad. <symbol=note_with_outline>"
msgstr "Ne sono felice. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||160||||4"
msgid "All right, I'll give you a massage."
msgstr "D'accordo, ti farò io un massaggio."

msgctxt "8||speech_list_caba_riona||table||161||||4"
msgid "Huh? Right now?"
msgstr "Eh? Adesso?"

msgctxt "8||speech_list_caba_riona||table||162||||4"
msgid "I thought you might be tired.\nNow, where does it hurt?"
msgstr "Pensavo potessi essere stanca.\nAllora, dove ti fa male?"

msgctxt "8||speech_list_caba_riona||table||163||||4"
msgid "Uh, no...\nI'm okay! Really, I swear!"
msgstr "Ehm, no...\nSto bene! Davvero, lo giuro!"

msgctxt "8||speech_list_caba_riona||table||164||||4"
msgid "O-Oh... You seemed tired, so I got worried.\nDon't push yourself too hard, okay?"
msgstr "O-Oh... Sembravi stanca, perciò mi sono preoccupato.\nNon sforzarti troppo, d'accordo?"

msgctxt "8||speech_list_caba_riona||table||165||||4"
msgid "Thanks. I'm the type to keep it all bottled\nin, so I'm glad you're concerned about me."
msgstr "Grazie. Sono il tipo che si tiene tutto dentro,\nquindi mi fa piacere che ti preoccupi per me."

msgctxt "8||speech_list_caba_riona||table||166||||4"
msgid "Kiryu-san, do you have plans after this?"
msgstr "Kiryu-san, hai impegni dopo il lavoro?"

msgctxt "8||speech_list_caba_riona||table||167||||4"
msgid "No. What's up?"
msgstr "No. Che succede?"

msgctxt "8||speech_list_caba_riona||table||168||||4"
msgid "If you feel up to it, would ya want to go out?"
msgstr "Se te la senti, ti andrebbe di uscire?"

msgctxt "8||speech_list_caba_riona||table||169||||4"
msgid "There's somewhere I want to take you."
msgstr "C'è un posto in cui vorrei portarti."

msgctxt "8||speech_list_caba_riona||table||170||||4"
msgid "Yeah, sure."
msgstr "Sì, certo."

msgctxt "8||speech_list_caba_riona||table||171||||4"
msgid "Thanks!\nWe'll meet up after you leave."
msgstr "Grazie!\nCi incontriamo dopo che esci."

msgctxt "8||speech_list_caba_riona||table||172||||4"
msgid "Okay."
msgstr "Okay."

msgctxt "8||speech_list_caba_riona||table||173||||4"
msgid "See you later, then."
msgstr "A dopo, allora."

msgctxt "8||speech_list_caba_riona||table||174||||4"
msgid "See you."
msgstr "A dopo."

msgctxt "8||speech_list_caba_riona||table||175||||4"
msgid "I don't know if ya'd call it a hobby,\nbut I love beauty products."
msgstr "Non so se lo definiresti un hobby,\nma adoro i prodotti di bellezza."

msgctxt "8||speech_list_caba_riona||table||176||||4"
msgid "Beauty products?"
msgstr "Prodotti di bellezza?"

msgctxt "8||speech_list_caba_riona||table||177||||4"
msgid "Like lookin' for perfume in my style,\nor a skincare regimen to avoid drying out."
msgstr "Cose come cercare un profumo adatto al mio stile,\no una routine di cura della pelle contro la secchezza."

msgctxt "8||speech_list_caba_riona||table||178||||4"
msgid "Staying on top of self improvement is important.\nNo wonder you're so beautiful."
msgstr "È importante curare sempre il proprio aspetto.\nNon c'è da stupirsi che tu sia così bella."

msgctxt "8||speech_list_caba_riona||table||179||||4"
msgid "Kiryu-san, you're a flatterer. I hope\nyou're not expecting anythin' special!"
msgstr "Kiryu-san, sei un adulatore. Spero\nnon ti aspetti niente di speciale!"

msgctxt "8||speech_list_caba_riona||table||180||||4"
msgid "Sounds like an expensive hobby."
msgstr "Sembra un hobby costoso."

msgctxt "8||speech_list_caba_riona||table||181||||4"
msgid "I s'pose it does add up...\nBut I try not to be too stingy about it."
msgstr "Suppongo che il conto salga in fretta...\nMa cerco di non fare troppo la tirchia al riguardo."

msgctxt "8||speech_list_caba_riona||table||182||||4"
msgid "You won't last long in this job if ya think of\nit that way. I'm not as young as I used to be."
msgstr "Non durerai a lungo in questo lavoro se la pensi in\nquesto modo. Non sono più giovane come un tempo."

msgctxt "8||speech_list_caba_riona||table||183||||4"
msgid "Sounds rough.\nBut, I'm glad it's working out for you."
msgstr "Sembra dura.\nMa, sono felice che stia funzionando per te."

msgctxt "8||speech_list_caba_riona||table||184||||4"
msgid "Why thank you."
msgstr "Ma grazie."

msgctxt "8||speech_list_caba_riona||table||185||||4"
msgid "Your skin is quite beautiful.\nMaybe I'll touch you and see for myself..."
msgstr "La tua pelle è davvero bellissima.\nForse dovrei toccarti e vedere di persona..."

msgctxt "8||speech_list_caba_riona||table||186||||4"
msgid "Now now, Kiryu-san.\nNo touching!"
msgstr "Su, su, Kiryu-san.\nNiente mani addosso!"

msgctxt "8||speech_list_caba_riona||table||187||||4"
msgid "It was just a joke."
msgstr "Era solo uno scherzo."

msgctxt "8||speech_list_caba_riona||table||188||||4"
msgid "Let's seeee... On my days off,\nI usually go to the spa or something."
msgstr "Vediamooo... Nei miei giorni liberi,\ndi solito vado alla spa o roba del genere."

msgctxt "8||speech_list_caba_riona||table||189||||4"
msgid "Spa?"
msgstr "Spa?"

msgctxt "8||speech_list_caba_riona||table||190||||4"
msgid "Yep. Do you not know what that is?"
msgstr "Già. Non sai cos'è?"

msgctxt "8||speech_list_caba_riona||table||191||||4"
msgid "I do, it's like a public bath, right?\nYou go to some pretty classy places."
msgstr "Certo, è tipo un bagno pubblico, vero?\nFrequenti posti piuttosto di classe."

msgctxt "8||speech_list_caba_riona||table||192||||4"
msgid "It's a little different from a public bath,\nbut... it has a lot of health and beauty benefits."
msgstr "È un po' diverso da un bagno pubblico,\nma... ha molti benefici per la salute e la bellezza."

msgctxt "8||speech_list_caba_riona||table||193||||4"
msgid "So it's like a hot spring... Still classy."
msgstr "Quindi è come una sorgente termale... Comunque di classe."

msgctxt "8||speech_list_caba_riona||table||195||||4"
msgid "Nope, no clue.\nI feel like I've heard the word before, though."
msgstr "No, non ne ho idea.\nAnche se mi sembra di aver già sentito questa parola."

msgctxt "8||speech_list_caba_riona||table||196||||4"
msgid "They usually have baths and workout machines,\nbut the places I go have salons, too."
msgstr "Di solito hanno vasche e macchine per allenarsi,\nma i posti in cui vado io hanno anche centri estetici."

msgctxt "8||speech_list_caba_riona||table||197||||4"
msgid "If you're curious,\nwould ya care to join me, Kiryu-san?"
msgstr "Se sei curioso,\nti andrebbe di venirci con me, Kiryu-san?"

msgctxt "8||speech_list_caba_riona||table||198||||4"
msgid "Taking a bath together..."
msgstr "Fare un bagno insieme..."

msgctxt "8||speech_list_caba_riona||table||199||||4"
msgid "Of course I know that abbreviation.\nSpaghetti's delicious."
msgstr "Certo che conosco l'abbreviazione.\nGli spaghetti sono deliziosi."

msgctxt "8||speech_list_caba_riona||table||200||||4"
msgid "Kiryu-san... Are you serious?"
msgstr "Kiryu-san... Dici sul serio?"

msgctxt "8||speech_list_caba_riona||table||201||||4"
msgid "Uh, no... It was a joke."
msgstr "Ehm, no... Era uno scherzo."

msgctxt "8||speech_list_caba_riona||table||202||||4"
msgid "I started when I was 19,\nso I guess it's been about ten years."
msgstr "Ho iniziato a 19 anni,\nquindi direi che sono passati circa dieci anni."

msgctxt "8||speech_list_caba_riona||table||203||||4"
msgid "Osaka. I used to work at a club over\nthere before I came here."
msgstr "Osaka. Lavoravo in un club da\nquelle parti, prima di venire qui."

msgctxt "8||speech_list_caba_riona||table||204||||4"
msgid "Veggies don't do much for me,\nso I eat a lot of meat."
msgstr "Le verdure non mi fanno impazzire,\nquindi mangio molta carne."

msgctxt "8||speech_list_caba_riona||table||205||||4"
msgid "Huh. But wouldn't all that meat make you fat?"
msgstr "Mhm. Ma tutta quella carne non fa ingrassare?"

msgctxt "8||speech_list_caba_riona||table||206||||4"
msgid "Well, I still manage my diet. I make up\nfor the lack of veggies with supplements."
msgstr "Beh, tengo comunque d'occhio la dieta. Compenso\nla mancanza di verdure con gli integratori."

msgctxt "8||speech_list_caba_riona||table||207||||4"
msgid "Hmm... I s'pose... I like seductive men."
msgstr "Mhm... Suppongo... mi piacciano gli uomini seducenti."

msgctxt "8||speech_list_caba_riona||table||208||||4"
msgid "Seductive?"
msgstr "Seducenti?"

msgctxt "8||speech_list_caba_riona||table||209||||4"
msgid "Yeah, ever heard the word \"sexy\" to\ndescribe a guy? That's my type of man."
msgstr "Sì, hai mai sentito la parola \"sexy\"\nper descrivere un uomo? Quello è il mio tipo ideale."

msgctxt "8||speech_list_caba_riona||table||210||||4"
msgid "So, a seductive... sexy man, huh?"
msgstr "Quindi, un uomo seducente... sexy, eh?"

msgctxt "8||speech_list_caba_riona||table||211||||4"
msgid "Like a man who's quick to take off his shirt?"
msgstr "Tipo un uomo veloce a togliersi la maglietta?"

msgctxt "8||speech_list_caba_riona||table||212||||4"
msgid "That ain't sexy, that's just perverted.\nWhat kinda woman do you take me for, Kiryu-san?"
msgstr "Quello non è essere sexy, è da pervertiti.\nPer che genere di donna mi hai preso, Kiryu-san?"

msgctxt "8||speech_list_caba_riona||table||213||||4"
msgid "Yeah, you're right. Sorry."
msgstr "Sì, hai ragione. Scusa."

msgctxt "8||speech_list_caba_riona||table||214||||4"
msgid "You mean a feminine man?\nSo, you like it when they speak like a woman..."
msgstr "Intendi un uomo femminile?\nQuindi, ti piace quando parlano come una donna..."

msgctxt "8||speech_list_caba_riona||table||215||||4"
msgid "What part of that is sexy?\nKiryu-san, are you teasing me?"
msgstr "Cosa ci sarebbe di sexy in questo?\nKiryu-san, mi stai prendendo in giro?"

msgctxt "8||speech_list_caba_riona||table||216||||4"
msgid "It was just a joke."
msgstr "Era solo uno scherzo."

msgctxt "8||speech_list_caba_riona||table||217||||4"
msgid "Wait a sec...\nDo you mean a man like me...?"
msgstr "Aspetta un attimo...\nIntendi un uomo come me...?"

msgctxt "8||speech_list_caba_riona||table||218||||4"
msgid "You'd say that 'bout yourself!?\nBut yeah, you are pretty sexy, Kiryu-san."
msgstr "Lo dici da te!?\nMa sì, sei piuttosto sexy, Kiryu-san."

msgctxt "8||speech_list_caba_riona||table||219||||4"
msgid "You're not just manly<symbol=em_dash_with_outline>you're... delicate?\nYou have gravitas... Yeah, you're totally sexy!"
msgstr "Non sei solo virile<symbol=em_dash_with_outline>sei... delicato?\nHai molto carisma... Sì, sei totalmente sexy!"

msgctxt "8||speech_list_caba_riona||table||220||||4"
msgid "And you're all too aware of it, huh?"
msgstr "E ne sei fin troppo consapevole, eh?"

msgctxt "8||speech_list_caba_riona||table||221||||4"
msgid "This is starting to get embarrassing...\nAren't you laying it on a little thick?"
msgstr "Sta iniziando a diventare imbarazzante...\nNon starai esagerando un po'?"

msgctxt "8||speech_list_caba_riona||table||222||||4"
msgid "Figured I'd tease ya a little. <symbol=note_with_outline>"
msgstr "Pensavo di prenderti un po' in giro. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||223||||4"
msgid "Hmmm... I think I'd want to know more about\nwhat makes the guy tick or what he likes."
msgstr "Mhm... Credo vorrei sapere di più su\ncome ragiona quel ragazzo o cosa gli piace."

msgctxt "8||speech_list_caba_riona||table||224||||4"
msgid "Hm? And what would you do if you knew?\nAnything in particular?"
msgstr "Mhm? E cosa faresti se lo sapessi?\nQualcosa in particolare?"

msgctxt "8||speech_list_caba_riona||table||225||||4"
msgid "I'm the type who likes to dote on people,\nso I'd want to offer my advice and support."
msgstr "Sono il tipo a cui piace viziare le persone,\nquindi vorrei offrirgli i miei consigli e il mio supporto."

msgctxt "8||speech_list_caba_riona||table||226||||4"
msgid "But maybe they'd find that annoying? What do you\nthink of a woman who wants to support her man?"
msgstr "Ma forse lo troverebbe fastidioso? Cosa ne pensi\ndi una donna che vuole sostenere il proprio uomo?"

msgctxt "8||speech_list_caba_riona||table||227||||4"
msgid "I prefer it. Seems like I'd be able to rely\non her in a lot of aspects of my life."
msgstr "Lo preferisco. Sento che potrei fare\naffidamento su di lei in molti aspetti della mia vita."

msgctxt "8||speech_list_caba_riona||table||228||||4"
msgid "I see. That's good. If I was dating you,\nKiryu-san, I'd try to support ya any way I could."
msgstr "Capisco. È un bene. Se uscissi con te,\nKiryu-san, cercherei di sostenerti in ogni modo."

msgctxt "8||speech_list_caba_riona||table||229||||4"
msgid "I'll count on it, then."
msgstr "Ci conterò, allora."

msgctxt "8||speech_list_caba_riona||table||230||||4"
msgid "It's nice to have that kind of support,\nbut I'd want to support her in return."
msgstr "È bello avere quel tipo di sostegno,\nma vorrei poterla sostenere a mia volta."

msgctxt "8||speech_list_caba_riona||table||231||||4"
msgid "I had a feeling."
msgstr "Me lo sentivo."

msgctxt "8||speech_list_caba_riona||table||232||||4"
msgid "It varies by person, but, sometimes vulnerable\nwomen are actually more attractive to a man."
msgstr "Varia da persona a persona, ma, a volte le donne\nvulnerabili sono in realtà più attraenti per un uomo."

msgctxt "8||speech_list_caba_riona||table||233||||4"
msgid "I see. I do kinda try to make sure\nI don't seem vulnerable."
msgstr "Capisco. In effetti cerco di assicurarmi\ndi non sembrare troppo vulnerabile."

msgctxt "8||speech_list_caba_riona||table||234||||4"
msgid "I should probably try to rely on men more,\nbut I'm just no good at it."
msgstr "Probabilmente dovrei cercare di affidarmi di più\nagli uomini, ma proprio non ci riesco."

msgctxt "8||speech_list_caba_riona||table||235||||4"
msgid "That was a useful tip, though, Kiryu-san.\nIt's good to get a guy's perspective on that."
msgstr "È stato un consiglio utile, comunque, Kiryu-san.\nÈ bello avere la prospettiva di un uomo al riguardo."

msgctxt "8||speech_list_caba_riona||table||236||||4"
msgid "Hmmm... It kind of makes them\nseem like an old woman."
msgstr "Mhm... Le fa un po'\nsembrare delle vecchiette."

msgctxt "8||speech_list_caba_riona||table||237||||4"
msgid "What!? So mean!\nYou didn't have to say it like that!"
msgstr "Cosa!? Che cattiveria!\nNon c'era bisogno di dirlo in quel modo!"

msgctxt "8||speech_list_caba_riona||table||238||||4"
msgid "No, I'm not saying it's a bad thing.\nThe old women in my neighborhood support me, too."
msgstr "No, non sto dicendo che sia un male.\nAnche le anziane del mio quartiere mi sostengono."

msgctxt "8||speech_list_caba_riona||table||239||||4"
msgid "You keep digging that hole...\nKiryu-san, you're definitely a strange one."
msgstr "Stai continuando a scavarti la fossa...\nKiryu-san, sei decisamente un tipo strano."

msgctxt "8||speech_list_caba_riona||table||240||||4"
msgid "I wanna be the kinda hostess people can take\none look at and know I'm amazin'."
msgstr "Voglio essere il tipo di hostess che la gente\nguarda una volta e capisce che sono incredibile."

msgctxt "8||speech_list_caba_riona||table||241||||4"
msgid "So you want to be more respected...?"
msgstr "Quindi vuoi essere più rispettata...?"

msgctxt "8||speech_list_caba_riona||table||242||||4"
msgid "Yep. I want to give hope to other\nhostesses like me."
msgstr "Sì. Voglio dare speranza alle altre\nhostess come me."

msgctxt "8||speech_list_caba_riona||table||243||||4"
msgid "I wouldn't say I've got any particularly\namazing talents or anything..."
msgstr "Non direi di avere dei talenti\nparticolarmente incredibili o cose del genere..."

msgctxt "8||speech_list_caba_riona||table||244||||4"
msgid "But if I can pull it off, I feel like maybe I\ncould inspire other girls to be more optimistic."
msgstr "Ma se ci riuscissi, sento che forse potrei\nispirare altre ragazze a essere più ottimiste."

msgctxt "8||speech_list_caba_riona||table||245||||4"
msgid "I see..."
msgstr "Capisco..."

msgctxt "8||speech_list_caba_riona||table||246||||4"
msgid "It's not a real concrete goal, though, huh?\nWhat's the criteria to become someone like that?"
msgstr "Non è un obiettivo molto concreto, però, eh?\nQuali sono i criteri per diventare una persona del genere?"

msgctxt "8||speech_list_caba_riona||table||247||||4"
msgid "How about becoming a model?\nEvery woman dreams of that."
msgstr "Che ne dici di diventare una modella?\nOgni donna lo sogna."

msgctxt "8||speech_list_caba_riona||table||248||||4"
msgid "Yeah, modelin' might be a good idea!\nAn ex-hostess model... I can dream, huh?"
msgstr "Sì, fare la modella potrebbe essere una buona idea!\nUna modella ex-hostess... Si può sognare, no?"

msgctxt "8||speech_list_caba_riona||table||249||||4"
msgid "Well, you're a hard worker. If you set your\nsights on it, I'm sure you'll get there someday."
msgstr "Beh, sei una gran lavoratrice. Se te lo metti\nin testa, sono sicuro che un giorno ci arriverai."

msgctxt "8||speech_list_caba_riona||table||250||||4"
msgid "Thanks! I'll work on making that my\nconcrete goal! Wish me luck!"
msgstr "Grazie! Lavorerò per farlo diventare il mio\nobiettivo concreto! Augurami buona fortuna!"

msgctxt "8||speech_list_caba_riona||table||251||||4"
msgid "How about opening your own club?"
msgstr "Che ne dici di aprire un club tutto tuo?"

msgctxt "8||speech_list_caba_riona||table||252||||4"
msgid "That's certainly a dream a lot of hostesses have,\nbut I think I'd prefer a different industry."
msgstr "Questo è sicuramente un sogno che hanno molte hostess,\nma credo che preferirei un settore diverso."

msgctxt "8||speech_list_caba_riona||table||253||||4"
msgid "I want people to know that if ya can make it as a\nhostess, you can be successful in other fields, too."
msgstr "Voglio che la gente sappia che se ce la fai come\nhostess, puoi avere successo anche in altri campi."

msgctxt "8||speech_list_caba_riona||table||254||||4"
msgid "That does seem like a nice message of hope.\nGood luck."
msgstr "Sembra proprio un bel messaggio di speranza.\nBuona fortuna."

msgctxt "8||speech_list_caba_riona||table||255||||4"
msgid "Thanks! I'll try!"
msgstr "Grazie! Ci proverò!"

msgctxt "8||speech_list_caba_riona||table||256||||4"
msgid "How about becoming an idol?"
msgstr "Che ne diresti di diventare un'idol?"

msgctxt "8||speech_list_caba_riona||table||257||||4"
msgid "That might be nice, but...\nCould I really be an idol at this age?"
msgstr "Sarebbe bello, ma...\nPotrei davvero fare l'idol alla mia età?"

msgctxt "8||speech_list_caba_riona||table||258||||4"
msgid "Might be tough."
msgstr "Potrebbe essere dura."

msgctxt "8||speech_list_caba_riona||table||259||||4"
msgid "Ugh, such a meanie, Kiryu-san!\nBut, a model or a TV personality might work."
msgstr "Ugh, che cattivone, Kiryu-san!\nMa una modella o un personaggio televisivo potrebbero funzionare."

msgctxt "8||speech_list_caba_riona||table||260||||4"
msgid "Yeah, well, you're a hard worker. If you set your\nsights on it, I'm sure you'll get there someday."
msgstr "Sì, beh, sei una gran lavoratrice. Se te lo metti\nin testa, sono sicuro che un giorno ci arriverai."

msgctxt "8||speech_list_caba_riona||table||261||||4"
msgid "Thanks! I'm gonna see about makin' it as an\nex-hostess talent of some kind. <symbol=note_with_outline>"
msgstr "Grazie! Vedrò di farcela come una specie\ndi talento ex-hostess. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||262||||4"
msgid "When I was a kid? Hmmm... I don't think there\nwas anything in particular I wanted to be."
msgstr "Quando ero bambina? Mhmm... Non credo ci fosse\nniente in particolare che volessi fare da grande."

msgctxt "8||speech_list_caba_riona||table||263||||4"
msgid "Buuut... I always knew I wanted to be cute.\nThat's true even today."
msgstr "Maaa... ho sempre saputo di voler essere carina.\nÈ vero ancora oggi."

msgctxt "8||speech_list_caba_riona||table||264||||4"
msgid "You wanted to be cute, huh?\nThen... your dream's already come true."
msgstr "Volevi essere carina, eh?\nAllora... il tuo sogno si è già realizzato."

msgctxt "8||speech_list_caba_riona||table||265||||4"
msgid "It's nice to hear you say that."
msgstr "È bello sentirtelo dire."

msgctxt "8||speech_list_caba_riona||table||266||||4"
msgid "But personally, I feel like I have\na long way to go. I want to be even cuter..."
msgstr "Ma personalmente sento di avere ancora\nmolta strada da fare. Voglio essere ancora più carina..."

msgctxt "8||speech_list_caba_riona||table||267||||4"
msgid "Especially in a job like this, where people always\nhave an eye on ya, appearance is so important."
msgstr "Specialmente in un lavoro come questo, dove le persone ti\ntengono sempre d'occhio, l'aspetto esteriore è molto importante."

msgctxt "8||speech_list_caba_riona||table||268||||4"
msgid "You think like a pro.\nI half-expected an answer like that."
msgstr "Ragioni come una professionista.\nMe lo aspettavo, in un certo senso."

msgctxt "8||speech_list_caba_riona||table||269||||4"
msgid "You want to be cute, huh?\nA dream like that takes real effort."
msgstr "Vuoi essere carina, eh?\nUn sogno del genere richiede molto impegno."

msgctxt "8||speech_list_caba_riona||table||270||||4"
msgid "It really does.\nNo one becomes beautiful overnight."
msgstr "È proprio così.\nNessuno diventa bello dall'oggi al domani."

msgctxt "8||speech_list_caba_riona||table||271||||4"
msgid "And in a job like this, ya have to be\nespecially aware of how people see you."
msgstr "E in un lavoro come questo, devi essere\nparticolarmente consapevole di come la gente ti vede."

msgctxt "8||speech_list_caba_riona||table||272||||4"
msgid "My special skill is... my presentation!"
msgstr "La mia abilità speciale è... la presentazione!"

msgctxt "8||speech_list_caba_riona||table||273||||4"
msgid "What do you mean by that?"
msgstr "Cosa intendi dire?"

msgctxt "8||speech_list_caba_riona||table||274||||4"
msgid "Thinking about my personal brand,\nand then executing on it."
msgstr "Pensare al mio marchio personale,\ne poi metterlo in pratica."

msgctxt "8||speech_list_caba_riona||table||275||||4"
msgid "I'd say it was only because I did that well that\nI succeeded in an industry as tough as this."
msgstr "Direi che è solo perché l'ho fatto bene che ho\navuto successo in un settore così difficile come questo."

msgctxt "8||speech_list_caba_riona||table||276||||4"
msgid "I see. If that's the case,\nyou must have..."
msgstr "Capisco. Se è così,\ndevi fare..."

msgctxt "8||speech_list_caba_riona||table||277||||4"
msgid "...Good use of social media and blogs, right?"
msgstr "...Un buon uso dei social media e dei blog, giusto?"

msgctxt "8||speech_list_caba_riona||table||278||||4"
msgid "Yeah! Wow!\nYou're into that kinda stuff too, Kiryu-san?"
msgstr "Sì! Wow!\nTi interessi anche tu a queste cose, Kiryu-san?"

msgctxt "8||speech_list_caba_riona||table||279||||4"
msgid "I'm decent for my age."
msgstr "Me la cavo discretamente per la mia età."

msgctxt "8||speech_list_caba_riona||table||280||||4"
msgid "If ya can advertise effectively on social media\nor a blog, new customers request you more often."
msgstr "Se riesci a farti pubblicità in modo efficace sui social\no su un blog, i nuovi clienti ti richiedono più spesso."

msgctxt "8||speech_list_caba_riona||table||281||||4"
msgid "So Kiryu-san, if ya ever decide to become a host,\nyou should give it a shot."
msgstr "Quindi Kiryu-san, se mai decidessi di diventare un host,\ndovresti farci un pensiero."

msgctxt "8||speech_list_caba_riona||table||282||||4"
msgid "I'll keep that in mind."
msgstr "Lo terrò a mente."

msgctxt "8||speech_list_caba_riona||table||283||||4"
msgid "...Fliers or something, right? Or maybe putting\nyourself on some pocket tissues would work."
msgstr "...Volantini o qualcosa del genere, giusto? O magari mettere\nla tua faccia su dei fazzoletti di carta potrebbe funzionare."

msgctxt "8||speech_list_caba_riona||table||284||||4"
msgid "Kiryu-san, that's a little old-fashioned... It\nmight've worked a decade ago, but not any more."
msgstr "Kiryu-san, è un po' antiquato... Forse\navrebbe funzionato un decennio fa, ma non più."

msgctxt "8||speech_list_caba_riona||table||285||||4"
msgid "I used social media and my blog to advertise.\nIt's been really effective."
msgstr "Ho usato i social media e il mio blog per farmi pubblicità.\nÈ stato molto efficace."

msgctxt "8||speech_list_caba_riona||table||286||||4"
msgid "...Blasted emails to a whole bunch of random\npeople? Chain letters and stuff like that."
msgstr "...Inviare e-mail a raffica a un mucchio di persone\na caso? Catene di Sant'Antonio e roba del genere."

msgctxt "8||speech_list_caba_riona||table||287||||4"
msgid "I would never be so inconsiderate!\nI'm not some kinda con-artist."
msgstr "Non sarei mai così sconsiderata!\nNon sono mica una truffatrice."

msgctxt "8||speech_list_caba_riona||table||288||||4"
msgid "Oh yeah, the other day,\na customer from Kyoto came in."
msgstr "Ah sì, l'altro giorno è\nvenuto un cliente da Kyoto."

msgctxt "8||speech_list_caba_riona||table||289||||4"
msgid "All the way here?\nThat's dedication."
msgstr "Fin qui?\nQuesta sì che è dedizione."

msgctxt "8||speech_list_caba_riona||table||290||||4"
msgid "Not only that, it was a girl."
msgstr "E non solo, era una ragazza."

msgctxt "8||speech_list_caba_riona||table||291||||4"
msgid "A girl? At a cabaret club?"
msgstr "Una ragazza? In un cabaret club?"

msgctxt "8||speech_list_caba_riona||table||292||||4"
msgid "Yeah. She said she came all the way\nto Kamurocho just to see me."
msgstr "Sì. Ha detto di essere venuta fino\na Kamurocho solo per vedermi."

msgctxt "8||speech_list_caba_riona||table||293||||4"
msgid "Was she a fan of yours?"
msgstr "Era una tua fan?"

msgctxt "8||speech_list_caba_riona||table||294||||4"
msgid "I guess so. She said she was a regular reader\non my blog. Melted my heart."
msgstr "Immagino di sì. Ha detto di leggere regolarmente\nil mio blog. Mi ha sciolto il cuore."

msgctxt "8||speech_list_caba_riona||table||295||||4"
msgid "Yeah, I guess girls read blogs, too...\nTimes sure are changing..."
msgstr "Sì, immagino che anche le ragazze leggano i blog...\nI tempi stanno proprio cambiando..."

msgctxt "8||speech_list_caba_riona||table||296||||4"
msgid "Actually, about 30% of the people who\nrequest me are women."
msgstr "A dire il vero, circa il 30% delle persone che\nmi richiedono sono donne."

msgctxt "8||speech_list_caba_riona||table||297||||4"
msgid "That's really something.\nYou've got a wide appeal."
msgstr "È davvero una cosa notevole.\nHai un fascino che non passa inosservato."

msgctxt "8||speech_list_caba_riona||table||298||||4"
msgid "Oh, stop. But, it is refreshing to\nbe admired by your own gender."
msgstr "Oh, piantala. Ma è piacevole essere\nammirate dal proprio stesso sesso."

msgctxt "8||speech_list_caba_riona||table||299||||4"
msgid "Was she a friend?"
msgstr "Era un'amica?"

msgctxt "8||speech_list_caba_riona||table||300||||4"
msgid "No, she was a fan who followed my blog."
msgstr "No, era una fan che seguiva il mio blog."

msgctxt "8||speech_list_caba_riona||table||301||||4"
msgid "Was she your girlfriend? Wait, are you..."
msgstr "Era la tua ragazza? Aspetta, sei per caso..."

msgctxt "8||speech_list_caba_riona||table||302||||4"
msgid "No! She was a fan who followed my blog."
msgstr "No! Era una fan che seguiva il mio blog."

msgctxt "8||speech_list_caba_riona||table||303||||4"
msgid "Hmm... I don't know if I'd say it's a lot,\nbut I guess I have my fair share of girl friends."
msgstr "Mhm... Non so se ne ho tantissime, ma\nsuppongo di avere la mia buona dose di amiche."

msgctxt "8||speech_list_caba_riona||table||304||||4"
msgid "But if I had to come out and say it,\nI think women like me more than men."
msgstr "Ma, ad essere del tutto onesta,\ncredo di piacere più alle donne che agli uomini."

msgctxt "8||speech_list_caba_riona||table||305||||4"
msgid "I even get some women who\ncome in here as customers."
msgstr "A volte mi capita persino di avere\ndelle donne come clienti."

msgctxt "8||speech_list_caba_riona||table||306||||4"
msgid "Kiryu-san, what kind of friends do you have?"
msgstr "Kiryu-san, tu che tipo di amici hai?"

msgctxt "8||speech_list_caba_riona||table||307||||4"
msgid "I try not to talk about it too openly, but...\nI know a lot of people in the yakuza."
msgstr "Cerco di non parlarne troppo apertamente, ma...\nConosco molta gente nella yakuza."

msgctxt "8||speech_list_caba_riona||table||308||||4"
msgid "Oh really...\nWell, I guess that does fit your image."
msgstr "Oh, davvero...\nBeh, direi che combacia con la tua immagine."

msgctxt "8||speech_list_caba_riona||table||309||||4"
msgid "...Is that the kind of image I have?"
msgstr "...È questa l'immagine che do?"

msgctxt "8||speech_list_caba_riona||table||310||||4"
msgid "Cute women... I guess."
msgstr "Donne carine... immagino."

msgctxt "8||speech_list_caba_riona||table||311||||4"
msgid "You do seem good with the ladies, Kiryu-san."
msgstr "Sembri uno che ci sa fare con le signore, Kiryu-san."

msgctxt "8||speech_list_caba_riona||table||312||||4"
msgid "Not really. But, I'd say there's a pretty\ngood lady right here in front of me."
msgstr "Non proprio. Ma direi che c'è una ragazza\npiuttosto in gamba proprio qui di fronte a me."

msgctxt "8||speech_list_caba_riona||table||313||||4"
msgid "Oh, Kiryu-san. <symbol=note_with_outline>\nFlattery'll get you nowhere with me."
msgstr "Oh, Kiryu-san. <symbol=note_with_outline>\nL'adulazione non ti porterà da nessuna parte con me."

msgctxt "8||speech_list_caba_riona||table||314||||4"
msgid "Some taxi drivers, I guess."
msgstr "Qualche tassista, direi."

msgctxt "8||speech_list_caba_riona||table||315||||4"
msgid "Huh? Did you used to be a driver?"
msgstr "Eh? Facevi il tassista in passato?"

msgctxt "8||speech_list_caba_riona||table||316||||4"
msgid "A few years back. They took me in when I had no\nwhere to go. I owe my boss and coworkers a lot."
msgstr "Qualche anno fa. Mi hanno accolto quando non avevo\ndove andare. Devo molto al mio capo e ai miei colleghi."

msgctxt "8||speech_list_caba_riona||table||317||||4"
msgid "Wow. Just goes to show ya never know a person's\nhistory. I'm glad ya have friends like that."
msgstr "Wow. Questo dimostra che non si sa mai il passato\ndi una persona. Sono felice che tu abbia amici del genere."

msgctxt "8||speech_list_caba_riona||table||318||||4"
msgid "I don't play too many games, but I dabble\nwith them on my phone sometimes."
msgstr "Non gioco molto ai videogiochi, ma\nogni tanto ci smanetto sul telefono."

msgctxt "8||speech_list_caba_riona||table||319||||4"
msgid "Do you play games, Kiryu-san?\nYou don't seem like the type."
msgstr "Tu giochi ai videogiochi, Kiryu-san?\nNon mi sembri il tipo."

msgctxt "8||speech_list_caba_riona||table||320||||4"
msgid "I play a lot, actually.\nI hit the arcades sometimes."
msgstr "A dire il vero gioco un sacco.\nA volte vado in sala giochi."

msgctxt "8||speech_list_caba_riona||table||321||||4"
msgid "Wow! You're a game master!\nYou should tell me more about that sometime."
msgstr "Wow! Sei un mago dei videogiochi!\nDovresti parlarmene di più, qualche volta."

msgctxt "8||speech_list_caba_riona||table||322||||4"
msgid "I don't play them much anymore.\nI did when I was younger, though."
msgstr "Non ci gioco più molto.\nPerò lo facevo da giovane."

msgctxt "8||speech_list_caba_riona||table||323||||4"
msgid "I see. Sounds like you'll have to study up\non some modern games."
msgstr "Capisco. Sembra che tu debba aggiornarti\nsui giochi moderni."

msgctxt "8||speech_list_caba_riona||table||324||||4"
msgid "Life is its own sort of game."
msgstr "La vita è essa stessa una sorta di gioco."

msgctxt "8||speech_list_caba_riona||table||325||||4"
msgid "Ooh. That's really deep."
msgstr "Ooh. Questo è molto profondo."

msgctxt "8||speech_list_caba_riona||table||326||||4"
msgid "Ooh. That's pretty deep."
msgstr "Ooh. Piuttosto profondo."

msgctxt "8||speech_list_caba_riona||table||327||||4"
msgid "True, at your age, I bet you've got\na lot of experience under your belt."
msgstr "Vero, alla tua età, scommetto che hai\nun sacco di esperienza alle spalle."

msgctxt "8||speech_list_caba_riona||table||328||||4"
msgid "I wanna hear all about your life, Kiryu-san. <symbol=note_with_outline>"
msgstr "Voglio sentire tutto sulla tua vita, Kiryu-san. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||329||||4"
msgid "It's not as interesting as you'd think."
msgstr "Non è così interessante come potresti pensare."

msgctxt "8||speech_list_caba_riona||table||330||||4"
msgid "Huh? What kind of secret?"
msgstr "Eh? Che tipo di segreto?"

msgctxt "8||speech_list_caba_riona||table||331||||4"
msgid "Ages ago... I was the chairman."
msgstr "Secoli fa... Ero il presidente."

msgctxt "8||speech_list_caba_riona||table||332||||4"
msgid "You mean like, student council president?\nYou're just serious enough to do that."
msgstr "Intendi tipo, il presidente del consiglio studentesco?\nSei abbastanza serio per farlo."

msgctxt "8||speech_list_caba_riona||table||333||||4"
msgid "I was actually raised in an orphanage."
msgstr "In realtà sono cresciuto in un orfanotrofio."

msgctxt "8||speech_list_caba_riona||table||334||||4"
msgid "I wouldn't'a guessed..."
msgstr "Non l'avrei mai detto..."

msgctxt "8||speech_list_caba_riona||table||335||||4"
msgid "I lost both my parents. But my guardian and the\nother orphans became like a family to me."
msgstr "Ho perso entrambi i genitori. Ma il mio tutore e gli\naltri orfani sono diventati come una famiglia per me."

msgctxt "8||speech_list_caba_riona||table||336||||4"
msgid "I was raised by a single mother,\nso I understand how that feels."
msgstr "Sono stata cresciuta da una madre single,\nquindi capisco come ci si sente."

msgctxt "8||speech_list_caba_riona||table||337||||4"
msgid "I'm sure I caused her no end of headaches, but...\nThat's why I'm workin' so hard to pay her back."
msgstr "Sono sicura di averle causato un sacco di grattacapi, ma...\nÈ per questo che lavoro così sodo per ripagarla."

msgctxt "8||speech_list_caba_riona||table||338||||4"
msgid "That's great."
msgstr "È fantastico."

msgctxt "8||speech_list_caba_riona||table||339||||4"
msgid "I'm glad we got to talk about this together."
msgstr "Sono felice che ne abbiamo potuto parlare insieme."

msgctxt "8||speech_list_caba_riona||table||340||||4"
msgid "...No, I probably shouldn't. \nI shouldn't just go around sharing my secrets."
msgstr "...No, probabilmente non dovrei.\nNon dovrei andarmene in giro a svelare i miei segreti."

msgctxt "8||speech_list_caba_riona||table||341||||4"
msgid "Really!? Come on, tell me!\nYa got me curious!"
msgstr "Davvero!? Dai, dimmelo!\nMi hai incuriosita!"

msgctxt "8||speech_list_caba_riona||table||342||||4"
msgid "It seems like a lot of people\nget them for fashion nowadays."
msgstr "Sembra che al giorno d'oggi molta\ngente se li faccia per moda."

msgctxt "8||speech_list_caba_riona||table||343||||4"
msgid "Fashion... Is that all they are these days?"
msgstr "Moda... È solo questo che sono, al giorno d'oggi?"

msgctxt "8||speech_list_caba_riona||table||344||||4"
msgid "How you do feel about that, Kiryu-san?"
msgstr "Tu come ti senti al riguardo, Kiryu-san?"

msgctxt "8||speech_list_caba_riona||table||345||||4"
msgid "As long as it's all in good fun,\nI don't have any complaints."
msgstr "Finché è tutto un gioco,\nnon ho niente in contrario."

msgctxt "8||speech_list_caba_riona||table||346||||4"
msgid "Oh, really? I woulda thought\nyou'd say it was shameful."
msgstr "Oh, davvero? Avrei pensato\nche avresti detto che è una vergogna."

msgctxt "8||speech_list_caba_riona||table||347||||4"
msgid "I don't think that would be\nvery convincing coming from me."
msgstr "Non credo che suonerebbe\nmolto convincente, detto da me."

msgctxt "8||speech_list_caba_riona||table||348||||4"
msgid "Huh...?"
msgstr "Ehe...?"

msgctxt "8||speech_list_caba_riona||table||349||||4"
msgid "I'm not sure I approve of people\ngetting them just for fashion's sake."
msgstr "Non credo di approvare chi\nse li fa solo per moda."

msgctxt "8||speech_list_caba_riona||table||350||||4"
msgid "It's engraved into your skin, so you need\nto be prepared to live with it forever."
msgstr "È inciso nella tua pelle, quindi devi\nessere pronto a conviverci per sempre."

msgctxt "8||speech_list_caba_riona||table||351||||4"
msgid "I see... That's thoughtful.\nYou can't erase it, after all."
msgstr "Capisco... È un pensiero profondo.\nDopo tutto, non puoi cancellarlo."

msgctxt "8||speech_list_caba_riona||table||352||||4"
msgid "Yeah. When I got mine,\nI understood the consequences."
msgstr "Sì. Quando ho fatto il mio,\nne ho compreso le conseguenze."

msgctxt "8||speech_list_caba_riona||table||353||||4"
msgid "I see... Wait, what!?\nYou have one, Kiryu-san?"
msgstr "Capisco... Aspetta, cosa!?\nTu ne hai uno, Kiryu-san?"

msgctxt "8||speech_list_caba_riona||table||354||||4"
msgid "Why didn't ya say so sooner?"
msgstr "Perché non me l'hai detto prima?"

msgctxt "8||speech_list_caba_riona||table||355||||4"
msgid "Sorry, sorry."
msgstr "Scusa, scusa."

msgctxt "8||speech_list_caba_riona||table||356||||4"
msgid "I can't hold mine very well.\nIt makes this job hard sometimes."
msgstr "Non reggo molto bene l'alcol.\nA volte mi rende il lavoro difficile."

msgctxt "8||speech_list_caba_riona||table||357||||4"
msgid "Help me understand what's so great about drinking.\nWhat do you see in it, Kiryu-san?"
msgstr "Aiutami a capire cos'abbia di così bello il bere.\nCosa ci trovi, Kiryu-san?"

msgctxt "8||speech_list_caba_riona||table||358||||4"
msgid "I like how it makes me feel.\nIt also helps me forget the bad stuff."
msgstr "Mi piace come mi fa sentire.\nInoltre mi aiuta a dimenticare le cose brutte."

msgctxt "8||speech_list_caba_riona||table||359||||4"
msgid "You have bad memories too, huh, Kiryu-san?"
msgstr "Hai anche tu dei brutti ricordi, eh, Kiryu-san?"

msgctxt "8||speech_list_caba_riona||table||360||||4"
msgid "Well, yeah. I'd bet most of the guys who come in\nto drink do. So why not help them out? Goes for me, too."
msgstr "Beh, sì. Scommetto che li abbiano quasi tutti i clienti che vengono\nqui a bere. Quindi perché non aiutarli? E vale anche per me."

msgctxt "8||speech_list_caba_riona||table||361||||4"
msgid "You're right. Even though I can't drink,\nI'll try to enjoy it in my own way."
msgstr "Hai ragione. Anche se non posso bere,\ncercherò di godermela a modo mio."

msgctxt "8||speech_list_caba_riona||table||362||||4"
msgid "It's good for your health.\nThey say it makes you live longer."
msgstr "Fa bene alla salute.\nDicono che faccia vivere più a lungo."

msgctxt "8||speech_list_caba_riona||table||363||||4"
msgid "Huh? Really?\nI thought it was generally considered unhealthy."
msgstr "Eh? Davvero?\nPensavo fosse generalmente considerato poco salutare."

msgctxt "8||speech_list_caba_riona||table||364||||4"
msgid "Apparently the issue is how much you drink.\nSome people say it's good for beauty, too."
msgstr "A quanto pare il problema è quanto si beve.\nAlcuni dicono che faccia bene anche alla bellezza."

msgctxt "8||speech_list_caba_riona||table||365||||4"
msgid "Wow, really? If it's good for beauty,\nmaybe I should give it another chance!"
msgstr "Wow, sul serio? Se fa bene alla bellezza,\nforse dovrei dargli un'altra possibilità!"

msgctxt "8||speech_list_caba_riona||table||366||||4"
msgid "It's proof you're a man. Only real\nmen can hold their alcohol."
msgstr "È la prova che sei un uomo. Solo i veri\nuomini sanno reggere l'alcol."

msgctxt "8||speech_list_caba_riona||table||367||||4"
msgid "I see... And what if you're a woman?"
msgstr "Capisco... E se invece sei una donna?"

msgctxt "8||speech_list_caba_riona||table||368||||4"
msgid "Huh? Um... No idea."
msgstr "Eh? Ehm... Non ne ho idea."

msgctxt "8||speech_list_caba_riona||table||369||||4"
msgid "I've heard about them on the news. All I\ngot from it is how scary they are, though."
msgstr "Ne ho sentito parlare al telegiornale. Tutto quello che\nho capito, però, è quanto facciano paura."

msgctxt "8||speech_list_caba_riona||table||370||||4"
msgid "I know her. Idol fans still talk\nabout her debut concert to this day."
msgstr "La conosco. I fan delle idol parlano ancora\noggi del suo concerto di debutto."

msgctxt "8||speech_list_caba_riona||table||371||||4"
msgid "Oh? What have you done?"
msgstr "Oh? E cos'avresti fatto?"

msgctxt "8||speech_list_caba_riona||table||372||||4"
msgid "I've been in a movie before.\nJust as a stand-in, though."
msgstr "Ho recitato in un film, in passato.\nSolo come controfigura, però."

msgctxt "8||speech_list_caba_riona||table||373||||4"
msgid "Wow! Doesn't matter what, that's awesome!\nWhat kinda movie?"
msgstr "Wow! Non importa il ruolo, è fantastico!\nChe tipo di film era?"

msgctxt "8||speech_list_caba_riona||table||374||||4"
msgid "An action movie.\nIt was just a small thing."
msgstr "Un film d'azione.\nEra solo una piccola cosa."

msgctxt "8||speech_list_caba_riona||table||375||||4"
msgid "I used to fight in an arena a lot."
msgstr "Un tempo combattevo spesso in un'arena."

msgctxt "8||speech_list_caba_riona||table||376||||4"
msgid "What? You're a martial artist, Kiryu-san?"
msgstr "Cosa? Sei un esperto di arti marziali, Kiryu-san?"

msgctxt "8||speech_list_caba_riona||table||377||||4"
msgid "Martial arts isn't quite right, but...\nWell, something like that."
msgstr "Arti marziali non è proprio il termine esatto, ma...\nBeh, qualcosa del genere."

msgctxt "8||speech_list_caba_riona||table||378||||4"
msgid "When I was in Fukuoka,\nI had a showdown with a street racer."
msgstr "Quando ero a Fukuoka,\nho avuto una resa dei conti con un pilota clandestino."

msgctxt "8||speech_list_caba_riona||table||379||||4"
msgid "A street racer...?\nLike a biker gang or something?"
msgstr "Un pilota clandestino...?\nTipo una gang di motociclisti o roba simile?"

msgctxt "8||speech_list_caba_riona||table||380||||4"
msgid "It's a little different, but we raced\nfor the title of fastest in Fukuoka."
msgstr "È un po' diverso, ma abbiamo gareggiato\nper il titolo di più veloce di Fukuoka."

msgctxt "8||speech_list_caba_riona||table||381||||4"
msgid "Hmm. I'd be worried about\ngetting into an accident."
msgstr "Mhm. Io sarei preoccupata di\nfare un incidente."

msgctxt "8||speech_list_caba_riona||table||382||||4"
msgid "I don't really cook.\nSometimes I make some snacks, though."
msgstr "Non cucino molto.\nMa a volte preparo qualche spuntino."

msgctxt "8||speech_list_caba_riona||table||383||||4"
msgid "I'm a typical type A. Temperamental and serious,\nI guess. People ask me if I'm type A a lot."
msgstr "Sono un tipico gruppo A. Lunatica e seria,\ncredo. La gente mi chiede spesso se sono di gruppo A."

msgctxt "8||speech_list_caba_riona||table||384||||4"
msgid "That's a bit much, isn't it?"
msgstr "È un po' esagerato, non trovi?"

msgctxt "8||speech_list_caba_riona||table||385||||4"
msgid "I'll leave that to your imagination."
msgstr "Lo lascerò alla tua immaginazione."

msgctxt "8||speech_list_caba_riona||table||386||||4"
msgid "...I wonder."
msgstr "...Chissà."

msgctxt "8||speech_list_caba_riona||table||387||||4"
msgid "There's someone I'm interested in...\nI guess?"
msgstr "C'è qualcuno che mi interessa...\nCredo?"

msgctxt "8||speech_list_caba_riona||table||388||||4"
msgid "I wasn't going to pursue this line of work,\nbut a friend invited me to try it out."
msgstr "Non avevo intenzione di fare questo lavoro,\nma un'amica mi ha invitato a provarci."

msgctxt "8||speech_list_caba_riona||table||389||||4"
msgid "Now I've been at it for quite some time.\nStrange how life works sometimes, huh?"
msgstr "E ora sono qui da un bel po' di tempo.\nStrano come va la vita a volte, eh?"

msgctxt "8||speech_list_caba_riona||table||390||||4"
msgid "What's gotten into you?"
msgstr "Che ti prende?"

msgctxt "8||speech_list_caba_riona||table||391||||4"
msgid "Hey, that's not how the game works..."
msgstr "Ehi, non è così che funziona il gioco..."

msgctxt "8||speech_list_caba_riona||table||392||||4"
msgid "Yaaaay! Wait, that's not how the game works.\nC'mon now."
msgstr "Siii! Aspetta, non è così che funziona il gioco.\nAndiamo."

msgctxt "8||speech_list_caba_riona||table||393||||4"
msgid "Lemme think... I guess I listen to Western\nmusic every now and again."
msgstr "Fammici pensare... Credo di ascoltare\nmusica occidentale, di tanto in tanto."

msgctxt "8||speech_list_caba_riona||table||394||||4"
msgid "I'm glad to hear you say that."
msgstr "Sono felice di sentirtelo dire."

msgctxt "8||speech_list_caba_riona||table||395||||4"
msgid "It's fun spending time with you, too. <symbol=note_with_outline>"
msgstr "È divertente passare del tempo anche con te. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||396||||4"
msgid "Hasn't it?\nI'm doing my best to avoid gettin' sick."
msgstr "Vero?\nSto facendo del mio meglio per evitare di ammalarmi."

msgctxt "8||speech_list_caba_riona||table||397||||4"
msgid "That's nice to hear, even if you are just\nflattering me. Just don't get sick, huh?"
msgstr "È bello sentirselo dire, anche se mi stai solo\nadulando. Cerca solo di non ammalarti, eh?"

msgctxt "8||speech_list_caba_riona||table||398||||4"
msgid "Thanks..."
msgstr "Grazie..."

msgctxt "8||speech_list_caba_riona||table||399||||4"
msgid "Oh, Kiryu-san...\nYou're makin' me blush."
msgstr "Oh, Kiryu-san...\nMi fai arrossire."

msgctxt "8||speech_list_caba_riona||table||400||||4"
msgid "Whoa!? What's gotten into you?"
msgstr "Whoa!? Che ti prende?"

msgctxt "8||speech_list_caba_riona||table||401||||4"
msgid "Uh... Forget that just happened."
msgstr "Ehm... Dimentica quello che è appena successo."

msgctxt "8||speech_list_caba_riona||table||402||||4"
msgid "Whoa! That scared me!\nIs that what you're really like?"
msgstr "Whoa! Mi hai spaventata!\nSei fatto davvero così?"

msgctxt "8||speech_list_caba_riona||table||403||||4"
msgid "No... It's just fun to do that."
msgstr "No... È solo divertente farlo."

msgctxt "8||speech_list_caba_riona||table||404||||4"
msgid "A little out of character... \nbut as long as you're havin' fun, I'm happy. <symbol=note_with_outline>"
msgstr "Un po' fuori dal personaggio...\nma finché ti diverti, io sono felice. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||405||||4"
msgid "Yahoo!"
msgstr "Yahoo!"

msgctxt "8||speech_list_caba_riona||table||406||||4"
msgid "Whoa! What's gotten into you?"
msgstr "Whoa! Che ti è preso?"

msgctxt "8||speech_list_caba_riona||table||407||||4"
msgid "Hey, you started it, Kiryu-san!\nI'm havin' fun too, so I gave it a shot."
msgstr "Ehi, hai iniziato tu, Kiryu-san!\nMi sto divertendo anch'io, quindi ho provato."

msgctxt "8||speech_list_caba_riona||table||408||||4"
msgid "That felt better than I thought it would.\nMaybe I should start shouting more."
msgstr "È stato meglio di quanto pensassi.\nForse dovrei iniziare a urlare più spesso."

msgctxt "8||speech_list_caba_riona||table||409||||4"
msgid "Hello, Kiryu-san."
msgstr "Ciao, Kiryu-san."

msgctxt "8||speech_list_caba_riona||table||410||||4"
msgid "Hey, you can't do that!\nGeez, you're hopeless."
msgstr "Ehi, non puoi farlo!\nCavoli, sei senza speranza."

msgctxt "8||speech_list_caba_riona||table||411||||4"
msgid "Thanks.\nA compliment always makes my day."
msgstr "Grazie.\nUn complimento mi raddrizza sempre la giornata."

msgctxt "8||speech_list_caba_riona||table||412||||4"
msgid "Huh? Really!?"
msgstr "Eh? Davvero!?"

msgctxt "8||speech_list_caba_riona||table||413||||4"
msgid "Yeah. It's a beautiful establishment,\nalways clean down to the corners."
msgstr "Sì. È un bellissimo locale,\nsempre pulito in ogni angolo."

msgctxt "8||speech_list_caba_riona||table||414||||4"
msgid "Whaaaat!? That's what you meant?\nYou're terrible!"
msgstr "Cooosa!? Era quello che intendevi?\nSei terribile!"

msgctxt "8||speech_list_caba_riona||table||415||||4"
msgid "Just kidding."
msgstr "Scherzavo."

msgctxt "8||speech_list_caba_riona||table||416||||4"
msgid "Kiryu-san? Are you okay?"
msgstr "Kiryu-san? Tutto bene?"

msgctxt "8||speech_list_caba_riona||table||417||||4"
msgid "Uh... Never mind."
msgstr "Ehm... Lascia perdere."

msgctxt "8||speech_list_caba_riona||table||418||||4"
msgid "Oh Kiryu-san, you're so greedy. If I agree,\ndoes that mean you'll only have eyes for me?"
msgstr "Oh Kiryu-san, sei così ingordo. Se accetto,\nsignifica che avrai occhi solo per me?"

msgctxt "8||speech_list_caba_riona||table||419||||4"
msgid "Not at the moment.\nI've got my eyes peeled, though."
msgstr "Non al momento.\nPerò tengo gli occhi aperti."

msgctxt "8||speech_list_caba_riona||table||420||||4"
msgid "There may be someone I'm interested in..."
msgstr "Potrebbe esserci qualcuno che mi interessa..."

msgctxt "8||speech_list_caba_riona||table||421||||4"
msgid "I do... Maybe they don't realize it yet..."
msgstr "Sì... Forse non se ne è ancora reso conto..."

msgctxt "8||speech_list_caba_riona||table||422||||4"
msgid "Then, I'll be careful not to fall for you! <symbol=note_with_outline>"
msgstr "Allora, starò attenta a non innamorarmi di te! <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||423||||4"
msgid "It... might be too late."
msgstr "Potrebbe... essere troppo tardi."

msgctxt "8||speech_list_caba_riona||table||424||||4"
msgid "Thanks. We try to make sure our\ncustomers can relax while they're here."
msgstr "Grazie. Cerchiamo di assicurarci che i nostri\nclienti possano rilassarsi mentre sono qui."

msgctxt "8||speech_list_caba_riona||table||425||||4"
msgid "We want them all to walk away satisfied."
msgstr "Vogliamo che vadano via tutti soddisfatti."

msgctxt "8||speech_list_caba_riona||table||426||||4"
msgid "You guys have your head in the game.\nNo wonder it feels so good to be here."
msgstr "Siete proprio concentrate sul lavoro.\nNon c'è da stupirsi che si stia così bene qui."

msgctxt "8||speech_list_caba_riona||table||427||||4"
msgid "I'm pretty new in Tokyo, so I don't have the lay\nof the land yet. I do want to try places, though."
msgstr "Sono abbastanza nuovo a Tokyo, quindi non mi so\nancora orientare bene. Vorrei provare qualche posto, però."

msgctxt "8||speech_list_caba_riona||table||428||||4"
msgid "I... I don't really know what to say..."
msgstr "Io... non so proprio cosa dire..."

msgctxt "8||speech_list_caba_riona||table||429||||4"
msgid "What what what!? You really went that wild?\nYou'll leave the club alone, though, right?"
msgstr "Cosa cosa cosa!? Ti sei scatenato fino a quel punto?\nLascerai in pace il club, però, vero?"

msgctxt "8||speech_list_caba_riona||table||430||||4"
msgid "You poor guy...\nI'll listen if you ever want to let it out."
msgstr "Poveretto...\nTi ascolterò se avrai mai voglia di sfogarti."

msgctxt "8||speech_list_caba_riona||table||431||||4"
msgid "Kiryu-san, I can tell he was\nreally important to you..."
msgstr "Kiryu-san, si capisce che era\ndavvero importante per te..."

msgctxt "8||speech_list_caba_riona||table||432||||4"
msgid "A true friend...\nThat's a pretty tough question."
msgstr "Un vero amico...\nÈ una domanda piuttosto difficile."

msgctxt "8||speech_list_caba_riona||table||433||||4"
msgid "Yeah. I don't have much of an answer myself."
msgstr "Già. Neanch'io ho una vera risposta."

msgctxt "8||speech_list_caba_riona||table||434||||4"
msgid "You're the kinda guy who values his friends,\nKiryu-san. That's what I like about you."
msgstr "Sei il tipo di uomo che dà valore ai propri amici,\nKiryu-san. È questo che mi piace di te."

msgctxt "8||speech_list_caba_riona||table||435||||4"
msgid "I wasn't expectin' that!\nYou can't judge a book by its cover!"
msgstr "Questa non me l'aspettavo!\nNon si può giudicare un libro dalla copertina!"

msgctxt "8||speech_list_caba_riona||table||436||||4"
msgid "That's amazing! I have so much respect for\npeople who can do things I can't."
msgstr "È fantastico! Ho un sacco di rispetto per\nle persone in grado di fare cose che io non so fare."

msgctxt "8||speech_list_caba_riona||table||437||||4"
msgid "Kiryu-san fishing...\nI'd like to see that sometime."
msgstr "Kiryu-san che pesca...\nMi piacerebbe vederlo qualche volta."

msgctxt "8||speech_list_caba_riona||table||438||||4"
msgid "If you visit me in Onomichi,\nI'll show you the whole process."
msgstr "Se vieni a trovarmi a Onomichi,\nti mostrerò l'intero processo."

msgctxt "8||speech_list_caba_riona||table||439||||4"
msgid "That sounds rough...\nBe careful out there, okay?"
msgstr "Sembra dura...\nFa' attenzione là fuori, d'accordo?"

msgctxt "8||speech_list_caba_riona||table||440||||4"
msgid "Maybe you have some kind of charismatic\naura that draws angry people to you?"
msgstr "Forse hai una sorta di aura\ncarismatica che attira la gente arrabbiata?"

msgctxt "8||speech_list_caba_riona||table||441||||4"
msgid "You do have a different aura than most people.\nYep! It's your charisma!"
msgstr "In effetti hai un'aura diversa dalla maggior parte della gente.\nSì! È il tuo carisma!"

msgctxt "8||speech_list_caba_riona||table||442||||4"
msgid "I wish I didn't..."
msgstr "Vorrei non averla..."

msgctxt "8||speech_list_caba_riona||table||443||||4"
msgid "Wow, I've never heard of that before.\nWho knew? It does sound fun, though."
msgstr "Wow, non ne avevo mai sentito parlare.\nChi l'avrebbe mai detto? Sembra divertente, però."

msgctxt "8||speech_list_caba_riona||table||444||||4"
msgid "Wow, really? For your health?"
msgstr "Wow, davvero? Per la tua salute?"

msgctxt "8||speech_list_caba_riona||table||445||||4"
msgid "Well, something like that.\nI also just want to keep getting stronger."
msgstr "Beh, qualcosa del genere.\nVoglio anche solo continuare a diventare più forte."

msgctxt "8||speech_list_caba_riona||table||446||||4"
msgid "You want to improve yourself, huh?\nI love people like that."
msgstr "Vuoi migliorare te stesso, eh?\nAdoro le persone così."

msgctxt "8||speech_list_caba_riona||table||447||||4"
msgid "I've been thinking about joinin' a gym myself.\nYou'll have to tell me more about that."
msgstr "Stavo pensando anch'io di iscrivermi in palestra.\nDovrai parlarmene un po' di più."

msgctxt "8||speech_list_caba_riona||table||448||||4"
msgid "Sure."
msgstr "Certo."

msgctxt "8||speech_list_caba_riona||table||449||||4"
msgid "Does that mean you don't like clubs like this?"
msgstr "Significa che non ti piacciono i club come questo?"

msgctxt "8||speech_list_caba_riona||table||450||||4"
msgid "No... I like this club because it\nmeans I get to see you."
msgstr "No... Questo club mi piace perché\nsignifica che posso vedere te."

msgctxt "8||speech_list_caba_riona||table||451||||4"
msgid "Kiryu-san... You're good at this."
msgstr "Kiryu-san... Ci sai proprio fare."

msgctxt "8||speech_list_caba_riona||table||452||||4"
msgid "Really? I wouldn't have guessed that about you,\nbut, being more measured about it is more mature."
msgstr "Davvero? Non l'avrei mai detto di te,\nma essere più misurati a riguardo è da persone mature."

msgctxt "8||speech_list_caba_riona||table||453||||4"
msgid "Really? I'm actually the same way."
msgstr "Davvero? In realtà anch'io sono così."

msgctxt "8||speech_list_caba_riona||table||454||||4"
msgid "To this day, I'm still not very good at dealing\nwith customers who don't specifically request me."
msgstr "Ancora oggi, non sono molto brava a trattare\ncon i clienti che non mi richiedono nello specifico."

msgctxt "8||speech_list_caba_riona||table||455||||4"
msgid "Really? Well, that's not the kind of thing\nyou can just get over because you want to."
msgstr "Davvero? Beh, non è il tipo di cosa che\npuoi superare solo perché lo vuoi."

msgctxt "8||speech_list_caba_riona||table||456||||4"
msgid "Hm... I wonder what I could do then."
msgstr "Mhm... Mi chiedo cosa potrei fare, allora."

msgctxt "8||speech_list_caba_riona||table||457||||4"
msgid "Think of them as vegetables.\nI've heard that works."
msgstr "Pensali come se fossero delle verdure.\nHo sentito dire che funziona."

msgctxt "8||speech_list_caba_riona||table||458||||4"
msgid "Isn't that a trick to stop being nervous?"
msgstr "Non è un trucco per smettere di essere nervosi?"

msgctxt "8||speech_list_caba_riona||table||459||||4"
msgid "Oh, is it?"
msgstr "Ah, dici?"

msgctxt "8||speech_list_caba_riona||table||460||||4"
msgid "But, it might be a good idea to\nbe a little less wary of them."
msgstr "Però, potrebbe essere una buona idea\nessere un po' meno diffidente nei loro confronti."

msgctxt "8||speech_list_caba_riona||table||461||||4"
msgid "How about trying to love them\nfrom the bottom of your heart?"
msgstr "Che ne diresti di provare ad amarli\ndal profondo del tuo cuore?"

msgctxt "8||speech_list_caba_riona||table||462||||4"
msgid "That seems rather grandiose..."
msgstr "Mi sembra una cosa un po' grandiosa..."

msgctxt "8||speech_list_caba_riona||table||463||||4"
msgid "Yeah..."
msgstr "Già..."

msgctxt "8||speech_list_caba_riona||table||464||||4"
msgid "But I s'pose I could be putting up some\ninternal walls. I'll keep at it!"
msgstr "Ma suppongo di star forse innalzando dei\nmuri interiori. Continuerò a lavorarci su!"

msgctxt "8||speech_list_caba_riona||table||465||||4"
msgid "I don't know.\nI'm not good at it either."
msgstr "Non lo so.\nNon sono bravo in queste cose neanch'io."

msgctxt "8||speech_list_caba_riona||table||466||||4"
msgid "You make a good point!\nI asked the wrong person."
msgstr "Hai ragione!\nHo chiesto alla persona sbagliata."

msgctxt "8||speech_list_caba_riona||table||467||||4"
msgid "But you and I clicked right from the start,\nso maybe we have a more natural chemistry."
msgstr "Però noi due siamo entrati in sintonia fin dall'inizio,\nquindi forse abbiamo una chimica più naturale."

msgctxt "8||speech_list_caba_riona||table||468||||4"
msgid "Yeah, maybe."
msgstr "Sì, forse."

msgctxt "8||speech_list_caba_riona||table||469||||4"
msgid "Anyway, I'm glad we're compatible\nwith each other. <symbol=note_with_outline>"
msgstr "Comunque, sono felice che siamo compatibili\nl'uno con l'altra. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||470||||4"
msgid "Wow, that's amazing.\nYou'll have to take me to one sometime."
msgstr "Wow, è incredibile.\nDovrai portarmici, qualche volta."

msgctxt "8||speech_list_caba_riona||table||471||||4"
msgid "Hm... About 40?"
msgstr "Mhm... Sui 40?"

msgctxt "8||speech_list_caba_riona||table||472||||4"
msgid "Huh... So I look a little younger than I am."
msgstr "Mhm... Quindi sembro un po' più giovane di quel che sono."

msgctxt "8||speech_list_caba_riona||table||473||||4"
msgid "You definitely still look young, Kiryu-san.\nYou've aged like a fine wine."
msgstr "Sembri sicuramente ancora giovane, Kiryu-san.\nSei invecchiato come il buon vino."

msgctxt "8||speech_list_caba_riona||table||474||||4"
msgid "Thanks."
msgstr "Grazie."

msgctxt "8||speech_list_caba_riona||table||475||||4"
msgid "I think you're a great guy.\nYou seem like you'd be a hit with the ladies."
msgstr "Penso che tu sia un grand'uomo.\nSembri il tipo che ha successo con le donne."

msgctxt "8||speech_list_caba_riona||table||476||||4"
msgid "I think you're really charming...\nYeah... And handsome..."
msgstr "Credo che tu sia davvero affascinante...\nSì... E bello..."

msgctxt "8||speech_list_caba_riona||table||477||||4"
msgid "You're... someone irreplaceable to me, I guess?\nIt's embarrassing saying that to your face."
msgstr "Sei... una persona insostituibile per me, immagino?\nÈ imbarazzante dirtelo in faccia."

msgctxt "8||speech_list_caba_riona||table||478||||4"
msgid "I can go either way, I guess.\nAge isn't a factor to me."
msgstr "Mi vanno bene entrambe, credo.\nL'età non è un fattore determinante per me."

msgctxt "8||speech_list_caba_riona||table||479||||4"
msgid "That said, I guess I like strong, independent men,\nso I probably lean more toward older guys."
msgstr "Detto questo, credo mi piacciano gli uomini forti e\nindipendenti, quindi probabilmente propendo per i più grandi."

msgctxt "8||speech_list_caba_riona||table||480||||4"
msgid "Yeah, it does seem like that's the\ntype of guy you'd get along with."
msgstr "Sì, in effetti sembrano proprio\nil tipo di ragazzi con cui andresti d'accordo."

msgctxt "8||speech_list_caba_riona||table||481||||4"
msgid "I... don't really have any fetishes."
msgstr "Io... non ho nessun feticismo in particolare."

msgctxt "8||speech_list_caba_riona||table||482||||4"
msgid "If I had to say, I like open-minded people.\nThat's not really a fetish, though."
msgstr "Se proprio devo, mi piacciono le persone di mentalità aperta.\nAnche se non è propriamente un feticismo."

msgctxt "8||speech_list_caba_riona||table||483||||4"
msgid "I really want more beauty products..."
msgstr "Voglio davvero altri prodotti di bellezza..."

msgctxt "8||speech_list_caba_riona||table||484||||4"
msgid "Should I give you some as a present?"
msgstr "Dovrei regalartene un po'?"

msgctxt "8||speech_list_caba_riona||table||485||||4"
msgid "No, I'll work toward buying them myself.\nBut in exchange, you should request me again. <symbol=note_with_outline>"
msgstr "No, mi impegnerò per comprarmeli da sola.\nMa in cambio, dovresti richiedermi di nuovo. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||486||||4"
msgid "Okay, sure."
msgstr "D'accordo, certo."

msgctxt "8||speech_list_caba_riona||table||487||||4"
msgid "My first love...\nWhen was that again?"
msgstr "Il mio primo amore...\nQuando è stato?"

msgctxt "8||speech_list_caba_riona||table||488||||4"
msgid "Probably when I was a student. There was this\ncute senpai, and I had a crush on him."
msgstr "Probabilmente quando ero una studentessa. C'era\nquesto senpai carino, e io avevo una cotta per lui."

msgctxt "8||speech_list_caba_riona||table||489||||4"
msgid "But I'm actually pretty shy,\nso I never confessed to him."
msgstr "Ma in realtà sono piuttosto timida,\nquindi non mi sono mai dichiarata a lui."

msgctxt "8||speech_list_caba_riona||table||490||||4"
msgid "Do you regret it?"
msgstr "Te ne penti?"

msgctxt "8||speech_list_caba_riona||table||491||||4"
msgid "A little, but nothin' to be done about it now.\nJust have to accept it wasn't meant to be and move on!"
msgstr "Un po', ma ora non c'è più niente da fare.\nDevo solo accettare che non fosse destino e andare avanti!"

msgctxt "8||speech_list_caba_riona||table||492||||4"
msgid "Maybe it'd be easier if I just learned to\nconfess my feelings to whoever I wanted."
msgstr "Forse sarebbe più facile se imparassi semplicemente\na confessare i miei sentimenti a chiunque voglia."

msgctxt "8||speech_list_caba_riona||table||493||||4"
msgid "Then, why not practice on me?"
msgstr "Allora, perché non fai pratica con me?"

msgctxt "8||speech_list_caba_riona||table||494||||4"
msgid "Maybe. I'll think about it."
msgstr "Forse. Ci penserò su."

msgctxt "8||speech_list_caba_riona||table||495||||4"
msgid "Oh, so you're type who prefers that\nsomeone confess to you?"
msgstr "Oh, quindi sei il tipo che preferisce che\nsiano gli altri a dichiararsi a te?"

msgctxt "8||speech_list_caba_riona||table||496||||4"
msgid "I guess so. If I like a guy, I'll try to make\nit as comfortable as I can for him to do that."
msgstr "Credo di sì. Se mi piace un ragazzo, cercherò di metterlo il più\npossibile a suo agio perché sia lui a fare il primo passo."

msgctxt "8||speech_list_caba_riona||table||497||||4"
msgid "You can confess to me whenever you want. <symbol=note_with_outline>"
msgstr "Puoi dichiararti a me quando vuoi. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||498||||4"
msgid "I'll think about it."
msgstr "Ci penserò."

msgctxt "8||speech_list_caba_riona||table||499||||4"
msgid "Sounds like you need to work on it.\nWant to practice on me?"
msgstr "Sembra che tu debba lavorarci su.\nVuoi fare pratica con me?"

msgctxt "8||speech_list_caba_riona||table||500||||4"
msgid "What? Where did you get that idea?\nBut, that might be fun..."
msgstr "Cosa? Da dove ti è venuta quest'idea?\nPerò, potrebbe essere divertente..."

msgctxt "8||speech_list_caba_riona||table||501||||4"
msgid "Okay. Here goes nothin'."
msgstr "Okay. O la va o la spacca."

msgctxt "8||speech_list_caba_riona||table||502||||4"
msgid "Kiryu-san... I've always..."
msgstr "Kiryu-san... Ho sempre..."

msgctxt "8||speech_list_caba_riona||table||503||||4"
msgid "What's wrong?"
msgstr "Cosa c'è che non va?"

msgctxt "8||speech_list_caba_riona||table||504||||4"
msgid "You just looked so serious, Kiryu-san!\nIt was funny for some reason."
msgstr "Sembravi così serio, Kiryu-san!\nÈ stato divertente per qualche motivo."

msgctxt "8||speech_list_caba_riona||table||505||||4"
msgid "...Confessing is hard, huh?\nThanks for lettin' me practice on you."
msgstr "...Dichiararsi è difficile, eh?\nGrazie per avermi lasciato fare pratica con te."

msgctxt "8||speech_list_caba_riona||table||506||||4"
msgid "Let me know if you ever want\nto give it another shot."
msgstr "Fammi sapere se vuoi\nfare un altro tentativo, qualche volta."

msgctxt "8||speech_list_caba_riona||table||507||||4"
msgid "Huh what huh?\nHave you ever heard of tact?"
msgstr "Eh cosa, eh?\nHai mai sentito parlare di tatto?"

msgctxt "8||speech_list_caba_riona||table||508||||4"
msgid "Why do you even care?\nKiryu-san, you're like a pervy old man."
msgstr "Ma a te cosa importa?\nKiryu-san, sembri un vecchio pervertito."

msgctxt "8||speech_list_caba_riona||table||509||||4"
msgid "I'm still not really thinking about marriage...\nMaybe I should be?"
msgstr "Non sto ancora pensando seriamente al matrimonio...\nForse dovrei?"

msgctxt "8||speech_list_caba_riona||table||510||||4"
msgid "Well, focusing on your job is admirable. You\nwouldn't be able to give it your all, otherwise."
msgstr "Beh, concentrarsi sul lavoro è ammirevole. Altrimenti\nnon saresti in grado di dare il massimo."

msgctxt "8||speech_list_caba_riona||table||511||||4"
msgid "You get me, Kiryu-san.\nYeah. I want to focus on my career for now."
msgstr "Mi capisci, Kiryu-san.\nGià. Per ora voglio concentrarmi sulla mia carriera."

msgctxt "8||speech_list_caba_riona||table||512||||4"
msgid "Is that a compliment?"
msgstr "È un complimento?"

msgctxt "8||speech_list_caba_riona||table||513||||4"
msgid "Of course.\nI think your whole presentation is great."
msgstr "Certo.\nPenso che tutta la tua presentazione sia fantastica."

msgctxt "8||speech_list_caba_riona||table||514||||4"
msgid "Kiryu-san... I'm thrilled! I actually put a lot\nof effort into my presentation."
msgstr "Kiryu-san... Sono felicissima! In realtà metto un sacco\ndi impegno nella mia presentazione."

msgctxt "8||speech_list_caba_riona||table||515||||4"
msgid "Does that mean I'm doing a good job?\nThat was just the boost of confidence I needed."
msgstr "Significa che sto facendo un buon lavoro?\nEra proprio l'iniezione di fiducia di cui avevo bisogno."

msgctxt "8||speech_list_caba_riona||table||516||||4"
msgid "I feel like I might have\nseen you in Osaka, too."
msgstr "Ho come l'impressione di aver\nvisto anche te a Osaka."

msgctxt "8||speech_list_caba_riona||table||517||||4"
msgid "Were you in Osaka a long time ago?"
msgstr "Sei stato a Osaka tanto tempo fa?"

msgctxt "8||speech_list_caba_riona||table||518||||4"
msgid "Yeah, I end up there pretty frequently."
msgstr "Sì, ci finisco abbastanza di frequente."

msgctxt "8||speech_list_caba_riona||table||519||||4"
msgid "Then maybe we really have\nseen each other before."
msgstr "Allora forse ci siamo davvero\ngià visti."

msgctxt "8||speech_list_caba_riona||table||520||||4"
msgid "Thanks! I'm not too confident about it,\nthough. It's nice to hear that, though."
msgstr "Grazie! Però non ne sono poi così sicura.\nMa fa comunque piacere sentirtelo dire."

msgctxt "8||speech_list_caba_riona||table||521||||4"
msgid "I'd never forgive someone who cheated on me.\nYou'd better never, Kiryu-san!"
msgstr "Non perdonerei mai chi mi ha tradito.\nE tu non farlo mai, Kiryu-san!"

msgctxt "8||speech_list_caba_riona||table||522||||4"
msgid "O-Of course not."
msgstr "C-Certo che no."

msgctxt "8||speech_list_caba_riona||table||523||||4"
msgid "Outdoor dates are great! If we went out,\nI'd want to see some beautiful scenery."
msgstr "Gli appuntamenti all'aperto sono fantastici! Se uscissimo,\nmi piacerebbe ammirare qualche bel paesaggio."

msgctxt "8||speech_list_caba_riona||table||524||||4"
msgid "Relaxing at home is nice now and then. But if\nthat's all ya ever do... it's just a bit sad."
msgstr "Rilassarsi a casa è bello ogni tanto. Ma se\nè tutto ciò che fai... è un po' triste."

msgctxt "8||speech_list_caba_riona||table||525||||4"
msgid "Is that how I look?\nI didn't!"
msgstr "Ti do quest'impressione?\nNon è così!"

msgctxt "8||speech_list_caba_riona||table||526||||4"
msgid "Is that a marriage proposal?\nI'd have preferred a more romantic line..."
msgstr "È una proposta di matrimonio?\nAvrei preferito una frase un po' più romantica..."

msgctxt "8||speech_list_caba_riona||table||527||||4"
msgid "Sorry, I'm no good at miso soup..."
msgstr "Scusa, non sono brava con la zuppa di miso..."

msgctxt "8||speech_list_caba_riona||table||528||||4"
msgid "Saying stuff like that only makes you\nsound older and older, you know."
msgstr "Dire cose del genere ti fa solo\nsembrare sempre più vecchio, lo sai."

msgctxt "8||speech_list_caba_riona||table||529||||4"
msgid "I haven't gone lately, actually.\nI used to go a lot, though."
msgstr "In realtà ultimamente non ci vado più.\nPerò ci andavo un sacco."

msgctxt "8||speech_list_caba_riona||table||530||||4"
msgid "Do you go a lot, Kiryu-san?"
msgstr "Ci vai spesso, Kiryu-san?"

msgctxt "8||speech_list_caba_riona||table||531||||4"
msgid "Well, now and then."
msgstr "Beh, di tanto in tanto."

msgctxt "8||speech_list_caba_riona||table||532||||4"
msgid "Huh. What kind of songs do you sing?"
msgstr "Mhm. Che genere di canzoni canti?"

msgctxt "8||speech_list_caba_riona||table||533||||4"
msgid "I used to sing a lot of Enka.\nStuff like \"Kamuro Lullaby.\""
msgstr "Cantavo spesso Enka.\nRoba tipo \"Kamuro Lullaby\"."

msgctxt "8||speech_list_caba_riona||table||534||||4"
msgid "Wow, that's so refined.\nIt really makes you seem like a mature man."
msgstr "Wow, che raffinatezza.\nTi fa davvero sembrare un uomo maturo."

msgctxt "8||speech_list_caba_riona||table||535||||4"
msgid "Rock!\nStuff like \"Machine Gun Kiss.\""
msgstr "Rock!\nRoba tipo \"Machine Gun Kiss\"."

msgctxt "8||speech_list_caba_riona||table||536||||4"
msgid "Rock, huh? You have a great voice,\nso I bet you sound cool!"
msgstr "Rock, eh? Hai una bellissima voce,\nquindi scommetto che sei fantastico!"

msgctxt "8||speech_list_caba_riona||table||537||||4"
msgid "Interjections."
msgstr "Cori."

msgctxt "8||speech_list_caba_riona||table||538||||4"
msgid "I-Interjections?"
msgstr "C-Cori?"

msgctxt "8||speech_list_caba_riona||table||539||||4"
msgid "Yeah. I'm better at getting the mood going\nthan singing myself."
msgstr "Sì. Sono più bravo a creare l'atmosfera\nche a cantare."

msgctxt "8||speech_list_caba_riona||table||540||||4"
msgid "Really...?\nKiryu-san, you're an odd one."
msgstr "Davvero...?\nKiryu-san, sei proprio un tipo strano."

msgctxt "8||speech_list_caba_riona||table||541||||4"
msgid "Really? \nPersonally I prefer guys that are more safe."
msgstr "Davvero?\nPersonalmente preferisco i ragazzi un po' più tranquilli."

msgctxt "8||speech_list_caba_riona||table||542||||4"
msgid "Wow, I've never met anyone like him.\nHe sounds very... unique?"
msgstr "Wow, non ho mai incontrato nessuno come lui.\nSembra un tipo molto... particolare?"

msgctxt "8||speech_list_caba_riona||table||543||||4"
msgid "A friend in the police, huh?\nKiryu-san, were you a bad boy?"
msgstr "Un amico nella polizia, eh?\nKiryu-san, sei stato un cattivo ragazzo?"

msgctxt "8||speech_list_caba_riona||table||544||||4"
msgid "Well... somewhat."
msgstr "Beh... in un certo senso."

msgctxt "8||speech_list_caba_riona||table||545||||4"
msgid "You're friends with a hot-shot like that?\nI'd like to pick his brain."
msgstr "Sei amico di un pezzo grosso del genere?\nMi piacerebbe scambiarci due parole."

msgctxt "8||speech_list_caba_riona||table||546||||4"
msgid "He's from Kansai too, huh?\nMaybe we could be friends. <symbol=note_with_outline>"
msgstr "Viene dal Kansai anche lui, eh?\nForse potremmo diventare amici. <symbol=note_with_outline>"

msgctxt "8||speech_list_caba_riona||table||547||||4"
msgid "Wow, he's the chairman of the organization?\nThat's amazing for his age."
msgstr "Wow, è il presidente dell'organizzazione?\nÈ incredibile per la sua età."

msgctxt "8||speech_list_caba_riona||table||548||||4"
msgid "There's a sophisticated feel to that place, right?\nSeems like a good place to relax."
msgstr "C'è un'atmosfera sofisticata in quel posto, vero?\nSembra un bel posto per rilassarsi."

msgctxt "9||speech_list_caba_saki||table||0||||4"
msgid "Kiryu-san! Sorry I'm late. <symbol=note_with_outline>"
msgstr "Kiryu-san! Scusami per il ritardo. <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||1||||4"
msgid "Did you have to wait long...?"
msgstr "Hai dovuto aspettare molto...?"

msgctxt "9||speech_list_caba_saki||table||2||||4"
msgid "Kiryu-san! I couldn't wait to see you again! <symbol=note_with_outline>"
msgstr "Kiryu-san! Non vedevo l'ora di rivederti! <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||3||||4"
msgid "Where should we go?"
msgstr "Dove andiamo?"

msgctxt "9||speech_list_caba_saki||table||4||||4"
msgid "Karaoke! Nice choice!"
msgstr "Karaoke! Ottima scelta!"

msgctxt "9||speech_list_caba_saki||table||5||||4"
msgid "That sounds fun!\nI never really get to play darts."
msgstr "Sembra divertente!\nNon gioco quasi mai a freccette."

msgctxt "9||speech_list_caba_saki||table||6||||4"
msgid "C'mon, let's go. <symbol=note_with_outline>"
msgstr "Andiamo. <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||7||||4"
msgid "I wonder what song you'll sing... <symbol=heart_with_outline>"
msgstr "Chissà che canzone canterai... <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||8||||4"
msgid "Let's see...\nWhat should I sing today? <symbol=note_with_outline>"
msgstr "Vediamo...\nCosa dovrei cantare oggi? <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||9||||4"
msgid "I'm not so hot at darts, so go easy on me!"
msgstr "Non sono un fenomeno a freccette, quindi vacci piano!"

msgctxt "9||speech_list_caba_saki||table||10||||4"
msgid "All right! Let's do this!"
msgstr "Va bene! Diamoci dentro!"

msgctxt "9||speech_list_caba_saki||table||11||||4"
msgid "W-Well, we're just getting started.\nWe can still have some fun, right...?"
msgstr "B-Beh, abbiamo appena iniziato.\nPossiamo ancora divertirci un po', no...?"

msgctxt "9||speech_list_caba_saki||table||12||||4"
msgid "That was fun! <symbol=note_with_outline>\nWe should do this again sometime."
msgstr "È stato divertente! <symbol=note_with_outline>\nDobbiamo rifarlo, qualche volta."

msgctxt "9||speech_list_caba_saki||table||13||||4"
msgid "That was so fun! <symbol=heart_with_outline> It's rare to have a\ncustomer who's so fun to hang out with!"
msgstr "È stato divertentissimo! <symbol=heart_with_outline> È raro trovare un\ncliente con cui sia così bello uscire!"

msgctxt "9||speech_list_caba_saki||table||14||||4"
msgid "Well, it's about that time.\nLet's head back to the club."
msgstr "Beh, si è fatta una certa.\nTorniamo al club."

msgctxt "9||speech_list_caba_saki||table||15||||4"
msgid "Oh, I love this song! <symbol=heart_with_outline>\nI want you to hear it. <symbol=note_with_outline>"
msgstr "Oh, adoro questa canzone! <symbol=heart_with_outline>\nVoglio fartela sentire. <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||16||||4"
msgid "Cool, they have this song at karaoke? <symbol=note_with_outline>\nThat's the one I'm singing then."
msgstr "Forte, hanno questa canzone al karaoke? <symbol=note_with_outline>\nAllora ho deciso cosa cantare."

msgctxt "9||speech_list_caba_saki||table||17||||4"
msgid "Hm... I'm having a hard time getting\nin the groove today..."
msgstr "Mhm... Oggi faccio fatica a prendere\nil ritmo..."

msgctxt "9||speech_list_caba_saki||table||18||||4"
msgid "Kiryu-san! That's kinda distracting..."
msgstr "Kiryu-san! Così mi distrai..."

msgctxt "9||speech_list_caba_saki||table||19||||4"
msgid "That was so fun!\nYou're great at getting the mood going. <symbol=heart_with_outline>"
msgstr "È stato divertentissimo!\nSei bravissimo a creare l'atmosfera. <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||20||||4"
msgid "I feel like I sang my heart out. <symbol=heart_with_outline>\nYou made me feel right at home. <symbol=note_with_outline>"
msgstr "Sento di aver cantato con tutta l'anima. <symbol=heart_with_outline>\nMi hai fatto sentire a casa. <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||21||||4"
msgid "Hey, you're gonna sing something too, right? <symbol=note_with_outline>"
msgstr "Ehi, canterai qualcosa anche tu, vero? <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||22||||4"
msgid "Aww... I wanted to hear what you sound like..."
msgstr "Aww... Volevo sentire la tua voce..."

msgctxt "9||speech_list_caba_saki||table||23||||4"
msgid "Um, well...\nI think I could tell what you were going for!"
msgstr "Ehm, beh...\nCredo di aver capito la tua intenzione!"

msgctxt "9||speech_list_caba_saki||table||24||||4"
msgid "You're a great singer! <symbol=note_with_outline>\nYou had me swept up in your voice."
msgstr "Sei bravissimo a cantare! <symbol=note_with_outline>\nMi hai letteralmente rapita con la tua voce."

msgctxt "9||speech_list_caba_saki||table||25||||4"
msgid "How did you become such a good singer!?\nI just want to listen to you forever... <symbol=heart_with_outline>"
msgstr "Come fai a cantare così bene!?\nVorrei ascoltarti all'infinito... <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||26||||4"
msgid "Huh? Really!?\nYou've got deep pockets. <symbol=heart_with_outline>"
msgstr "Eh? Davvero!?\nNon badi a spese. <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||27||||4"
msgid "Thank you."
msgstr "Grazie."

msgctxt "9||speech_list_caba_saki||table||28||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "9||speech_list_caba_saki||table||29||||4"
msgid "Oh, that one's really good. <symbol=note_with_outline>\nI like it, too. <symbol=note_with_outline>"
msgstr "Oh, quello è davvero buono. <symbol=note_with_outline>\nPiace molto anche a me. <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||30||||4"
msgid "Excuse me."
msgstr "Permesso."

msgctxt "9||speech_list_caba_saki||table||31||||4"
msgid "Nice to meet you.\nI'm Saki."
msgstr "Piacere di conoscerti.\nSono Saki."

msgctxt "9||speech_list_caba_saki||table||32||||4"
msgid "Fun fact, I'm actually a pro wrestler."
msgstr "Curiosità: in realtà sono una pro wrestler."

msgctxt "9||speech_list_caba_saki||table||33||||4"
msgid "Huh. That's unusual.\nThis should be fun."
msgstr "Mhm. Insolito.\nSarà divertente."

msgctxt "9||speech_list_caba_saki||table||34||||4"
msgid "I'm glad to hear you say that.\nUm, can I ask what your name is?"
msgstr "Sono felice di sentirtelo dire.\nEhm, posso chiederti come ti chiami?"

msgctxt "9||speech_list_caba_saki||table||35||||4"
msgid "Yeah. Kazuma Kiryu."
msgstr "Sì. Kazuma Kiryu."

msgctxt "9||speech_list_caba_saki||table||36||||4"
msgid "Kiryu-san, then!\nLet's have some fun today then, hm? <symbol=note_with_outline>"
msgstr "Kiryu-san, allora!\nDivertiamoci un po' oggi, eh? <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||37||||4"
msgid "Thanks for requesting me today. <symbol=heart_with_outline>\nThink you'll come back again...?"
msgstr "Grazie per avermi richiesta oggi. <symbol=heart_with_outline>\nPensi che tornerai ancora...?"

msgctxt "9||speech_list_caba_saki||table||38||||4"
msgid "Yeah, I had a good time."
msgstr "Sì, sono stato bene."

msgctxt "9||speech_list_caba_saki||table||39||||4"
msgid "I'm happy to hear that."
msgstr "Sono felice di sentirlo."

msgctxt "9||speech_list_caba_saki||table||40||||4"
msgid "Kiryu-san, I'm glad you came back."
msgstr "Kiryu-san, sono felice che tu sia tornato."

msgctxt "9||speech_list_caba_saki||table||41||||4"
msgid "Kiryu-san, I've been waiting for you. <symbol=note_with_outline>"
msgstr "Kiryu-san, ti stavo aspettando. <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||42||||4"
msgid "Kiryu-san, I've been hoping you'd\nshow up... <symbol=heart_with_outline>"
msgstr "Kiryu-san, speravo proprio\nche ti saresti fatto vivo... <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||43||||4"
msgid "I'm glad we got to spend more time together\nthan usual today. <symbol=heart_with_outline>"
msgstr "Sono felice che oggi abbiamo potuto passare\npiù tempo del solito insieme. <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||44||||4"
msgid "Come on in."
msgstr "Entra pure."

msgctxt "9||speech_list_caba_saki||table||45||||4"
msgid "Kiryu-san!"
msgstr "Kiryu-san!"

msgctxt "9||speech_list_caba_saki||table||46||||4"
msgid "Thanks for coming today.\nHope to see you again."
msgstr "Grazie per essere venuto oggi.\nSpero di rivederti."

msgctxt "9||speech_list_caba_saki||table||47||||4"
msgid "Thanks for coming today. <symbol=note_with_outline>\nYou'd better come back, okay? <symbol=heart_with_outline>"
msgstr "Grazie per essere venuto oggi. <symbol=note_with_outline>\nVedi di tornare, d'accordo? <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||48||||4"
msgid "Thank you, Kiryu-san. <symbol=note_with_outline>\nI want to see you again soon... <symbol=heart_with_outline>"
msgstr "Grazie, Kiryu-san. <symbol=note_with_outline>\nVoglio rivederti presto... <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||49||||4"
msgid "I'll see you later, Kiryu-san. <symbol=heart_with_outline>"
msgstr "A dopo, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||50||||4"
msgid "Cheers!"
msgstr "Salute!"

msgctxt "9||speech_list_caba_saki||table||51||||4"
msgid "Oh, Kiryu-san.\nDo you have a sec?"
msgstr "Oh, Kiryu-san.\nHai un secondo?"

msgctxt "9||speech_list_caba_saki||table||52||||4"
msgid "Here's my number.\nI expect you to invite me out sometime, okay? <symbol=heart_with_outline>"
msgstr "Ecco il mio numero.\nMi aspetto che mi inviti a uscire qualche volta, okay? <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||53||||4"
msgid "It's almost time.\nWhat do you wanna do?"
msgstr "È quasi ora.\nCosa vuoi fare?"

msgctxt "9||speech_list_caba_saki||table||54||||4"
msgid "Time's up...\nThat really flew by."
msgstr "Il tempo è scaduto...\nÈ letteralmente volato."

msgctxt "9||speech_list_caba_saki||table||55||||4"
msgid "Yay! I knew I could count on you, Kiryu-san. <symbol=heart_with_outline>"
msgstr "Evviva! Sapevo di poter contare su di te, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||56||||4"
msgid "Thanks a lot for today."
msgstr "Grazie mille per oggi."

msgctxt "9||speech_list_caba_saki||table||57||||4"
msgid "Oh, that's true!"
msgstr "Oh, è vero!"

msgctxt "9||speech_list_caba_saki||table||58||||4"
msgid "Yeah, I totally know what you mean!"
msgstr "Sì, so perfettamente cosa intendi!"

msgctxt "9||speech_list_caba_saki||table||59||||4"
msgid "No doubt about it."
msgstr "Senza alcun dubbio."

msgctxt "9||speech_list_caba_saki||table||60||||4"
msgid "I agree!\nI feel the same way."
msgstr "Sono d'accordo!\nProvo la stessa cosa."

msgctxt "9||speech_list_caba_saki||table||61||||4"
msgid "Huh? I don't think so."
msgstr "Eh? Non direi proprio."

msgctxt "9||speech_list_caba_saki||table||62||||4"
msgid "Hmm... Really?"
msgstr "Mhm... Davvero?"

msgctxt "9||speech_list_caba_saki||table||63||||4"
msgid "I don't think so..."
msgstr "Non credo..."

msgctxt "9||speech_list_caba_saki||table||64||||4"
msgid "Sorry, I don't really get it."
msgstr "Scusa, non ho ben capito."

msgctxt "9||speech_list_caba_saki||table||65||||4"
msgid "Geez, what are you saying, Kiryu-san?"
msgstr "Cavoli, ma che dici, Kiryu-san?"

msgctxt "9||speech_list_caba_saki||table||66||||4"
msgid "Yeah, that's right. <symbol=note_with_outline>"
msgstr "Sì, esatto. <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||67||||4"
msgid "Wow, really?"
msgstr "Wow, sul serio?"

msgctxt "9||speech_list_caba_saki||table||68||||4"
msgid "I wonder..."
msgstr "Chissà..."

msgctxt "9||speech_list_caba_saki||table||69||||4"
msgid "I have to say, it's rare for someone\nto be both a hostess and a pro wrestler."
msgstr "Devo ammettere che è raro trovare qualcuno\nche faccia sia la hostess che la pro wrestler."

msgctxt "9||speech_list_caba_saki||table||70||||4"
msgid "Yeah, that's what everyone says."
msgstr "Già, me lo dicono tutti."

msgctxt "9||speech_list_caba_saki||table||71||||4"
msgid "How do you feel about that?"
msgstr "Tu come la vivi?"

msgctxt "9||speech_list_caba_saki||table||72||||4"
msgid "Guys request me for the novelty of it, but the\nreaction's not great if they wanted a \"traditional\" girl."
msgstr "I ragazzi mi richiedono per la novità, ma la\nreazione non è il massimo se volevano una ragazza \"tradizionale\"."

msgctxt "9||speech_list_caba_saki||table||73||||4"
msgid "Kinda makes me wonder... should I try to act\nmore feminine so I can be more popular?"
msgstr "Questo mi fa pensare... dovrei cercare di comportarmi\nin modo più femminile per essere più popolare?"

msgctxt "9||speech_list_caba_saki||table||74||||4"
msgid "You are who you are, right?"
msgstr "Tu sei quella che sei, no?"

msgctxt "9||speech_list_caba_saki||table||75||||4"
msgid "Huh...?"
msgstr "Ehe...?"

msgctxt "9||speech_list_caba_saki||table||76||||4"
msgid "You shouldn't have to hide who you really are.\nYour physique sets you apart, as far as I'm concerned."
msgstr "Non dovresti nascondere chi sei veramente.\nIl tuo fisico ti distingue, per quanto mi riguarda."

msgctxt "9||speech_list_caba_saki||table||77||||4"
msgid "Kiryu-san..."
msgstr "Kiryu-san..."

msgctxt "9||speech_list_caba_saki||table||78||||4"
msgid "Kiryu-san... Y-You're right!\nI was getting kinda self-conscious."
msgstr "Kiryu-san... H-Hai ragione!\nMi stavo facendo troppe paranoie."

msgctxt "9||speech_list_caba_saki||table||79||||4"
msgid "You sound more optimistic already."
msgstr "Sembri già più ottimista."

msgctxt "9||speech_list_caba_saki||table||80||||4"
msgid "Yeah! I'll aim for the number one\nspot in my own way!"
msgstr "Sì! Punterò al primo posto\na modo mio!"

msgctxt "9||speech_list_caba_saki||table||81||||4"
msgid "Yeah, and I'll support you however I can."
msgstr "Sì, e io ti sosterrò in ogni modo possibile."

msgctxt "9||speech_list_caba_saki||table||82||||4"
msgid "Well, you are kind of manly."
msgstr "Beh, sei un po' mascolina."

msgctxt "9||speech_list_caba_saki||table||83||||4"
msgid "You're right... but guys do say it\nmakes me easier to talk to, though."
msgstr "Hai ragione... ma i ragazzi dicono che\nquesto rende più facile parlarmi, però."

msgctxt "9||speech_list_caba_saki||table||84||||4"
msgid "Then, why not use that to your advantage?\nYou just have to own it and stay optimistic."
msgstr "Allora, perché non usarlo a tuo vantaggio?\nDevi solo accettarlo e restare ottimista."

msgctxt "9||speech_list_caba_saki||table||85||||4"
msgid "You're right. No point being indecisive!\nI'll try to be more optimistic!"
msgstr "Hai ragione. Non ha senso essere indecisa!\nCercherò di essere più ottimista!"

msgctxt "9||speech_list_caba_saki||table||86||||4"
msgid "There you go.\nThat's a manly thing to say."
msgstr "Ecco così.\nQuesta sì che è una cosa virile da dire."

msgctxt "9||speech_list_caba_saki||table||87||||4"
msgid "Come on, Kiryu-san.\nDon't tease me."
msgstr "Andiamo, Kiryu-san.\nNon prendermi in giro."

msgctxt "9||speech_list_caba_saki||table||88||||4"
msgid "I love... wrestling."
msgstr "Io amo... il wrestling."

msgctxt "9||speech_list_caba_saki||table||89||||4"
msgid "What!? Pro wrestling?\nAren't you supposed to say you love me?"
msgstr "Cosa!? Il pro wrestling?\nNon dovresti dire che ami me?"

msgctxt "9||speech_list_caba_saki||table||90||||4"
msgid "Just kidding. But I do think talking so\ncasually like this is part of your charm."
msgstr "Scherzavo. Ma penso che parlare in modo così\ninformale faccia parte del tuo fascino."

msgctxt "9||speech_list_caba_saki||table||91||||4"
msgid "Kiryu-san... That's true.\nI do have my own way of doing things."
msgstr "Kiryu-san... È vero.\nHo il mio personalissimo modo di fare le cose."

msgctxt "9||speech_list_caba_saki||table||92||||4"
msgid "I'm feeling more optimistic now!\nThank you, Kiryu-san."
msgstr "Mi sento molto più ottimista adesso!\nGrazie, Kiryu-san."

msgctxt "9||speech_list_caba_saki||table||93||||4"
msgid "No problem. Good luck."
msgstr "Di nulla. Buona fortuna."

msgctxt "9||speech_list_caba_saki||table||94||||4"
msgid "By the way, Saki, why'd you go into pro\nwrestling? What was your motivation?"
msgstr "A proposito, Saki, perché sei entrata nel\npro wrestling? Qual è stata la tua motivazione?"

msgctxt "9||speech_list_caba_saki||table||95||||4"
msgid "Actually I wasn't interested at all at first,\nbut the more I did it, the more I fell in love."
msgstr "A dirla tutta, all'inizio non mi interessava affatto,\nma più lo facevo, più me ne innamoravo."

msgctxt "9||speech_list_caba_saki||table||96||||4"
msgid "Before I realized it, going pro had its hooks\nin me. I've been working hard at it ever since!"
msgstr "Prima che me ne rendessi conto, l'idea di diventare una professionista\nmi aveva rapita. Da allora ci ho dato dentro!"

msgctxt "9||speech_list_caba_saki||table||97||||4"
msgid "There were some bumps in the road, but I managed\nto make connections and now I'm a pro wrestler."
msgstr "Ci sono stati degli ostacoli lungo la strada, ma sono riuscita\na farmi dei contatti e ora sono una pro wrestler."

msgctxt "9||speech_list_caba_saki||table||98||||4"
msgid "Huh. So you didn't like it at the start."
msgstr "Mhm. Quindi all'inizio non ti piaceva."

msgctxt "9||speech_list_caba_saki||table||99||||4"
msgid "Right. But I saw this match that really moved me.\nIt's like that match gave me a purpose in life."
msgstr "Esatto. Ma poi ho visto un incontro che mi ha davvero emozionata.\nÈ come se quell'incontro mi avesse dato uno scopo nella vita."

msgctxt "9||speech_list_caba_saki||table||100||||4"
msgid "When I saw that, I decided I wanted to be able\nto move people in the same way."
msgstr "Quando l'ho visto, ho deciso che volevo essere in grado\ndi emozionare le persone allo stesso modo."

msgctxt "9||speech_list_caba_saki||table||101||||4"
msgid "That's great.\nI'd like to see if you stir my emotions, too."
msgstr "È fantastico.\nMi piacerebbe vedere se riesci a far emozionare anche me."

msgctxt "9||speech_list_caba_saki||table||102||||4"
msgid "Kiryu-san, you've got it. I'll work at it\nuntil I've met your expectations!"
msgstr "Kiryu-san, ci puoi contare. Lavorerò sodo\nfinché non avrò soddisfatto le tue aspettative!"

msgctxt "9||speech_list_caba_saki||table||103||||4"
msgid "Someday maybe I'll let you\ntouch my championship belt."
msgstr "Magari un giorno ti lascerò\ntoccare la mia cintura da campionessa."

msgctxt "9||speech_list_caba_saki||table||104||||4"
msgid "Looking forward to it."
msgstr "Non vedo l'ora."

msgctxt "9||speech_list_caba_saki||table||105||||4"
msgid "I'd like to move you, too."
msgstr "Mi piacerebbe far emozionare anche te."

msgctxt "9||speech_list_caba_saki||table||106||||4"
msgid "Huh? Are you going to take up pro wrestling, too?\nYou do look capable enough..."
msgstr "Eh? Vuoi darti al pro wrestling anche tu?\nIn effetti sembri averne la stoffa..."

msgctxt "9||speech_list_caba_saki||table||107||||4"
msgid "No, you just looked so happy talking about your\ndreams. It made me feel like I have to keep up."
msgstr "No, è solo che sembravi così felice mentre parlavi dei tuoi\nsogni. Mi hai fatto venire voglia di tenere il passo."

msgctxt "9||speech_list_caba_saki||table||108||||4"
msgid "In that sense...\nmaybe you've already moved me."
msgstr "In tal senso...\nforse mi hai già fatto emozionare."

msgctxt "9||speech_list_caba_saki||table||109||||4"
msgid "Kiryu-san... That makes me so happy.\nI hope I can really stir your emotions someday!"
msgstr "Kiryu-san... Questo mi rende così felice.\nSpero davvero di riuscire a farti emozionare un giorno!"

msgctxt "9||speech_list_caba_saki||table||110||||4"
msgid "Do one of your moves on me!"
msgstr "Fammi una delle tue mosse!"

msgctxt "9||speech_list_caba_saki||table||111||||4"
msgid "Huh? Where'd that come from, Kiryu-san?"
msgstr "Eh? Da dove ti è uscita questa, Kiryu-san?"

msgctxt "9||speech_list_caba_saki||table||112||||4"
msgid "Well, I just thought I'd get a taste of what you\nfelt if you did one of your moves on me."
msgstr "Beh, pensavo solo di provare sulla mia pelle cosa\nsi prova se mi facessi una delle tue mosse."

msgctxt "9||speech_list_caba_saki||table||113||||4"
msgid "All you'd get from that is sore.\nIf you wanna be moved, come see a match sometime."
msgstr "Ne ricaveresti solo un gran dolore.\nSe vuoi emozionarti, vieni a vedere un incontro, qualche volta."

msgctxt "9||speech_list_caba_saki||table||114||||4"
msgid "Okay.\nLooking forward to it."
msgstr "Okay.\nNon vedo l'ora."

msgctxt "9||speech_list_caba_saki||table||115||||4"
msgid "So now I know why you became a pro wrestler,\nbut what made you decide to become a hostess?"
msgstr "Quindi ora so perché sei diventata una pro wrestler,\nma cosa ti ha spinta a fare la hostess?"

msgctxt "9||speech_list_caba_saki||table||116||||4"
msgid "I'm a tomboy and I'm a pro wrestler on top of it,\nso I wanted to become more feminine."
msgstr "Sono un maschiaccio e oltretutto faccio la pro wrestler,\nquindi volevo diventare più femminile."

msgctxt "9||speech_list_caba_saki||table||117||||4"
msgid "I thought being a hostess might help me polish\nthat aspect of myself. Also... well, the money."
msgstr "Ho pensato che fare la hostess avrebbe potuto aiutarmi a\ncurare quell'aspetto di me stessa. E poi... beh, per i soldi."

msgctxt "9||speech_list_caba_saki||table||118||||4"
msgid "Money?"
msgstr "I soldi?"

msgctxt "9||speech_list_caba_saki||table||119||||4"
msgid "Yeah. The team I'm on isn't very big,\nso we're pretty poor, if I'm being honest."
msgstr "Sì. Il team di cui faccio parte non è molto grande,\nquindi siamo piuttosto poveri, a essere sincera."

msgctxt "9||speech_list_caba_saki||table||120||||4"
msgid "Even when I fight, the money isn't very good.\nA lot of us have part-time jobs on the side."
msgstr "Anche quando combatto, i guadagni non sono granché.\nMolte di noi hanno dei lavori part-time per arrotondare."

msgctxt "9||speech_list_caba_saki||table||121||||4"
msgid "And when you get hurt you have to pay for the\ntreatment... the costs really add up."
msgstr "E quando ti fai male devi pagare per le\ncure mediche... i costi si accumulano in fretta."

msgctxt "9||speech_list_caba_saki||table||122||||4"
msgid "I see... Sounds like being a pro wrestler\ncan be kind of rough."
msgstr "Capisco... Sembra che fare il pro wrestler\npossa essere piuttosto dura."

msgctxt "9||speech_list_caba_saki||table||123||||4"
msgid "It is. Someday I'd like to be able\nto focus on just wrestling, though."
msgstr "Lo è. Un giorno però mi piacerebbe potermi\nconcentrare solo sul wrestling."

msgctxt "9||speech_list_caba_saki||table||124||||4"
msgid "It's great that you want to focus on wrestling,\nbut... that wouldn't be great for me."
msgstr "È fantastico che tu voglia concentrarti sul wrestling,\nma... per me non sarebbe una bella notizia."

msgctxt "9||speech_list_caba_saki||table||125||||4"
msgid "Huh? Why's that?"
msgstr "Eh? E perché?"

msgctxt "9||speech_list_caba_saki||table||126||||4"
msgid "Because I wouldn't be able\nto see you anymore, of course."
msgstr "Perché non potrei più vederti, ovviamente."

msgctxt "9||speech_list_caba_saki||table||127||||4"
msgid "Kiryu-san...\nGosh, what are you saying?"
msgstr "Kiryu-san...\nCielo, ma che vai dicendo?"

msgctxt "9||speech_list_caba_saki||table||128||||4"
msgid "But, you're right. I've actually met a lot of\npeople here that I've turned into wrestling fans."
msgstr "Però hai ragione. In realtà qui ho incontrato un\nsacco di persone che ho trasformato in fan del wrestling."

msgctxt "9||speech_list_caba_saki||table||129||||4"
msgid "I should continue working here and aim for the\ntop for their sake!"
msgstr "Dovrei continuare a lavorare qui e puntare\nalla vetta per il loro bene!"

msgctxt "9||speech_list_caba_saki||table||130||||4"
msgid "Nice. Wouldn't it be even better to aim\nfor the top in both jobs?"
msgstr "Bello. Non sarebbe ancora meglio puntare\nalla vetta in entrambi i lavori?"

msgctxt "9||speech_list_caba_saki||table||131||||4"
msgid "Totally. I'll aim for the champion's\nbelt in the cabaret trade, too!"
msgstr "Assolutamente. Punterò alla cintura\ndi campionessa anche nel cabaret!"

msgctxt "9||speech_list_caba_saki||table||132||||4"
msgid "What if I supported you?"
msgstr "E se ti mantenessi io?"

msgctxt "9||speech_list_caba_saki||table||133||||4"
msgid "Really? That's so nice of you.\nBut, I'm happy enough that you offered."
msgstr "Davvero? È molto dolce da parte tua.\nMa mi basta anche solo il pensiero."

msgctxt "9||speech_list_caba_saki||table||134||||4"
msgid "I want to at least be able\nto support my own lifestyle."
msgstr "Voglio almeno essere in grado\ndi mantenermi da sola."

msgctxt "9||speech_list_caba_saki||table||135||||4"
msgid "I don't feel like I could entertain an audience\nif I were living off someone else's money."
msgstr "Non credo che riuscirei a intrattenere il pubblico\nse vivessi con i soldi di un altro."

msgctxt "9||speech_list_caba_saki||table||136||||4"
msgid "I like that determination.\nYou're a real professional, Saki."
msgstr "Mi piace la tua determinazione.\nSei una vera professionista, Saki."

msgctxt "9||speech_list_caba_saki||table||137||||4"
msgid "Thank you."
msgstr "Grazie."

msgctxt "9||speech_list_caba_saki||table||138||||4"
msgid "But, when I retire from wrestling and run\nout of money, maybe I'll come knocking, huh?"
msgstr "Ma quando mi ritirerò dal wrestling e sarò a\ncorto di soldi, magari verrò a bussare alla tua porta, eh?"

msgctxt "9||speech_list_caba_saki||table||139||||4"
msgid "I'll think about it."
msgstr "Ci penserò."

msgctxt "9||speech_list_caba_saki||table||140||||4"
msgid "Then you should just marry me."
msgstr "Allora dovresti semplicemente sposarmi."

msgctxt "9||speech_list_caba_saki||table||141||||4"
msgid "Huh!? Kiryu-san, where'd that come from!?"
msgstr "Eh!? Kiryu-san, da dove ti è uscita!?"

msgctxt "9||speech_list_caba_saki||table||142||||4"
msgid "Well, if we got married,\nI could support you as family."
msgstr "Beh, se fossimo sposati,\npotrei mantenerti come si fa in famiglia."

msgctxt "9||speech_list_caba_saki||table||143||||4"
msgid "Oh, I see.\nI didn't think of it that way..."
msgstr "Oh, capisco.\nNon l'avevo vista in questo modo..."

msgctxt "9||speech_list_caba_saki||table||144||||4"
msgid "But sheesh... That caught me off guard.\nMy heart's still racing..."
msgstr "Però cavoli... Mi hai presa alla sprovvista.\nMi batte ancora forte il cuore..."

msgctxt "9||speech_list_caba_saki||table||145||||4"
msgid "It was just a what-if.\nSorry to make you panic."
msgstr "Era solo un'ipotesi.\nScusa se ti ho fatto prendere il panico."

msgctxt "9||speech_list_caba_saki||table||146||||4"
msgid "No, this'll make a great fantasy...\nThanks for the idea!"
msgstr "No, questa sarà un'ottima fantasia...\nGrazie per l'idea!"

msgctxt "9||speech_list_caba_saki||table||147||||4"
msgid "Ooh, that's pretty good, too..."
msgstr "Ooh, anche questo non è niente male..."

msgctxt "9||speech_list_caba_saki||table||148||||4"
msgid "What happened?\nYou're grinning ear to ear."
msgstr "Che succede?\nStai sorridendo da un orecchio all'altro."

msgctxt "9||speech_list_caba_saki||table||149||||4"
msgid "Oh, sorry!\nI was off in fantasy land."
msgstr "Oh, scusa!\nEro persa nelle mie fantasie."

msgctxt "9||speech_list_caba_saki||table||150||||4"
msgid "Ohhh. Hm?\nIs that your fantasy notebook there?"
msgstr "Ohhh. Mhm?\nQuello lì è il tuo quaderno delle fantasie?"

msgctxt "9||speech_list_caba_saki||table||151||||4"
msgid "Yeah, it is. I write down my fantasy scenarios\nso I can come back to them later."
msgstr "Sì. Ci scrivo i miei scenari di fantasia\ncosì posso rileggerli più tardi."

msgctxt "9||speech_list_caba_saki||table||152||||4"
msgid "So diligent.\nWhy would you need to, though?"
msgstr "Che diligenza.\nMa perché ne hai bisogno?"

msgctxt "9||speech_list_caba_saki||table||153||||4"
msgid "So I can reuse them. That way I can enjoy\nthe same fantasy as many times as I want."
msgstr "Così posso riutilizzarli. In questo modo posso godermi\nla stessa fantasia tutte le volte che voglio."

msgctxt "9||speech_list_caba_saki||table||154||||4"
msgid "Wow... There's all sorts of stuff in here.\nHmm? \"Kiryu-san Scenarios\"...?"
msgstr "Wow... C'è un sacco di roba qui dentro.\nMhm? \"Scenari su Kiryu-san\"...?"

msgctxt "9||speech_list_caba_saki||table||155||||4"
msgid "Waaahhhhh! You can't look at that one!\nGeez, don't even open that, please!"
msgstr "Waaahhhhh! Non puoi guardare quello!\nCavoli, non aprirlo nemmeno, ti prego!"

msgctxt "9||speech_list_caba_saki||table||156||||4"
msgid "O-Oh. Sorry."
msgstr "O-Oh. Scusa."

msgctxt "9||speech_list_caba_saki||table||157||||4"
msgid "I can't let my guard down for\na second around you. Too close!"
msgstr "Non posso abbassare la guardia un solo\nsecondo con te. C'è mancato poco!"

msgctxt "9||speech_list_caba_saki||table||158||||4"
msgid "Being around you makes me think\nfantasizing might be kind of fun."
msgstr "Stare con te mi fa pensare che\nfantasticare potrebbe essere divertente."

msgctxt "9||speech_list_caba_saki||table||159||||4"
msgid "It is fun! I recommend it.\nWhat do you say we give it a try!?"
msgstr "È divertente! Te lo consiglio.\nChe ne dici di fare un tentativo!?"

msgctxt "9||speech_list_caba_saki||table||160||||4"
msgid "So, Kiryu-san, what kind of scenario\nwould you imagine me in?"
msgstr "Allora, Kiryu-san, in che tipo di scenario\nmi immagineresti?"

msgctxt "9||speech_list_caba_saki||table||161||||4"
msgid "A pro wrestler, I guess?"
msgstr "Una pro wrestler, suppongo?"

msgctxt "9||speech_list_caba_saki||table||162||||4"
msgid "That's what I already am.\nPut some imagination into it, please!"
msgstr "Lo sono già.\nMettici un po' di immaginazione, dai!"

msgctxt "9||speech_list_caba_saki||table||163||||4"
msgid "Hm... This is pretty hard."
msgstr "Mhm... È piuttosto difficile."

msgctxt "9||speech_list_caba_saki||table||164||||4"
msgid "Sometimes I do find myself in\nfantasies based on reality, though."
msgstr "A volte mi capita di farmi delle\nfantasie basate sulla realtà, però."

msgctxt "9||speech_list_caba_saki||table||165||||4"
msgid "Like, you invite me out on a date after work,\nand then you surprise me with a bouquet..."
msgstr "Tipo che mi inviti a un appuntamento dopo il lavoro,\ne poi mi sorprendi con un mazzo di fiori..."

msgctxt "9||speech_list_caba_saki||table||166||||4"
msgid "Hey, I thought I was supposed\nto be the one fantasizing."
msgstr "Ehi, pensavo dovessi essere\nio quello che fantasticava."

msgctxt "9||speech_list_caba_saki||table||167||||4"
msgid "My wife, I guess."
msgstr "Mia moglie, suppongo."

msgctxt "9||speech_list_caba_saki||table||168||||4"
msgid "Wha!? Um...\nYou mean we'd be... married?"
msgstr "Cosa!? Ehm...\nVuoi dire che saremmo... sposati?"

msgctxt "9||speech_list_caba_saki||table||169||||4"
msgid "Yeah. It's fun talking with you,\nso it's not hard to imagine us married."
msgstr "Sì. È divertente parlare con te,\nquindi non è difficile immaginarci sposati."

msgctxt "9||speech_list_caba_saki||table||170||||4"
msgid "Kiryu-san... Oh man, this is kind of\nembarrassing. But, I'm really happy..."
msgstr "Kiryu-san... Cavoli, è un po'\nimbarazzante. Ma sono davvero felice..."

msgctxt "9||speech_list_caba_saki||table||171||||4"
msgid "You know, you don't have to let it end as a\nfantasy... We could make it a reality... Maybe?"
msgstr "Sai, non devi per forza lasciare che resti una\nfantasia... Potremmo renderla realtà... Forse?"

msgctxt "9||speech_list_caba_saki||table||172||||4"
msgid "Hm? What was that?"
msgstr "Mhm? Cosa hai detto?"

msgctxt "9||speech_list_caba_saki||table||173||||4"
msgid "No-no-no-nope-nope-nope!\nThis is turning out to be a good day! <symbol=heart_with_outline>"
msgstr "No-no-no-niente-niente-niente!\nQuesta si sta rivelando un'ottima giornata! <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||174||||4"
msgid "My mom, I guess."
msgstr "Mia madre, credo."

msgctxt "9||speech_list_caba_saki||table||175||||4"
msgid "What!? You mean I would be your mom?"
msgstr "Cosa!? Vuoi dire che sarei tua mamma?"

msgctxt "9||speech_list_caba_saki||table||176||||4"
msgid "Yeah. I feel like you'd do\na great job raising me."
msgstr "Sì. Sento che faresti\nun ottimo lavoro nel crescermi."

msgctxt "9||speech_list_caba_saki||table||177||||4"
msgid "Kiryu-san, what exactly do you see me as?"
msgstr "Kiryu-san, come mi vedi esattamente?"

msgctxt "9||speech_list_caba_saki||table||178||||4"
msgid "Well, I can't deny it would be\npretty great living together with you."
msgstr "Beh, non posso negare che sarebbe\npiuttosto bello vivere insieme a te."

msgctxt "9||speech_list_caba_saki||table||179||||4"
msgid "That does make me happy.\nBut, you should make me your wife, then."
msgstr "Questo mi fa felice.\nMa allora dovresti farmi diventare tua moglie."

msgctxt "9||speech_list_caba_saki||table||180||||4"
msgid "Yeah, good point..."
msgstr "Già, giusto..."

msgctxt "9||speech_list_caba_saki||table||181||||4"
msgid "Today's been fun. Thanks."
msgstr "Oggi mi sono divertito. Grazie."

msgctxt "9||speech_list_caba_saki||table||182||||4"
msgid "No, I should be thanking you. <symbol=heart_with_outline>\nBy the way, I have a proposal..."
msgstr "No, dovrei essere io a ringraziarti. <symbol=heart_with_outline>\nA proposito, avrei una proposta..."

msgctxt "9||speech_list_caba_saki||table||183||||4"
msgid "Hm? What's that?"
msgstr "Mhm? Quale?"

msgctxt "9||speech_list_caba_saki||table||184||||4"
msgid "Um, are you free after this?\nI was wondering if you'd like to go on a date."
msgstr "Ehm, sei libero dopo il lavoro?\nMi chiedevo se ti andrebbe di uscire con me."

msgctxt "9||speech_list_caba_saki||table||185||||4"
msgid "I don't mind.\nYou're good to go?"
msgstr "Per me va bene.\nTu sei pronta per andare?"

msgctxt "9||speech_list_caba_saki||table||186||||4"
msgid "Of course! I'd follow you to the\nends of the Earth! All right! It's a promise!"
msgstr "Certo! Ti seguirei in capo al\nmondo! Va bene! È una promessa!"

msgctxt "9||speech_list_caba_saki||table||187||||4"
msgid "You okay with meeting in\nfront of the Millennium Tower?"
msgstr "Ti va bene se ci incontriamo\ndavanti alla Millennium Tower?"

msgctxt "9||speech_list_caba_saki||table||188||||4"
msgid "I'll text you later."
msgstr "Ti mando un messaggio più tardi."

msgctxt "9||speech_list_caba_saki||table||189||||4"
msgid "Yeah. See you soon."
msgstr "Sì. A dopo."

msgctxt "9||speech_list_caba_saki||table||190||||4"
msgid "Okay! Oh, I can't wait!"
msgstr "Okay! Oh, non vedo l'ora!"

msgctxt "9||speech_list_caba_saki||table||191||||4"
msgid "My hobbies?\nMaybeee... fantasizing?"
msgstr "I miei hobby?\nForseee... fantasticare?"

msgctxt "9||speech_list_caba_saki||table||192||||4"
msgid "F-Fantasizing?"
msgstr "F-Fantasticare?"

msgctxt "9||speech_list_caba_saki||table||193||||4"
msgid "Yeah. I fantasize all the time! You know, like,\n\"What would it be like to date that guy?\""
msgstr "Sì. Fantastico in continuazione! Sai, cose tipo:\n\"Come sarebbe uscire con quel ragazzo?\""

msgctxt "9||speech_list_caba_saki||table||194||||4"
msgid "Then, I write it all down in a notebook so\nI can come back to it if I want to."
msgstr "Poi scrivo tutto su un quaderno così\nposso tornarci su se mi va."

msgctxt "9||speech_list_caba_saki||table||195||||4"
msgid "Sounds like a good read.\nCan I see the notebook?"
msgstr "Sembra un'ottima lettura.\nPosso vedere il quaderno?"

msgctxt "9||speech_list_caba_saki||table||196||||4"
msgid "Whaaaat!? No way!\nI'd just die!"
msgstr "Cooosa!? Non se ne parla!\nNe morirei!"

msgctxt "9||speech_list_caba_saki||table||197||||4"
msgid "Aww, why not?"
msgstr "Aww, e perché no?"

msgctxt "9||speech_list_caba_saki||table||198||||4"
msgid "Hmmm... Fine, how 'bout I choose some fantasies\nI'm okay with sharing and you can see those?"
msgstr "Mhm... E va bene, che ne dici se scelgo alcune fantasie\nche non mi dispiace condividere e tu leggi quelle?"

msgctxt "9||speech_list_caba_saki||table||199||||4"
msgid "It'd be too embarrassing to show\nyou the low quality ones."
msgstr "Sarebbe troppo imbarazzante farti\nvedere quelle di bassa qualità."

msgctxt "9||speech_list_caba_saki||table||200||||4"
msgid "S-Sure...\nThe mind of a pro is something else..."
msgstr "C-Certo...\nLa mente di una professionista è tutta un'altra cosa..."

msgctxt "9||speech_list_caba_saki||table||201||||4"
msgid "You're not fantasizing about me, are you?"
msgstr "Non fantastichi su di me, vero?"

msgctxt "9||speech_list_caba_saki||table||202||||4"
msgid "Doesn't being told not to do something just make\nyou want to do it more? What should I picture?"
msgstr "Sentirsi dire di non fare una cosa non fa venire\nancora più voglia di farla? Cosa dovrei immaginare?"

msgctxt "9||speech_list_caba_saki||table||203||||4"
msgid "Heeey..."
msgstr "Ehii..."

msgctxt "9||speech_list_caba_saki||table||204||||4"
msgid "Think you could fit me\ninto one of your fantasies?"
msgstr "Pensi di potermi inserire\nin una delle tue fantasie?"

msgctxt "9||speech_list_caba_saki||table||205||||4"
msgid "Sure! Kiryu-san...\nHmm, let's see here..."
msgstr "Certo! Kiryu-san...\nMhm, vediamo un po'..."

msgctxt "9||speech_list_caba_saki||table||206||||4"
msgid "Kiryu-san is actually a firefighter...\nAnd after we start dating, there's a fire..."
msgstr "Kiryu-san è in realtà un pompiere...\nE dopo che iniziamo a frequentarci, scoppia un incendio..."

msgctxt "9||speech_list_caba_saki||table||207||||4"
msgid "So he comes to save me, but...\nNaaaw, this is getting too clichéd."
msgstr "Così arriva a salvarmi, ma...\nNaaah, sta diventando troppo un cliché."

msgctxt "9||speech_list_caba_saki||table||208||||4"
msgid "Aww..."
msgstr "Aww..."

msgctxt "9||speech_list_caba_saki||table||209||||4"
msgid "I let myself get some sleep on my days off!\nAnd maybe fit in some online shopping?"
msgstr "Mi concedo di dormire un bel po' nei miei giorni liberi!\nE magari ci incastro un po' di shopping online?"

msgctxt "9||speech_list_caba_saki||table||210||||4"
msgid "My job takes a lot out of me physically, so on\nmy days off, I just want to veg."
msgstr "Il mio lavoro mi prosciuga fisicamente, quindi nei\ngiorni liberi voglio solo vegetare."

msgctxt "9||speech_list_caba_saki||table||211||||4"
msgid "Not too long, actually.\nThere's still a lot I'm not used to."
msgstr "Non da molto, a dire il vero.\nCi sono ancora un sacco di cose a cui non sono abituata."

msgctxt "9||speech_list_caba_saki||table||212||||4"
msgid "I want to pick up the pace a little\nand figure out how to be a little more girly."
msgstr "Voglio prendere un po' di più il ritmo\ne capire come essere un po' più femminile."

msgctxt "9||speech_list_caba_saki||table||213||||4"
msgid "Based on the slight accent... Kyoto?"
msgstr "A giudicare dal leggero accento... Kyoto?"

msgctxt "9||speech_list_caba_saki||table||214||||4"
msgid "Wow, good guess, Kiryu-san!\nI <font_kind=yakuza_italic>am</font_kind> from Kyoto."
msgstr "Wow, bella intuizione, Kiryu-san!\nVengo <font_kind=yakuza_italic>proprio</font_kind> da Kyoto."

msgctxt "9||speech_list_caba_saki||table||215||||4"
msgid "Monkfish liver, I guess.\nAnything that goes down well with booze."
msgstr "Fegato di rana pescatrice, direi.\nQualsiasi cosa si sposi bene con l'alcol."

msgctxt "9||speech_list_caba_saki||table||216||||4"
msgid "I'm glad you asked!\nI like my men like I like my gorillas!"
msgstr "Sono contenta che tu me l'abbia chiesto!\nMi piacciono gli uomini come mi piacciono i gorilla!"

msgctxt "9||speech_list_caba_saki||table||217||||4"
msgid "G-Gorillas?"
msgstr "I g-gorilla?"

msgctxt "9||speech_list_caba_saki||table||218||||4"
msgid "You mean, manly and rugged like a gorilla?"
msgstr "Intendi dire, virili e rudi come dei gorilla?"

msgctxt "9||speech_list_caba_saki||table||219||||4"
msgid "Exactly, rugged is a good word for it.\nAnd gorillas have the kindest faces, right?"
msgstr "Esatto, rude è la parola giusta.\nE i gorilla hanno le facce più gentili, vero?"

msgctxt "9||speech_list_caba_saki||table||220||||4"
msgid "A gorilla, huh?\nSo, someone like me?"
msgstr "Un gorilla, eh?\nQuindi, uno come me?"

msgctxt "9||speech_list_caba_saki||table||221||||4"
msgid "You <font_kind=yakuza_italic>may</font_kind> be just rugged enough\nto qualify as a gorilla, Kiryu-san!"
msgstr "<font_kind=yakuza_italic>Potresti</font_kind> essere abbastanza rude\nda qualificarti come gorilla, Kiryu-san!"

msgctxt "9||speech_list_caba_saki||table||222||||4"
msgid "But you're like... a pure, refined,\nurban gorilla, or something. In a good way?"
msgstr "Ma tu sei tipo... un gorilla puro e raffinato,\ndi città, per così dire. In senso buono, eh?"

msgctxt "9||speech_list_caba_saki||table||223||||4"
msgid "An urban gorilla...\nI don't know how to feel about that."
msgstr "Un gorilla di città...\nNon so come prenderla."

msgctxt "9||speech_list_caba_saki||table||224||||4"
msgid "Ook ook..."
msgstr "Uu-uu ah-ah..."

msgctxt "9||speech_list_caba_saki||table||225||||4"
msgid "Kiryu-san...!"
msgstr "Kiryu-san...!"

msgctxt "9||speech_list_caba_saki||table||226||||4"
msgid "Never mind.\nForget I ever did that."
msgstr "Lascia perdere.\nDimentica che l'abbia mai fatto."

msgctxt "9||speech_list_caba_saki||table||227||||4"
msgid "But that was pretty funny, Kiryu-san!\nYou're a riot!"
msgstr "Ma è stato molto divertente, Kiryu-san!\nSei uno spasso!"

msgctxt "9||speech_list_caba_saki||table||228||||4"
msgid "When I fall in love, I want to do anything I can\nfor that person. I'd even cook for him every day."
msgstr "Quando mi innamoro, voglio fare tutto il possibile\nper quella persona. Cucinerei persino per lui ogni giorno."

msgctxt "9||speech_list_caba_saki||table||229||||4"
msgid "But when I say that kind of stuff, people tell\nme it's kind of out of character for me."
msgstr "Ma quando dico cose del genere, la gente mi dice\nche è un po' fuori dal personaggio per me."

msgctxt "9||speech_list_caba_saki||table||230||||4"
msgid "I don't think that's true. On the inside,\nmaybe you're girlier than you think."
msgstr "Non credo sia vero. Sotto sotto,\nforse sei più femminile di quanto credi."

msgctxt "9||speech_list_caba_saki||table||231||||4"
msgid "Huh? You think so? You're the only person\nwho's ever told me that. I'm all happy now."
msgstr "Eh? Lo pensi davvero? Sei l'unica persona che\nme l'abbia mai detto. Ora sono tutta felice."

msgctxt "9||speech_list_caba_saki||table||232||||4"
msgid "As a pro wrestler, only being the best.\nIn my private life, getting married, I guess?"
msgstr "Come pro wrestler, solo essere la migliore.\nNella mia vita privata, immagino sposarmi?"

msgctxt "9||speech_list_caba_saki||table||233||||4"
msgid "You wouldn't know to look at me, but I'm a great\ncook, and I'd be such a devoted, great wife to my husband!"
msgstr "Non si direbbe guardandomi, ma sono un'ottima cuoca,\ne sarei una moglie devota e fantastica per mio marito!"

msgctxt "9||speech_list_caba_saki||table||234||||4"
msgid "You're sure of yourself, huh?"
msgstr "Sei molto sicura di te, eh?"

msgctxt "9||speech_list_caba_saki||table||235||||4"
msgid "Sometimes you've gotta make a case for yourself,\ny'know? You mull it over, Kiryu-san. Sound good?"
msgstr "A volte devi saperti vendere,\nsai com'è? Pensaci su, Kiryu-san. D'accordo?"

msgctxt "9||speech_list_caba_saki||table||236||||4"
msgid "My parents were both into martial arts,\nso I always dreamed of being some kind of fighter."
msgstr "I miei genitori erano entrambi appassionati di arti marziali,\nperciò ho sempre sognato di fare la combattente."

msgctxt "9||speech_list_caba_saki||table||237||||4"
msgid "Honestly though, I never thought I'd become a pro\nwrestler. Life has a strange way of working out."
msgstr "Onestamente però, non avrei mai pensato di diventare una pro\nwrestler. A volte la vita prende pieghe davvero inaspettate."

msgctxt "9||speech_list_caba_saki||table||238||||4"
msgid "Special skills?\nHmmmmm.... I s'pose I'm a pretty good cook."
msgstr "Abilità speciali?\nMhm.... Suppongo di essere un'ottima cuoca."

msgctxt "9||speech_list_caba_saki||table||239||||4"
msgid "Other than that...\nhigh kicks and sleeper holds?"
msgstr "A parte questo...\ncalci alti e prese di sottomissione?"

msgctxt "9||speech_list_caba_saki||table||240||||4"
msgid "Those are more techniques than skills..."
msgstr "Quelle sono tecniche più che abilità..."

msgctxt "9||speech_list_caba_saki||table||241||||4"
msgid "True! Oh, speaking of special techniques,\nI have a few original ones, you know."
msgstr "Vero! Oh, a proposito di mosse speciali,\nne ho un paio tutte mie, sai."

msgctxt "9||speech_list_caba_saki||table||242||||4"
msgid "Yeah? What are they called?"
msgstr "Ah sì? E come si chiamano?"

msgctxt "9||speech_list_caba_saki||table||243||||4"
msgid "Oh, whatever could they be?\nHere's a hint: \"Blank Galaxy.\""
msgstr "Oh, come potrebbero chiamarsi?\nEcco un indizio: \"Galaxy Qualcosa.\""

msgctxt "9||speech_list_caba_saki||table||244||||4"
msgid "Salaryman Galaxy!\nIs that right?"
msgstr "Salaryman Galaxy!\nCi ho preso?"

msgctxt "9||speech_list_caba_saki||table||245||||4"
msgid "Huh!? How did you know!? That's amazing!\nAre you a mind-reader?"
msgstr "Eh!? Come facevi a saperlo!? È incredibile!\nLeggi nel pensiero?"

msgctxt "9||speech_list_caba_saki||table||246||||4"
msgid "Nah, but maybe I'd heard it somewhere."
msgstr "Nah, ma forse l'avevo sentito da qualche parte."

msgctxt "9||speech_list_caba_saki||table||247||||4"
msgid "Whoa. Does that mean I'm actually getting famous?\nThat's the best news! <symbol=note_with_outline>"
msgstr "Whoa. Significa che sto davvero diventando famosa?\nÈ una bellissima notizia! <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||248||||4"
msgid "Lover Love Galaxy!\nIs that right?"
msgstr "Lover Love Galaxy!\nCi ho preso?"

msgctxt "9||speech_list_caba_saki||table||249||||4"
msgid "Bzzzt!\nThe right answer was \"Salaryman Galaxy\"!"
msgstr "Bzzzt!\nLa risposta esatta era \"Salaryman Galaxy\"!"

msgctxt "9||speech_list_caba_saki||table||250||||4"
msgid "How was I supposed to guess that...?"
msgstr "E come avrei dovuto indovinarlo...?"

msgctxt "9||speech_list_caba_saki||table||251||||4"
msgid "But \"Lover Love Galaxy\" is kind of cute.\nMaybe that's what I'll call my next one..."
msgstr "Però \"Lover Love Galaxy\" è piuttosto carino.\nForse chiamerò così la mia prossima mossa..."

msgctxt "9||speech_list_caba_saki||table||252||||4"
msgid "Nah, it's too embarrassing.\nForget it..."
msgstr "Nah, è troppo imbarazzante.\nLascia perdere..."

msgctxt "9||speech_list_caba_saki||table||253||||4"
msgid "Cinderella Galaxy!\nIs that right?"
msgstr "Cinderella Galaxy!\nCi ho preso?"

msgctxt "9||speech_list_caba_saki||table||254||||4"
msgid "Whoa! Isn't that some old song? And it's wrong,\nanyway! The right answer was \"Salaryman Galaxy\"!"
msgstr "Whoa! Non è una vecchia canzone? E in ogni caso\nè sbagliato! La risposta esatta era \"Salaryman Galaxy\"!"

msgctxt "9||speech_list_caba_saki||table||255||||4"
msgid "I never would have gotten that..."
msgstr "Non ci sarei mai arrivato..."

msgctxt "9||speech_list_caba_saki||table||256||||4"
msgid "Something interesting...\nHmmm... Meeting you, Kiryu-san?"
msgstr "Qualcosa di interessante...\nMhm... Incontrare te, Kiryu-san?"

msgctxt "9||speech_list_caba_saki||table||257||||4"
msgid "Am I that interesting?"
msgstr "Sono così interessante?"

msgctxt "9||speech_list_caba_saki||table||258||||4"
msgid "Kiryu-san, you're super interesting.\nMaybe you just don't know it?"
msgstr "Kiryu-san, sei super interessante.\nForse sei solo tu a non saperlo?"

msgctxt "9||speech_list_caba_saki||table||259||||4"
msgid "Not too many.\nI have a few good friends, though."
msgstr "Non tantissimi.\nHo qualche buon amico, però."

msgctxt "9||speech_list_caba_saki||table||260||||4"
msgid "Huh, I see.\nYou seem like the type to have a lot."
msgstr "Oh, capisco.\nSembri il tipo che ne ha un sacco."

msgctxt "9||speech_list_caba_saki||table||261||||4"
msgid "You know how girls tend to hang out in packs?\nI've never really liked that."
msgstr "Sai che le ragazze tendono a uscire in gruppo?\nA me non è mai piaciuta molto questa cosa."

msgctxt "9||speech_list_caba_saki||table||262||||4"
msgid "Maybe that part of me's kinda boyish.\nBut once I fall in love, I'm all woman. <symbol=heart_with_outline>"
msgstr "Forse quella parte di me è un po' da maschiaccio.\nMa quando mi innamoro, sono tutta donna. <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||263||||4"
msgid "Makes sense. I think guys tend\nto like dating girls like that."
msgstr "Ha senso. Penso che ai ragazzi piaccia\nuscire con ragazze del genere."

msgctxt "9||speech_list_caba_saki||table||264||||4"
msgid "That's good. Pro wrestling is dominated by men.\nMaybe that's a good fit for me, in that sense."
msgstr "Meglio così. Il pro wrestling è dominato dagli uomini.\nIn quel senso, forse è il posto giusto per me."

msgctxt "9||speech_list_caba_saki||table||265||||4"
msgid "I totally suck at games. But I like watching\nsometimes. I'd watch you play, Kiryu-san."
msgstr "Faccio davvero pena ai videogiochi. Ma a volte mi piace\nguardare. Guarderei giocare te, Kiryu-san."

msgctxt "9||speech_list_caba_saki||table||266||||4"
msgid "Hm? What's this then?\nWhat are these deep, dark secrets?"
msgstr "Mhm? E di che si tratta?\nQuali sono questi oscuri e profondi segreti?"

msgctxt "9||speech_list_caba_saki||table||267||||4"
msgid "I was actually a wrestler myself at one\ntime called \"Dragon Mask.\""
msgstr "Una volta anch'io ero un wrestler,\nmi facevo chiamare \"Dragon Mask\"."

msgctxt "9||speech_list_caba_saki||table||268||||4"
msgid "What!? Are you serious?"
msgstr "Cosa!? Dici sul serio?"

msgctxt "9||speech_list_caba_saki||table||269||||4"
msgid "I only did it to entertain some kids, though."
msgstr "Però l'ho fatto solo per far divertire dei bambini."

msgctxt "9||speech_list_caba_saki||table||270||||4"
msgid "It's actually kind of hard to have a serious\nfight while trying to entertain an audience."
msgstr "In effetti è piuttosto difficile fare un incontro serio\nmentre si cerca di intrattenere il pubblico."

msgctxt "9||speech_list_caba_saki||table||271||||4"
msgid "Yeah. You can't be just strong. You have to\nfight in a way the audience wants to watch."
msgstr "Già. Non basta essere forti. Devi combattere\nin un modo che il pubblico apprezzi."

msgctxt "9||speech_list_caba_saki||table||272||||4"
msgid "It made me realize how deep pro wrestling is.\nIn fact, I found a new respect for pros like you."
msgstr "Mi ha fatto capire quanto sia profondo il pro wrestling.\nInfatti, ho trovato un nuovo rispetto per le professioniste come te."

msgctxt "9||speech_list_caba_saki||table||273||||4"
msgid "Kiryu-san... Thank you.\nYou're too nice to me."
msgstr "Kiryu-san... Grazie.\nSei troppo gentile con me."

msgctxt "9||speech_list_caba_saki||table||274||||4"
msgid "Huh!? You have a tattoo, Kiryu-san!?\nI wanna see! Tear your shirt off, right now!"
msgstr "Eh!? Hai un tatuaggio, Kiryu-san!?\nVoglio vederlo! Strappati via la camicia, subito!"

msgctxt "9||speech_list_caba_saki||table||275||||4"
msgid "U-Uh... I can't do that in here..."
msgstr "E-Ehm... Non posso farlo qui dentro..."

msgctxt "9||speech_list_caba_saki||table||276||||4"
msgid "Alcohol? I love a good drink!"
msgstr "L'alcol? Adoro una bella bevuta!"

msgctxt "9||speech_list_caba_saki||table||277||||4"
msgid "As favorites go, it's shochu and sake...\nBut pretty much anything goes!"
msgstr "I miei preferiti sono shochu e sake...\nMa mi va bene più o meno tutto!"

msgctxt "9||speech_list_caba_saki||table||278||||4"
msgid "Then we should drink the place dry."
msgstr "Allora dovremmo prosciugare questo posto."

msgctxt "9||speech_list_caba_saki||table||279||||4"
msgid "Totally! Let's really crank up the fun.\nBesides, if sales go up, so does my rank!"
msgstr "Assolutamente! Spingiamo il divertimento al massimo.\nE poi, se gli incassi salgono, sale anche la mia classifica!"

msgctxt "9||speech_list_caba_saki||table||280||||4"
msgid "You're pretty clever."
msgstr "Sei piuttosto furba."

msgctxt "9||speech_list_caba_saki||table||281||||4"
msgid "I'm just joking.\nBut I'm plenty serious about the fun part. <symbol=note_with_outline>"
msgstr "Sto solo scherzando.\nMa sono serissima sulla parte del divertimento. <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||282||||4"
msgid "Wow. It's unusual for someone your age to get\ninto the hard liquor."
msgstr "Wow. È insolito per una della tua età\nandare a superalcolici."

msgctxt "9||speech_list_caba_saki||table||283||||4"
msgid "I know, right? But I like how they're meant to\nbe savored, and they go great with snacks."
msgstr "Vero? Ma mi piace il fatto che vadano assaporati,\ne si sposano benissimo con gli spuntini."

msgctxt "9||speech_list_caba_saki||table||284||||4"
msgid "You know the right way to enjoy a drink.\nAnd I'll drink to that."
msgstr "Sai il modo giusto di goderti un drink.\nE brinderò a questo."

msgctxt "9||speech_list_caba_saki||table||285||||4"
msgid "Oh, sounds good!\nI'll join you!"
msgstr "Oh, mi sembra ottimo!\nMi unisco a te!"

msgctxt "9||speech_list_caba_saki||table||286||||4"
msgid "Nice, then... I'll have a water!"
msgstr "Bene, allora... io prendo un bicchiere d'acqua!"

msgctxt "9||speech_list_caba_saki||table||287||||4"
msgid "What the<symbol=em_dash_with_outline> You can't just do that!"
msgstr "Ma che<symbol=em_dash_with_outline> Non puoi fare una cosa del genere!"

msgctxt "9||speech_list_caba_saki||table||288||||4"
msgid "I'm joking."
msgstr "Sto scherzando."

msgctxt "9||speech_list_caba_saki||table||289||||4"
msgid "Oh, Kiryu-san's apparently a comedian...\nYou're real funny..."
msgstr "Oh, a quanto pare Kiryu-san è un comico...\nSei davvero divertente..."

msgctxt "9||speech_list_caba_saki||table||290||||4"
msgid "The Tojo... Clan?\nWasn't that the name of a pro wrestling team?"
msgstr "Il... Clan Tojo?\nNon era il nome di una squadra di pro wrestling?"

msgctxt "9||speech_list_caba_saki||table||291||||4"
msgid "No, it's not a wrestling team... Though they\nsure do get into about as many brawls..."
msgstr "No, non è una squadra di wrestling... Anche se finiscono\nsicuramente in un numero simile di risse..."

msgctxt "9||speech_list_caba_saki||table||292||||4"
msgid "Oh, I know her!\nShe was on TV a while back, right?"
msgstr "Oh, la conosco!\nÈ stata in TV qualche tempo fa, giusto?"

msgctxt "9||speech_list_caba_saki||table||293||||4"
msgid "If I recall, she did a concert with another\ngroup called T-Back..."
msgstr "Se ben ricordo, ha fatto un concerto con un\naltro gruppo chiamato T-Back..."

msgctxt "9||speech_list_caba_saki||table||294||||4"
msgid "...Pretty sure it was T-Set."
msgstr "...Sono abbastanza sicuro che fossero le T-Set."

msgctxt "9||speech_list_caba_saki||table||295||||4"
msgid "Oh man, I'd love to hear about\nyour crazy adventures, Kiryu-san!"
msgstr "Oh cavoli, mi piacerebbe tanto sentire le\ntue folli avventure, Kiryu-san!"

msgctxt "9||speech_list_caba_saki||table||296||||4"
msgid "They weren't that crazy...\nAnd they'll take a while to explain..."
msgstr "Non erano poi così folli...\nE ci vorrà un po' per spiegarle..."

msgctxt "9||speech_list_caba_saki||table||297||||4"
msgid "Oh, long story?\nThat's okay, forget it then!"
msgstr "Oh, storia lunga?\nVa bene, lascia perdere, allora!"

msgctxt "9||speech_list_caba_saki||table||298||||4"
msgid "Hey now..."
msgstr "Ehi, dai..."

msgctxt "9||speech_list_caba_saki||table||299||||4"
msgid "I'm sure I don't look the part, but I cook a lot.\nI'm pretty good at making stews."
msgstr "So di non averne l'aria, ma cucino spesso.\nMe la cavo piuttosto bene con gli stufati."

msgctxt "9||speech_list_caba_saki||table||300||||4"
msgid "I'm good at stuff like stews and hot pots."
msgstr "Me la cavo con cose tipo stufati e hot pot."

msgctxt "9||speech_list_caba_saki||table||301||||4"
msgid "Those sound great. Now that I think about it,\nI haven't had hot pot in a long time."
msgstr "Sembrano ottimi. Ora che ci penso,\nè da un pezzo che non mangio un hot pot."

msgctxt "9||speech_list_caba_saki||table||302||||4"
msgid "Yeah, it's not a one-person meal.\nWanna come over and share some?"
msgstr "Sì, non è un pasto per una sola persona.\nVuoi venire da me e dividerne uno?"

msgctxt "9||speech_list_caba_saki||table||303||||4"
msgid "You wouldn't mind?"
msgstr "Non ti dispiacerebbe?"

msgctxt "9||speech_list_caba_saki||table||304||||4"
msgid "Course not! It'd be awesome\nto share a hot pot with you! <symbol=heart_with_outline>"
msgstr "Certo che no! Sarebbe fantastico condividere\nun hot pot con te! <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||305||||4"
msgid "Looking forward to it."
msgstr "Non vedo l'ora."

msgctxt "9||speech_list_caba_saki||table||306||||4"
msgid "What type do you think I am?"
msgstr "Che tipo pensi che io sia?"

msgctxt "9||speech_list_caba_saki||table||307||||4"
msgid "Hmm..."
msgstr "Mhm..."

msgctxt "9||speech_list_caba_saki||table||308||||4"
msgid "Type A!"
msgstr "Gruppo A!"

msgctxt "9||speech_list_caba_saki||table||309||||4"
msgid "Oh, good guess!"
msgstr "Oh, bella intuizione!"

msgctxt "9||speech_list_caba_saki||table||310||||4"
msgid "Type B!"
msgstr "Gruppo B!"

msgctxt "9||speech_list_caba_saki||table||311||||4"
msgid "Nope. I'm a type A!"
msgstr "No. Sono di gruppo A!"

msgctxt "9||speech_list_caba_saki||table||312||||4"
msgid "Either AB or O."
msgstr "O di gruppo AB o zero."

msgctxt "9||speech_list_caba_saki||table||313||||4"
msgid "Hey, c'mon now, Kiryu-san! No fair!\nThey're both wrong anyway!"
msgstr "Ehi, andiamo, Kiryu-san! Non vale!\nE comunque sono sbagliate entrambe!"

msgctxt "9||speech_list_caba_saki||table||314||||4"
msgid "You really want to know?\nWell I'm not telling, mister pervert."
msgstr "Vuoi davvero saperlo?\nBeh, non te lo dico, signor pervertito."

msgctxt "9||speech_list_caba_saki||table||315||||4"
msgid "Nope! This is your chance, Kiryu-san!"
msgstr "No! Questa è la tua occasione, Kiryu-san!"

msgctxt "9||speech_list_caba_saki||table||316||||4"
msgid "A lot of reasons really, but the biggest one\nhas to do with overcoming my complex."
msgstr "Un sacco di motivi, in realtà, ma il principale\nha a che fare con il superare il mio complesso."

msgctxt "9||speech_list_caba_saki||table||317||||4"
msgid "Complex?"
msgstr "Complesso?"

msgctxt "9||speech_list_caba_saki||table||318||||4"
msgid "Between my personality and being a pro wrestler,\nI don't get treated like a girl very often."
msgstr "Tra la mia personalità e il fatto di essere una pro wrestler,\nnon vengo trattata come una ragazza molto spesso."

msgctxt "9||speech_list_caba_saki||table||319||||4"
msgid "And part of me's not okay with that..."
msgstr "E a una parte di me la cosa non sta bene..."

msgctxt "9||speech_list_caba_saki||table||320||||4"
msgid "That makes sense."
msgstr "Ha senso."

msgctxt "9||speech_list_caba_saki||table||321||||4"
msgid "So I thought maybe working as a hostess would\nhelp me figure out how to be more feminine."
msgstr "Così ho pensato che lavorare come hostess mi avrebbe\naiutato a capire come essere più femminile."

msgctxt "9||speech_list_caba_saki||table||322||||4"
msgid "It's certainly true that femininity is how you\nget ahead in a cabaret club. It's the right idea."
msgstr "È indubbio che la femminilità sia il modo per\nfare strada in un cabaret club. È l'idea giusta."

msgctxt "9||speech_list_caba_saki||table||323||||4"
msgid "Yeah, I'm going to keep trying to work\non being more of a girly girl."
msgstr "Sì, continuerò a sforzarmi di lavorare\nsull'essere una ragazza più femminile."

msgctxt "9||speech_list_caba_saki||table||324||||4"
msgid "Well, if you ask me, I think you're feminine\nenough as you are. I only see you as a woman."
msgstr "Beh, se lo chiedi a me, penso che tu sia già abbastanza\nfemminile così. Io ti vedo solo come una donna."

msgctxt "9||speech_list_caba_saki||table||325||||4"
msgid "Kiryu-san...! Thank you so much! Keep smooth\ntalkin' me like that and I might fall for you."
msgstr "Kiryu-san...! Grazie infinite! Continua a parlarmi in\nmodo così suadente e potrei innamorarmi di te."

msgctxt "9||speech_list_caba_saki||table||326||||4"
msgid "Whoa, Kiryu-san! That's a new one.\nYou're a funny guy."
msgstr "Whoa, Kiryu-san! Questa è nuova.\nSei un tipo simpatico."

msgctxt "9||speech_list_caba_saki||table||327||||4"
msgid "I'm so not playing the king game, though."
msgstr "Però scordatelo che io giochi al gioco del re."

msgctxt "9||speech_list_caba_saki||table||329||||4"
msgid "Hmm... These days I've been listening to a lot\nof love songs and music aimed at girls."
msgstr "Mhm... Ultimamente ascolto un sacco\ndi canzoni d'amore e musica per ragazze."

msgctxt "9||speech_list_caba_saki||table||330||||4"
msgid "Huh, that's different."
msgstr "Oh, qualcosa di diverso."

msgctxt "9||speech_list_caba_saki||table||331||||4"
msgid "I may not have the look, but I'm pretty girly\non the inside. Cute, right?"
msgstr "Forse non ne ho l'aspetto, ma dentro sono molto\nfemminile. Carino, vero?"

msgctxt "9||speech_list_caba_saki||table||332||||4"
msgid "It's fun talking with you too, Kiryu-san."
msgstr "È divertente parlare anche con te, Kiryu-san."

msgctxt "9||speech_list_caba_saki||table||333||||4"
msgid "Agreed... If I get sick from not dressing warm\nenough, I won't be able to wrestle."
msgstr "Sono d'accordo... Se mi ammalassi per non essermi\nvestita abbastanza pesante, non potrei più lottare."

msgctxt "9||speech_list_caba_saki||table||334||||4"
msgid "Yeah... Try not to catch a cold, Kiryu-san."
msgstr "Già... Cerca di non prenderti un raffreddore, Kiryu-san."

msgctxt "9||speech_list_caba_saki||table||335||||4"
msgid "Okay, how about I warm you up a bit?\nJoking. <symbol=heart_with_outline>"
msgstr "Okay, che ne dici se ti riscaldo un po' io?\nScherzo. <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||336||||4"
msgid "Nice! That makes me really happy to hear.\nLet's throw a few more back!"
msgstr "Fantastico! Mi rende davvero felice sentirtelo dire.\nBeviamone un altro po'!"

msgctxt "9||speech_list_caba_saki||table||337||||4"
msgid "Wow, thank you so much!"
msgstr "Wow, grazie mille!"

msgctxt "9||speech_list_caba_saki||table||338||||4"
msgid "Wait, what!? You're just gonna confess to me\nout of the blue? I wasn't ready for that..."
msgstr "Aspetta, cosa!? Vuoi dichiararti così, di punto in\nbianco? Non ero preparata per una cosa del genere..."

msgctxt "9||speech_list_caba_saki||table||339||||4"
msgid "I was kidding."
msgstr "Stavo scherzando."

msgctxt "9||speech_list_caba_saki||table||340||||4"
msgid "Oh, you're terrible!"
msgstr "Oh, sei terribile!"

msgctxt "9||speech_list_caba_saki||table||341||||4"
msgid "Yaaaaaaaay!\nThis is so fun."
msgstr "Siiiiiiiii!\nÈ così divertente."

msgctxt "9||speech_list_caba_saki||table||342||||4"
msgid "Hi! How ya doin'?"
msgstr "Ciao! Come va?"

msgctxt "9||speech_list_caba_saki||table||343||||4"
msgid "Great, thanks to you."
msgstr "Alla grande, grazie a te."

msgctxt "9||speech_list_caba_saki||table||344||||4"
msgid "Huh? Wait, just out of the blue like that!?\nAre you serious, Kiryu-san?"
msgstr "Eh? Aspetta, così, di punto in bianco!?\nDici sul serio, Kiryu-san?"

msgctxt "9||speech_list_caba_saki||table||345||||4"
msgid "Yeah. I'm very serious."
msgstr "Sì. Sono serissimo."

msgctxt "9||speech_list_caba_saki||table||346||||4"
msgid "I've never had anyone ask me\nto let them touch me so seriously like that!"
msgstr "Non ho mai avuto nessuno che mi chiedesse\ndi farsi toccare in modo così serio!"

msgctxt "9||speech_list_caba_saki||table||347||||4"
msgid "Really?"
msgstr "Davvero?"

msgctxt "9||speech_list_caba_saki||table||348||||4"
msgid "Yes! You're a weird one, Kiryu-san."
msgstr "Sì! Sei un tipo strano, Kiryu-san."

msgctxt "9||speech_list_caba_saki||table||349||||4"
msgid "I'm not serious."
msgstr "Non faccio sul serio."

msgctxt "9||speech_list_caba_saki||table||350||||4"
msgid "You're such a funny guy!\nWell, either way, no touching!"
msgstr "Sei proprio un tipo buffo!\nBeh, in ogni caso, niente mani addosso!"

msgctxt "9||speech_list_caba_saki||table||352||||4"
msgid "It's an American joke!"
msgstr "È un American joke!"

msgctxt "9||speech_list_caba_saki||table||353||||4"
msgid "That's not an American joke at all!\nKiryu-san... You're so funny."
msgstr "Non è affatto una battuta all'americana!\nKiryu-san... Sei così divertente."

msgctxt "9||speech_list_caba_saki||table||354||||4"
msgid "(Wait... I can't get a read on her...)"
msgstr "(Aspetta... Non riesco proprio a inquadrarla...)"

msgctxt "9||speech_list_caba_saki||table||355||||4"
msgid "I'm so happy to hear that.\nOh no, I'm seein' hearts..."
msgstr "Sono così felice di sentirtelo dire.\nOh no, vedo i cuoricini..."

msgctxt "9||speech_list_caba_saki||table||356||||4"
msgid "Oh, I'm not, really!"
msgstr "Oh, non lo sono, davvero!"

msgctxt "9||speech_list_caba_saki||table||357||||4"
msgid "Wow! Kiryu-san, you're fluent in English!\nGood English!"
msgstr "Wow! Kiryu-san, parli fluentemente l'inglese!\nUn ottimo inglese!"

msgctxt "9||speech_list_caba_saki||table||358||||4"
msgid "Thank you."
msgstr "Grazie."

msgctxt "9||speech_list_caba_saki||table||359||||4"
msgid "Only you?\nHm, what should I do?"
msgstr "Solo te?\nMhm, cosa dovrei fare?"

msgctxt "9||speech_list_caba_saki||table||360||||4"
msgid "Hey... You should only look\nat me too, okay?"
msgstr "Ehi... Anche tu dovresti guardare\nsolo me, okay?"

msgctxt "9||speech_list_caba_saki||table||361||||4"
msgid "Huh? That's a secret. <symbol=note_with_outline>"
msgstr "Eh? È un segreto. <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||362||||4"
msgid "You want me to tell you?\nHm, should I? <symbol=note_with_outline>"
msgstr "Vuoi che te lo dica?\nMhm, dovrei? <symbol=note_with_outline>"

msgctxt "9||speech_list_caba_saki||table||363||||4"
msgid "Is there anyone you like?"
msgstr "C'è qualcuno che ti piace?"

msgctxt "9||speech_list_caba_saki||table||364||||4"
msgid "Oh, don't make me say it!\nOf course there is... <symbol=heart_with_outline>"
msgstr "Oh, non farmelo dire!\nCerto che c'è... <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||365||||4"
msgid "Really?\nMaybe I'll see what happens... <symbol=heart_with_outline>"
msgstr "Davvero?\nForse vedrò cosa succede... <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||366||||4"
msgid "Thank you. The owners are really good people,\nso it's a nice place to work."
msgstr "Grazie. I proprietari sono davvero delle brave persone,\nquindi è un bel posto in cui lavorare."

msgctxt "9||speech_list_caba_saki||table||367||||4"
msgid "And they're really open-minded to actually hire\na pro wrestler like me."
msgstr "E sono di mentalità molto aperta per assumere\nuna pro wrestler come me."

msgctxt "9||speech_list_caba_saki||table||368||||4"
msgid "I'd say they're good at their jobs to hire\na girl like you."
msgstr "Direi che sono in gamba nel loro lavoro ad aver assunto\nuna ragazza come te."

msgctxt "9||speech_list_caba_saki||table||369||||4"
msgid "Too smooth, Kiryu-san!\nYou make me feel like I can do anything! <symbol=heart_with_outline>"
msgstr "Troppo lusinghiero, Kiryu-san!\nMi fai sentire come se potessi fare qualsiasi cosa! <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||370||||4"
msgid "I don't know too many, actually.\nBut I'm eager to try some new ones."
msgstr "Non ne conosco moltissimi, a dire il vero.\nMa non vedo l'ora di provarne di nuovi."

msgctxt "9||speech_list_caba_saki||table||371||||4"
msgid "You go to places like that...? Oh no,\nI'm starting to imagine it! Let's change subjects!"
msgstr "Tu vai in posti del genere...? Oh no,\ninizio a immaginarmelo! Cambiamo argomento!"

msgctxt "9||speech_list_caba_saki||table||372||||4"
msgid "Huh!? You wrecked a convenience store?\nYou sure you don't wanna be a pro wrestler?"
msgstr "Eh!? Hai distrutto un minimarket?\nSicuro di non voler fare il pro wrestler?"

msgctxt "9||speech_list_caba_saki||table||373||||4"
msgid "Hmm, well, it wasn't intentional..."
msgstr "Mhm, beh, non è stato intenzionale..."

msgctxt "9||speech_list_caba_saki||table||374||||4"
msgid "Destroying a convenience store... Actually,\na convenience store death match could totally work!"
msgstr "Distruggere un minimarket... In effetti, un death match\nin un minimarket potrebbe assolutamente funzionare!"

msgctxt "9||speech_list_caba_saki||table||375||||4"
msgid "That's a great idea! Thank you!"
msgstr "È un'ottima idea! Grazie!"

msgctxt "9||speech_list_caba_saki||table||376||||4"
msgid "S-Sure..."
msgstr "C-Certo..."

msgctxt "9||speech_list_caba_saki||table||377||||4"
msgid "Whoa! Pulling out the heavy topics!"
msgstr "Whoa! Tiri fuori gli argomenti pesanti!"

msgctxt "9||speech_list_caba_saki||table||378||||4"
msgid "Memories of someone who's passed on, huh? You\ncan't help but think about it sometimes."
msgstr "Ricordi di qualcuno che è passato a miglior vita, eh?\nNon si può fare a meno di pensarci, a volte."

msgctxt "9||speech_list_caba_saki||table||379||||4"
msgid "Maybe it's not my place to say, but, I think\nyou've got to work hard for his sake, too."
msgstr "Forse non spetta a me dirlo, ma credo che tu\ndebba lavorare sodo anche per il suo bene."

msgctxt "9||speech_list_caba_saki||table||380||||4"
msgid "True enough.\nI think that's the right attitude."
msgstr "Giusto.\nCredo che sia l'atteggiamento corretto."

msgctxt "9||speech_list_caba_saki||table||381||||4"
msgid "Yeah. I'm glad we got to talk about this."
msgstr "Sì. Sono felice che ne abbiamo parlato."

msgctxt "9||speech_list_caba_saki||table||382||||4"
msgid "A true friend, huh? That's someone you can say\nwhatever you really feel without holding back, I guess."
msgstr "Un vero amico, eh? Credo sia qualcuno a cui puoi dire\ntutto ciò che provi davvero senza doverti trattenere."

msgctxt "9||speech_list_caba_saki||table||383||||4"
msgid "Speaking of friends...\ndo you think men and women can be just friends?"
msgstr "A proposito di amici...\npensi che uomini e donne possano essere solo amici?"

msgctxt "9||speech_list_caba_saki||table||384||||4"
msgid "Why not?\nI have some friends where gender means nothing."
msgstr "Perché no?\nHo alcune amicizie in cui il genere non conta nulla."

msgctxt "9||speech_list_caba_saki||table||385||||4"
msgid "Exactly, right!?\nI have a lot of guy friends!"
msgstr "Esatto, vero!?\nHo un sacco di amici maschi!"

msgctxt "9||speech_list_caba_saki||table||386||||4"
msgid "You're probably the type of person\nguys find easy to talk to."
msgstr "Probabilmente sei il tipo di persona\ncon cui i ragazzi trovano facile parlare."

msgctxt "9||speech_list_caba_saki||table||387||||4"
msgid "You think so?\nPeople are always saying I'm so manly, though."
msgstr "Dici?\nEppure la gente mi dice sempre che sono un maschiaccio."

msgctxt "9||speech_list_caba_saki||table||388||||4"
msgid "I don't think so.\nA guy always has ulterior motives."
msgstr "Non credo.\nUn ragazzo ha sempre dei secondi fini."

msgctxt "9||speech_list_caba_saki||table||389||||4"
msgid "What? You think so? I've got a lot of guy friends,\nso that's making me wonder."
msgstr "Cosa? Lo pensi davvero? Ho un sacco di amici maschi,\nquindi la cosa mi fa riflettere."

msgctxt "9||speech_list_caba_saki||table||390||||4"
msgid "You think so?\nPeople are always saying I'm so manly, though."
msgstr "Dici?\nEppure la gente mi dice sempre che sono un maschiaccio."

msgctxt "9||speech_list_caba_saki||table||391||||4"
msgid "I think they can, but...\nI couldn't make that work with you."
msgstr "Penso di sì, ma...\ncon te non ce la farei."

msgctxt "9||speech_list_caba_saki||table||392||||4"
msgid "Huh!? Why not!?\nDid I say something that got under your skin?"
msgstr "Eh!? E perché no!?\nHo detto qualcosa che ti ha dato fastidio?"

msgctxt "9||speech_list_caba_saki||table||393||||4"
msgid "No, I just mean I see you more\nas a woman than a friend."
msgstr "No, intendo dire che ti vedo più\ncome una donna che come un'amica."

msgctxt "9||speech_list_caba_saki||table||394||||4"
msgid "K-Kiryu-san...! Seriously,\ndo you always have to be so cool?"
msgstr "K-Kiryu-san...! Dico sul serio,\ndevi sempre fare così il figo?"

msgctxt "9||speech_list_caba_saki||table||395||||4"
msgid "Whew... I haven't felt a rush\nlike that in a while."
msgstr "Fiuu... È da un pezzo che non provavo\nun brivido del genere."

msgctxt "9||speech_list_caba_saki||table||396||||4"
msgid "Mission accomplished."
msgstr "Missione compiuta."

msgctxt "9||speech_list_caba_saki||table||397||||4"
msgid "Really!? You <font_kind=yakuza_italic>do</font_kind> seem like you'd spoil them.\nYou're really kind."
msgstr "Davvero!? Sembra <font_kind=yakuza_italic>proprio</font_kind> che li vizieresti.\nSei davvero gentile."

msgctxt "9||speech_list_caba_saki||table||398||||4"
msgid "Maybe if I were just a baby,\nyou'd be nicer to me!"
msgstr "Forse se fossi una bambina\nsaresti più carino con me!"

msgctxt "9||speech_list_caba_saki||table||399||||4"
msgid "Hey, I'm plenty nice now, aren't I?"
msgstr "Ehi, sono già abbastanza carino, non ti pare?"

msgctxt "9||speech_list_caba_saki||table||400||||4"
msgid "You're right."
msgstr "Hai ragione."

msgctxt "9||speech_list_caba_saki||table||401||||4"
msgid "You fish, Kiryu-san?"
msgstr "Vai a pesca, Kiryu-san?"

msgctxt "9||speech_list_caba_saki||table||402||||4"
msgid "Yeah, I've been spearfishing lately."
msgstr "Sì, ultimamente faccio pesca subacquea."

msgctxt "9||speech_list_caba_saki||table||403||||4"
msgid "That's so cool! I bet the fish\nyou catch would taste amazing!"
msgstr "Che figata! Scommetto che il pesce\nche peschi è delizioso!"

msgctxt "9||speech_list_caba_saki||table||404||||4"
msgid "Wow, so kind of like a war between two teams?\nThis sounds like a pro wrestling storyline."
msgstr "Wow, quindi una specie di guerra tra due squadre?\nSembra la trama di un incontro di pro wrestling."

msgctxt "9||speech_list_caba_saki||table||405||||4"
msgid "It's just because you look so strong, right?\nYou can't help but wanna conquer something strong."
msgstr "È solo perché sembri così forte, giusto?\nNon si può fare a meno di voler conquistare qualcosa di forte."

msgctxt "9||speech_list_caba_saki||table||406||||4"
msgid "If I'm bein' honest...\nI'd like to fight you sometime!"
msgstr "A essere sincera...\nMi piacerebbe combattere contro di te, qualche volta!"

msgctxt "9||speech_list_caba_saki||table||407||||4"
msgid "Hey, it's not like I enjoy violence."
msgstr "Ehi, non è che mi piaccia la violenza."

msgctxt "9||speech_list_caba_saki||table||408||||4"
msgid "Sorry Kiryu-san, but that doesn't sound\nvery convincing coming from you."
msgstr "Scusa Kiryu-san, ma detto da te non suona\nmolto convincente."

msgctxt "9||speech_list_caba_saki||table||409||||4"
msgid "Have you ever heard of Pocket Circuit?"
msgstr "Hai mai sentito parlare del Pocket Circuit?"

msgctxt "9||speech_list_caba_saki||table||410||||4"
msgid "Of course I have! When I was little, I used to\nplay down at the stadium with all the boys."
msgstr "Certo che sì! Quando ero piccola, ci giocavo\nsempre allo stadio con tutti i ragazzi."

msgctxt "9||speech_list_caba_saki||table||411||||4"
msgid "My best car was a Golem Tiger, and for\nmy motor, I customized it like this..."
msgstr "La mia auto migliore era una Golem Tiger, e per\nil motore, l'avevo personalizzata così..."

msgctxt "9||speech_list_caba_saki||table||412||||4"
msgid "Wow! You really know your stuff!"
msgstr "Wow! Te ne intendi davvero!"

msgctxt "9||speech_list_caba_saki||table||413||||4"
msgid "You're a gym rat, Kiryu-san?\nGood, if you don't work out, you'll get all weak."
msgstr "Sei un maniaco della palestra, Kiryu-san?\nBene, se non ti alleni diventerai tutto debole."

msgctxt "9||speech_list_caba_saki||table||414||||4"
msgid "It'd be pretty fun to go on a gym date\nwith you sometime...<symbol=heart_with_outline>"
msgstr "Sarebbe divertente fare un appuntamento in palestra\ncon te, prima o poi...<symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||415||||4"
msgid "Yeah, you seem like the quiet type, Kiryu-san."
msgstr "Già, sembri il tipo silenzioso, Kiryu-san."

msgctxt "9||speech_list_caba_saki||table||416||||4"
msgid "But don't you ever feel like you\nwanna cut loose and get loud?"
msgstr "Ma non hai mai voglia di lasciarti\nandare e fare un po' di casino?"

msgctxt "9||speech_list_caba_saki||table||417||||4"
msgid "Not really.\nThis is my default level."
msgstr "Non proprio.\nQuesto è il mio livello predefinito."

msgctxt "9||speech_list_caba_saki||table||418||||4"
msgid "You serious? I bet you have your\nmoments where you get amped up."
msgstr "Dici sul serio? Scommetto che hai anche tu i\ntuoi momenti in cui ti gaserai."

msgctxt "9||speech_list_caba_saki||table||419||||4"
msgid "Well, who can say..."
msgstr "Beh, chi può dirlo..."

msgctxt "9||speech_list_caba_saki||table||420||||4"
msgid "I guess when I'm singing karaoke...\nI might get a little carried away."
msgstr "Immagino che quando canto al karaoke...\npotrei farmi prendere un po' la mano."

msgctxt "9||speech_list_caba_saki||table||421||||4"
msgid "Awesome! Now this I've gotta see!\nKiryu-san getting into the groove!"
msgstr "Fantastico! Questo voglio proprio vederlo!\nKiryu-san che si fa prendere dal ritmo!"

msgctxt "9||speech_list_caba_saki||table||422||||4"
msgid "Sometimes I might unintentionally,\nvery subconsciously, get like that."
msgstr "A volte potrei, involontariamente e\ninconsciamente, diventare così."

msgctxt "9||speech_list_caba_saki||table||423||||4"
msgid "Huh? You mean that?\nI bet you totally do it on purpose."
msgstr "Eh? Dici sul serio?\nScommetto che lo fai assolutamente di proposito."

msgctxt "9||speech_list_caba_saki||table||424||||4"
msgid "Maybe just when I'm around you."
msgstr "Forse solo quando sono con te."

msgctxt "9||speech_list_caba_saki||table||425||||4"
msgid "Huh? If this is getting loud,\nwhat are you like normally...?"
msgstr "Eh? Se per te questo è \"fare casino\",\ncome sei di solito...?"

msgctxt "9||speech_list_caba_saki||table||426||||4"
msgid "Oh, really? I just assumed\nyou were the aggressive type."
msgstr "Oh, davvero? Avevo dato per scontato\nche fossi il tipo aggressivo."

msgctxt "9||speech_list_caba_saki||table||427||||4"
msgid "Well, don't feel like you have to go all\nvegetarian with me! I'm a carnivore's delight."
msgstr "Beh, non sentirti in dovere di fare il vegetariano\ncon me! Io sono la gioia dei carnivori."

msgctxt "9||speech_list_caba_saki||table||428||||4"
msgid "I actually don't warm up to people very easily."
msgstr "A dire il vero non mi apro molto facilmente con le persone."

msgctxt "9||speech_list_caba_saki||table||429||||4"
msgid "Really? But you're doing just fine with me.\nMaybe we're compatible."
msgstr "Davvero? Ma con me vai alla grande.\nForse siamo compatibili."

msgctxt "9||speech_list_caba_saki||table||430||||4"
msgid "Yeah, maybe."
msgstr "Sì, forse."

msgctxt "9||speech_list_caba_saki||table||431||||4"
msgid "Even if it's not a special occasion?\nYou go every time?"
msgstr "Anche se non è un'occasione speciale?\nCi vai ogni volta?"

msgctxt "9||speech_list_caba_saki||table||432||||4"
msgid "A man likes to show off."
msgstr "A un uomo piace mettersi in mostra."

msgctxt "9||speech_list_caba_saki||table||433||||4"
msgid "I see... Well if it were me,\nI'd put that money to better use."
msgstr "Capisco... Beh se fossi in te,\nspenderei quei soldi in modo migliore."

msgctxt "9||speech_list_caba_saki||table||434||||4"
msgid "You seem like the kinda guy that's younger than\nhe looks... I'll say, 39? How's that?"
msgstr "Sembri il tipo di persona più giovane di quel che\nsembra... Direi, 39 anni? Che ne dici?"

msgctxt "9||speech_list_caba_saki||table||435||||4"
msgid "It's nice to hear it, but unfortunately\nI'm well into my 40s."
msgstr "Fa piacere sentirselo dire, ma purtroppo\nho superato abbondantemente i 40."

msgctxt "9||speech_list_caba_saki||table||436||||4"
msgid "Really!? You don't look that old at all!\nYou seem so young and brimming with energy!"
msgstr "Davvero!? Non li dimostri affatto!\nSembri così giovane e pieno di energia!"

msgctxt "9||speech_list_caba_saki||table||437||||4"
msgid "You're kinda like a sharp knife.\nYou look intimidating, but really cool, too."
msgstr "Sei un po' come un coltello affilato.\nHai un'aria minacciosa, ma anche molto affascinante."

msgctxt "9||speech_list_caba_saki||table||438||||4"
msgid "I think you're a great guy. You look\npretty intimidating, but you're a sweetheart."
msgstr "Penso che tu sia un uomo fantastico. Hai un'aria\npiuttosto minacciosa, ma sei un tesoro."

msgctxt "9||speech_list_caba_saki||table||439||||4"
msgid "Older guys, I guess.\nI prefer a man who can take the lead."
msgstr "I ragazzi più grandi, direi.\nPreferisco un uomo che sappia prendere l'iniziativa."

msgctxt "9||speech_list_caba_saki||table||440||||4"
msgid "I don't think I have any big fetishes!\nI make up for it with my fantasies."
msgstr "Non credo di avere grandi feticismi!\nColmo questa lacuna con le mie fantasie."

msgctxt "9||speech_list_caba_saki||table||441||||4"
msgid "What do I want?\nA belt, I guess."
msgstr "Cosa voglio?\nUna cintura, immagino."

msgctxt "9||speech_list_caba_saki||table||442||||4"
msgid "A belt?\nFor your pants?"
msgstr "Una cintura?\nPer i pantaloni?"

msgctxt "9||speech_list_caba_saki||table||443||||4"
msgid "No no, the wrestling kind."
msgstr "No no, di quelle da wrestling."

msgctxt "9||speech_list_caba_saki||table||444||||4"
msgid "Of course I want a champion's belt, Kiryu-san...\nbut yours would be fine..."
msgstr "Certo che voglio una cintura da campionessa, Kiryu-san...\nma anche la tua andrebbe bene..."

msgctxt "9||speech_list_caba_saki||table||445||||4"
msgid "Hm? Excuse me?"
msgstr "Mhm? Come, scusa?"

msgctxt "9||speech_list_caba_saki||table||446||||4"
msgid "N-Never mind!\nI said nothing!"
msgstr "N-Niente!\nNon ho detto niente!"

msgctxt "9||speech_list_caba_saki||table||447||||4"
msgid "My first love, huh? It was so long ago,\nand I was so young. Such bittersweet memories..."
msgstr "Il mio primo amore, eh? È stato così tanto tempo fa,\ned ero così giovane. Che ricordi agrodolci..."

msgctxt "9||speech_list_caba_saki||table||448||||4"
msgid "What!? You can't ask a girl that!"
msgstr "Cosa!? Non puoi chiedere una cosa del genere a una ragazza!"

msgctxt "9||speech_list_caba_saki||table||449||||4"
msgid "What a perv, Kiryu-san!\nI'm not answering any weird questions!"
msgstr "Che pervertito, Kiryu-san!\nNon risponderò a nessuna domanda strana!"

msgctxt "9||speech_list_caba_saki||table||450||||4"
msgid "Marriage, huh?\nWell, I dream about it as much as any girl!"
msgstr "Il matrimonio, eh?\nBeh, lo sogno quanto qualsiasi altra ragazza!"

msgctxt "9||speech_list_caba_saki||table||451||||4"
msgid "What about you?"
msgstr "E tu?"

msgctxt "9||speech_list_caba_saki||table||452||||4"
msgid "Me?\nWell... maybe someday..."
msgstr "Io?\nBeh... forse un giorno..."

msgctxt "9||speech_list_caba_saki||table||453||||4"
msgid "Oh, you're red red red!"
msgstr "Oh, sei rosso, rosso, rosso!"

msgctxt "9||speech_list_caba_saki||table||454||||4"
msgid "Marriage, huh? If I found a guy like you,\nI'd jump right in, Kiryu-san. <symbol=heart_with_outline>"
msgstr "Il matrimonio, eh? Se trovassi un tipo come te,\nmi ci butterei a capofitto, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||455||||4"
msgid "I don't really know how to respond when\nyou put me on the spot like that..."
msgstr "Non so bene cosa rispondere quando\nmi metti in difficoltà in questo modo..."

msgctxt "9||speech_list_caba_saki||table||456||||4"
msgid "Oh, Kiryu-san! I'm just joking. <symbol=note_with_outline>\nNo need to get all flustered. <symbol=heart_with_outline>"
msgstr "Oh, Kiryu-san! Sto solo scherzando. <symbol=note_with_outline>\nNon c'è bisogno di agitarsi tanto. <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||457||||4"
msgid "No one's ever told me that before.\nI'm not even that good at it!"
msgstr "Nessuno me l'aveva mai detto prima.\nNon sono nemmeno così brava!"

msgctxt "9||speech_list_caba_saki||table||458||||4"
msgid "Really?\nThen maybe you're just naturally beautiful."
msgstr "Davvero?\nAllora forse sei semplicemente bella di natura."

msgctxt "9||speech_list_caba_saki||table||459||||4"
msgid "Whoa! Kiryu-san, too smooth!"
msgstr "Whoa! Kiryu-san, che ruffiano!"

msgctxt "9||speech_list_caba_saki||table||460||||4"
msgid "Hey... Have we met somewhere before?"
msgstr "Ehi... Ci siamo già visti da qualche parte?"

msgctxt "9||speech_list_caba_saki||table||461||||4"
msgid "Huh? Have we...?"
msgstr "Eh? Ci siamo visti...?"

msgctxt "9||speech_list_caba_saki||table||462||||4"
msgid "I might've seen you at a wrestling match."
msgstr "Potrei averti visto a un incontro di wrestling."

msgctxt "9||speech_list_caba_saki||table||463||||4"
msgid "Oh, that'd make sense.\nI suppose it's possible!"
msgstr "Oh, questo avrebbe senso.\nImmagino sia possibile!"

msgctxt "9||speech_list_caba_saki||table||464||||4"
msgid "I'd be thrilled if you'd seen\none of my matches, Kiryu-san!"
msgstr "Sarei felicissima se avessi visto\nuno dei miei incontri, Kiryu-san!"

msgctxt "9||speech_list_caba_saki||table||465||||4"
msgid "Nah, I was overthinking it.\nForget I said anything."
msgstr "Nah, ci stavo pensando troppo su.\nDimentica quello che ho detto."

msgctxt "9||speech_list_caba_saki||table||466||||4"
msgid "Aw, don't go gettin' my hopes\nup like that..."
msgstr "Aw, non illudermi così..."

msgctxt "9||speech_list_caba_saki||table||467||||4"
msgid "Maybe... we met in a dream."
msgstr "Forse... ci siamo incontrati in un sogno."

msgctxt "9||speech_list_caba_saki||table||468||||4"
msgid "And now you're a romantic all of a sudden,\nKiryu-san? You're a real strange guy..."
msgstr "E adesso diventi un romanticone tutto all'improvviso,\nKiryu-san? Sei un tipo davvero strano..."

msgctxt "9||speech_list_caba_saki||table||469||||4"
msgid "Thanks! Maybe it's because I train so much. \nAlthough I'm worried my abs are starting to show..."
msgstr "Grazie! Forse è perché mi alleno tanto.\nAnche se ho paura che i miei addominali stiano iniziando a vedersi..."

msgctxt "9||speech_list_caba_saki||table||470||||4"
msgid "Cheating? Well, it certainly\nsucks when it happens to you!"
msgstr "Il tradimento? Beh, fa sicuramente\nschifo quando capita a te!"

msgctxt "9||speech_list_caba_saki||table||471||||4"
msgid "Don't tell me...\nYou're a cheater, Kiryu-san!?"
msgstr "Non dirmi che...\nSei uno che tradisce, Kiryu-san!?"

msgctxt "9||speech_list_caba_saki||table||472||||4"
msgid "Yes, actually..."
msgstr "Sì, a dire il vero..."

msgctxt "9||speech_list_caba_saki||table||473||||4"
msgid "Whoa! Putting it right out there, huh!? Well,\nKiryu-san, I'm sure you're popular with the ladies."
msgstr "Whoa! Lo ammetti così, eh!? Beh,\nKiryu-san, sono sicura che tu sia popolare tra le donne."

msgctxt "9||speech_list_caba_saki||table||474||||4"
msgid "I get it! You get a pass this once, Kiryu-san!"
msgstr "Ho capito! Te la lascio passare per questa volta, Kiryu-san!"

msgctxt "9||speech_list_caba_saki||table||475||||4"
msgid "O-Oh. Thanks..."
msgstr "O-Oh. Grazie..."

msgctxt "9||speech_list_caba_saki||table||476||||4"
msgid "No, that's not what I meant."
msgstr "No, non è quello che intendevo."

msgctxt "9||speech_list_caba_saki||table||477||||4"
msgid "Really? That's what they all say. A lady's man\nlike you, Kiryu-san? I'm kinda suspicious..."
msgstr "Davvero? È quello che dicono tutti. Un donnaiolo\ncome te, Kiryu-san? Sono un po' sospettosa..."

msgctxt "9||speech_list_caba_saki||table||478||||4"
msgid "You're the only one for me."
msgstr "Tu sei l'unica per me."

msgctxt "9||speech_list_caba_saki||table||479||||4"
msgid "Wh-What's all this out of the blue, Kiryu-san!?"
msgstr "Ch-Che cos'è questa cosa così dal nulla, Kiryu-san!?"

msgctxt "9||speech_list_caba_saki||table||480||||4"
msgid "You're making me all flustered!\nYou've got a mean sense of humor..."
msgstr "Mi stai facendo agitare tutta!\nHai un pessimo senso dell'umorismo..."

msgctxt "9||speech_list_caba_saki||table||482||||4"
msgid "I prefer staying in, I think. I get so much\nexercise, I just wanna relax at home when I can."
msgstr "Credo di preferire stare in casa. Faccio già tanto esercizio,\nvoglio solo rilassarmi a casa quando posso."

msgctxt "9||speech_list_caba_saki||table||483||||4"
msgid "Oh, you're one of those people, Kiryu-san?\nMe too!"
msgstr "Oh, sei una di quelle persone, Kiryu-san?\nAnch'io!"

msgctxt "9||speech_list_caba_saki||table||484||||4"
msgid "Maybe it's because I push myself so hard every\nday, but it makes me just want to relax at home."
msgstr "Forse è perché mi sforzo tanto ogni giorno,\nma questo mi fa solo venire voglia di rilassarmi a casa."

msgctxt "9||speech_list_caba_saki||table||485||||4"
msgid "I'm on the same page!\nIf we were dating, I'm sure we'd get along. <symbol=heart_with_outline>"
msgstr "La pensiamo allo stesso modo!\nSe uscissimo insieme, sono sicura che andremmo d'accordo. <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||486||||4"
msgid "Yeah, I did. So, pop quiz.\nWhat team was I on?"
msgstr "Sì, l'ho fatto. Allora, test a sorpresa.\nIn che squadra ero?"

msgctxt "9||speech_list_caba_saki||table||487||||4"
msgid "You're tall, so... volleyball?"
msgstr "Sei alta, quindi... pallavolo?"

msgctxt "9||speech_list_caba_saki||table||488||||4"
msgid "Whoa! You got it, Kiryu-san!\nI'm impressed."
msgstr "Whoa! Ci hai azzeccato, Kiryu-san!\nSono impressionata."

msgctxt "9||speech_list_caba_saki||table||489||||4"
msgid "I heard they scout people based on height.\nI'm sure you were the perfect fit."
msgstr "Ho sentito che reclutano la gente in base all'altezza.\nSono sicuro fossi perfetta."

msgctxt "9||speech_list_caba_saki||table||490||||4"
msgid "Aw, thanks."
msgstr "Aw, grazie."

msgctxt "9||speech_list_caba_saki||table||491||||4"
msgid "You're a pro wrestler, so... wrestling?"
msgstr "Sei una pro wrestler, quindi... lotta libera?"

msgctxt "9||speech_list_caba_saki||table||492||||4"
msgid "Nope! Wrong.\nBack then I wasn't that into wrestling yet."
msgstr "No! Sbagliato.\nAll'epoca non mi interessava ancora il wrestling."

msgctxt "9||speech_list_caba_saki||table||493||||4"
msgid "I love it now, but the right answer\nwas the volleyball team."
msgstr "Adesso lo adoro, ma la risposta esatta\nera la squadra di pallavolo."

msgctxt "9||speech_list_caba_saki||table||494||||4"
msgid "Volleyball, huh?\nYou do seem like you'd be a good fit for that."
msgstr "Pallavolo, eh?\nIn effetti mi sembra un'attività adatta a te."

msgctxt "9||speech_list_caba_saki||table||495||||4"
msgid "Were you... not on a team?"
msgstr "Eri... in nessuna squadra?"

msgctxt "9||speech_list_caba_saki||table||496||||4"
msgid "Bzzzt! The right answer is... the volleyball team!\nI just told I was on a team, didn't I?"
msgstr "Bzzzt! La risposta esatta è... la squadra di pallavolo!\nTi avevo appena detto che facevo parte di una squadra, no?"

msgctxt "9||speech_list_caba_saki||table||497||||4"
msgid "But when I was a kid, I kinda lost sight of my\ngoals... I was just coasting without a plan."
msgstr "Ma quando ero piccola, ho un po' perso di vista i miei\nobiettivi... Andavo avanti per inerzia, senza un piano."

msgctxt "9||speech_list_caba_saki||table||498||||4"
msgid "Looking back on it, I have no idea what I was\nthinking. I was just a dumb teenager, I guess."
msgstr "Ripensandoci, non ho idea a cosa stessi pensando.\nEro solo una stupida adolescente, suppongo."

msgctxt "9||speech_list_caba_saki||table||499||||4"
msgid "That's life."
msgstr "Così è la vita."

msgctxt "9||speech_list_caba_saki||table||500||||4"
msgid "What? No way. Laundry sucks.\nWash them yourself, please."
msgstr "Cosa? Scordatelo. Fare il bucato fa schifo.\nLavateli da solo, per favore."

msgctxt "9||speech_list_caba_saki||table||501||||4"
msgid "Oh, are you asking me to be your girlfriend?\nWhatever should I do...? <symbol=heart_with_outline>"
msgstr "Oh, mi stai forse chiedendo di essere la tua ragazza?\nChe cosa dovrei fare...? <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||502||||4"
msgid "You should save that line for\nthe girl you want to marry."
msgstr "Dovresti riservare quella frase per\nla ragazza che vorrai sposare."

msgctxt "9||speech_list_caba_saki||table||503||||4"
msgid "Huh? Are you serious?"
msgstr "Eh? Dici sul serio?"

msgctxt "9||speech_list_caba_saki||table||504||||4"
msgid "Huh? A-Are you asking...\nIf you'll have me... <symbol=heart_with_outline>"
msgstr "Eh? M-Mi stai chiedendo...\nSe mi vorrai... <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||505||||4"
msgid "Oho? Why do you think that?"
msgstr "Oho? Perché pensi questo?"

msgctxt "9||speech_list_caba_saki||table||506||||4"
msgid "Most of them can't even speak properly."
msgstr "La maggior parte di loro non sa nemmeno parlare correttamente."

msgctxt "9||speech_list_caba_saki||table||507||||4"
msgid "Y'know, Kiryu...\nIt ain't right."
msgstr "Sai, Kiryu...\nnon è giusto."

msgctxt "9||speech_list_caba_saki||table||508||||4"
msgid "Hey, is that how you really talk?"
msgstr "Ehi, è così che parli veramente?"

msgctxt "9||speech_list_caba_saki||table||509||||4"
msgid "Joking, joking. <symbol=heart_with_outline> If you can be polite to\nstrangers, then be polite to your friends."
msgstr "Scherzo, scherzo. <symbol=heart_with_outline> Se sai essere educato con\ngli estranei, allora sii educato con i tuoi amici."

msgctxt "9||speech_list_caba_saki||table||510||||4"
msgid "They just lack conviction."
msgstr "Mancano semplicemente di convinzione."

msgctxt "9||speech_list_caba_saki||table||511||||4"
msgid "Oh, I can get on board with that.\nI see it a lot in young pro wrestlers."
msgstr "Oh, sono pienamente d'accordo.\nLo vedo spesso nelle giovani pro wrestler."

msgctxt "9||speech_list_caba_saki||table||512||||4"
msgid "It's like... they have no passion.\nNo desire to make it big."
msgstr "È come se... non avessero passione.\nNessun desiderio di sfondare."

msgctxt "9||speech_list_caba_saki||table||513||||4"
msgid "Man, saying all this makes me sound like an\nold woman. I gotta watch it."
msgstr "Cavoli, dire tutto questo mi fa sembrare una\nvecchia. Devo farci attenzione."

msgctxt "9||speech_list_caba_saki||table||514||||4"
msgid "Looks like we're on the same side."
msgstr "Sembra che siamo dalla stessa parte."

msgctxt "9||speech_list_caba_saki||table||515||||4"
msgid "Hey, you take that back.\nI'm still young and lively, I swear!"
msgstr "Ehi, rimangiati quello che hai detto.\nSono ancora giovane e piena di vita, lo giuro!"

msgctxt "9||speech_list_caba_saki||table||516||||4"
msgid "The girls are really letting themselves go...\nKinda gross."
msgstr "Le ragazze si stanno davvero lasciando andare...\nPiuttosto disgustoso."

msgctxt "9||speech_list_caba_saki||table||517||||4"
msgid "Oh, is that what you meant?\nI was thinking you'd have a lot worse to say!"
msgstr "Oh, è questo che intendevi?\nPensavo avresti detto di molto peggio!"

msgctxt "9||speech_list_caba_saki||table||518||||4"
msgid "I sing a lot, but I like the cutesy songs.\nThey're such a breath of fresh air."
msgstr "Canto molto, ma mi piacciono le canzoni un po' sdolcinate.\nSono una boccata d'aria fresca."

msgctxt "9||speech_list_caba_saki||table||519||||4"
msgid "Really? I don't know if I agree.\nI like a man who's more calm and collected."
msgstr "Davvero? Non so se sono d'accordo.\nMi piace un uomo che sia più calmo e pacato."

msgctxt "9||speech_list_caba_saki||table||520||||4"
msgid "Someone who's kind and open-minded...\nwith a face like a gorilla!"
msgstr "Qualcuno di gentile e dalla mentalità aperta...\ncon la faccia da gorilla!"

msgctxt "9||speech_list_caba_saki||table||521||||4"
msgid "A gorilla..."
msgstr "Un gorilla..."

msgctxt "9||speech_list_caba_saki||table||522||||4"
msgid "He wears an eyepatch and he's half naked under a\nweird jacket? Is this Majima-san a pro wrestler?"
msgstr "Porta una benda sull'occhio ed è mezzo nudo sotto una\ngiacca stramba? Questo Majima-san è un pro wrestler?"

msgctxt "9||speech_list_caba_saki||table||523||||4"
msgid "No, he's a civilian... Well, not exactly.\nBut, he's strong enough to impress a wrestler."
msgstr "No, è un civile... Beh, non esattamente.\nMa è abbastanza forte da impressionare una wrestler."

msgctxt "9||speech_list_caba_saki||table||524||||4"
msgid "What!? I really want to meet him now...\nI might totally fall for this guy if we met..."
msgstr "Cosa!? Adesso voglio proprio conoscerlo...\nPotrei innamorarmi completamente di lui se ci incontrassimo..."

msgctxt "9||speech_list_caba_saki||table||525||||4"
msgid "Ah, Majima-san..."
msgstr "Ah, Majima-san..."

msgctxt "9||speech_list_caba_saki||table||526||||4"
msgid "Hey, what part of anything I just said\nmakes this guy sound attractive?"
msgstr "Ehi, quale parte di quello che ho appena detto\nfa sembrare attraente questo tizio?"

msgctxt "9||speech_list_caba_saki||table||527||||4"
msgid "A detective, huh? Sounds a little scatterbrained,\nbut I'm sure he's good guy."
msgstr "Un detective, eh? Sembra un po' sbadato,\nma sono sicura che sia un brav'uomo."

msgctxt "9||speech_list_caba_saki||table||528||||4"
msgid "This Akiyama-san is an entrepreneur?\nSounds rich! Ah, you should bring him by!"
msgstr "Questo Akiyama-san è un imprenditore?\nSembra ricco! Ah, dovresti portarlo qui!"

msgctxt "9||speech_list_caba_saki||table||529||||4"
msgid "If I can just get him to request me..."
msgstr "Se solo riuscissi a convincerlo a richiedermi..."

msgctxt "9||speech_list_caba_saki||table||530||||4"
msgid "What!?\nHe took down a bear!?"
msgstr "Cosa!?\nHa abbattuto un orso!?"

msgctxt "9||speech_list_caba_saki||table||531||||4"
msgid "It's my <font_kind=yakuza_italic>dream</font_kind> as a fighter to take down a bear!\nGive me details here!"
msgstr "È il mio <font_kind=yakuza_italic>sogno</font_kind> come lottatrice abbattere un orso!\nVoglio tutti i dettagli!"

msgctxt "9||speech_list_caba_saki||table||532||||4"
msgid "S-Sure...\nDidn't figure that would strike a chord..."
msgstr "C-Certo...\nNon immaginavo che avrei toccato un tasto sensibile..."

msgctxt "9||speech_list_caba_saki||table||533||||4"
msgid "You trust him a lot, huh? I'd like\nto get to that level with you, Kiryu-san."
msgstr "Ti fidi molto di lui, eh? Mi piacerebbe\narrivare a quel livello con te, Kiryu-san."

msgctxt "9||speech_list_caba_saki||table||534||||4"
msgid "I've never been before.\nWhat do you do for fun there, Kiryu-san?"
msgstr "Non ci sono mai stata.\nCosa fai per divertirti lì, Kiryu-san?"

msgctxt "9||speech_list_caba_saki||table||535||||4"
msgid "Well...\nAbout all they've got there are bars."
msgstr "Beh...\nHanno quasi solo bar da quelle parti."

msgctxt "9||speech_list_caba_saki||table||536||||4"
msgid "I spend most of the time just chatting with\nthe bartender, sipping a glass of liquor."
msgstr "Passo la maggior parte del tempo a chiacchierare con\nil barista, sorseggiando un bicchiere di liquore."

msgctxt "9||speech_list_caba_saki||table||537||||4"
msgid "Huh! That sounds like a nice little situation.\nI could have some good fantasies about that... <symbol=heart_with_outline>"
msgstr "Oh! Sembra una bella situazione.\nPotrei farmi delle ottime fantasie al riguardo... <symbol=heart_with_outline>"

msgctxt "9||speech_list_caba_saki||table||538||||4"
msgid "Don't go too crazy."
msgstr "Non andarci giù troppo pesante."

msgctxt "10||speech_list_caba_sora||table||0||||4"
msgid "Kiryu-san. Sorry for the wait."
msgstr "Kiryu-san. Scusa per l'attesa."

msgctxt "10||speech_list_caba_sora||table||1||||4"
msgid "Sorry I'm late."
msgstr "Scusa per il ritardo."

msgctxt "10||speech_list_caba_sora||table||2||||4"
msgid "Kiryu-san! I've been waiting for you."
msgstr "Kiryu-san! Ti stavo aspettando."

msgctxt "10||speech_list_caba_sora||table||3||||4"
msgid "So, where should we go?"
msgstr "Allora, dove andiamo?"

msgctxt "10||speech_list_caba_sora||table||4||||4"
msgid "Sounds good!\nI love karaoke."
msgstr "Mi sembra ottimo!\nAdoro il karaoke."

msgctxt "10||speech_list_caba_sora||table||5||||4"
msgid "Darts, huh? <symbol=note_with_outline>"
msgstr "Freccette, eh? <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||6||||4"
msgid "Well, shall we? <symbol=note_with_outline>"
msgstr "Bene, andiamo? <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||7||||4"
msgid "I'd like to hear you sing! <symbol=heart_with_outline>"
msgstr "Mi piacerebbe sentirti cantare! <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||8||||4"
msgid "What should I sing today? <symbol=note_with_outline>"
msgstr "Cosa dovrei cantare oggi? <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||9||||4"
msgid "You wanna play against me?\nSure!"
msgstr "Vuoi giocare contro di me?\nCerto!"

msgctxt "10||speech_list_caba_sora||table||10||||4"
msgid "All right, let's do this!"
msgstr "Va bene, diamoci dentro!"

msgctxt "10||speech_list_caba_sora||table||11||||4"
msgid "Don't let it get you down.\nIt's all just for fun!"
msgstr "Non abbatterti.\nÈ solo per divertirsi!"

msgctxt "10||speech_list_caba_sora||table||12||||4"
msgid "That was fun. <symbol=note_with_outline>\nWe should come back sometime. <symbol=heart_with_outline>"
msgstr "È stato divertente. <symbol=note_with_outline>\nDovremmo tornarci, qualche volta. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||13||||4"
msgid "That was so fun!\nWe should meet up more often. <symbol=note_with_outline>"
msgstr "È stato divertentissimo!\nDovremmo incontrarci più spesso. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||14||||4"
msgid "Well, let's head back to the club."
msgstr "Beh, torniamo al club."

msgctxt "10||speech_list_caba_sora||table||15||||4"
msgid "Oh, I'm good at this song. <symbol=heart_with_outline>"
msgstr "Oh, me la cavo bene con questa canzone. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||16||||4"
msgid "I'm feeling good about singing today. <symbol=note_with_outline>"
msgstr "Oggi mi sento in vena di cantare. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||17||||4"
msgid "My throat's a little sore..."
msgstr "Mi fa un po' male la gola..."

msgctxt "10||speech_list_caba_sora||table||18||||4"
msgid "I-It's hard to sing like that..."
msgstr "È-È difficile cantare così..."

msgctxt "10||speech_list_caba_sora||table||19||||4"
msgid "You're good at getting me going. <symbol=heart_with_outline>"
msgstr "Sei bravo a darmi la carica. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||20||||4"
msgid "That was really fun to sing, thanks to you. <symbol=heart_with_outline>"
msgstr "È stato davvero divertente cantare, grazie a te. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||21||||4"
msgid "Now it's your turn!"
msgstr "Ora tocca a te!"

msgctxt "10||speech_list_caba_sora||table||22||||4"
msgid "Aww... I wanted to hear you sing something."
msgstr "Aww... Volevo sentirti cantare qualcosa."

msgctxt "10||speech_list_caba_sora||table||23||||4"
msgid "K-Kiryu-san...\nIs this your first time doing karaoke?"
msgstr "K-Kiryu-san...\nÈ la tua prima volta al karaoke?"

msgctxt "10||speech_list_caba_sora||table||24||||4"
msgid "You were pretty cool. <symbol=note_with_outline>"
msgstr "Sei stato piuttosto in gamba. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||25||||4"
msgid "You're good, Kiryu-san!\nI wish you'd sing to me forever... <symbol=heart_with_outline>"
msgstr "Sei bravo, Kiryu-san!\nVorrei che cantassi per me all'infinito... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||26||||4"
msgid "Whoa! You're a big spender, Kiryu-san. <symbol=heart_with_outline>"
msgstr "Whoa! Non badi a spese, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||27||||4"
msgid "Thank you."
msgstr "Grazie."

msgctxt "10||speech_list_caba_sora||table||28||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "10||speech_list_caba_sora||table||29||||4"
msgid "Oh, I love that. <symbol=note_with_outline>\nIt's tasty."
msgstr "Oh, lo adoro. <symbol=note_with_outline>\nÈ squisito."

msgctxt "10||speech_list_caba_sora||table||30||||4"
msgid "Excuse me."
msgstr "Permesso."

msgctxt "10||speech_list_caba_sora||table||31||||4"
msgid "Nice to meet you.\nI'm Sora, from Taiwan."
msgstr "Piacere di conoscerti.\nSono Sora, vengo da Taiwan."

msgctxt "10||speech_list_caba_sora||table||32||||4"
msgid "Huh. Your Japanese is pretty good."
msgstr "Mhm. Il tuo giapponese è molto buono."

msgctxt "10||speech_list_caba_sora||table||33||||4"
msgid "Thank you. I came here more than ten\nyears ago, so I've gotten used to it."
msgstr "Grazie. Sono venuta qui più di dieci\nanni fa, quindi ci ho fatto l'abitudine."

msgctxt "10||speech_list_caba_sora||table||34||||4"
msgid "My mom's Taiwanese, but my dad's actually half\nJapanese. He's the one who taught me the language."
msgstr "Mia mamma è taiwanese, ma mio papà è in realtà per metà\ngiapponese. È lui che mi ha insegnato la lingua."

msgctxt "10||speech_list_caba_sora||table||35||||4"
msgid "Makes sense. Now that you've said that,\nI can see a little Japanese in there."
msgstr "Ha senso. Ora che me lo dici,\nci vedo un po' di giapponese in te."

msgctxt "10||speech_list_caba_sora||table||36||||4"
msgid "Thank you."
msgstr "Grazie."

msgctxt "10||speech_list_caba_sora||table||37||||4"
msgid "Um, may I ask what your name is?"
msgstr "Ehm, posso chiederti come ti chiami?"

msgctxt "10||speech_list_caba_sora||table||38||||4"
msgid "Yeah. I'm Kiryu."
msgstr "Sì. Sono Kiryu."

msgctxt "10||speech_list_caba_sora||table||39||||4"
msgid "Kiryu-san, then.\nI look forward to spending time with you today. <symbol=note_with_outline>"
msgstr "Kiryu-san, allora.\nNon vedo l'ora di passare del tempo con te oggi. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||40||||4"
msgid "Likewise."
msgstr "Piacere mio."

msgctxt "10||speech_list_caba_sora||table||41||||4"
msgid "Kiryu-san, thanks for coming in today.\nDid you have fun?"
msgstr "Kiryu-san, grazie per essere venuto oggi.\nTi sei divertito?"

msgctxt "10||speech_list_caba_sora||table||42||||4"
msgid "Yeah, of course."
msgstr "Sì, certo."

msgctxt "10||speech_list_caba_sora||table||43||||4"
msgid "Wonderful. <symbol=note_with_outline>\nCome back anytime. <symbol=heart_with_outline>"
msgstr "Meraviglioso. <symbol=note_with_outline>\nTorna quando vuoi. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||44||||4"
msgid "Welcome back.\nI'm so happy to see you again. <symbol=note_with_outline>"
msgstr "Bentornato.\nSono così felice di rivederti. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||45||||4"
msgid "Welcome back, Kiryu-san. <symbol=note_with_outline>\nI've been waiting for you... <symbol=heart_with_outline>"
msgstr "Bentornato, Kiryu-san. <symbol=note_with_outline>\nTi stavo aspettando... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||46||||4"
msgid "Kiryu-san, I've been waiting for you... <symbol=heart_with_outline>"
msgstr "Kiryu-san, ti stavo aspettando... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||47||||4"
msgid "Let's go for the extended session today. <symbol=heart_with_outline>"
msgstr "Oggi prolunghiamo la sessione. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||48||||4"
msgid "Right this way."
msgstr "Da questa parte."

msgctxt "10||speech_list_caba_sora||table||49||||4"
msgid "Kiryu-san!"
msgstr "Kiryu-san!"

msgctxt "10||speech_list_caba_sora||table||50||||4"
msgid "Thanks for coming in today. <symbol=note_with_outline>\nI hope you'll come back again soon."
msgstr "Grazie per essere venuto oggi. <symbol=note_with_outline>\nSpero che tornerai presto."

msgctxt "10||speech_list_caba_sora||table||51||||4"
msgid "Kiryu-san. Thanks for coming in today. <symbol=note_with_outline>\nYou'd better come back soon. <symbol=heart_with_outline>"
msgstr "Kiryu-san. Grazie per essere venuto oggi. <symbol=note_with_outline>\nVedi di tornare presto. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||52||||4"
msgid "Goodbyes are always the hardest...\nCome see me again soon, okay? <symbol=heart_with_outline>"
msgstr "Gli addii sono sempre la cosa più difficile...\nTorna a trovarmi presto, okay? <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||53||||4"
msgid "Thanks, Kiryu-san. <symbol=heart_with_outline>"
msgstr "Grazie, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||54||||4"
msgid "Cheers! <symbol=note_with_outline>"
msgstr "Salute! <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||55||||4"
msgid "Oh, Kiryu-san?"
msgstr "Oh, Kiryu-san?"

msgctxt "10||speech_list_caba_sora||table||56||||4"
msgid "This is my phone number. <symbol=note_with_outline>\nText me sometime if you feel like it. <symbol=heart_with_outline>"
msgstr "Questo è il mio numero di telefono. <symbol=note_with_outline>\nMandami un messaggio qualche volta, se ti va. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||57||||4"
msgid "Looks like our time's almost up."
msgstr "Sembra che il nostro tempo sia quasi scaduto."

msgctxt "10||speech_list_caba_sora||table||58||||4"
msgid "Time truly flies when you're having fun."
msgstr "Il tempo vola davvero quando ci si diverte."

msgctxt "10||speech_list_caba_sora||table||59||||4"
msgid "Thank you. <symbol=heart_with_outline>\nLet's keep having fun! <symbol=note_with_outline>"
msgstr "Grazie. <symbol=heart_with_outline>\nContinuiamo a divertirci! <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||60||||4"
msgid "Thanks for coming today. <symbol=note_with_outline>"
msgstr "Grazie per essere venuto oggi. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||61||||4"
msgid "Yes, okay..."
msgstr "Sì, okay..."

msgctxt "10||speech_list_caba_sora||table||62||||4"
msgid "That's right. <symbol=note_with_outline>"
msgstr "Esatto. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||63||||4"
msgid "I know, right?"
msgstr "Vero?"

msgctxt "10||speech_list_caba_sora||table||64||||4"
msgid "Okay. If you don't mind. <symbol=heart_with_outline>"
msgstr "Va bene. Se non ti dispiace. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||65||||4"
msgid "No, that's not right."
msgstr "No, non è esatto."

msgctxt "10||speech_list_caba_sora||table||66||||4"
msgid "What!? That's not right at all!"
msgstr "Cosa!? Non è affatto vero!"

msgctxt "10||speech_list_caba_sora||table||67||||4"
msgid "I think that's weird."
msgstr "Penso che sia strano."

msgctxt "10||speech_list_caba_sora||table||68||||4"
msgid "No way. <symbol=note_with_outline>"
msgstr "Assolutamente no. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||69||||4"
msgid "Wow, really?"
msgstr "Wow, davvero?"

msgctxt "10||speech_list_caba_sora||table||70||||4"
msgid "Maybe next time!"
msgstr "Forse la prossima volta!"

msgctxt "10||speech_list_caba_sora||table||71||||4"
msgid "Oh, Kiryu-san... <symbol=heart_with_outline>"
msgstr "Oh, Kiryu-san... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||72||||4"
msgid "That's a secret. <symbol=note_with_outline>"
msgstr "Questo è un segreto. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||73||||4"
msgid "So Kiryu-san, do you have any plans for \nNew Year's? Maybe, going overseas?"
msgstr "Allora Kiryu-san, hai programmi per \nCapodanno? Forse andrai all'estero?"

msgctxt "10||speech_list_caba_sora||table||74||||4"
msgid "No, not really.\nI'm not really the type to travel overseas."
msgstr "No, non proprio.\nNon sono il tipo che viaggia all'estero."

msgctxt "10||speech_list_caba_sora||table||75||||4"
msgid "Oh, I see."
msgstr "Oh, capisco."

msgctxt "10||speech_list_caba_sora||table||76||||4"
msgid "What about you, Sora?\nDo you go every year?"
msgstr "E tu, Sora?\nCi vai ogni anno?"

msgctxt "10||speech_list_caba_sora||table||77||||4"
msgid "I go a lot, but in my case, it's less of a\nvacation and more going home to visit family."
msgstr "Ci vado spesso, ma nel mio caso non è tanto una\nvacanza, quanto tornare a casa a trovare la famiglia."

msgctxt "10||speech_list_caba_sora||table||78||||4"
msgid "Oh, right.\nYou're from Taiwan."
msgstr "Oh, giusto.\nTu sei di Taiwan."

msgctxt "10||speech_list_caba_sora||table||79||||4"
msgid "Yep! I've loved my family my whole life. Even\nnow I get the urge to go see them all the time."
msgstr "Già! Ho amato la mia famiglia per tutta la vita. Ancora\nadesso mi viene continuamente voglia di andare a trovarli."

msgctxt "10||speech_list_caba_sora||table||80||||4"
msgid "What about you, Kiryu-san?\nDo you like your family?"
msgstr "E tu, Kiryu-san?\nA te piace la tua famiglia?"

msgctxt "10||speech_list_caba_sora||table||81||||4"
msgid "Of course I do."
msgstr "Certo che sì."

msgctxt "10||speech_list_caba_sora||table||82||||4"
msgid "You too, huh? I'm glad.\nFamily's great, right?"
msgstr "Anche a te, eh? Mi fa piacere.\nLa famiglia è fantastica, vero?"

msgctxt "10||speech_list_caba_sora||table||83||||4"
msgid "Yeah, you're right."
msgstr "Sì, hai ragione."

msgctxt "10||speech_list_caba_sora||table||84||||4"
msgid "(Family, huh?)"
msgstr "(Famiglia, eh?)"

msgctxt "10||speech_list_caba_sora||table||85||||4"
msgid "(All those days I spent with Kazama-san and\nNishiki... Thinking about it takes me back.)"
msgstr "(Tutti i giorni che ho passato con Kazama-san e\nNishiki... Ripensarci mi riporta indietro nel tempo.)"

msgctxt "10||speech_list_caba_sora||table||86||||4"
msgid "Kiryu-san...? What's wrong?"
msgstr "Kiryu-san...? Che c'è che non va?"

msgctxt "10||speech_list_caba_sora||table||87||||4"
msgid "Nothing, just lost in thought.\nSora, you take care of your family, okay?"
msgstr "Niente, ero solo perso nei miei pensieri.\nSora, prenditi cura della tua famiglia, intesi?"

msgctxt "10||speech_list_caba_sora||table||88||||4"
msgid "The time you have with them is finite,\nso don't ever forget how irreplaceable they are."
msgstr "Il tempo che passi con loro non è infinito,\nperciò non dimenticare mai quanto siano insostituibili."

msgctxt "10||speech_list_caba_sora||table||89||||4"
msgid "Yeah... You're exactly right. I want to keep\nworking hard to do my part for my parents!"
msgstr "Sì... Hai perfettamente ragione. Voglio continuare a\nlavorare sodo per fare la mia parte per i miei genitori!"

msgctxt "10||speech_list_caba_sora||table||90||||4"
msgid "I... never knew my parents."
msgstr "Io... non ho mai conosciuto i miei genitori."

msgctxt "10||speech_list_caba_sora||table||91||||4"
msgid "Huh? O-Oh...\nI... I'm sorry."
msgstr "Eh? O-Oh...\nIo... mi dispiace."

msgctxt "10||speech_list_caba_sora||table||92||||4"
msgid "No, it's okay. Don't worry about it.\nIt doesn't really bother me."
msgstr "No, va tutto bene. Non preoccuparti.\nNon mi pesa."

msgctxt "10||speech_list_caba_sora||table||93||||4"
msgid "Besides, even though I never knew my parents,\nI've met so many people I'm proud to call family."
msgstr "Inoltre, anche se non ho mai conosciuto i miei genitori,\nho incontrato così tante persone che sono orgoglioso di poter chiamare famiglia."

msgctxt "10||speech_list_caba_sora||table||94||||4"
msgid "They mean more to me than any blood ever could."
msgstr "Significano per me più di quanto potrebbe mai fare un legame di sangue."

msgctxt "10||speech_list_caba_sora||table||95||||4"
msgid "I see. I think you're very lucky to have so many\npeople you'd consider close enough to be family."
msgstr "Capisco. Penso che tu sia molto fortunato ad avere così tante\npersone che consideri così vicine da essere come una famiglia."

msgctxt "10||speech_list_caba_sora||table||96||||4"
msgid "Yeah. I hope you make lots of bonds like that too,\nand that goes for your whole family."
msgstr "Sì. Spero che anche tu riesca a creare molti legami di questo tipo,\ne lo stesso vale per tutta la tua famiglia."

msgctxt "10||speech_list_caba_sora||table||97||||4"
msgid "Yeah! It would be nice if the two\nof us could become like family, huh?"
msgstr "Sì! Sarebbe bello se noi due\npotessimo diventare come una famiglia, eh?"

msgctxt "10||speech_list_caba_sora||table||98||||4"
msgid "That would be pretty nice."
msgstr "Sarebbe davvero bello."

msgctxt "10||speech_list_caba_sora||table||99||||4"
msgid "Kazama-san, Nishiki, Yumi..."
msgstr "Kazama-san, Nishiki, Yumi..."

msgctxt "10||speech_list_caba_sora||table||100||||4"
msgid "Anyone I thought of family has long\nsince died and left me behind."
msgstr "Chiunque considerassi una famiglia è morto da\ntempo, lasciandomi indietro."

msgctxt "10||speech_list_caba_sora||table||101||||4"
msgid "Oh... I... I'm sorry..."
msgstr "Oh... Io... mi dispiace..."

msgctxt "10||speech_list_caba_sora||table||102||||4"
msgid "It's fine. Don't worry about it."
msgstr "Va bene così. Non preoccuparti."

msgctxt "10||speech_list_caba_sora||table||103||||4"
msgid "That just means you have to treasure\nyour family more for my sake, too."
msgstr "Significa solo che devi fare ancora più tesoro\ndella tua famiglia, anche per me."

msgctxt "10||speech_list_caba_sora||table||104||||4"
msgid "The time you have with them is finite,\nso don't ever forget how irreplaceable they are."
msgstr "Il tempo che passi con loro non è infinito,\nperciò non dimenticare mai quanto siano insostituibili."

msgctxt "10||speech_list_caba_sora||table||105||||4"
msgid "Kiryu-san... That's so deep.\nYou're a great guy."
msgstr "Kiryu-san... Questo è molto profondo.\nSei un grande uomo."

msgctxt "10||speech_list_caba_sora||table||106||||4"
msgid "I'm nothing special. Sorry to get so preachy.\nWanna get back to drinking?"
msgstr "Non sono niente di speciale. Scusa per la predica.\nVogliamo tornare a bere?"

msgctxt "10||speech_list_caba_sora||table||107||||4"
msgid "O-Okay!"
msgstr "O-Okay!"

msgctxt "10||speech_list_caba_sora||table||108||||4"
msgid "You said you were born in Taiwan, right?\nWhat do you think? Is it easy to live in Japan?"
msgstr "Hai detto di essere nata a Taiwan, vero?\nChe ne pensi? È facile vivere in Giappone?"

msgctxt "10||speech_list_caba_sora||table||109||||4"
msgid "Yep. Everyone's so nice, and it's so convenient\nhere. I love Japanese culture, too."
msgstr "Sì. Tutti sono così gentili ed è così comodo\nqui. Amo molto anche la cultura giapponese."

msgctxt "10||speech_list_caba_sora||table||110||||4"
msgid "Japanese culture?"
msgstr "La cultura giapponese?"

msgctxt "10||speech_list_caba_sora||table||111||||4"
msgid "Games, anime, manga...\nI love all that stuff!"
msgstr "Videogiochi, anime, manga...\nAdoro tutta questa roba!"

msgctxt "10||speech_list_caba_sora||table||112||||4"
msgid "In fact... I cosplay a lot, too."
msgstr "Infatti... faccio anche molto cosplay."

msgctxt "10||speech_list_caba_sora||table||113||||4"
msgid "Huh. That so?"
msgstr "Oh. Davvero?"

msgctxt "10||speech_list_caba_sora||table||114||||4"
msgid "Kiryu-san, what do you think about that\nkind of culture and stuff like cosplay?"
msgstr "Kiryu-san, cosa ne pensi di questo\ntipo di cultura e del cosplay?"

msgctxt "10||speech_list_caba_sora||table||115||||4"
msgid "It looks so fun.\nI'm kinda jealous."
msgstr "Sembra così divertente.\nSono un po' invidioso."

msgctxt "10||speech_list_caba_sora||table||116||||4"
msgid "Jealous? I mean, I'm happy,\nbut that was pretty unexpected."
msgstr "Invidioso? Voglio dire, ne sono felice,\nma è stato piuttosto inaspettato."

msgctxt "10||speech_list_caba_sora||table||117||||4"
msgid "Really?"
msgstr "Davvero?"

msgctxt "10||speech_list_caba_sora||table||118||||4"
msgid "Yeah. I figured a tough guy like you\nwould look down on that kind of stuff."
msgstr "Sì. Immaginavo che un duro come te\ndisprezzasse roba del genere."

msgctxt "10||speech_list_caba_sora||table||119||||4"
msgid "Who am I to judge? Besides, nobody gets to\nsay one thing is better or worse than the other."
msgstr "Chi sono io per giudicare? Inoltre, nessuno può\ndire che una cosa sia migliore o peggiore di un'altra."

msgctxt "10||speech_list_caba_sora||table||120||||4"
msgid "I think it's great to really dive into something.\nThat said, I can't stand people who half-ass things."
msgstr "Penso sia fantastico tuffarsi davvero in qualcosa.\nDetto questo, non sopporto la gente che fa le cose a metà."

msgctxt "10||speech_list_caba_sora||table||121||||4"
msgid "Kiryu-san... You have a wonderful outlook on it.\nWe should cosplay together sometime. <symbol=note_with_outline>"
msgstr "Kiryu-san... Hai un punto di vista meraviglioso.\nDovremmo fare cosplay insieme qualche volta. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||122||||4"
msgid "M-Me...?\nUm... Hm. If I'm up to it."
msgstr "I-Io...?\nEhm... Mhm. Se me la sentirò."

msgctxt "10||speech_list_caba_sora||table||123||||4"
msgid "I'm actually a little\ninterested in it myself..."
msgstr "In effetti la cosa interessa\nun po' anche a me..."

msgctxt "10||speech_list_caba_sora||table||124||||4"
msgid "Whaaat!? You mean that!?"
msgstr "Cooosa!? Dici sul serio!?"

msgctxt "10||speech_list_caba_sora||table||125||||4"
msgid "Yeah, people who do it always seem to be having\nso much fun. That must mean it's worth the effort."
msgstr "Sì, la gente che lo fa sembra sempre divertirsi un\nmondo. Questo vuol dire che ne vale la pena."

msgctxt "10||speech_list_caba_sora||table||126||||4"
msgid "Kiryu-san, you're so open-minded!\nWe should cosplay together sometime!"
msgstr "Kiryu-san, hai una mentalità così aperta!\nDovremmo fare cosplay insieme qualche volta!"

msgctxt "10||speech_list_caba_sora||table||127||||4"
msgid "Ahhh, who would you look good as?\nMaybe that character... No. <font_kind=yakuza_italic>That</font_kind> character...!"
msgstr "Ahhh, nei panni di chi staresti bene?\nForse quel personaggio... No. <font_kind=yakuza_italic>Quel</font_kind> personaggio...!"

msgctxt "10||speech_list_caba_sora||table||128||||4"
msgid "Hmmm..."
msgstr "Mhm..."

msgctxt "10||speech_list_caba_sora||table||129||||4"
msgid "Wait! You'd make a great villain, too! The frog\npresident with the black mask from that one series!"
msgstr "Aspetta! Saresti anche un ottimo cattivo! Il presidente\nrana con la maschera nera di quella serie là!"

msgctxt "10||speech_list_caba_sora||table||130||||4"
msgid "Wh-What in the world?\nUh, let's start off easy..."
msgstr "M-Ma che diamine?\nEhm, iniziamo con qualcosa di semplice..."

msgctxt "10||speech_list_caba_sora||table||131||||4"
msgid "To be honest, I don't really get it."
msgstr "Ad essere onesto, non ci arrivo proprio."

msgctxt "10||speech_list_caba_sora||table||132||||4"
msgid "That makes sense. It probably feels like a\ntotally different world than the one you live in."
msgstr "Ha senso. Probabilmente ti sembra un mondo\ntotalmente diverso da quello in cui vivi."

msgctxt "10||speech_list_caba_sora||table||133||||4"
msgid "But if that world ever gets you down, maybe you\nshould come chill with us in ours, you know?"
msgstr "Ma se mai il tuo mondo dovesse buttarti giù, forse\ndovresti venire a rilassarti con noi nel nostro, sai?"

msgctxt "10||speech_list_caba_sora||table||134||||4"
msgid "Maybe. Sometimes I think\nI could use a change of scenery."
msgstr "Forse. A volte penso che mi\nfarebbe comodo un cambio di scenario."

msgctxt "10||speech_list_caba_sora||table||135||||4"
msgid "If you decide, you just give me a call.\nI want to see you cosplay..."
msgstr "Se ti decidi, fammi uno squillo.\nVoglio vederti fare cosplay..."

msgctxt "10||speech_list_caba_sora||table||136||||4"
msgid "You seem pretty accustomed to Japanese life.\nIs there anything tough to get used to here?"
msgstr "Sembri esserti abituata abbastanza bene alla vita giapponese.\nC'è qualcosa a cui è stato difficile abituarsi, qui?"

msgctxt "10||speech_list_caba_sora||table||137||||4"
msgid "Hmm... Sometimes the little differences between\nJapanese and Taiwanese cultures give me trouble."
msgstr "Mhm... A volte le piccole differenze tra la cultura\ngiapponese e quella taiwanese mi creano problemi."

msgctxt "10||speech_list_caba_sora||table||138||||4"
msgid "Huh, culture differences?\nYou have an example?"
msgstr "Ah, differenze culturali?\nHai un esempio?"

msgctxt "10||speech_list_caba_sora||table||139||||4"
msgid "Manners are what really gets me. It's fine to pass\nfood between chopsticks in Taiwan, but not here."
msgstr "Le buone maniere mi fregano sempre. A Taiwan va bene passarsi\nil cibo da bacchetta a bacchetta, ma qui no."

msgctxt "10||speech_list_caba_sora||table||140||||4"
msgid "Also... I can speak the language just fine, but\nsometimes I struggle to find the right word."
msgstr "E poi... riesco a parlare bene la lingua, ma\na volte fatico a trovare la parola giusta."

msgctxt "10||speech_list_caba_sora||table||141||||4"
msgid "Especially when it comes to foreign katakana\nwords. There are so many tough ones, you know?"
msgstr "Specialmente quando si tratta di parole straniere scritte in\nkatakana. Ce ne sono un sacco difficili, sai?"

msgctxt "10||speech_list_caba_sora||table||142||||4"
msgid "I get that. Loaner katakana words, huh?\nSo, would you know this?"
msgstr "Lo capisco. Parole in prestito in katakana, eh?\nQuesta la sai?"

msgctxt "10||speech_list_caba_sora||table||143||||4"
msgid "I love you..."
msgstr "I love you..."

msgctxt "10||speech_list_caba_sora||table||144||||4"
msgid "Where did that come from, Kiryu-san!? This is\nall so sudden... Can you tell I'm blushing?"
msgstr "Da dove ti è uscita, Kiryu-san!? È stato\ncosì improvviso... Si nota che sto arrossendo?"

msgctxt "10||speech_list_caba_sora||table||145||||4"
msgid "I guess that was too easy.\nDo you know what it means?"
msgstr "Immagino fosse troppo facile.\nSai cosa significa?"

msgctxt "10||speech_list_caba_sora||table||146||||4"
msgid "Please, of course I know that one! Geez,\nyou did that on purpose, didn't you? Meanie!"
msgstr "Ma dai, certo che la conosco! Cavoli,\nl'hai fatto apposta, non è vero? Cattivone!"

msgctxt "10||speech_list_caba_sora||table||147||||4"
msgid "Maybe I did."
msgstr "Forse."

msgctxt "10||speech_list_caba_sora||table||148||||4"
msgid "Kiryu-san, you can be such a cheeseball.\nAll the same, I'm happy..."
msgstr "Kiryu-san, sai essere così smielato.\nAd ogni modo, sono felice..."

msgctxt "10||speech_list_caba_sora||table||149||||4"
msgid "Well, if you're ever stuck on katakana, ask away.\nI'll tell you anything, as long as I know it."
msgstr "Beh, se mai ti bloccassi sul katakana, chiedi pure.\nTi dirò qualsiasi cosa, purché io la sappia."

msgctxt "10||speech_list_caba_sora||table||150||||4"
msgid "Okay. Thanks.\nGlad I can rely on you, then."
msgstr "Okay. Grazie.\nSono contenta di poter contare su di te, allora."

msgctxt "10||speech_list_caba_sora||table||151||||4"
msgid "Soup dumplings..."
msgstr "Ravioli in brodo..."

msgctxt "10||speech_list_caba_sora||table||152||||4"
msgid "Of course I know that one! You know,\nthat's not even written in katakana, you know."
msgstr "Certo che lo so! Ma guarda che quello\nnon si scrive nemmeno in katakana, lo sai, vero."

msgctxt "10||speech_list_caba_sora||table||153||||4"
msgid "Hrm. Really?"
msgstr "Mhm. Davvero?"

msgctxt "10||speech_list_caba_sora||table||154||||4"
msgid "You're a unique one, Kiryu-san. You're this tough\nguy, but your hidden inner goofball is so <font_kind=yakuza_italic>moe</font_kind>. <symbol=heart_with_outline>"
msgstr "Sei un tipo unico, Kiryu-san. Sei questo ragazzo duro, ma\nil tuo lato goffo e nascosto è così <font_kind=yakuza_italic>moe</font_kind>. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||155||||4"
msgid "<font_kind=yakuza_italic>Moeru</font_kind>? Like, you're burning up? Like a fierce\nman, a blazing turn of events, or a burning passion?"
msgstr "<font_kind=yakuza_italic>Moeru</font_kind>? Nel senso di bruciare? Come un uomo fiero,\nun evento fiammante o una passione ardente?"

msgctxt "10||speech_list_caba_sora||table||156||||4"
msgid "No no no, not the \"burning\" kind of <font_kind=yakuza_italic>moe</font_kind>. It's a\nslang thing for when your heart is all aflutter."
msgstr "No no no, non il tipo di <font_kind=yakuza_italic>moe</font_kind> \"bruciante\". È un\ntermine gergale per quando ti batte forte il cuore."

msgctxt "10||speech_list_caba_sora||table||157||||4"
msgid "Oh, well, thank you?\nJapanese is rough, huh?"
msgstr "Oh, beh, grazie?\nIl giapponese è difficile, eh?"

msgctxt "10||speech_list_caba_sora||table||158||||4"
msgid "There's that goofball again, Kiryu-san!\nI'm going to fall for that <font_kind=yakuza_italic>moe</font_kind> so hard."
msgstr "Ecco di nuovo quel lato goffo, Kiryu-san!\nFinirò per innamorarmi alla follia di questo <font_kind=yakuza_italic>moe</font_kind>."

msgctxt "10||speech_list_caba_sora||table||159||||4"
msgid "Burning <font_kind=yakuza_italic>moe</font_kind>..."
msgstr "<font_kind=yakuza_italic>Moe</font_kind> ardente..."

msgctxt "10||speech_list_caba_sora||table||160||||4"
msgid "Dreamcast..."
msgstr "Dreamcast..."

msgctxt "10||speech_list_caba_sora||table||161||||4"
msgid "Oh! I know that! That's the game console that took\nthe world by storm, yeah? It's famous in Taiwan, too!"
msgstr "Oh! Quello lo conosco! È la console di gioco che ha conquistato\nil mondo, giusto? È famosa anche a Taiwan!"

msgctxt "10||speech_list_caba_sora||table||162||||4"
msgid "I don't know if it really took the world by storm,\nbut, I'm surprised you knew about it."
msgstr "Non so se ha proprio conquistato il mondo,\nma mi sorprende che tu lo conosca."

msgctxt "10||speech_list_caba_sora||table||163||||4"
msgid "I don't say I'm a gamer for show, Kiryu-san.\nWere you a big Dreamcast fan?"
msgstr "Non dico di essere una gamer tanto per dire, Kiryu-san.\nEri un grande fan del Dreamcast?"

msgctxt "10||speech_list_caba_sora||table||164||||4"
msgid "No, I've just heard the name before.\nI don't know home consoles too well."
msgstr "No, ne avevo solo sentito il nome in giro.\nNon mi intendo molto di console casalinghe."

msgctxt "10||speech_list_caba_sora||table||165||||4"
msgid "Why don't we pick one up and play it at my place?\nNothing beats playing two player games!"
msgstr "Perché non ne compriamo uno e ci giochiamo a casa mia?\nNiente batte i giochi a due giocatori!"

msgctxt "10||speech_list_caba_sora||table||166||||4"
msgid "Oh, you wouldn't mind having me over?"
msgstr "Oh, non ti dispiacerebbe avermi ospite?"

msgctxt "10||speech_list_caba_sora||table||167||||4"
msgid "Ah, you make it sound like I'm seducing you.\nI just figured I could trust you, Kiryu-san."
msgstr "Ah, la fai sembrare come se ti stessi seducendo.\nHo solo pensato che potevo fidarmi di te, Kiryu-san."

msgctxt "10||speech_list_caba_sora||table||168||||4"
msgid "It's not like I go around inviting just anyone\nover, y'know? I'm not that kind of woman, okay?"
msgstr "Non è che me ne vada in giro a invitare chiunque a\ncasa, sai? Non sono quel tipo di donna, intesi?"

msgctxt "10||speech_list_caba_sora||table||169||||4"
msgid "Of course. I can tell you're\non the straight and narrow."
msgstr "Certo. Si capisce che sei\nuna ragazza a modo."

msgctxt "10||speech_list_caba_sora||table||170||||4"
msgid "Good. Then, you should definitely come over.\nYou promise?"
msgstr "Bene. Allora devi assolutamente venire da me.\nLo prometti?"

msgctxt "10||speech_list_caba_sora||table||171||||4"
msgid "Yeah, looking forward to it."
msgstr "Sì, non vedo l'ora."

msgctxt "10||speech_list_caba_sora||table||172||||4"
msgid "Did you like living in Taiwan, Sora?\nDo you ever think about going back?"
msgstr "Ti piaceva vivere a Taiwan, Sora?\nPensi mai di tornarci?"

msgctxt "10||speech_list_caba_sora||table||173||||4"
msgid "All the time. When all's said and done,\nthere's no place like home to me."
msgstr "Di continuo. Alla fin fine,\nper me non c'è nessun posto come casa propria."

msgctxt "10||speech_list_caba_sora||table||174||||4"
msgid "I see..."
msgstr "Capisco..."

msgctxt "10||speech_list_caba_sora||table||175||||4"
msgid "But Japan means a lot to me, too. I've met some\ngreat people and made some wonderful memories."
msgstr "Ma anche il Giappone significa molto per me. Ho incontrato\npersone fantastiche e creato ricordi meravigliosi."

msgctxt "10||speech_list_caba_sora||table||176||||4"
msgid "And more than anything else...\nthere's someone I like here..."
msgstr "E più di ogni altra cosa...\nc'è una persona che mi piace qui..."

msgctxt "10||speech_list_caba_sora||table||177||||4"
msgid "Oh? That does make it difficult."
msgstr "Oh? Questo rende le cose difficili."

msgctxt "10||speech_list_caba_sora||table||178||||4"
msgid "...It just makes me even more\nunsure about what I should do."
msgstr "...Mi rende solo ancora più\ninsicura su cosa dovrei fare."

msgctxt "10||speech_list_caba_sora||table||179||||4"
msgid "Is it better to go back,\nor live the rest of my life here?"
msgstr "È meglio tornare,\no vivere il resto della mia vita qui?"

msgctxt "10||speech_list_caba_sora||table||180||||4"
msgid "Quite the dilemma..."
msgstr "Un bel dilemma..."

msgctxt "10||speech_list_caba_sora||table||181||||4"
msgid "If he'd come back to Taiwan with me,\r\nI think I'd want to go, but..."
msgstr "Se lui venisse a Taiwan con me,\r\ncredo che vorrei andarci, ma..."

msgctxt "10||speech_list_caba_sora||table||182||||4"
msgid "If you like him enough to take that big a step,\ndon't you think you should ask how he feels?"
msgstr "Se ti piace abbastanza da fare un passo così importante,\nnon pensi che dovresti chiedergli cosa prova lui?"

msgctxt "10||speech_list_caba_sora||table||183||||4"
msgid "Y-You think so?"
msgstr "L-Lo pensi davvero?"

msgctxt "10||speech_list_caba_sora||table||184||||4"
msgid "Yeah. You've got to be honest with yourself about\nyour feelings. You can't keep it all bottled up."
msgstr "Sì. Devi essere onesta con te stessa riguardo ai\ntuoi sentimenti. Non puoi tenerti tutto dentro."

msgctxt "10||speech_list_caba_sora||table||185||||4"
msgid "But if I told him I wanted to take him back to\nTaiwan, don't you think it'd scare him away?"
msgstr "Ma se gli dicessi che voglio portarlo a Taiwan con\nme, non pensi che lo spaventerebbe?"

msgctxt "10||speech_list_caba_sora||table||186||||4"
msgid "I don't know. It would depend on the guy.\nIf you're important to him, he'd probably go."
msgstr "Non saprei. Dipende dal ragazzo.\nSe sei importante per lui, probabilmente verrebbe."

msgctxt "10||speech_list_caba_sora||table||187||||4"
msgid "Then again, if there's something he can't leave\nunfinished in Japan, he might choose to stay here."
msgstr "D'altra parte, se c'è qualcosa che non può lasciare in\nsospeso in Giappone, potrebbe scegliere di restare qui."

msgctxt "10||speech_list_caba_sora||table||188||||4"
msgid "You're right..."
msgstr "Hai ragione..."

msgctxt "10||speech_list_caba_sora||table||189||||4"
msgid "Yep. Either way, I think you're stuck\nuntil you figure out how he feels."
msgstr "Sì. In ogni caso, credo che non andrai\nda nessuna parte finché non capirai cosa prova lui."

msgctxt "10||speech_list_caba_sora||table||190||||4"
msgid "Yeah... Thank you for the pep talk.\nIt's helping."
msgstr "Sì... Grazie per il discorso di incoraggiamento.\nMi sta aiutando."

msgctxt "10||speech_list_caba_sora||table||191||||4"
msgid "Maybe... I should go for an all-out attack."
msgstr "Forse... dovrei optare per un attacco frontale."

msgctxt "10||speech_list_caba_sora||table||192||||4"
msgid "I admit I'm a little jealous of this guy,\nhaving a girl like you fall for him like this."
msgstr "Ammetto di essere un po' geloso di questo ragazzo,\navere una ragazza come te che si innamora di lui in questo modo."

msgctxt "10||speech_list_caba_sora||table||193||||4"
msgid "He's a <font_kind=yakuza_italic>really</font_kind> good guy. That said,\nyou're pretty dense, Kiryu-san..."
msgstr "Lui è <font_kind=yakuza_italic>davvero</font_kind> un brav'uomo. Detto questo,\nsei piuttosto di coccio, Kiryu-san..."

msgctxt "10||speech_list_caba_sora||table||194||||4"
msgid "I am?"
msgstr "Lo sono?"

msgctxt "10||speech_list_caba_sora||table||195||||4"
msgid "Yup. But, that's what makes you so moe."
msgstr "Già. Ma è questo che ti rende così moe."

msgctxt "10||speech_list_caba_sora||table||196||||4"
msgid "I'm on fire..."
msgstr "Vado a fuoco..."

msgctxt "10||speech_list_caba_sora||table||197||||4"
msgid "Well, you'll find the answer eventually. If fate\nleads you back to Taiwan, you'll go back."
msgstr "Beh, alla fine troverai la risposta. Se il destino\nti riporterà a Taiwan, ci tornerai."

msgctxt "10||speech_list_caba_sora||table||198||||4"
msgid "You're right."
msgstr "Hai ragione."

msgctxt "10||speech_list_caba_sora||table||199||||4"
msgid "But, that said, love takes two. If you wait too\nlong, you'll only end up full of regret later."
msgstr "Ma detto questo, in amore si è in due. Se aspetti troppo,\nfinirai solo con l'essere piena di rimpianti più tardi."

msgctxt "10||speech_list_caba_sora||table||200||||4"
msgid "Kiryu-san, has that been your experience?"
msgstr "Kiryu-san, è andata così per tua esperienza personale?"

msgctxt "10||speech_list_caba_sora||table||201||||4"
msgid "I've just seen my share... so, if you really\nlike him, finding out how he feels is worthwhile."
msgstr "Ne ho semplicemente viste di tutti i colori... quindi, se ti\npiace davvero, vale la pena scoprire cosa prova."

msgctxt "10||speech_list_caba_sora||table||202||||4"
msgid "Tai'want to go to Taiwan, too."
msgstr "Taiwan...ta voglia di andarci anch'io."

msgctxt "10||speech_list_caba_sora||table||203||||4"
msgid "K-Kiryu-san...!?\nWas that a pun!?"
msgstr "K-Kiryu-san...!?\nEra un gioco di parole!?"

msgctxt "10||speech_list_caba_sora||table||204||||4"
msgid "Lame is what it was...\nBut I really would like to visit Taiwan."
msgstr "Pessimo, direi...\nMa mi piacerebbe davvero visitare Taiwan."

msgctxt "10||speech_list_caba_sora||table||205||||4"
msgid "The food is good and I hear they're on good terms\nwith Japan. I'd like to see it at least once."
msgstr "Il cibo è buono e sento dire che sono in buoni rapporti\ncol Giappone. Mi piacerebbe vederla almeno una volta."

msgctxt "10||speech_list_caba_sora||table||206||||4"
msgid "Really!? Then let's go sometime!\nI'll be your tour guide!"
msgstr "Davvero!? Allora andiamoci qualche volta!\nSarò la tua guida turistica!"

msgctxt "10||speech_list_caba_sora||table||207||||4"
msgid "Thanks. I'd need that."
msgstr "Grazie. Mi servirebbe."

msgctxt "10||speech_list_caba_sora||table||208||||4"
msgid "While we're on the subject... How do you feel\nabout Taiwan, Kiryu-san? Could you live there?"
msgstr "Visto che siamo in argomento... Che ne pensi\ndi Taiwan, Kiryu-san? Potresti viverci?"

msgctxt "10||speech_list_caba_sora||table||209||||4"
msgid "It would depend on the situation. If I had any\nunfinished business here, I'd need to stay."
msgstr "Dipenderebbe dalla situazione. Se avessi questioni\nin sospeso qui, dovrei restare."

msgctxt "10||speech_list_caba_sora||table||210||||4"
msgid "That said, if that wasn't the case, it wouldn't\nbe so bad to go overseas for a woman I loved."
msgstr "Detto questo, se non fosse così, non sarebbe male\nandare all'estero per la donna che amo."

msgctxt "10||speech_list_caba_sora||table||211||||4"
msgid "I see. Good point.\nI guess if I don't ask, I'll never know."
msgstr "Capisco. Giusto.\nImmagino che, se non glielo chiedo, non lo saprò mai."

msgctxt "10||speech_list_caba_sora||table||212||||4"
msgid "Thank you for that!\n...I feel like I'm finding my courage now!"
msgstr "Grazie per avermelo detto!\n...Sento di aver trovato il coraggio, adesso!"

msgctxt "10||speech_list_caba_sora||table||213||||4"
msgid "Good to hear, and glad I can support you."
msgstr "Mi fa piacere sentirlo, e sono felice di poterti supportare."

msgctxt "10||speech_list_caba_sora||table||214||||4"
msgid "Yeah... I have to say, though,\nyou're pretty dense, Kiryu-san..."
msgstr "Sì... Devo dire, però,\nche sei piuttosto di coccio, Kiryu-san..."

msgctxt "10||speech_list_caba_sora||table||215||||4"
msgid "Really? I'm trying to be sensitive here..."
msgstr "Davvero? Io cerco di essere comprensivo, qui..."

msgctxt "10||speech_list_caba_sora||table||216||||4"
msgid "Oh, are you?"
msgstr "Oh, davvero?"

msgctxt "10||speech_list_caba_sora||table||217||||4"
msgid "And you're funny, too...\nI'll never forget that pun!"
msgstr "E sei anche divertente...\nNon dimenticherò mai quel gioco di parole!"

msgctxt "10||speech_list_caba_sora||table||218||||4"
msgid "I wish you would, actually..."
msgstr "Preferirei che tu lo facessi, in realtà..."

msgctxt "10||speech_list_caba_sora||table||219||||4"
msgid "Kiryu-san, umm...\nDo you have some time after this?"
msgstr "Kiryu-san, ehm...\nHai un po' di tempo dopo il lavoro?"

msgctxt "10||speech_list_caba_sora||table||220||||4"
msgid "After this?\nI can make the time."
msgstr "Dopo il lavoro?\nPosso trovarlo."

msgctxt "10||speech_list_caba_sora||table||221||||4"
msgid "If you're up to it,\nwould you want to go out together?"
msgstr "Se te la senti,\nti andrebbe di uscire insieme?"

msgctxt "10||speech_list_caba_sora||table||222||||4"
msgid "Um... I have something I want to tell you..."
msgstr "Ehm... Ho qualcosa che voglio dirti..."

msgctxt "10||speech_list_caba_sora||table||223||||4"
msgid "To tell me? I don't mind going out,\nbut why can't you say it here?"
msgstr "Da dirmi? Non mi dispiace uscire,\nma perché non puoi dirmelo qui?"

msgctxt "10||speech_list_caba_sora||table||224||||4"
msgid "Well... I'd prefer somewhere with a\nlittle more atmosphere."
msgstr "Beh... Preferirei un posto con un\npo' più di atmosfera."

msgctxt "10||speech_list_caba_sora||table||225||||4"
msgid "Okay. How about we go somewhere\nwhere we can feel the night breeze?"
msgstr "D'accordo. Che ne dici di andare in un posto in\ncui possiamo godere della brezza notturna?"

msgctxt "10||speech_list_caba_sora||table||226||||4"
msgid "O-Okay! Thank you. <symbol=note_with_outline>"
msgstr "O-Okay! Grazie. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||227||||4"
msgid "Well, I'll see you later, then!"
msgstr "Beh, ci vediamo dopo, allora!"

msgctxt "10||speech_list_caba_sora||table||228||||4"
msgid "I'll text you the spot, but..."
msgstr "Ti manderò il posto per messaggio, ma..."

msgctxt "10||speech_list_caba_sora||table||229||||4"
msgid "Can you meet me around Theater Square?"
msgstr "Riesci a farti trovare nei pressi di Piazza del Teatro?"

msgctxt "10||speech_list_caba_sora||table||230||||4"
msgid "Sure, no problem."
msgstr "Certo, nessun problema."

msgctxt "10||speech_list_caba_sora||table||231||||4"
msgid "...I can't wait!"
msgstr "...Non vedo l'ora!"

msgctxt "10||speech_list_caba_sora||table||232||||4"
msgid "My main hobby is cosplay. I mostly dress up\nas video game or anime characters."
msgstr "Il mio hobby principale è il cosplay. Mi travesto per\nlo più da personaggi di videogiochi o anime."

msgctxt "10||speech_list_caba_sora||table||233||||4"
msgid "Wow, cosplay...\nIs it fun?"
msgstr "Wow, il cosplay...\nÈ divertente?"

msgctxt "10||speech_list_caba_sora||table||234||||4"
msgid "It is! It's especially fun to take video while\ndancing around in cosplay and put it up online."
msgstr "Lo è! È divertente in particolare riprendermi mentre\nballo in cosplay per metterlo online."

msgctxt "10||speech_list_caba_sora||table||235||||4"
msgid "You get to see all the reactions,\nand that really makes it."
msgstr "Vedi tutte le reazioni della gente,\ne questo è il massimo."

msgctxt "10||speech_list_caba_sora||table||236||||4"
msgid "Let's see... I go to the market a lot."
msgstr "Vediamo... Vado spesso al mercato."

msgctxt "10||speech_list_caba_sora||table||237||||4"
msgid "The market?\nAre you looking for good fish?"
msgstr "Il mercato?\nCerchi del buon pesce?"

msgctxt "10||speech_list_caba_sora||table||238||||4"
msgid "It's not a fish market! I go to buy loads\nof fresh fruit and vegetables."
msgstr "Non è un mercato del pesce! Ci vado per comprare\nun sacco di frutta e verdura fresca."

msgctxt "10||speech_list_caba_sora||table||239||||4"
msgid "I haven't been a hostess too long, actually.\nI'm still figuring it out."
msgstr "Non faccio la hostess da molto, a dire il vero.\nCi sto ancora prendendo la mano."

msgctxt "10||speech_list_caba_sora||table||240||||4"
msgid "I'm from Taipei, Taiwan.\nMy mom's Taiwanese and my dad's half Japanese."
msgstr "Vengo da Taipei, a Taiwan.\nMia mamma è taiwanese e mio papà è per metà giapponese."

msgctxt "10||speech_list_caba_sora||table||241||||4"
msgid "Oh, really?"
msgstr "Oh, davvero?"

msgctxt "10||speech_list_caba_sora||table||242||||4"
msgid "Yep. Tell me, Kiryu-san,\nwhat's your image of Taiwan?"
msgstr "Sì. Dimmi, Kiryu-san,\nche immagine hai di Taiwan?"

msgctxt "10||speech_list_caba_sora||table||243||||4"
msgid "Taiwan, huh?\nLet me think..."
msgstr "Taiwan, eh?\nFammi pensare..."

msgctxt "10||speech_list_caba_sora||table||244||||4"
msgid "The first thing that comes to\nmind is all the amazing food."
msgstr "La prima cosa che mi viene\nin mente è l'incredibile cibo."

msgctxt "10||speech_list_caba_sora||table||245||||4"
msgid "True, it's a great place to eat!"
msgstr "Vero, si mangia benissimo lì!"

msgctxt "10||speech_list_caba_sora||table||246||||4"
msgid "A friend I brought back to Taiwan with me once\nloved the dumplings so much, she inhaled 50 of them!"
msgstr "Un'amica che portai a Taiwan con me una volta adorò i\nravioli a tal punto da divorarsene 50!"

msgctxt "10||speech_list_caba_sora||table||247||||4"
msgid "I'd like to go sometime to\nget that authentic taste."
msgstr "Mi piacerebbe andarci, prima o poi,\nper assaggiare i sapori autentici."

msgctxt "10||speech_list_caba_sora||table||248||||4"
msgid "You should.\nI'll show you all the good restaurants. <symbol=note_with_outline>"
msgstr "Dovresti.\nTi mostrerò tutti i migliori ristoranti. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||249||||4"
msgid "I don't know much about it, but it seems\nlike it's really on the way up?"
msgstr "Non ne so molto, ma sembra\nche si stia espandendo velocemente?"

msgctxt "10||speech_list_caba_sora||table||250||||4"
msgid "Oh, \"on the way\" was a long time ago.\nIt's already amazing these days."
msgstr "Oh, \"espandendo\" risale a un bel po' di tempo fa.\nOggigiorno è già fantastica."

msgctxt "10||speech_list_caba_sora||table||251||||4"
msgid "In fact, Taipei is so prosperous now,\nit even rivals Tokyo."
msgstr "A dire il vero, Taipei ora è così fiorente\nche rivaleggia con Tokyo."

msgctxt "10||speech_list_caba_sora||table||252||||4"
msgid "Wow, that's news to me.\nI'd like to see for myself someday."
msgstr "Wow, questa mi è nuova.\nMi piacerebbe vederla con i miei occhi, un giorno."

msgctxt "10||speech_list_caba_sora||table||253||||4"
msgid "You should.\nI'll be your tour guide. <symbol=note_with_outline>"
msgstr "Dovresti.\nIo sarò la tua guida turistica. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||254||||4"
msgid "I imagine there's tons of cute girls there."
msgstr "Immagino che sia pieno di belle ragazze, da quelle parti."

msgctxt "10||speech_list_caba_sora||table||255||||4"
msgid "Aww, is that really your image of it?\nAlthough I guess when I think about it, it's true."
msgstr "Aww, è davvero questa l'immagine che ne hai?\nAnche se, a pensarci bene, credo sia vero."

msgctxt "10||speech_list_caba_sora||table||256||||4"
msgid "Speaking of cute girls,\nyou'd count me among them, right? <symbol=note_with_outline>"
msgstr "A proposito di belle ragazze,\nconteresti anche me tra loro, vero? <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||257||||4"
msgid "Yeah, of course."
msgstr "Sì, certo."

msgctxt "10||speech_list_caba_sora||table||258||||4"
msgid "Really!? That's nice to hear,\neven if you are just flattering me... <symbol=heart_with_outline>"
msgstr "Davvero!? È bello sentirselo dire,\nanche se mi stai solo adulando... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||259||||4"
msgid "Nah, not a chance."
msgstr "Nah, scordatelo."

msgctxt "10||speech_list_caba_sora||table||260||||4"
msgid "Whaaat? You didn't have to be savage about it...\nKiryu-san, you're mean."
msgstr "Cooosa? Non c'era bisogno di essere così crudele...\nKiryu-san, sei cattivo."

msgctxt "10||speech_list_caba_sora||table||261||||4"
msgid "Who can say?"
msgstr "Chi può dirlo?"

msgctxt "10||speech_list_caba_sora||table||262||||4"
msgid "Oh come on, you should say \"of course you are\"\neven if it's a lie... So stubborn, Kiryu-san."
msgstr "Oh andiamo, dovresti dire \"certo che lo sei\"\nanche se è una bugia... Sei proprio testardo, Kiryu-san."

msgctxt "10||speech_list_caba_sora||table||263||||4"
msgid "I like noodles.\nMy favorites are ramen and glass noodles."
msgstr "Mi piacciono i noodle.\nI miei preferiti sono il ramen e gli spaghetti di soia."

msgctxt "10||speech_list_caba_sora||table||264||||4"
msgid "I like a man who's really down to earth.\nAnd I love black hair, too."
msgstr "Mi piace un uomo che sia davvero con i piedi per terra.\nE adoro anche i capelli neri."

msgctxt "10||speech_list_caba_sora||table||265||||4"
msgid "I'm actually pretty sokubakki."
msgstr "In realtà sono un po' una sokubakki."

msgctxt "10||speech_list_caba_sora||table||266||||4"
msgid "S-Sokubakki...?\nWhat the heck?"
msgstr "S-Sokubakki...?\nE che diavolo sarebbe?"

msgctxt "10||speech_list_caba_sora||table||267||||4"
msgid "Is that some kind of new cookie?"
msgstr "È una specie di nuovo biscotto?"

msgctxt "10||speech_list_caba_sora||table||268||||4"
msgid "Not quite! Sokubakki refers to someone who's\ncontrolling. It's from the word <font_kind=yakuza_italic>sokubaku</font_kind>."
msgstr "Non esattamente! Sokubakki si riferisce a qualcuno che\nè possessivo. Deriva dalla parola <font_kind=yakuza_italic>sokubaku</font_kind>."

msgctxt "10||speech_list_caba_sora||table||269||||4"
msgid "I want the person I love to only\nhave eyes for me, as I would for them."
msgstr "Voglio che la persona che amo abbia\nocchi solo per me, come io li avrei per lui."

msgctxt "10||speech_list_caba_sora||table||270||||4"
msgid "I could see that.\nWell, that's how it works, ideally."
msgstr "Lo capisco.\nBeh, idealmente è così che funziona."

msgctxt "10||speech_list_caba_sora||table||271||||4"
msgid "Is that someone who's controlling,\nmaybe from the word <font_kind=yakuza_italic>sokubaku</font_kind>?"
msgstr "Sarebbe qualcuno che è possessivo,\nforse derivato dalla parola <font_kind=yakuza_italic>sokubaku</font_kind>?"

msgctxt "10||speech_list_caba_sora||table||272||||4"
msgid "Yes, exactly. The more their love grows,\nthe more restraints they put on their partner."
msgstr "Sì, esattamente. Più il loro amore cresce,\npiù pongono restrizioni al proprio partner."

msgctxt "10||speech_list_caba_sora||table||273||||4"
msgid "On the other hand,\nwe also tend to enjoy being controlled."
msgstr "D'altro canto,\nci piace anche essere controllate a nostra volta."

msgctxt "10||speech_list_caba_sora||table||274||||4"
msgid "Huh... So it's like consensual restrictions?"
msgstr "Mhm... Quindi sono tipo delle restrizioni consensuali?"

msgctxt "10||speech_list_caba_sora||table||275||||4"
msgid "I think it's ideal for people who want to\nbe mutually exclusive to each other."
msgstr "Penso che sia l'ideale per le persone che vogliono\nessere un'esclusiva reciproca l'uno per l'altra."

msgctxt "10||speech_list_caba_sora||table||276||||4"
msgid "\"Restriction\" has kind of a bad connotation,\nbut if you're both like that, it works out great."
msgstr "La parola \"restrizione\" ha un'accezione un po' negativa,\nma se siete entrambi così, funziona alla grande."

msgctxt "10||speech_list_caba_sora||table||277||||4"
msgid "Makes sense.\nI can see the logic in it."
msgstr "Ha senso.\nNe capisco la logica."

msgctxt "10||speech_list_caba_sora||table||278||||4"
msgid "I'm more of a kazumakki."
msgstr "Io sono più un kazumakki."

msgctxt "10||speech_list_caba_sora||table||279||||4"
msgid "Huh...? Oh...\nUh, sure."
msgstr "Eh...? Oh...\nEhm, certo."

msgctxt "10||speech_list_caba_sora||table||280||||4"
msgid "...Never mind."
msgstr "...Lascia perdere."

msgctxt "10||speech_list_caba_sora||table||281||||4"
msgid "I don't really have a concrete\nidea of what I want to do, but..."
msgstr "Non ho un'idea veramente concreta\ndi cosa voglio fare, ma..."

msgctxt "10||speech_list_caba_sora||table||282||||4"
msgid "...I'd like my family back in Taiwan\nto be able to see me working hard."
msgstr "...mi piacerebbe che la mia famiglia a Taiwan\npotesse vedermi lavorare sodo."

msgctxt "10||speech_list_caba_sora||table||283||||4"
msgid "I get that. You just want your family\nin Taiwan to be happy, right?"
msgstr "Lo capisco. Vuoi solo che la tua famiglia\na Taiwan sia felice, giusto?"

msgctxt "10||speech_list_caba_sora||table||284||||4"
msgid "Exactly. They're always so worried about\nwhether or not I'm getting by okay in Japan."
msgstr "Esattamente. Sono sempre così preoccupati che\nio riesca o meno a cavarmela bene in Giappone."

msgctxt "10||speech_list_caba_sora||table||285||||4"
msgid "If I could only show them how hard I'm working\nhere in Japan, I think they'd be able to relax."
msgstr "Se solo potessi mostrare loro quanto sto lavorando sodo\nqui in Giappone, penso che potrebbero mettersi il cuore in pace."

msgctxt "10||speech_list_caba_sora||table||286||||4"
msgid "That's a good dream."
msgstr "È un bel sogno."

msgctxt "10||speech_list_caba_sora||table||287||||4"
msgid "I've loved anime and Japanese video\ngames ever since I was little."
msgstr "Ho amato gli anime e i videogiochi giapponesi\nfin da quando ero piccola."

msgctxt "10||speech_list_caba_sora||table||288||||4"
msgid "So until about high school,\nmy dream was to learn magic."
msgstr "Quindi fino a circa le superiori,\nil mio sogno era imparare la magia."

msgctxt "10||speech_list_caba_sora||table||289||||4"
msgid "I've long since realized that's\nnot going to happen, though."
msgstr "Tuttavia ho capito da tempo\nche non succederà mai."

msgctxt "10||speech_list_caba_sora||table||290||||4"
msgid "You thought you could learn magic all the way to\nhigh school? You were an awkward kid, huh?"
msgstr "Pensavi di poter imparare la magia fino alle\nsuperiori? Eri una ragazzina un po' strana, eh?"

msgctxt "10||speech_list_caba_sora||table||291||||4"
msgid "Uh... I won't deny that..."
msgstr "Ehm... Non posso negarlo..."

msgctxt "10||speech_list_caba_sora||table||292||||4"
msgid "You've unlocked my tragic backstory!"
msgstr "Hai sbloccato il mio tragico passato!"

msgctxt "10||speech_list_caba_sora||table||293||||4"
msgid "Nothing's impossible.\nNever give up on your dreams."
msgstr "Niente è impossibile.\nNon rinunciare mai ai tuoi sogni."

msgctxt "10||speech_list_caba_sora||table||294||||4"
msgid "Wh-What's all this all of a sudden, Kiryu-san?\nYou got really passionate about that..."
msgstr "Ch-Che ti prende all'improvviso, Kiryu-san?\nTi sei proprio infervorato al riguardo..."

msgctxt "10||speech_list_caba_sora||table||295||||4"
msgid "Ah, maybe you're the type who gets\nreally fired up after a few drinks?"
msgstr "Ah, forse sei il tipo che si\ninfiamma davvero dopo qualche drink?"

msgctxt "10||speech_list_caba_sora||table||296||||4"
msgid "That's a cute dream."
msgstr "È un sogno carino."

msgctxt "10||speech_list_caba_sora||table||297||||4"
msgid "You think so?\nWhy, thank you. <symbol=note_with_outline>"
msgstr "Lo pensi davvero?\nMa grazie. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||298||||4"
msgid "Nothing I can show off,\nbut I am practicing something."
msgstr "Niente di cui potermi vantare,\nma sto facendo pratica con qualcosa."

msgctxt "10||speech_list_caba_sora||table||299||||4"
msgid "And what's that?"
msgstr "Sarebbe a dire?"

msgctxt "10||speech_list_caba_sora||table||300||||4"
msgid "I love horses, so when I'm alone in the bath,\nI practice my horse whinny practically every day."
msgstr "Adoro i cavalli, quindi quando sono sola nella vasca, mi esercito\nnel mio nitrito di cavallo praticamente ogni giorno."

msgctxt "10||speech_list_caba_sora||table||301||||4"
msgid "Huh. Horses?\nThat's cool."
msgstr "Oh. Cavalli?\nForte."

msgctxt "10||speech_list_caba_sora||table||302||||4"
msgid "Huh? No, I mean, I still have a long way to go."
msgstr "Eh? No, voglio dire, ho ancora molta strada da fare."

msgctxt "10||speech_list_caba_sora||table||303||||4"
msgid "Let's hear it then."
msgstr "Sentiamolo, allora."

msgctxt "10||speech_list_caba_sora||table||304||||4"
msgid "I-If you really want me to...\nOkay. Here I go."
msgstr "S-Se lo vuoi davvero...\nOkay. Ci provo."

msgctxt "10||speech_list_caba_sora||table||306||||4"
msgid "<font_kind=yakuza_italic>Horse whinnying</font_kind>"
msgstr "<font_kind=yakuza_italic>Nitrito di cavallo</font_kind>"

msgctxt "10||speech_list_caba_sora||table||307||||4"
msgid "H-How'd I do!?"
msgstr "C-Come sono andata!?"

msgctxt "10||speech_list_caba_sora||table||308||||4"
msgid "You may not want to do that in public..."
msgstr "Forse è meglio se eviti di farlo in pubblico..."

msgctxt "10||speech_list_caba_sora||table||309||||4"
msgid "What!? Was it that bad...?\nDo I need more practice?"
msgstr "Cosa!? Era così pessimo...?\nHo bisogno di più pratica?"

msgctxt "10||speech_list_caba_sora||table||310||||4"
msgid "Amazing...!\nIt's like I'm talking to a real horse."
msgstr "Incredibile...!\nÈ come se stessi parlando con un vero cavallo."

msgctxt "10||speech_list_caba_sora||table||311||||4"
msgid "Was it that good?"
msgstr "Era così bello?"

msgctxt "10||speech_list_caba_sora||table||312||||4"
msgid "To be honest, I thought it still needed a lot\nof work, but I'm feeling more confident now."
msgstr "Ad essere sincera, pensavo avesse ancora bisogno di molto\nlavoro, ma ora mi sento più sicura di me."

msgctxt "10||speech_list_caba_sora||table||313||||4"
msgid "Huh? Something interesting?\nLet me think..."
msgstr "Mhm? Qualcosa di interessante?\nFammi pensare..."

msgctxt "10||speech_list_caba_sora||table||314||||4"
msgid "Oh, this morning as I was brushing my teeth,\nI realized my mouth was foaming up with bubbles."
msgstr "Oh, stamattina mentre mi lavavo i denti,\nmi sono accorta di avere la bocca piena di schiuma."

msgctxt "10||speech_list_caba_sora||table||315||||4"
msgid "And when I say bubbles, I mean <font_kind=yakuza_italic>bubbles</font_kind>!"
msgstr "E quando dico schiuma, intendo <font_kind=yakuza_italic>un sacco di schiuma</font_kind>!"

msgctxt "10||speech_list_caba_sora||table||316||||4"
msgid "But then when I looked at my toothpaste, I realized\nI'd grabbed the face cleanser! How funny is that?"
msgstr "Ma poi, guardando il dentifricio, mi sono resa conto\ndi aver preso il detergente per il viso! Buffo, no?"

msgctxt "10||speech_list_caba_sora||table||317||||4"
msgid "That's good."
msgstr "È una buona storia."

msgctxt "10||speech_list_caba_sora||table||318||||4"
msgid "Right? <symbol=note_with_outline>\nI couldn't help but laugh."
msgstr "Vero? <symbol=note_with_outline>\nNon ho potuto fare a meno di ridere."

msgctxt "10||speech_list_caba_sora||table||319||||4"
msgid "No, that's not funny at all.\nIt could have been toxic..."
msgstr "No, non è affatto buffo.\nSarebbe potuto essere tossico..."

msgctxt "10||speech_list_caba_sora||table||320||||4"
msgid "Huh? Maybe you and I have\ndifferent ideas of humor, Kiryu-san..."
msgstr "Eh? Forse tu e io abbiamo idee\ndiverse sull'umorismo, Kiryu-san..."

msgctxt "10||speech_list_caba_sora||table||321||||4"
msgid "I guess I'd say I have not too many,\nbut not too few."
msgstr "Credo di poterne vantare non troppi,\nma nemmeno troppo pochi."

msgctxt "10||speech_list_caba_sora||table||322||||4"
msgid "When I first got here, I had a tough time making\nfriends but going to anime and game events really helped."
msgstr "Quando sono arrivata qui, ho faticato a farmi delle amicizie,\nma andare agli eventi di anime e videogiochi mi ha aiutato molto."

msgctxt "10||speech_list_caba_sora||table||323||||4"
msgid "Now I have tons of friends,\nand we all share the same hobbies."
msgstr "Ora ho un sacco di amici,\ne condividiamo tutti gli stessi hobby."

msgctxt "10||speech_list_caba_sora||table||324||||4"
msgid "Nice.\nThat's great."
msgstr "Bello.\nÈ fantastico."

msgctxt "10||speech_list_caba_sora||table||325||||4"
msgid "Yeah, I'm really thankful to anime and games.\nThey even helped me make friends."
msgstr "Sì, sono davvero grata agli anime e ai videogiochi.\nMi hanno persino aiutata a farmi degli amici."

msgctxt "10||speech_list_caba_sora||table||326||||4"
msgid "Yeah, I totally play games. My favorites\nare the ones where you raise cute monsters."
msgstr "Sì, gioco un sacco. I miei preferiti sono\nquelli in cui devi allevare dei mostri carini."

msgctxt "10||speech_list_caba_sora||table||327||||4"
msgid "Oh, and I've recently gotten into these romance\ngames aimed at men where you woo cute girls."
msgstr "Oh, e di recente mi sono appassionata ai giochi di\nappuntamenti per ragazzi in cui corteggi ragazze carine."

msgctxt "10||speech_list_caba_sora||table||328||||4"
msgid "Oh yeah? Wouldn't it be rare for a girl\nto play romance games for men?"
msgstr "Ah sì? Non è un po' raro che una ragazza\ngiochi ai giochi di appuntamenti per ragazzi?"

msgctxt "10||speech_list_caba_sora||table||329||||4"
msgid "How should I put this? I thought maybe it'd give\nme some insight into how men approach romance."
msgstr "Come dire? Ho pensato che potesse darmi qualche\nintuizione su come gli uomini si approcciano al romanticismo."

msgctxt "10||speech_list_caba_sora||table||330||||4"
msgid "But wouldn't that be a pretty bad reference?"
msgstr "Ma non è un pessimo punto di riferimento?"

msgctxt "10||speech_list_caba_sora||table||331||||4"
msgid "Huh? Really?\nHmm, so games won't work, either..."
msgstr "Eh? Davvero?\nMhm, quindi neanche i videogiochi andranno bene..."

msgctxt "10||speech_list_caba_sora||table||332||||4"
msgid "Romance games are probably the best reference."
msgstr "I giochi di appuntamenti sono probabilmente il miglior punto di riferimento."

msgctxt "10||speech_list_caba_sora||table||333||||4"
msgid "Thank you."
msgstr "Grazie."

msgctxt "10||speech_list_caba_sora||table||334||||4"
msgid "I knew these games would come in handy... <symbol=note_with_outline>"
msgstr "Sapevo che questi giochi mi sarebbero tornati utili... <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||335||||4"
msgid "Yeah. Those games are made with guys in mind.\nCould be more useful than some real life flings."
msgstr "Sì. Quei giochi sono realizzati pensando ai ragazzi.\nPotrebbero essere più utili di certe scappatelle reali."

msgctxt "10||speech_list_caba_sora||table||336||||4"
msgid "I see...!\nKiryu-san, do you play those games too?"
msgstr "Capisco...!\nKiryu-san, ci giochi anche tu?"

msgctxt "10||speech_list_caba_sora||table||337||||4"
msgid "Maybe, maybe not."
msgstr "Forse sì, forse no."

msgctxt "10||speech_list_caba_sora||table||338||||4"
msgid "As long as we're here,\nyou should woo me, too."
msgstr "Visto che siamo qui,\ndovresti corteggiare anche me."

msgctxt "10||speech_list_caba_sora||table||339||||4"
msgid "Huh? I-I couldn't...\nOut of the blue... <symbol=heart_with_outline>"
msgstr "Eh? I-Io non potrei...\nCosì, di punto in bianco... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||340||||4"
msgid "W-Well... after I finish the other three routes\nand I've learned the secret... Maybe I will... <symbol=heart_with_outline>"
msgstr "B-Beh... dopo aver finito le altre tre route e\naver scoperto il segreto... Forse lo farò... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||341||||4"
msgid "Huh? What is it?\nNow I'm curious."
msgstr "Eh? Di che si tratta?\nOra sono curiosa."

msgctxt "10||speech_list_caba_sora||table||342||||4"
msgid "Actually, I..."
msgstr "In realtà, io..."

msgctxt "10||speech_list_caba_sora||table||343||||4"
msgid "I used to be a taxi driver."
msgstr "Una volta facevo il tassista."

msgctxt "10||speech_list_caba_sora||table||344||||4"
msgid "Really? I wouldn't have expected that!\nYou should take me on a drive sometime!"
msgstr "Davvero? Non me lo sarei mai aspettata!\nDovresti portarmi a fare un giro in macchina qualche volta!"

msgctxt "10||speech_list_caba_sora||table||345||||4"
msgid "I'm from Taiwan."
msgstr "Vengo da Taiwan."

msgctxt "10||speech_list_caba_sora||table||346||||4"
msgid "[Huh? Really?]"
msgstr "[Eh? Davvero?]"

msgctxt "10||speech_list_caba_sora||table||347||||4"
msgid "Huh? Wh-What...?"
msgstr "Eh? C-Cosa...?"

msgctxt "10||speech_list_caba_sora||table||348||||4"
msgid "You didn't catch a word of that!\nLies will catch up to you, you know?"
msgstr "Non ne hai capito una parola!\nLe bugie hanno le gambe corte, lo sai, vero?"

msgctxt "10||speech_list_caba_sora||table||349||||4"
msgid "I'm broke right now..."
msgstr "Sono al verde al momento..."

msgctxt "10||speech_list_caba_sora||table||350||||4"
msgid "What!? D-Does that mean...\nYou can't pay your bill...?"
msgstr "Cosa!? S-Significa che...\nnon puoi pagare il conto...?"

msgctxt "10||speech_list_caba_sora||table||351||||4"
msgid "This is bad... H-Hold on.\nI'll go get some money from my purse."
msgstr "Questa non ci voleva... A-Aspetta un attimo.\nVado a prendere dei soldi dalla mia borsa."

msgctxt "10||speech_list_caba_sora||table||352||||4"
msgid "No, uh... Sorry.\nI was joking."
msgstr "No, ehm... Scusa.\nStavo scherzando."

msgctxt "10||speech_list_caba_sora||table||353||||4"
msgid "Huh...? A joke?"
msgstr "Eh...? Uno scherzo?"

msgctxt "10||speech_list_caba_sora||table||354||||4"
msgid "Whew. That's a relief...\nI'm glad you're not broke, Kiryu-san."
msgstr "Fiuuu. Che sollievo...\nSono contenta che tu non sia al verde, Kiryu-san."

msgctxt "10||speech_list_caba_sora||table||355||||4"
msgid "You're so gullible... Sorry."
msgstr "Sei così credulona... Scusa."

msgctxt "10||speech_list_caba_sora||table||356||||4"
msgid "Hm... I feel kind of uncomfortable\naround people with them. They can be scary."
msgstr "Mhm... Mi sento un po' a disagio vicino\nalle persone che li hanno. Fanno un po' paura."

msgctxt "10||speech_list_caba_sora||table||357||||4"
msgid "I can drink, but I'm a lightweight.\nI prefer to just sip plum wine."
msgstr "Posso bere, ma reggo poco.\nPreferisco semplicemente sorseggiare del vino di prugne."

msgctxt "10||speech_list_caba_sora||table||358||||4"
msgid "The Tojo Clan?\nIs that some kind of karate dojo or something?"
msgstr "Il Clan Tojo?\nÈ una specie di dojo di karate o qualcosa del genere?"

msgctxt "10||speech_list_caba_sora||table||359||||4"
msgid "Hmm. I've never heard of her.\nSorry."
msgstr "Mhm. Non ne ho mai sentito parlare.\nMi spiace."

msgctxt "10||speech_list_caba_sora||table||360||||4"
msgid "Huh? Oh, do tell!\nWhat kind of adventures have you had?"
msgstr "Eh? Oh, racconta!\nChe tipo di avventure hai avuto?"

msgctxt "10||speech_list_caba_sora||table||361||||4"
msgid "I've actually been shot before."
msgstr "In realtà mi hanno sparato in passato."

msgctxt "10||speech_list_caba_sora||table||362||||4"
msgid "What!? You mean with real bullets?\nYou're lucky to be alive, aren't you?"
msgstr "Cosa!? Intendi dire con proiettili veri?\nSei fortunato ad essere ancora vivo, vero?"

msgctxt "10||speech_list_caba_sora||table||363||||4"
msgid "I've fought in an arena before."
msgstr "Ho combattuto in un'arena in passato."

msgctxt "10||speech_list_caba_sora||table||364||||4"
msgid "An arena?\nYou mean like those video game tournaments?"
msgstr "Un'arena?\nIntendi come quei tornei di videogiochi?"

msgctxt "10||speech_list_caba_sora||table||365||||4"
msgid "No... Well, I guess it is kinda like that."
msgstr "No... Beh, immagino sia qualcosa del genere."

msgctxt "10||speech_list_caba_sora||table||366||||4"
msgid "I'm amazing at karaoke."
msgstr "Sono un mostro al karaoke."

msgctxt "10||speech_list_caba_sora||table||367||||4"
msgid "Oh? Amazing in what way?\nYou should take me sometime."
msgstr "Oh? In che senso un mostro?\nDovresti portarmici, qualche volta."

msgctxt "10||speech_list_caba_sora||table||368||||4"
msgid "You'll see when you get there."
msgstr "Lo capirai quando saremo lì."

msgctxt "10||speech_list_caba_sora||table||369||||4"
msgid "I'm good at making <font_kind=yakuza_italic>danzai</font_kind> noodles!"
msgstr "Sono brava a preparare i noodles <font_kind=yakuza_italic>danzai</font_kind>!"

msgctxt "10||speech_list_caba_sora||table||370||||4"
msgid "<font_kind=yakuza_italic>Danzai</font_kind> noodles?\nKinda like <font_kind=yakuza_italic>dandan</font_kind> noodles?"
msgstr "I noodles <font_kind=yakuza_italic>danzai</font_kind>?\nTipo i noodles <font_kind=yakuza_italic>dandan</font_kind>?"

msgctxt "10||speech_list_caba_sora||table||371||||4"
msgid "They're totally different!\n<font_kind=yakuza_italic>Danzai</font_kind> noodles are a Taiwanese specialty."
msgstr "Sono completamente diversi!\nI noodles <font_kind=yakuza_italic>danzai</font_kind> sono una specialità taiwanese."

msgctxt "10||speech_list_caba_sora||table||372||||4"
msgid "They're really light and go down easy."
msgstr "Sono molto leggeri e vanno giù che è un piacere."

msgctxt "10||speech_list_caba_sora||table||373||||4"
msgid "Huh... That does sound good."
msgstr "Mhm... Sembrano ottimi."

msgctxt "10||speech_list_caba_sora||table||374||||4"
msgid "I'm type B. I don't know if it's related,\nbut people always tell me I'm pretty easygoing."
msgstr "Sono di gruppo B. Non so se le cose siano collegate,\nma mi dicono sempre che sono una tipa alla mano."

msgctxt "10||speech_list_caba_sora||table||375||||4"
msgid "Geez, what would you even do if I told you?"
msgstr "Cavoli, cosa te ne faresti se te lo dicessi?"

msgctxt "10||speech_list_caba_sora||table||376||||4"
msgid "Nope. I had one until last year,\nbut we broke up."
msgstr "No. Ce l'avevo fino all'anno scorso,\nma ci siamo lasciati."

msgctxt "10||speech_list_caba_sora||table||377||||4"
msgid "That means now's your chance, Kiryu-san!"
msgstr "Significa che ora è la tua grande occasione, Kiryu-san!"

msgctxt "10||speech_list_caba_sora||table||378||||4"
msgid "What? O-Okay...!"
msgstr "Cosa? O-Okay...!"

msgctxt "10||speech_list_caba_sora||table||379||||4"
msgid "I actually had a bit of a complex\nabout being taller than most women."
msgstr "In realtà avevo un po' un complesso per\nil fatto di essere più alta della media."

msgctxt "10||speech_list_caba_sora||table||380||||4"
msgid "Then a friend told me that would work in my favor\nas a hostess, so I got into this line of work."
msgstr "Poi un'amica mi ha detto che la cosa avrebbe giocato a mio\nvantaggio come hostess, così ho intrapreso questo lavoro."

msgctxt "10||speech_list_caba_sora||table||381||||4"
msgid "It's working. You have a model's figure and you're \nbeautiful too, so you must be the one to beat here."
msgstr "E ha funzionato. Hai il fisico di una modella e sei anche \nbellissima, quindi devi essere tu quella da battere, qui."

msgctxt "10||speech_list_caba_sora||table||382||||4"
msgid "I'd be lying if I said no... <symbol=note_with_outline>"
msgstr "Mentirei se dicessi di no... <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||384||||4"
msgid "But thanks to this job, I don't feel nearly as\nself-conscious about my height anymore."
msgstr "Ma grazie a questo lavoro, non mi sento\npiù così in imbarazzo per la mia altezza."

msgctxt "10||speech_list_caba_sora||table||385||||4"
msgid "Nowadays, I'm glad I decided to become a hostess."
msgstr "Adesso, sono felice di aver deciso di fare la hostess."

msgctxt "10||speech_list_caba_sora||table||386||||4"
msgid "But in that case, wouldn't becoming a pro wrestler\nhave been a better choice than a hostess?"
msgstr "Ma in quel caso, non sarebbe stato meglio fare\nla pro wrestler piuttosto che la hostess?"

msgctxt "10||speech_list_caba_sora||table||387||||4"
msgid "No... I don't think I'd want to wrestle anyone."
msgstr "No... Non credo proprio che vorrei combattere con nessuno."

msgctxt "10||speech_list_caba_sora||table||388||||4"
msgid "How tall are you?"
msgstr "Quanto sei alta?"

msgctxt "10||speech_list_caba_sora||table||389||||4"
msgid "165 centimeters."
msgstr "165 centimetri."

msgctxt "10||speech_list_caba_sora||table||390||||4"
msgid "165? Is that even tall? \nSeems pretty short actually..."
msgstr "165? E sei considerata alta?\nMi sembri piuttosto bassina in realtà..."

msgctxt "10||speech_list_caba_sora||table||391||||4"
msgid "You're just built like a tree, Kiryu-san!"
msgstr "Sei tu a essere grande e grosso come un albero, Kiryu-san!"

msgctxt "10||speech_list_caba_sora||table||392||||4"
msgid "I was told the average is 155,\nso I'm on the taller end."
msgstr "Mi è stato detto che la media è 155,\nquindi io sono considerata alta."

msgctxt "10||speech_list_caba_sora||table||393||||4"
msgid "I see... I never paid much\nattention to stuff like that."
msgstr "Capisco... Non ho mai prestato\nmolta attenzione a questo genere di cose."

msgctxt "10||speech_list_caba_sora||table||394||||4"
msgid "Huh? You're the king, Kiryu-san!?"
msgstr "Eh? Sei il re, Kiryu-san!?"

msgctxt "10||speech_list_caba_sora||table||395||||4"
msgid "Yeah, I am. And as the king,\nyou have to do what I say, Sora."
msgstr "Sì, lo sono. E come re,\ndevi fare quello che ti dico io, Sora."

msgctxt "10||speech_list_caba_sora||table||396||||4"
msgid "B-By your leave!"
msgstr "A-Ai tuoi ordini!"

msgctxt "10||speech_list_caba_sora||table||397||||4"
msgid "Y-You're pretty good at this..."
msgstr "T-Te la cavi piuttosto bene..."

msgctxt "10||speech_list_caba_sora||table||398||||4"
msgid "I like a lot of Taiwanese tunes,\nbut I mostly end up listening to Japanese music."
msgstr "Mi piacciono un sacco le canzoni taiwanesi,\nma alla fine ascolto soprattutto musica giapponese."

msgctxt "10||speech_list_caba_sora||table||399||||4"
msgid "I just really love anime songs!\nYou should give them a shot, Kiryu-san."
msgstr "Adoro da impazzire le canzoni degli anime!\nDovresti dar loro una chance, Kiryu-san."

msgctxt "10||speech_list_caba_sora||table||400||||4"
msgid "I'm having fun, too! <symbol=note_with_outline>"
msgstr "Mi sto divertendo un mondo anch'io! <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||401||||4"
msgid "It has!\nWe have to take good care of ourselves!"
msgstr "È vero!\nDobbiamo aver cura di noi stessi!"

msgctxt "10||speech_list_caba_sora||table||402||||4"
msgid "I'm just happy to be the appetizer\nof choice then, Kiryu-san. <symbol=note_with_outline>"
msgstr "Allora sono felice di essere il tuo antipasto\npreferito, Kiryu-san. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||403||||4"
msgid "Hey, you shouldn't even joke about that.\nA lot of women would take you seriously."
msgstr "Ehi, non dovresti scherzarci su.\nMolte donne ti prenderebbero sul serio."

msgctxt "10||speech_list_caba_sora||table||404||||4"
msgid "Huh...? What's gotten into you!?"
msgstr "Eh...? Che ti prende!?"

msgctxt "10||speech_list_caba_sora||table||405||||4"
msgid "E-Even though I know you're joking,\nhearing you say it is still... I... <symbol=heart_with_outline>"
msgstr "A-Anche se so che stai scherzando,\nsentirtelo dire è pur sempre... Io... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||406||||4"
msgid "K-Keep it down, please!\nYou'll disturb the other customers..."
msgstr "A-Abbassa la voce, per favore!\nDisturberai gli altri clienti..."

msgctxt "10||speech_list_caba_sora||table||407||||4"
msgid "Yes, [hello]. <symbol=note_with_outline>"
msgstr "Sì, [ciao]. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||408||||4"
msgid "I didn't think you were that type of guy...\nAnd here I was just starting to like you, too."
msgstr "Non pensavo fossi quel tipo di ragazzo...\nE dire che cominciavi pure a piacermi."

msgctxt "10||speech_list_caba_sora||table||409||||4"
msgid "What? Uh, no... I meant..."
msgstr "Cosa? Ehm, no... Io intendevo..."

msgctxt "10||speech_list_caba_sora||table||410||||4"
msgid "Just kidding. <symbol=note_with_outline>"
msgstr "Stavo scherzando. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||411||||4"
msgid "......"
msgstr "......"

msgctxt "10||speech_list_caba_sora||table||412||||4"
msgid "Thank you.\nYou're pretty cute yourself."
msgstr "Grazie.\nAnche tu sei un bel bocconcino."

msgctxt "10||speech_list_caba_sora||table||413||||4"
msgid "I'll take the compliment!"
msgstr "Accetto il complimento!"

msgctxt "10||speech_list_caba_sora||table||414||||4"
msgid "Huh...? What?\nCould you say that again?"
msgstr "Eh...? Cosa?\nPotresti ripeterlo?"

msgctxt "10||speech_list_caba_sora||table||415||||4"
msgid "[Beautiful eyes...]"
msgstr "[Begli occhi...]"

msgctxt "10||speech_list_caba_sora||table||416||||4"
msgid "[Oh, thank you.] <symbol=note_with_outline>"
msgstr "[Oh, grazie.] <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||417||||4"
msgid "[Perfect nose...]"
msgstr "[Naso perfetto...]"

msgctxt "10||speech_list_caba_sora||table||418||||4"
msgid "Oh, I think that means \"perfect nose\"!"
msgstr "Oh, penso significhi \"naso perfetto\"!"

msgctxt "10||speech_list_caba_sora||table||419||||4"
msgid "I actually like my nose quite a bit,\nso, thank you. <symbol=note_with_outline>"
msgstr "In effetti il mio naso mi piace molto,\nquindi grazie. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||420||||4"
msgid "[Marvelous mouth...]"
msgstr "[Bocca meravigliosa...]"

msgctxt "10||speech_list_caba_sora||table||421||||4"
msgid "That's the first time anyone's\never complimented my mouth. Thank you. <symbol=note_with_outline>"
msgstr "È la prima volta che qualcuno mi fa\ndei complimenti per la bocca. Grazie. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||422||||4"
msgid "No problem. <symbol=note_with_outline>"
msgstr "Nessun problema. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||423||||4"
msgid "You don't have to tell me twice.\nI want to keep looking at you forever... <symbol=heart_with_outline>"
msgstr "Non devi dirmelo due volte.\nVoglio continuare a guardarti per sempre... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||424||||4"
msgid "Hmm... It's a secret... <symbol=note_with_outline>"
msgstr "Mhm... È un segreto... <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||425||||4"
msgid "Who could say? <symbol=note_with_outline>"
msgstr "Chi può dirlo? <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||426||||4"
msgid "Come on, don't be coy now."
msgstr "Suvvia, non fare la timida adesso."

msgctxt "10||speech_list_caba_sora||table||427||||4"
msgid "No way. <symbol=note_with_outline>\nMy lips are sealed, Kiryu-san! <symbol=heart_with_outline>"
msgstr "Non se ne parla. <symbol=note_with_outline>\nLe mie labbra sono cucite, Kiryu-san! <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||428||||4"
msgid "Burns hurt, so I don't want that."
msgstr "Le ustioni fanno male, quindi passo."

msgctxt "10||speech_list_caba_sora||table||429||||4"
msgid "Okay, I guess I better get\na bucket of cold water ready."
msgstr "Okay, mi sa che mi conviene\npreparare un secchio d'acqua fredda."

msgctxt "10||speech_list_caba_sora||table||430||||4"
msgid "Everyone will be happy to hear that!"
msgstr "Tutti saranno felici di sentirlo!"

msgctxt "10||speech_list_caba_sora||table||431||||4"
msgid "I go to Chinese places a lot."
msgstr "Vado spesso nei locali cinesi."

msgctxt "10||speech_list_caba_sora||table||432||||4"
msgid "<font_kind=yakuza_italic>Those</font_kind> kinds of shops? Specifically?"
msgstr "<font_kind=yakuza_italic>Quei</font_kind> tipi di locali? Per la precisione?"

msgctxt "10||speech_list_caba_sora||table||433||||4"
msgid "You might say they're... uh...\nplaces where men go to relax..."
msgstr "Potresti dire che sono... ehm...\nposti dove gli uomini vanno per rilassarsi..."

msgctxt "10||speech_list_caba_sora||table||434||||4"
msgid "Y'know... the women there dress up\nas nurses or police officers, and..."
msgstr "Sai... le ragazze lì si travestono\nda infermiere o da poliziotte, e..."

msgctxt "10||speech_list_caba_sora||table||435||||4"
msgid "Oh! They're cosplaying!?"
msgstr "Oh! Fanno cosplay!?"

msgctxt "10||speech_list_caba_sora||table||436||||4"
msgid "What?"
msgstr "Cosa?"

msgctxt "10||speech_list_caba_sora||table||437||||4"
msgid "You meant cosplay restaurants, right!?\nIn that case, leave it to me!"
msgstr "Intendevi i maid café a tema cosplay, giusto!?\nIn questo caso, lascia fare a me!"

msgctxt "10||speech_list_caba_sora||table||438||||4"
msgid "When it comes to cosplay restaurants,\nnobody can show you better ones than me. <symbol=note_with_outline>"
msgstr "Quando si tratta di questo genere di locali,\nnessuno li conosce meglio di me. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||439||||4"
msgid "R-Right..."
msgstr "C-Certo..."

msgctxt "10||speech_list_caba_sora||table||440||||4"
msgid "You went that wild?\nI'm amazed you didn't get arrested!"
msgstr "Hai fatto così tanto casino?\nMi stupisce che non ti abbiano arrestato!"

msgctxt "10||speech_list_caba_sora||table||441||||4"
msgid "Everyone makes mistakes now and then."
msgstr "A tutti capita di sbagliare, di tanto in tanto."

msgctxt "10||speech_list_caba_sora||table||442||||4"
msgid "My grandpa said that what's important is whether\nor not you can bear the weight of your actions."
msgstr "Mio nonno diceva che ciò che conta è se\nriesci a sopportare o meno il peso delle tue azioni."

msgctxt "10||speech_list_caba_sora||table||443||||4"
msgid "Your grandpa said that?\nActually, that's pretty good."
msgstr "L'ha detto tuo nonno?\nA dire il vero, è una gran bella frase."

msgctxt "10||speech_list_caba_sora||table||444||||4"
msgid "Yeah. I love my grandpa."
msgstr "Già. Voglio tanto bene a mio nonno."

msgctxt "10||speech_list_caba_sora||table||445||||4"
msgid "That's so sad... but I'm sure he's up in heaven\njust happy that you still think about him."
msgstr "È così triste... Ma sono certa che in paradiso sarà\nfelice di sapere che pensi ancora a lui."

msgctxt "10||speech_list_caba_sora||table||446||||4"
msgid "Honestly, I think it's different for everyone."
msgstr "Onestamente, penso sia diverso per ciascuno."

msgctxt "10||speech_list_caba_sora||table||447||||4"
msgid "Really? I'm surprised. I imagine most babies\nwould start crying the moment you picked them up."
msgstr "Davvero? Ne sono sorpresa. Immaginavo che la maggior\nparte dei bambini scoppierebbe a piangere appena li prendi in braccio."

msgctxt "10||speech_list_caba_sora||table||448||||4"
msgid "Wait a sec, that's not very nice.\nI'm practically a diaper master now."
msgstr "Aspetta un attimo, non è molto carino da dire.\nSono praticamente un maestro del cambio pannolini, ormai."

msgctxt "10||speech_list_caba_sora||table||449||||4"
msgid "You go fishing? That's so manly and cool. <symbol=note_with_outline>\nI kind of want to watch you fish, Kiryu-san."
msgstr "Vai a pesca? È una cosa così virile e fica. <symbol=note_with_outline>\nUn po' mi piacerebbe vederti pescare, Kiryu-san."

msgctxt "10||speech_list_caba_sora||table||450||||4"
msgid "You sound like the protagonist of an anime.\nThat's so cool! <symbol=note_with_outline>"
msgstr "Sembri il protagonista di un anime.\nChe figata! <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||451||||4"
msgid "You do have kind of an aura around you, Kiryu-san.\nI'm sure you stand out to those guys."
msgstr "In effetti emani una certa aura, Kiryu-san.\nSono sicura che salti all'occhio di quei tipi."

msgctxt "10||speech_list_caba_sora||table||452||||4"
msgid "I'm sure everyone's just jealous\nof how handsome you are... <symbol=heart_with_outline>"
msgstr "Sono certa che siano solo tutti gelosi\ndi quanto sei bello... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||453||||4"
msgid "Oh, is that all it is?\nThose petty punks."
msgstr "Oh, dici che è solo per quello?\nChe teppistelli meschini."

msgctxt "10||speech_list_caba_sora||table||454||||4"
msgid "Oh, I know that! Back in high school,\nI used to race against the boys in my class."
msgstr "Oh, quello lo conosco! Alle superiori\ngareggiavo sempre contro i ragazzi della mia classe."

msgctxt "10||speech_list_caba_sora||table||455||||4"
msgid "Really? No wonder.\nYour muscle definition hadn't escaped me. <symbol=heart_with_outline>"
msgstr "Davvero? Non mi sorprende affatto.\nI tuoi muscoli ben definiti non mi erano sfuggiti. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||456||||4"
msgid "Then let's take our drinks nice and slow today."
msgstr "Allora oggi sorseggeremo i nostri drink con calma."

msgctxt "10||speech_list_caba_sora||table||457||||4"
msgid "You're like a cute horse grazing in the grass. <symbol=note_with_outline>"
msgstr "Sembri un simpatico cavallino che bruca l'erba. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||458||||4"
msgid "If you're an herbivore, then I'll\nbe the grass... or something to that effect. <symbol=heart_with_outline>"
msgstr "Se tu sei un erbivoro, allora io\nsarò l'erba... o qualcosa del genere. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||459||||4"
msgid "I'm the same way, actually."
msgstr "In realtà, anche per me è lo stesso."

msgctxt "10||speech_list_caba_sora||table||460||||4"
msgid "I was actually a little\nnervous when we met, Kiryu-san."
msgstr "A dire il vero ero un po'\nnervosa quando ci siamo conosciuti, Kiryu-san."

msgctxt "10||speech_list_caba_sora||table||461||||4"
msgid "I never noticed."
msgstr "Non ci avevo fatto caso."

msgctxt "10||speech_list_caba_sora||table||462||||4"
msgid "Wow, that's amazing.\nDoes that mean you're rich, Kiryu-san?"
msgstr "Wow, è incredibile.\nQuesto significa che sei ricco, Kiryu-san?"

msgctxt "10||speech_list_caba_sora||table||463||||4"
msgid "Hm... About 35?"
msgstr "Mhm... Sui 35?"

msgctxt "10||speech_list_caba_sora||table||464||||4"
msgid "You're way off!\nI'm well past 40."
msgstr "Sei fuori strada!\nHo superato i 40 da un pezzo."

msgctxt "10||speech_list_caba_sora||table||465||||4"
msgid "What!? R-Really?\nYou don't look it at all."
msgstr "Cosa!? D-Davvero?\nNon li dimostri affatto."

msgctxt "10||speech_list_caba_sora||table||466||||4"
msgid "Um... Do you have any secrets\nthat keep you looking so young?"
msgstr "Ehm... Hai qualche segreto\nche ti fa sembrare così giovane?"

msgctxt "10||speech_list_caba_sora||table||467||||4"
msgid "No matter how old you are,\nnever stop loving."
msgstr "Per quanto vecchio tu sia,\nnon smettere mai di amare."

msgctxt "10||speech_list_caba_sora||table||468||||4"
msgid "You're a real cheesy romantic... <symbol=note_with_outline>\nBut, love really is the best. <symbol=heart_with_outline>"
msgstr "Sei proprio un romanticone smielato... <symbol=note_with_outline>\nMa in effetti l'amore è la cosa migliore. <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||469||||4"
msgid "I can only think of one thing that became a\ndaily routine, and that's getting into fights."
msgstr "Mi viene in mente solo una cosa diventata una vera e\npropria routine quotidiana: finire in mezzo alle risse."

msgctxt "10||speech_list_caba_sora||table||470||||4"
msgid "Huh!? Th-Then, starting tomorrow,\nI'm going to<symbol=em_dash_with_outline>"
msgstr "Eh!? A-Allora, a partire da domani,\ninizierò a<symbol=em_dash_with_outline>"

msgctxt "10||speech_list_caba_sora||table||471||||4"
msgid "H-Hey... Let's not get hasty..."
msgstr "E-Ehi... Non affrettiamo le cose..."

msgctxt "10||speech_list_caba_sora||table||472||||4"
msgid "Well, at the end of day,\nit all comes back to collagen."
msgstr "Beh, alla fin fine,\ntutto si riduce al collagene."

msgctxt "10||speech_list_caba_sora||table||473||||4"
msgid "Huh!? Kiryu-san!? You take collagen...?\nThat's not what I expected."
msgstr "Eh!? Kiryu-san!? Tu assumi il collagene...?\nNon me l'aspettavo proprio."

msgctxt "10||speech_list_caba_sora||table||474||||4"
msgid "Huh? You? Let's seeeee...\nI think you're a good person."
msgstr "Eh? Tu? Vediamoooo...\nPenso che tu sia una brava persona."

msgctxt "10||speech_list_caba_sora||table||475||||4"
msgid "I think that despite your looks,\nyou're actually a great guy. <symbol=note_with_outline>"
msgstr "Penso che, a dispetto del tuo aspetto,\ntu sia davvero un grand'uomo. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||476||||4"
msgid "Huh? U-Um...\nI think you're really manly... <symbol=heart_with_outline>"
msgstr "Eh? E-Ehm...\nPenso che tu sia molto virile... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||477||||4"
msgid "I like older men."
msgstr "Mi piacciono gli uomini più grandi."

msgctxt "10||speech_list_caba_sora||table||478||||4"
msgid "Most older guys are a little more collected,\nand they have a mature sexiness about them... <symbol=heart_with_outline>"
msgstr "La maggior parte dei ragazzi più grandi è un po' più posata,\ne ha una sorta di fascino maturo... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||479||||4"
msgid "Thanks."
msgstr "Grazie."

msgctxt "10||speech_list_caba_sora||table||480||||4"
msgid "I didn't say <font_kind=yakuza_italic>you</font_kind> specifically, Kiryu-san."
msgstr "Non mi stavo riferendo nello specifico a <font_kind=yakuza_italic>te</font_kind>, Kiryu-san."

msgctxt "10||speech_list_caba_sora||table||481||||4"
msgid "Although, I guess you would\nfall in that category... <symbol=heart_with_outline>"
msgstr "Anche se, immagino che tu rientreresti\npienamente in questa categoria... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||482||||4"
msgid "But the older they are,\nthe older they smell."
msgstr "Ma più invecchiano,\npiù sanno di stantio."

msgctxt "10||speech_list_caba_sora||table||483||||4"
msgid "What did my dreams ever do to you...?"
msgstr "Che cosa ti hanno mai fatto di male i miei sogni...?"

msgctxt "10||speech_list_caba_sora||table||484||||4"
msgid "You're really sexy, too."
msgstr "Anche tu sei davvero sexy."

msgctxt "10||speech_list_caba_sora||table||485||||4"
msgid "Oh, you think so? <symbol=note_with_outline>"
msgstr "Oh, lo pensi davvero? <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||486||||4"
msgid "This probably isn't a fetish, but seeing someone\nchowing down their food gets me a little excited."
msgstr "Probabilmente non è un vero feticismo, ma vedere qualcuno\ndivorare il proprio pasto mi fa sempre un certo effetto."

msgctxt "10||speech_list_caba_sora||table||487||||4"
msgid "Then I can brush a stray grain of rice\noff their cheek and... <symbol=heart_with_outline>"
msgstr "Poi potrei togliergli un chicco di riso disperso\nsulla guancia e... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||488||||4"
msgid "What I want the most?\nLet's see... Oh, I want a sewing machine."
msgstr "Cosa desidero di più?\nVediamo... Oh, vorrei una macchina da cucire."

msgctxt "10||speech_list_caba_sora||table||489||||4"
msgid "Huh. Kinda mundane, isn't it?\nWhy's that?"
msgstr "Oh. Una cosa piuttosto banale, non trovi?\nCome mai?"

msgctxt "10||speech_list_caba_sora||table||490||||4"
msgid "I want to sew my own cosplays, of course."
msgstr "Voglio cucirmi i miei cosplay da sola, ovviamente."

msgctxt "10||speech_list_caba_sora||table||491||||4"
msgid "So right now I'm keeping an eye for machines\nthat are easy for beginners."
msgstr "Quindi in questo momento sto tenendo d'occhio le macchine\npiù adatte e facili da usare per i principianti."

msgctxt "10||speech_list_caba_sora||table||492||||4"
msgid "I get that. I guess it would be more fun to wear\na costume you actually made by yourself."
msgstr "Lo capisco. Credo sia molto più divertente indossare\nun costume che hai realizzato con le tue stesse mani."

msgctxt "10||speech_list_caba_sora||table||493||||4"
msgid "I think so, too! It's probably going to\nbe a time sink, but I'm excited to try. <symbol=note_with_outline>"
msgstr "Lo penso anch'io! Probabilmente richiederà un sacco\ndi tempo, ma sono entusiasta all'idea di provarci. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||494||||4"
msgid "My first love lives on\nin my heart to this day! <symbol=heart_with_outline>"
msgstr "Il mio primo amore vive ancora oggi\nnel mio cuore! <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||495||||4"
msgid "His beautiful, straight, silver hair cascades down\nto his waist, and his sword is longer than he is."
msgstr "I suoi bellissimi e lisci capelli argentati gli scendono a cascata\nfino alla vita, e la sua spada è più lunga di lui."

msgctxt "10||speech_list_caba_sora||table||496||||4"
msgid "Sounds like a dangerous guy.\nYou hang out in those crowds?"
msgstr "Sembra un tipo pericoloso.\nTu frequenti quelle brutte compagnie?"

msgctxt "10||speech_list_caba_sora||table||497||||4"
msgid "Yup. He's the villain of an RPG\nI played when I was younger. <symbol=note_with_outline>"
msgstr "Sì. È l'antagonista di un RPG a cui ho giocato\nquando ero più piccola. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||498||||4"
msgid "O-Oh..."
msgstr "O-Oh..."

msgctxt "10||speech_list_caba_sora||table||499||||4"
msgid "What color would you want them to be?"
msgstr "Di che colore vorresti che fossero?"

msgctxt "10||speech_list_caba_sora||table||500||||4"
msgid "White, I guess...?"
msgstr "Bianchi, immagino...?"

msgctxt "10||speech_list_caba_sora||table||501||||4"
msgid "Then I'm sure you'd be happy... <symbol=heart_with_outline>"
msgstr "Allora sono certa che ne sarai felice... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||502||||4"
msgid "Oh...!"
msgstr "Oh...!"

msgctxt "10||speech_list_caba_sora||table||503||||4"
msgid "Black, I guess..."
msgstr "Neri, credo..."

msgctxt "10||speech_list_caba_sora||table||504||||4"
msgid "Oh, too bad. My black ones\nare in the laundry right now..."
msgstr "Oh, peccato. I miei slip neri\nsono a lavare, in questo momento..."

msgctxt "10||speech_list_caba_sora||table||505||||4"
msgid "I see..."
msgstr "Capisco..."

msgctxt "10||speech_list_caba_sora||table||506||||4"
msgid "None would be nice..."
msgstr "Senza sarebbe il massimo..."

msgctxt "10||speech_list_caba_sora||table||507||||4"
msgid "What? Come on, Kiryu-san.\nThat's just unsanitary."
msgstr "Cosa? Dai, Kiryu-san.\nÈ proprio antigienico."

msgctxt "10||speech_list_caba_sora||table||508||||4"
msgid "I do think I'd like to get married, someday. <symbol=note_with_outline>"
msgstr "Sì, mi piacerebbe sposarmi, un giorno. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||509||||4"
msgid "Oh, thank you. <symbol=note_with_outline>"
msgstr "Oh, grazie. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||510||||4"
msgid "My skin's nice today,\nso I nailed my makeup, too. <symbol=note_with_outline>"
msgstr "Oggi la mia pelle è bellissima,\nquindi mi sono truccata alla perfezione. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||511||||4"
msgid "What? Hmm... Hmmm... Oh, I know!"
msgstr "Cosa? Mhm... Mhmmm... Oh, lo so!"

msgctxt "10||speech_list_caba_sora||table||512||||4"
msgid "There was a guy groping people at the Taiwan\nairport this one time... Was that you, Kiryu-san?"
msgstr "Una volta c'era un tizio che palpava la gente all'aeroporto\ndi Taiwan... Eri forse tu, Kiryu-san?"

msgctxt "10||speech_list_caba_sora||table||513||||4"
msgid "Wrong guy..."
msgstr "Hai sbagliato persona..."

msgctxt "10||speech_list_caba_sora||table||514||||4"
msgid "[Thank you.] <symbol=note_with_outline>"
msgstr "[Grazie.] <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||515||||4"
msgid "I definitely wouldn't want it to happen to me.\nI'd have to break up with a guy I couldn't trust."
msgstr "Di certo non vorrei mai che capitasse a me. Sarei\ncostretta a rompere con un ragazzo di cui non posso fidarmi."

msgctxt "10||speech_list_caba_sora||table||516||||4"
msgid "So Kiryu-san, you'd better not cheat on me, okay?"
msgstr "Perciò Kiryu-san, ti conviene non tradirmi mai, intesi?"

msgctxt "10||speech_list_caba_sora||table||517||||4"
msgid "Y-Yeah..."
msgstr "S-Sì..."

msgctxt "10||speech_list_caba_sora||table||518||||4"
msgid "Oh, in that case, I recommend going to\na farm or walking around a market. It's fun!"
msgstr "Oh, in questo caso, ti consiglio di andare a visitare una fattoria\no di fare un giro al mercato. È divertente!"

msgctxt "10||speech_list_caba_sora||table||519||||4"
msgid "It'd be nice to relax with an\nanime or video game together. <symbol=note_with_outline>"
msgstr "Sarebbe bello rilassarsi guardando un anime\no giocando a un videogioco insieme. <symbol=note_with_outline>"

msgctxt "10||speech_list_caba_sora||table||520||||4"
msgid "Yep, you're right!\nI was on the dance team up through high school."
msgstr "Sì, hai indovinato!\nHo fatto parte del club di danza fino al liceo."

msgctxt "10||speech_list_caba_sora||table||521||||4"
msgid "Huh!? I-I wouldn't mind, but..."
msgstr "Eh!? N-Non mi dispiacerebbe affatto, ma..."

msgctxt "10||speech_list_caba_sora||table||522||||4"
msgid "By the way, Kiryu-san, what team are you on?"
msgstr "A proposito, Kiryu-san, tu in che squadra stai?"

msgctxt "10||speech_list_caba_sora||table||523||||4"
msgid "What? O-Oh, you mean do I wear boxers or briefs?"
msgstr "Cosa? O-Oh, mi stai chiedendo se indosso boxer o slip?"

msgctxt "10||speech_list_caba_sora||table||524||||4"
msgid "Yep. Which is it?"
msgstr "Già. Cosa preferisci?"

msgctxt "10||speech_list_caba_sora||table||525||||4"
msgid "Hmm. I..."
msgstr "Mhm. Io..."

msgctxt "10||speech_list_caba_sora||table||526||||4"
msgid "I wear boxers."
msgstr "Io indosso i boxer."

msgctxt "10||speech_list_caba_sora||table||527||||4"
msgid "I see. Some guys wear those I guess."
msgstr "Capisco. Immagino che alcuni ragazzi li usino."

msgctxt "10||speech_list_caba_sora||table||528||||4"
msgid "I wear a fundoshi."
msgstr "Io indosso il fundoshi."

msgctxt "10||speech_list_caba_sora||table||529||||4"
msgid "Wow, you're such a traditional Japanese man.\nHow wonderful... <symbol=heart_with_outline>"
msgstr "Wow, sei un uomo giapponese così tradizionale.\nChe meraviglia... <symbol=heart_with_outline>"

msgctxt "10||speech_list_caba_sora||table||530||||4"
msgid "All I need is a leaf."
msgstr "Tutto ciò che mi serve è una foglia."

msgctxt "10||speech_list_caba_sora||table||531||||4"
msgid "Huh? Isn't that a little too wacky?\nI guess it is ecological, but..."
msgstr "Eh? Non è un'idea un po' troppo stramba?\nCerto, sarà anche ecologico, ma..."

msgctxt "10||speech_list_caba_sora||table||532||||4"
msgid "I don't think we have miso soup on the menu..."
msgstr "Non credo che la zuppa di miso sia sul menu..."

msgctxt "10||speech_list_caba_sora||table||533||||4"
msgid "You sound like an old man. Saying that kind of\nstuff is just going to make you age faster."
msgstr "Sembri proprio un vecchietto. Dire cose del genere\nnon farà altro che farti invecchiare prima del tempo."

msgctxt "10||speech_list_caba_sora||table||534||||4"
msgid "I just go down the top-ranked anime\nsongs and sing a whole bunch."
msgstr "Scorro semplicemente tra le canzoni anime in\ncima alle classifiche e ne canto un mucchio."

msgctxt "10||speech_list_caba_sora||table||535||||4"
msgid "That's not my type at all!"
msgstr "Quello non è affatto il mio tipo!"

msgctxt "10||speech_list_caba_sora||table||536||||4"
msgid "He has an eyepatch and a tattoo of a <font_kind=yakuza_italic>hannya</font_kind>?\nIncredible! I bet he's a great cosplayer!"
msgstr "Ha una benda sull'occhio e un tatuaggio di un' <font_kind=yakuza_italic>hannya</font_kind>?\nIncredibile! Scommetto che è un ottimo cosplayer!"

msgctxt "10||speech_list_caba_sora||table||537||||4"
msgid "Well... If only it were cosplay..."
msgstr "Beh... Se solo fosse un cosplay..."

msgctxt "10||speech_list_caba_sora||table||538||||4"
msgid "Wow, he's a detective?\nThat's so cool!"
msgstr "Wow, è un detective?\nChe figata!"

msgctxt "10||speech_list_caba_sora||table||539||||4"
msgid "He's president of a company?\nSounds like a hotshot!"
msgstr "È il presidente di un'azienda?\nSembra un pezzo grosso!"

msgctxt "10||speech_list_caba_sora||table||540||||4"
msgid "Whoa... He's done hard time?\nKiryu-san, you know some strange people."
msgstr "Whoa... È stato in prigione?\nKiryu-san, conosci proprio gente strana."

msgctxt "10||speech_list_caba_sora||table||541||||4"
msgid "Wow. You really trust him,\ndon't you, Kiryu-san?"
msgstr "Wow. Ti fidi proprio di lui,\nnon è vero, Kiryu-san?"

msgctxt "10||speech_list_caba_sora||table||542||||4"
msgid "Oh, that port town in Hiroshima?\nWasn't there a TV drama set there a while back?"
msgstr "Oh, quella cittadina portuale a Hiroshima?\nNon ci hanno girato una serie TV qualche tempo fa?"

msgctxt "10||speech_list_caba_sora||table||543||||4"
msgid "Oh, was there?"
msgstr "Oh, dici sul serio?"

msgctxt "10||speech_list_caba_sora||table||544||||4"
msgid "Yeah, it's a really scenic town, right?"
msgstr "Sì, è un posto davvero pittoresco, vero?"

msgctxt "11||speech_list_cln||table||0||||4"
msgid "Yo! Hold up a sec, old man!"
msgstr "Ehi! Aspetta un secondo, vecchio!"

msgctxt "11||speech_list_cln||table||1||||4"
msgid "Can I help you?"
msgstr "Posso aiutarvi?"

msgctxt "11||speech_list_cln||table||2||||4"
msgid "Damn right. I'm in a real tight spot right now.\nHow 'bout you lend me your wallet for a bit?"
msgstr "Puoi dirlo forte. Sono in un bel guaio in questo momento.\nChe ne dici di prestarmi un po' il tuo portafoglio?"

msgctxt "11||speech_list_cln||table||3||||4"
msgid "I'm not sure about that.\nDoesn't sound like you'll be giving it back."
msgstr "Non saprei.\nNon sembra proprio che me lo restituiresti."

msgctxt "11||speech_list_cln||table||4||||4"
msgid "Huh? I'm done playin' nice, asshole!\nGimme your goddamn money!"
msgstr "Cosa? Ho finito di fare il gentile, stronzo!\nDammi i tuoi fottuti soldi!"

msgctxt "11||speech_list_cln||table||5||||4"
msgid "S-Seriously!? I don't get it...\nHow'd this old dude beat us!?"
msgstr "S-Sul serio!? Non lo capisco...\nCome ha fatto questo vecchio a batterci!?"

msgctxt "11||speech_list_cln||table||7||||4"
msgid "What's with all the commotion?"
msgstr "Cos'è tutto questo baccano?"

msgctxt "11||speech_list_cln||table||8||||4"
msgid "Ah!"
msgstr "Ah!"

msgctxt "11||speech_list_cln||table||9||||4"
msgid "You're... You're that JUSTIS guy."
msgstr "Tu sei... Sei quel tizio di JUSTIS."

msgctxt "11||speech_list_cln||table||10||||4"
msgid "R-Rainmaker...!"
msgstr "R-Rainmaker...!"

msgctxt "11||speech_list_cln||table||11||||4"
msgid "Looks like we've got a real fighter here."
msgstr "Sembra che abbiamo a che fare con un vero combattente, qui."

msgctxt "11||speech_list_cln||table||12||||4"
msgid "Having some trouble handling him, are we?\nNeed me to tag in for a round?"
msgstr "Avete problemi a gestirlo, eh?\nVi serve il mio cambio per un round?"

msgctxt "11||speech_list_cln||table||13||||4"
msgid "N-No thanks. We're good, seriously!\nPlease, we didn't wanna cause any trouble!"
msgstr "N-No grazie. Siamo a posto, sul serio!\nTi prego, non volevamo causare nessun problema!"

msgctxt "11||speech_list_cln||table||14||||4"
msgid "Really?"
msgstr "Davvero?"

msgctxt "11||speech_list_cln||table||16||||4"
msgid "Anyways... We're outta here!"
msgstr "Comunque sia... Noi ce ne andiamo!"

msgctxt "11||speech_list_cln||table||17||||4"
msgid "I'm picking up some intense vibes, from you...\nSimilar to that of a yakuza, yet not quite..."
msgstr "Percepisco delle vibrazioni intense, da te...\nSimili a quelle di uno yakuza, ma non del tutto..."

msgctxt "11||speech_list_cln||table||18||||4"
msgid "Perhaps... That's the life you left behind?\nAm I right?"
msgstr "Forse... è quella la vita che ti sei lasciato alle spalle?\nHo indovinato?"

msgctxt "11||speech_list_cln||table||19||||4"
msgid "Just who are you?"
msgstr "Chi diavolo sei?"

msgctxt "11||speech_list_cln||table||20||||4"
msgid "Me? I'm Komei of JUSTIS."
msgstr "Io? Sono Komei di JUSTIS."

msgctxt "11||speech_list_cln||table||21||||4"
msgid "JUSTIS? That some new gang in town?"
msgstr "JUSTIS? È per caso una nuova gang in città?"

msgctxt "11||speech_list_cln||table||22||||4"
msgid "\"Gang\" is not exactly the right word.\nIf anything, we were formed to destroy gangs."
msgstr "\"Gang\" non è esattamente il termine adatto.\nSemmai, siamo stati fondati per distruggerle, le gang."

msgctxt "11||speech_list_cln||table||23||||4"
msgid "JUSTIS is as the name implies<symbol=em_dash_with_outline>a gathering of\nlikeminded people determined to enact justice."
msgstr "JUSTIS è esattamente ciò che il nome implica<symbol=em_dash_with_outline>un gruppo di\npersone con la stessa mentalità determinate a fare giustizia."

msgctxt "11||speech_list_cln||table||24||||4"
msgid "Hm? Can't say you really look the part."
msgstr "Mhm? Non si direbbe affatto dal tuo aspetto."

msgctxt "11||speech_list_cln||table||25||||4"
msgid "Is this gonna take all day, Komei?"
msgstr "Ci vorrà tutto il giorno, Komei?"

msgctxt "11||speech_list_cln||table||27||||4"
msgid "Sorry, sorry. I tend to lose myself around such\ninteresting specimens. I'll be ready soon."
msgstr "Scusa, scusa. Tendo a perdermi quando ho davanti\nesemplari così interessanti. Sono subito pronto."

msgctxt "11||speech_list_cln||table||28||||4"
msgid "Hurry up."
msgstr "Sbrigati."

msgctxt "11||speech_list_cln||table||29||||4"
msgid "That man is Kazuchika Okada."
msgstr "Quell'uomo è Kazuchika Okada."

msgctxt "11||speech_list_cln||table||30||||4"
msgid "He who makes money fall like rain...\nHence his moniker, Rainmaker."
msgstr "Colui che fa piovere i soldi...\nDa cui deriva il suo epiteto, Rainmaker."

msgctxt "11||speech_list_cln||table||31||||4"
msgid "He is also the one who presides over\nthe 3,000 members of JUSTIS."
msgstr "Egli è anche colui che comanda i\n3.000 membri che compongono JUSTIS."

msgctxt "11||speech_list_cln||table||32||||4"
msgid "What? 3,000?"
msgstr "Come? 3.000?"

msgctxt "11||speech_list_cln||table||33||||4"
msgid "You're surprised? With a 3,000 man army...\nIt should be clear we are not to be trifled with."
msgstr "Ti sorprende? Con un esercito di 3.000 uomini...\nDovrebbe essere chiaro a chiunque che non c'è da scherzare con noi."

msgctxt "11||speech_list_cln||table||34||||4"
msgid "Drawn in by his charisma, the troubled youths\nof today flock to join the ranks of JUSTIS."
msgstr "Attratti dal suo carisma, i giovani problematici di\noggi si accalcano per unirsi ai ranghi di JUSTIS."

msgctxt "11||speech_list_cln||table||35||||4"
msgid "Here in the daunting streets of Kamurocho,\nwe give their rage direction and purpose."
msgstr "Qui nelle temibili strade di Kamurocho,\nnoi offriamo alla loro rabbia una direzione e uno scopo."

msgctxt "11||speech_list_cln||table||37||||4"
msgid "If my hunch is correct, we will most certainly\ncross paths again soon. Until then."
msgstr "Se il mio intuito non mi inganna, le nostre strade si incroceranno\nsicuramente di nuovo molto presto. A presto, allora."

msgctxt "11||speech_list_cln||table||38||||4"
msgid "I come back and it's like the whole\nplace has gone nuts... This damn city."
msgstr "Torno in città e sembra che l'intero posto\nsia impazzito... Questa dannata città."

msgctxt "11||speech_list_cln||table||39||||4"
msgid "Hm?"
msgstr "Mhm?"

msgctxt "11||speech_list_cln||table||40||||4"
msgid "Take this! We ain't done with you yet!"
msgstr "Prendi questo! Non abbiamo ancora finito con te!"

msgctxt "11||speech_list_cln||table||41||||4"
msgid "You probly thought you'd be able to run\nfrom us... but you thought wrong!"
msgstr "Probabilmente pensavi di poter fuggire\nda noi... ma ti sbagliavi di grosso!"

msgctxt "11||speech_list_cln||table||42||||4"
msgid "You had this comin', Joe! Now stand up!"
msgstr "Te la sei cercata, Joe! Ora alzati!"

msgctxt "11||speech_list_cln||table||43||||4"
msgid "It's time ya set this right, yeah!?"
msgstr "È ora che tu metta le cose a posto, eh!?"

msgctxt "11||speech_list_cln||table||44||||4"
msgid "Huh? Hold on."
msgstr "Cosa? Aspettate."

msgctxt "11||speech_list_cln||table||45||||4"
msgid "Hm?"
msgstr "Mhm?"

msgctxt "11||speech_list_cln||table||46||||4"
msgid "The hell're you lookin' at, grampa?\nBeat it."
msgstr "Che cazzo guardi, nonnino?\nSmamma."

msgctxt "11||speech_list_cln||table||47||||4"
msgid "I'm not sure what's going on here,\nbut that's enough."
msgstr "Non so bene cosa stia succedendo qui,\nma dateci un taglio."

msgctxt "11||speech_list_cln||table||48||||4"
msgid "You serious right now? You'd be better off\njust turnin' around now. You get me?"
msgstr "Stai dicendo sul serio? Faresti meglio a farti i\ncazzi tuoi e girare i tacchi, adesso. Ci siamo intesi?"

msgctxt "11||speech_list_cln||table||50||||4"
msgid "Are you all right?"
msgstr "Tutto bene?"

msgctxt "11||speech_list_cln||table||51||||4"
msgid "Don't do this, old man."
msgstr "Lascia perdere, vecchio."

msgctxt "11||speech_list_cln||table||52||||4"
msgid "Hm?"
msgstr "Mhm?"

msgctxt "11||speech_list_cln||table||53||||4"
msgid "I'm telling you to run!\nTh-They're too strong..."
msgstr "Ti sto dicendo di fuggire!\nS-Sono troppo forti..."

msgctxt "11||speech_list_cln||table||55||||4"
msgid "Time's up."
msgstr "Tempo scaduto."

msgctxt "11||speech_list_cln||table||56||||4"
msgid "I'm sick of slow old fucks like you.\nGuess I'll have to move you myself."
msgstr "Sono stanco dei vecchi stronzi e lenti come te.\nImmagino che dovrò toglierti di mezzo da solo."

msgctxt "11||speech_list_cln||table||57||||4"
msgid "Who are you guys?"
msgstr "Chi siete voi ragazzi?"

msgctxt "11||speech_list_cln||table||58||||4"
msgid "Us? We're JUSTIS."
msgstr "Noi? Noi siamo di JUSTIS."

msgctxt "11||speech_list_cln||table||59||||4"
msgid "JUSTIS...?"
msgstr "JUSTIS...?"

msgctxt "11||speech_list_cln||table||60||||4"
msgid "Me? I'm Komei from JUSTIS."
msgstr "Io? Io sono Komei di JUSTIS."

msgctxt "11||speech_list_cln||table||61||||4"
msgid "We don't care who ya are, gramps.\nYou're goin' straight to hell!"
msgstr "Non ci frega niente di chi tu sia, nonnino.\nAndrai dritto all'inferno!"

msgctxt "11||speech_list_cln||table||62||||4"
msgid "This is what happens when ya mess\nwith JUSTIS. Now die!"
msgstr "Questo è ciò che succede quando ti metti\ncontro JUSTIS. Ora muori!"

msgctxt "11||speech_list_cln||table||63||||4"
msgid "Y-You saved me."
msgstr "M-Mi hai salvato."

msgctxt "11||speech_list_cln||table||64||||4"
msgid "Can you stand?"
msgstr "Riesci ad alzarti?"

msgctxt "11||speech_list_cln||table||65||||4"
msgid "I-I told you to run... but you stayed and fought.\nYou're incredible, old man."
msgstr "T-Ti avevo detto di scappare... ma tu sei rimasto e hai\ncombattuto. Sei incredibile, vecchio."

msgctxt "11||speech_list_cln||table||66||||4"
msgid "We should get you to a doctor."
msgstr "Dovremmo portarti da un dottore."

msgctxt "11||speech_list_cln||table||67||||4"
msgid "Not yet. For now, we need to run..."
msgstr "Non ancora. Per ora, dobbiamo fuggire..."

msgctxt "11||speech_list_cln||table||68||||4"
msgid "Joe-san!"
msgstr "Joe-san!"

msgctxt "11||speech_list_cln||table||69||||4"
msgid "Man, those JUSTIS bastards...\nHow could they do this to you!?"
msgstr "Cazzo, quei bastardi di JUSTIS...\nCome hanno potuto farti questo!?"

msgctxt "11||speech_list_cln||table||70||||4"
msgid "Hey, are you a friend of his?"
msgstr "Ehi, sei un suo amico?"

msgctxt "11||speech_list_cln||table||71||||4"
msgid "Y-Yes! Uh, you're the one who\nhelped Joe-san out, aren't you?"
msgstr "S-Sì! Ehm, tu sei quello che\nha aiutato Joe-san, giusto?"

msgctxt "11||speech_list_cln||table||72||||4"
msgid "Um... Thank you very much!"
msgstr "Uhm... Molte grazie!"

msgctxt "11||speech_list_cln||table||73||||4"
msgid "It's all right. More importantly, we should get out of\nhere. We don't want to be here when more come."
msgstr "Non c'è di che. Cosa più importante, dovremmo andarcene\nda qui. Non vogliamo farci trovare se ne dovessero arrivare altri."

msgctxt "11||speech_list_cln||table||74||||4"
msgid "R-Right! There's a restaurant we've been using\nas a meeting spot. We can head over there!"
msgstr "C-Certo! C'è un ristorante che stiamo usando\ncome punto di ritrovo. Possiamo dirigerci lì!"

msgctxt "11||speech_list_cln||table||75||||4"
msgid "Okay."
msgstr "D'accordo."

msgctxt "11||speech_list_cln||table||76||||4"
msgid "This seems like a strange place for a hideout."
msgstr "Questo sembra un posto piuttosto insolito per un nascondiglio."

msgctxt "11||speech_list_cln||table||77||||4"
msgid "My sister's a part-timer here. I've grown to be\npretty good friends with the bartender, too."
msgstr "Mia sorella lavora qui part-time. Inoltre ho fatto\nuna bella amicizia col barista del posto."

msgctxt "11||speech_list_cln||table||78||||4"
msgid "Don't recall us ever becoming friends.\nSheesh, how'd my bar end up as your hideout?"
msgstr "Non ricordo che siamo mai diventati amici.\nCavoli, com'è che il mio bar è diventato il vostro nascondiglio?"

msgctxt "11||speech_list_cln||table||79||||4"
msgid "He looks a little soft, but the bartender here\nused to be a real rough dude."
msgstr "Sembra un po' rammollito, ma il barista qui un\ntempo era un vero duro."

msgctxt "11||speech_list_cln||table||80||||4"
msgid "Don't go spreading rumors about me. Sorry,\nthese guys are a real pain in the ass, huh?"
msgstr "Smettila di spargere dicerie sul mio conto. Scusami,\nquesti ragazzi sono un bel grattacapo, non trovi?"

msgctxt "11||speech_list_cln||table||81||||4"
msgid "It's all right."
msgstr "Non c'è problema."

msgctxt "11||speech_list_cln||table||84||||4"
msgid "Um, Kiryu-san. Sorry about this. My brother and\nhis friend here are a real pain in the neck."
msgstr "Uhm, Kiryu-san. Scusami tanto. Mio fratello e il suo\namico qui sono delle vere spine nel fianco."

msgctxt "11||speech_list_cln||table||85||||4"
msgid "Not at all."
msgstr "Ma figurati."

msgctxt "11||speech_list_cln||table||86||||4"
msgid "Hey Masa, I'm gonna go buy some medicine for Joe."
msgstr "Ehi Masa, vado a comprare delle medicine per Joe."

msgctxt "11||speech_list_cln||table||87||||4"
msgid "Right, thanks."
msgstr "Perfetto, grazie."

msgctxt "11||speech_list_cln||table||88||||4"
msgid "Um... Kiryu-san, was it?\nI almost forgot<symbol=em_dash_with_outline>my name's Masao."
msgstr "Ehm... Kiryu-san, dicevi?\nQuasi dimenticavo<symbol=em_dash_with_outline>mi chiamo Masao."

msgctxt "11||speech_list_cln||table||89||||4"
msgid "Joe-san... Er, Jojima-san and I went to grade school\ntogether. He was in sixth grade when I was in first."
msgstr "Joe-san... Ehm, Jojima-san e io abbiamo frequentato le elementari\ninsieme. Era in sesta quando io facevo la prima."

msgctxt "11||speech_list_cln||table||90||||4"
msgid "Joe-san's a big legend 'round here. He left Onomichi\nfor years... Only came back somewhat recently."
msgstr "Joe-san è una vera leggenda, da queste parti. Ha lasciato Onomichi\nper anni... Ci è ritornato solo abbastanza di recente."

msgctxt "11||speech_list_cln||table||91||||4"
msgid "And when he did... all the young punks\nin town couldn't have been more excited."
msgstr "E quando l'ha fatto... tutti i giovani teppisti in città\nnon avrebbero potuto esserne più entusiasti."

msgctxt "11||speech_list_cln||table||92||||4"
msgid "Joe-san went all the way to Tokyo,\nand came back an incredible man!"
msgstr "Joe-san è arrivato fino a Tokyo,\ned è tornato come un uomo incredibile!"

msgctxt "11||speech_list_cln||table||93||||4"
msgid "What do you mean...?"
msgstr "Cosa intendi dire...?"

msgctxt "11||speech_list_cln||table||94||||4"
msgid "After all, he was one of the founders\nof JUSTIS up in Kamurocho."
msgstr "Dopotutto, è stato uno dei fondatori\ndi JUSTIS su a Kamurocho."

msgctxt "11||speech_list_cln||table||95||||4"
msgid "What...?"
msgstr "Cosa...?"

msgctxt "11||speech_list_cln||table||96||||4"
msgid "I know what you're thinking. That those guys\nwho came for Joe-san earlier were JUSTIS, too."
msgstr "So a cosa stai pensando. Che anche quei tizi venuti a\ncercare Joe-san poco fa, facevano parte di JUSTIS."

msgctxt "11||speech_list_cln||table||98||||4"
msgid "I'm not entirely sure of the details myself."
msgstr "Non conosco bene i dettagli nemmeno io."

msgctxt "11||speech_list_cln||table||99||||4"
msgid "It doesn't seem like Joe-san managed\nto have a smooth break with the group, though."
msgstr "Sembra però che Joe-san non sia riuscito\na staccarsi pacificamente dal gruppo."

msgctxt "11||speech_list_cln||table||100||||4"
msgid "That's why day after day, JUSTIS members have\nbeen coming here to take Joe-san down."
msgstr "Ecco perché, giorno dopo giorno, i membri di JUSTIS\nvengono fin qui per far fuori Joe-san."

msgctxt "11||speech_list_cln||table||101||||4"
msgid "They're coming all the way from\nKamurocho just for him?"
msgstr "Vengono fin qui da Kamurocho\nsolo per lui?"

msgctxt "11||speech_list_cln||table||102||||4"
msgid "You know, I ran into them up in Kamurocho, too.\nJust who are these JUSTIS guys...?"
msgstr "Sai, li ho incontrati anch'io su a Kamurocho.\nChi diavolo sono questi tizi di JUSTIS...?"

msgctxt "11||speech_list_cln||table||103||||4"
msgid "I see... So you're from Kamurocho..."
msgstr "Capisco... Quindi vieni da Kamurocho..."

msgctxt "11||speech_list_cln||table||104||||4"
msgid "Joe-san! Are you okay?"
msgstr "Joe-san! Stai bene?"

msgctxt "11||speech_list_cln||table||105||||4"
msgid "Sorry about this, Masao."
msgstr "Scusami per tutto questo, Masao."

msgctxt "11||speech_list_cln||table||106||||4"
msgid "No, it's all right!"
msgstr "No, non c'è problema!"

msgctxt "11||speech_list_cln||table||107||||4"
msgid "I've gotta thank you for earlier.\nIf you hadn't been there to help me..."
msgstr "Devo ringraziarti per prima.\nSe non ci fossi stato tu ad aiutarmi..."

msgctxt "11||speech_list_cln||table||108||||4"
msgid "...Who knows how things\nwould've turned out."
msgstr "...Chissà come\nsarebbe andata a finire."

msgctxt "11||speech_list_cln||table||109||||4"
msgid "Right."
msgstr "Già."

msgctxt "11||speech_list_cln||table||110||||4"
msgid "You're the only reason I'm still alive. But..."
msgstr "Se sono ancora vivo è solo grazie a te. Ma..."

msgctxt "11||speech_list_cln||table||111||||4"
msgid "I think by saving me, you put yourself\nin a real bad position."
msgstr "Penso che salvandomi tu ti sia messo\nin una brutta situazione."

msgctxt "11||speech_list_cln||table||112||||4"
msgid "Hm?"
msgstr "Mhm?"

msgctxt "11||speech_list_cln||table||113||||4"
msgid "They've got eyes on you now.\nJUSTIS doesn't forget their grudges."
msgstr "Ora hanno gli occhi puntati su di te.\nJUSTIS non dimentica i torti subiti."

msgctxt "11||speech_list_cln||table||115||||4"
msgid "Wait, what? You saw Komei up\nin Kamurocho, Kiryu-san?"
msgstr "Aspetta, cosa? Hai visto Komei su\na Kamurocho, Kiryu-san?"

msgctxt "11||speech_list_cln||table||116||||4"
msgid "Yeah. We had a short chat."
msgstr "Sì. Abbiamo fatto due chiacchiere."

msgctxt "11||speech_list_cln||table||117||||4"
msgid "I see. Komei's the JUSTIS strategist.\nHe's the leader Okada's right-hand man."
msgstr "Capisco. Komei è lo stratega di JUSTIS.\nÈ il braccio destro del capo, Okada."

msgctxt "11||speech_list_cln||table||118||||4"
msgid "Oh yeah. That guy was there with Komei.\nGoes by the name \"Rainmaker\" or something."
msgstr "Ah, sì. C'era quel tizio con Komei.\nSi fa chiamare \"Rainmaker\" o qualcosa del genere."

msgctxt "11||speech_list_cln||table||119||||4"
msgid "The one who makes it rain cash...\nHe's a key figure in Kamurocho."
msgstr "Quello che fa piovere soldi...\nÈ una figura chiave a Kamurocho."

msgctxt "11||speech_list_cln||table||120||||4"
msgid "Kids who look up to him have formed an army\nand taken to the streets. That army is JUSTIS."
msgstr "I ragazzini che lo ammirano hanno formato un esercito\ne sono scesi in strada. Quell'esercito è JUSTIS."

msgctxt "11||speech_list_cln||table||121||||4"
msgid "But... Weren't you a founding officer?"
msgstr "Ma... non eri uno dei fondatori?"

msgctxt "11||speech_list_cln||table||122||||4"
msgid "It didn't use to be like that\nback when it first started, though."
msgstr "All'inizio, però,\nnon era affatto così."

msgctxt "11||speech_list_cln||table||123||||4"
msgid "A lot's happened, though. Okada and JUSTIS\nchanged, and now it's just a regular old street gang."
msgstr "Ma sono successe tante cose. Okada e JUSTIS sono\ncambiati, e ora è solo l'ennesima gang di strada."

msgctxt "11||speech_list_cln||table||124||||4"
msgid "And that's why you decided to leave."
msgstr "Ed è per questo che hai deciso di andartene."

msgctxt "11||speech_list_cln||table||125||||4"
msgid "Pretty much. I didn't think they'd chase me all\nthe way back to Onomichi, but that was naive of me."
msgstr "Più o meno. Non pensavo che mi avrebbero dato la caccia\nfino a Onomichi, sono stato un ingenuo."

msgctxt "11||speech_list_cln||table||126||||4"
msgid "They're also not the only ones here."
msgstr "E non sono nemmeno gli unici, qui."

msgctxt "11||speech_list_cln||table||127||||4"
msgid "Apparently they've got over 100 guys here\nto chase me down."
msgstr "A quanto pare hanno mandato più di 100 uomini\nqui a darmi la caccia."

msgctxt "11||speech_list_cln||table||128||||4"
msgid "And since you helped me fight against them...\nThey'll be coming for you, too."
msgstr "E visto che mi hai aiutato a combatterli...\nDaranno la caccia anche a te."

msgctxt "11||speech_list_cln||table||129||||4"
msgid "Sorry for dragging you into this."
msgstr "Scusa per averti trascinato in questa storia."

msgctxt "11||speech_list_cln||table||131||||4"
msgid "I'm not really sure who you are, but\nit's clear you've seen a fight or two."
msgstr "Non so bene chi tu sia, ma\nè evidente che sai come si combatte."

msgctxt "11||speech_list_cln||table||132||||4"
msgid "Even so... 100 guys would overwhelm even\na great fighter. Get out of town while you can."
msgstr "Ciononostante... 100 uomini schiaccerebbero perfino\nun gran lottatore. Lascia la città finché sei in tempo."

msgctxt "11||speech_list_cln||table||133||||4"
msgid "I'm actually here on important business.\nI can't just up and leave."
msgstr "In realtà sono qui per una faccenda importante.\nNon posso andarmene e basta."

msgctxt "11||speech_list_cln||table||134||||4"
msgid "Think about your safety!"
msgstr "Pensa alla tua sicurezza!"

msgctxt "11||speech_list_cln||table||135||||4"
msgid "It's an unknown caller.\nProbably those thugs from earlier."
msgstr "È un numero sconosciuto.\nProbabilmente sono quei teppisti di prima."

msgctxt "11||speech_list_cln||table||136||||4"
msgid "This is Joe.\nYeah, I know."
msgstr "Sono Joe.\nSì, lo so."

msgctxt "11||speech_list_cln||table||137||||4"
msgid "No, that guy had nothing to do with me.\nHe doesn't know a thing about JUSTIS."
msgstr "No, quel tizio non ha niente a che fare con me.\nNon sa nulla di JUSTIS."

msgctxt "11||speech_list_cln||table||139||||4"
msgid "What!? Hey, hold on!"
msgstr "Cosa!? Ehi, aspetta!"

msgctxt "11||speech_list_cln||table||140||||4"
msgid "Joe-san?"
msgstr "Joe-san?"

msgctxt "11||speech_list_cln||table||141||||4"
msgid "Those bastards...\nThey took your sister."
msgstr "Quei bastardi...\nHanno preso tua sorella."

msgctxt "11||speech_list_cln||table||142||||4"
msgid "Wait... What!? Sachiko!?\nYou can't be serious!"
msgstr "Aspetta... Cosa!? Sachiko!?\nDici sul serio!?"

msgctxt "11||speech_list_cln||table||143||||4"
msgid "They said we need to bring them\nKiryu-san if we want her back safe."
msgstr "Hanno detto che dobbiamo portargli Kiryu-san\nse vogliamo riaverla sana e salva."

msgctxt "11||speech_list_cln||table||144||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "11||speech_list_cln||table||145||||4"
msgid "Fine by me.\nTake me to them."
msgstr "Per me va bene.\nPortatemi da loro."

msgctxt "11||speech_list_cln||table||146||||4"
msgid "Don't you understand what's happening?\nWe can't just hand you over."
msgstr "Non capisci cosa sta succedendo?\nNon possiamo semplicemente consegnarti."

msgctxt "11||speech_list_cln||table||147||||4"
msgid "JUSTIS doesn't mess around. I bet they have over\n100 guys here, all itching for a chance to kill you."
msgstr "JUSTIS non scherza. Scommetto che hanno più di 100\nuomini là, che non vedono l'ora di farti la pelle."

msgctxt "11||speech_list_cln||table||148||||4"
msgid "You're probably right.\nBut so what?"
msgstr "Probabilmente hai ragione.\nE allora?"

msgctxt "11||speech_list_cln||table||149||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "11||speech_list_cln||table||150||||4"
msgid "So you'd want to save her if there were only 10,\nbut you can't when there are 100? Is that it?"
msgstr "Quindi vorresti salvarla se fossero solo in 10,\nma non puoi perché sono 100? È così?"

msgctxt "11||speech_list_cln||table||151||||4"
msgid "I don't care how many there are. Any scum\nwho'd take a girl hostage needs to get wiped up."
msgstr "Non mi importa quanti siano. Qualsiasi feccia che prenda\nuna ragazza in ostaggio merita di essere spazzata via."

msgctxt "11||speech_list_cln||table||152||||4"
msgid "If you ask me...\nIsn't that what being a man's about?"
msgstr "Se chiedi a me...\nNon è questo ciò che significa essere un uomo?"

msgctxt "11||speech_list_cln||table||153||||4"
msgid "Kiryu-san..."
msgstr "Kiryu-san..."

msgctxt "11||speech_list_cln||table||154||||4"
msgid "I... I'll go round up some friends!\nAs many local punks as I can!"
msgstr "I-Io... vado a radunare un po' di amici!\nTutti i teppisti locali che riesco a trovare!"

msgctxt "11||speech_list_cln||table||155||||4"
msgid "Masao..."
msgstr "Masao..."

msgctxt "11||speech_list_cln||table||156||||4"
msgid "A complete stranger's gonna fight\nfor my little sister."
msgstr "Un perfetto sconosciuto è pronto a\ncombattere per la mia sorellina."

msgctxt "11||speech_list_cln||table||157||||4"
msgid "As an Onomichi man, I can't just\nsit around and watch!"
msgstr "Come uomo di Onomichi, non posso\nrestare qui seduto a guardare!"

msgctxt "11||speech_list_cln||table||158||||4"
msgid "Hold on!"
msgstr "Fermo!"

msgctxt "11||speech_list_cln||table||159||||4"
msgid "If you fight back..."
msgstr "Se reagisci..."

msgctxt "11||speech_list_cln||table||160||||4"
msgid "JUSTIS will keep sending soldiers from Tokyo\nuntil they destroy you."
msgstr "JUSTIS continuerà a mandare soldati da Tokyo\nfinché non vi avrà distrutti."

msgctxt "11||speech_list_cln||table||161||||4"
msgid "Just so we're clear, this is the biggest gang in Japan.\nDo you guys know what you're getting into!?"
msgstr "Giusto per essere chiari, questa è la gang più grande del\nGiappone. Avete idea di in cosa vi state cacciando!?"

msgctxt "11||speech_list_cln||table||162||||4"
msgid "I guess we're just kinda dumb.\nBut I do know one thing."
msgstr "Forse siamo semplicemente un po' stupidi.\nMa una cosa la so."

msgctxt "11||speech_list_cln||table||163||||4"
msgid "It doesn't matter how big their gang is.\nI'm not letting them stomp all over us!"
msgstr "Non importa quanto sia grande la loro gang.\nNon permetterò che ci mettano i piedi in testa!"

msgctxt "11||speech_list_cln||table||164||||4"
msgid "Huh..."
msgstr "Mhm..."

msgctxt "11||speech_list_cln||table||165||||4"
msgid "I'm real sorry for dragging you into this.\nAnd for all the lame shit I've been spouting so far."
msgstr "Mi dispiace davvero per avervi trascinato in questa storia.\nE per tutte le cazzate patetiche che ho detto finora."

msgctxt "11||speech_list_cln||table||166||||4"
msgid "Thanks to you and Kiryu-san,\nthe truth is clear."
msgstr "Grazie a te e a Kiryu-san,\nla verità è chiara."

msgctxt "11||speech_list_cln||table||167||||4"
msgid "We've gotta go save Sachiko!\nAnd I'm gonna need you both!"
msgstr "Dobbiamo andare a salvare Sachiko!\nE avrò bisogno di voi due!"

msgctxt "11||speech_list_cln||table||168||||4"
msgid "Right!"
msgstr "Esatto!"

msgctxt "11||speech_list_cln||table||169||||4"
msgid "Then let's prepare for war.\nWe should find anyone willing to lend a hand."
msgstr "Allora prepariamoci alla guerra.\nDobbiamo trovare chiunque sia disposto a darci una mano."

msgctxt "11||speech_list_cln||table||170||||4"
msgid "We'll start scrounging a group together,\nso just let us know when you're ready, Kiryu-san."
msgstr "Inizieremo a mettere insieme un gruppo,\nquindi facci sapere quando sei pronto, Kiryu-san."

msgctxt "11||speech_list_cln||table||171||||4"
msgid "It's gonna take a little more time to get\na group together. Just wait a bit longer."
msgstr "Ci vorrà un po' più di tempo per mettere\ninsieme il gruppo. Aspetta ancora un po'."

msgctxt "11||speech_list_cln||table||172||||4"
msgid "We're ready to get going, Kiryu-san.\nAre you all set for the battle ahead?"
msgstr "Siamo pronti per muoverci, Kiryu-san.\nTu sei pronto per la battaglia che ci attende?"

msgctxt "11||speech_list_cln||table||173||||4"
msgid "Glad to hear it!\nAll right, let's go!"
msgstr "Felice di sentirlo!\nD'accordo, andiamo!"

msgctxt "11||speech_list_cln||table||174||||4"
msgid "Once you're ready,\nplease come let us know."
msgstr "Quando sarai pronto,\nvieni a farcelo sapere."

msgctxt "11||speech_list_cln||table||175||||4"
msgid "Do you see them, Kiryu-san?\nThat's the JUSTIS army."
msgstr "Li vedi, Kiryu-san?\nQuello è l'esercito di JUSTIS."

msgctxt "11||speech_list_cln||table||176||||4"
msgid "How does it look?"
msgstr "Come ti sembra la situazione?"

msgctxt "11||speech_list_cln||table||177||||4"
msgid "There's as many of them as I expected.\nThey must've known we'd try and fight back."
msgstr "Sono tanti quanti mi aspettavo.\nSapevano che avremmo provato a reagire."

msgctxt "11||speech_list_cln||table||178||||4"
msgid "We've got a pretty big army too, though. There might\nbe more of them, but we can win if we're careful."
msgstr "Anche noi abbiamo un bel gruppo, però. Loro saranno di\npiù, ma possiamo vincere se facciamo attenzione."

msgctxt "11||speech_list_cln||table||179||||4"
msgid "Right. Well, let's go."
msgstr "Giusto. Beh, andiamo."

msgctxt "11||speech_list_cln||table||180||||4"
msgid "Hold on a second."
msgstr "Aspetta un momento."

msgctxt "11||speech_list_cln||table||181||||4"
msgid "Hm? What's wrong?"
msgstr "Mhm? Cosa c'è che non va?"

msgctxt "11||speech_list_cln||table||182||||4"
msgid "Anyway, this is our fight, Kiryu-san.\nI don't want to pull you in too deep."
msgstr "Comunque sia, questa è la nostra battaglia, Kiryu-san.\nNon voglio immischiarti troppo."

msgctxt "11||speech_list_cln||table||183||||4"
msgid "Then what should I do?"
msgstr "Quindi io che dovrei fare?"

msgctxt "11||speech_list_cln||table||184||||4"
msgid "But... now that I think about it,\nour team is pretty lacking in leadership."
msgstr "Però... ora che ci penso,\nalla nostra squadra manca proprio una leadership."

msgctxt "11||speech_list_cln||table||185||||4"
msgid "If we rush straight in without a plan,\nthey'll almost definitely crush us."
msgstr "Se ci buttiamo nella mischia senza un piano,\nci distruggeranno senza ombra di dubbio."

msgctxt "11||speech_list_cln||table||186||||4"
msgid "So, Kiryu-san... I was thinking maybe you\ncould be the guy giving the orders."
msgstr "Quindi, Kiryu-san... pensavo che forse tu\npotresti essere quello che dà gli ordini."

msgctxt "11||speech_list_cln||table||187||||4"
msgid "How would that work?"
msgstr "Come funzionerebbe?"

msgctxt "11||speech_list_cln||table||188||||4"
msgid "Well, you'll just need to watch over the battle\nand tell us what to do and when to do it."
msgstr "Beh, dovrai semplicemente osservare la battaglia\ne dirci cosa fare e quando farlo."

msgctxt "11||speech_list_cln||table||189||||4"
msgid "With your experience in battle, Kiryu-san,\nI'm sure this'll be a cinch..."
msgstr "Con la tua esperienza in battaglia, Kiryu-san,\nsono sicuro che sarà un gioco da ragazzi..."

msgctxt "11||speech_list_cln||table||190||||4"
msgid "I prefer a more hands-on approach...\nBut fine."
msgstr "Preferisco un approccio più pratico...\nMa d'accordo."

msgctxt "11||speech_list_cln||table||191||||4"
msgid "JUSTIS is your enemy.\nThis battle isn't mine to fight."
msgstr "JUSTIS è il vostro nemico.\nQuesta non è la mia battaglia."

msgctxt "11||speech_list_cln||table||192||||4"
msgid "Thank you.\nOur enemy is strong and greater in number."
msgstr "Grazie.\nIl nostro nemico è forte e in superiorità numerica."

msgctxt "11||speech_list_cln||table||193||||4"
msgid "I hope your leadership can overcome that."
msgstr "Spero che la tua guida riesca a colmare il divario."

msgctxt "11||speech_list_cln||table||194||||4"
msgid "Hmph. Nothing to worry about."
msgstr "Mpf. Niente di cui preoccuparsi."

msgctxt "11||speech_list_cln||table||195||||4"
msgid "Hey, they're here!"
msgstr "Ehi, eccoli!"

msgctxt "11||speech_list_cln||table||196||||4"
msgid "Heh, I'm surprised you guys came, knowing how\nmany of us there are. Not bad, Joe-san."
msgstr "Heh, mi sorprende che siate venuti, sapendo quanti\nsiamo. Niente male, Joe-san."

msgctxt "11||speech_list_cln||table||197||||4"
msgid "My orders're coming from the top...\nSo no hard feelings, yeah?"
msgstr "I miei ordini arrivano dall'alto...\nQuindi niente rancore, eh?"

msgctxt "11||speech_list_cln||table||198||||4"
msgid "All right... Let's do this thing! Sachiko's\ncoming back to us! We're gonna win!"
msgstr "D'accordo... Diamoci dentro! Riportiamo\na casa Sachiko! Vinceremo noi!"

msgctxt "11||speech_list_cln||table||199||||4"
msgid "We took care of all of them.\nYou're a real boss, Kiryu-san."
msgstr "Li abbiamo sistemati tutti.\nSei un vero capo, Kiryu-san."

msgctxt "11||speech_list_cln||table||200||||4"
msgid "Same to you. I assumed you were weaker than\nthat since I've only ever seen you get beaten up."
msgstr "Lo stesso vale per te. Credevo fossi più debole di così,\nvisto che finora ti avevo visto solo prenderle."

msgctxt "11||speech_list_cln||table||201||||4"
msgid "Harsh, man."
msgstr "Che cattiveria, amico."

msgctxt "11||speech_list_cln||table||202||||4"
msgid "You bastards... Don't go thinking you can\nget away after what you did to my men!"
msgstr "Bastardi... Non crediate di potervela\ncavare dopo quello che avete fatto ai miei uomini!"

msgctxt "11||speech_list_cln||table||203||||4"
msgid "Don't you know about JUSTIS? With the thousands\nof soldiers we have... We're unstoppable!"
msgstr "Non conoscete JUSTIS? Con le migliaia di\nsoldati che abbiamo... Siamo inarrestabili!"

msgctxt "11||speech_list_cln||table||204||||4"
msgid "I used to believe that was the case,\nbut this man showed me the truth."
msgstr "Un tempo credevo fosse così,\nma quest'uomo mi ha mostrato la verità."

msgctxt "11||speech_list_cln||table||205||||4"
msgid "It doesn't matter if I think I'm gonna win or not.\nThat's not how I should decide what to do."
msgstr "Non importa se penso di poter vincere o no.\nNon è in questo modo che dovrei decidere cosa fare."

msgctxt "11||speech_list_cln||table||206||||4"
msgid "After all... I'm a man."
msgstr "Dopotutto... sono un uomo."

msgctxt "11||speech_list_cln||table||207||||4"
msgid "Hmph..."
msgstr "Mpf..."

msgctxt "11||speech_list_cln||table||208||||4"
msgid "What the hell're you talking about?"
msgstr "Di che cazzo stai parlando?"

msgctxt "11||speech_list_cln||table||209||||4"
msgid "Our orders're coming from the top.\nWe're gonna crush you one way or another!"
msgstr "I nostri ordini arrivano dall'alto.\nVi schiacceremo in un modo o nell'altro!"

msgctxt "11||speech_list_cln||table||211||||4"
msgid "I wish I didn't have to resort to this kinda\nviolence, but I don't got a choice."
msgstr "Vorrei non dover ricorrere a questo tipo\ndi violenza, ma non ho altra scelta."

msgctxt "11||speech_list_cln||table||212||||4"
msgid "Let me help, Joe."
msgstr "Lascia che ti aiuti, Joe."

msgctxt "11||speech_list_cln||table||213||||4"
msgid "But..."
msgstr "Ma..."

msgctxt "11||speech_list_cln||table||214||||4"
msgid "I could use the exercise. Shake some rust off.\nBesides, I want to teach these lowlife punks a lesson."
msgstr "Mi farebbe bene un po' di esercizio per togliermi la ruggine.\nInoltre, voglio dare una lezione a questi teppistelli da strapazzo."

msgctxt "11||speech_list_cln||table||215||||4"
msgid "All right.\nLet's do this!"
msgstr "D'accordo.\nFacciamolo!"

msgctxt "11||speech_list_cln||table||216||||4"
msgid "JUSTIS isn't gonna stand for this.\nYou bastards... It's time to die!"
msgstr "JUSTIS non lo tollererà.\nBastardi... È ora di morire!"

msgctxt "11||speech_list_cln||table||217||||4"
msgid "Well, guess we can't back down now."
msgstr "Beh, mi sa che non possiamo tirarci indietro ora."

msgctxt "11||speech_list_cln||table||218||||4"
msgid "Are you regretting this?"
msgstr "Te ne stai pentendo?"

msgctxt "11||speech_list_cln||table||219||||4"
msgid "No. If anything, it helped make things clear.\nI'm through living my life in fear."
msgstr "No. Se non altro, mi ha aiutato a chiarirmi le idee.\nHo finito di vivere la mia vita nella paura."

msgctxt "11||speech_list_cln||table||220||||4"
msgid "I've decided...\nJUSTIS is going down."
msgstr "Ho deciso...\nJUSTIS deve cadere."

msgctxt "11||speech_list_cln||table||221||||4"
msgid "And as for Rainmaker...\nI'll make him see the truth."
msgstr "E per quanto riguarda Rainmaker...\nGli aprirò gli occhi sulla verità."

msgctxt "11||speech_list_cln||table||222||||4"
msgid "Did Masao tell you I was\none of JUSTIS's founding officers?"
msgstr "Masao ti ha detto che ero\nuno dei membri fondatori di JUSTIS?"

msgctxt "11||speech_list_cln||table||223||||4"
msgid "Yeah, more or less."
msgstr "Sì, più o meno."

msgctxt "11||speech_list_cln||table||224||||4"
msgid "Back in the day, he and I were the best of friends.\nKamurocho was our regular stomping ground."
msgstr "All'epoca, lui e io eravamo migliori amici.\nKamurocho era il nostro ritrovo abituale."

msgctxt "11||speech_list_cln||table||225||||4"
msgid "But at the time, the city was full of young thugs\nrepping gangs in specific colors..."
msgstr "Ma a quei tempi, la città era piena di giovani teppisti\nche rappresentavano gang con colori specifici..."

msgctxt "11||speech_list_cln||table||226||||4"
msgid "Guys like Bloody Eye and Blue Z..."
msgstr "Tizi come i Bloody Eye e i Blue Z..."

msgctxt "11||speech_list_cln||table||228||||4"
msgid "Young as they were,\nthe color gangs ruled the city."
msgstr "Per quanto giovani fossero,\nle gang dei colori governavano la città."

msgctxt "11||speech_list_cln||table||229||||4"
msgid "Kamurocho was theirs and theirs alone.\nYou couldn't breathe without their permission."
msgstr "Kamurocho era loro e loro soltanto.\nNon potevi respirare senza il loro permesso."

msgctxt "11||speech_list_cln||table||230||||4"
msgid "They were pretty annoyed that Rainmaker\nand I refused to join them, though."
msgstr "Erano piuttosto infastiditi dal fatto che Rainmaker\ne io ci rifiutassimo di unirci a loro, però."

msgctxt "11||speech_list_cln||table||231||||4"
msgid "So in return, they started attacking our friends.\nAll to get us to join their dumb little gangs."
msgstr "Così, per ripicca, iniziarono ad attaccare i nostri amici.\nTutto per costringerci a unirci alle loro stupide gang."

msgctxt "11||speech_list_cln||table||233||||4"
msgid "Okada and I weren't going to take that lying down,\nthough. That's why we decided to fight back."
msgstr "Io e Okada non eravamo disposti a subire in silenzio,\nperò. Per questo abbiamo deciso di reagire."

msgctxt "11||speech_list_cln||table||234||||4"
msgid "That's why we formed JUSTIS."
msgstr "È per questo che abbiamo fondato JUSTIS."

msgctxt "11||speech_list_cln||table||235||||4"
msgid "Though I've gotta say, JUSTIS is looking more\nand more like a shitty color clone every day."
msgstr "Ma devo dire che JUSTIS sta diventando sempre più simile\na un pessimo clone di quelle gang dei colori, ogni giorno che passa."

msgctxt "11||speech_list_cln||table||236||||4"
msgid "So an organization formed to destroy a gang has\nturned into a gang itself... Ironic, I'd say."
msgstr "Così un'organizzazione nata per distruggere le gang\nè diventata a sua volta una gang... Ironico, direi."

msgctxt "11||speech_list_cln||table||237||||4"
msgid "Yeah. Since I helped organize them,\nit's up to me to help shut them down."
msgstr "Sì. Visto che ho contribuito a crearli,\nspetta a me contribuire a fermarli."

msgctxt "11||speech_list_cln||table||238||||4"
msgid "So, what happens now?\nAre you gonna try and stop them?"
msgstr "Quindi, cosa succede ora?\nProverete a fermarli?"

msgctxt "11||speech_list_cln||table||239||||4"
msgid "Now that we've meddled with their plans,\nJUSTIS won't rest until we're dead."
msgstr "Ora che ci siamo intromessi nei loro piani,\nJUSTIS non si fermerà finché non saremo morti."

msgctxt "11||speech_list_cln||table||240||||4"
msgid "They'll probably send the Six Lunatics after us."
msgstr "Probabilmente ci manderanno contro i Sei Folli."

msgctxt "11||speech_list_cln||table||241||||4"
msgid "The Six Lunatics...?"
msgstr "I Sei Folli...?"

msgctxt "11||speech_list_cln||table||242||||4"
msgid "They're the leaders of JUSTIS."
msgstr "Sono i leader di JUSTIS."

msgctxt "11||speech_list_cln||table||243||||4"
msgid "In order to strengthen the organization, Okada\nthrew some money around and brought them in."
msgstr "Per rafforzare l'organizzazione, Okada ha\nsborsato un sacco di soldi e li ha reclutati."

msgctxt "11||speech_list_cln||table||244||||4"
msgid "They might be strong, but they all\nhave some kinda shady past."
msgstr "Saranno anche forti, ma hanno\ntutti un passato alquanto losco."

msgctxt "11||speech_list_cln||table||245||||4"
msgid "Ever since they joined, JUSTIS has steadily\ntransformed into a terrible gang."
msgstr "Da quando si sono uniti, JUSTIS si è inesorabilmente\ntrasformata in una gang terribile."

msgctxt "11||speech_list_cln||table||246||||4"
msgid "The Six Lunatics, huh?\nAre they really that powerful?"
msgstr "I Sei Folli, eh?\nSono davvero così forti?"

msgctxt "11||speech_list_cln||table||247||||4"
msgid "From what I can tell, each one of them\nis just as strong a fighter as you, Kiryu-san."
msgstr "Per quello che ne so, ognuno di loro\nè un combattente forte quanto te, Kiryu-san."

msgctxt "11||speech_list_cln||table||248||||4"
msgid "Huh? As strong as Kiryu-san...?\nNo way...!"
msgstr "Eh? Forti come Kiryu-san...?\nImpossibile...!"

msgctxt "11||speech_list_cln||table||249||||4"
msgid "Didn't you see him fight?\nYou did see him fight, didn't you?"
msgstr "Non l'hai visto combattere?\nL'hai visto combattere, vero?"

msgctxt "11||speech_list_cln||table||250||||4"
msgid "...Yeah."
msgstr "...Sì."

msgctxt "11||speech_list_cln||table||251||||4"
msgid "Why did we have to make enemies outta\nthose guys!? We'll never win against them!"
msgstr "Perché abbiamo dovuto farci nemici\nquei tizi!? Non vinceremo mai contro di loro!"

msgctxt "11||speech_list_cln||table||252||||4"
msgid "You're the one who started it! I thought you\ndidn't wanna back down, no matter what!"
msgstr "Sei stato tu a cominciare! Credevo\nche non volessi tirarti indietro, per nessuna ragione!"

msgctxt "11||speech_list_cln||table||253||||4"
msgid "The Six Lunatics..."
msgstr "I Sei Folli..."

msgctxt "11||speech_list_cln||table||254||||4"
msgid "My dear Six Lunatics. We are all present, yes?\nIt seems we've run into a minor snag."
msgstr "Miei cari Sei Folli. Siamo tutti presenti, giusto?\nSembra che abbiamo incontrato un piccolo ostacolo."

msgctxt "11||speech_list_cln||table||255||||4"
msgid "What kinda snag're you talkin' about?\nJust get on with it. I'm busy here."
msgstr "Di che razza di ostacolo stai parlando?\nArriva al punto. Sono occupato."

msgctxt "11||speech_list_cln||table||256||||4"
msgid "Did the cops nab one of our boys?\nI'm right, ain't I?"
msgstr "Gli sbirri hanno beccato uno dei nostri ragazzi?\nHo indovinato, vero?"

msgctxt "11||speech_list_cln||table||257||||4"
msgid "You're in for a real bruisin'\nif that's all this is, Komei."
msgstr "Ti riempirò di botte se è solo\nper questo, Komei."

msgctxt "11||speech_list_cln||table||258||||4"
msgid "It's because of Joe."
msgstr "È a causa di Joe."

msgctxt "11||speech_list_cln||table||259||||4"
msgid "Hm? How did you know that?"
msgstr "Mhm? Come facevi a saperlo?"

msgctxt "11||speech_list_cln||table||260||||4"
msgid "I heard you put a crew together\nand went to go take him out."
msgstr "Ho saputo che hai messo insieme una squadra\ne sei andato a farlo fuori."

msgctxt "11||speech_list_cln||table||261||||4"
msgid "What were you thinking, Komei?\nThat's not your call to make."
msgstr "A cosa stavi pensando, Komei?\nNon è una decisione che spetta a te."

msgctxt "11||speech_list_cln||table||262||||4"
msgid "Okada told us to leave Joe alone.\nYou in the habit of disobeying orders now?"
msgstr "Okada ci ha detto di lasciare in pace Joe.\nOra hai preso il vizio di disobbedire agli ordini?"

msgctxt "11||speech_list_cln||table||263||||4"
msgid "Let's cool it, guys.\nIt's no problemo."
msgstr "Datevi una calmata, ragazzi.\nNon c'è problema."

msgctxt "11||speech_list_cln||table||264||||4"
msgid "People've gotta pay the price for cutting\nties with an organization like us."
msgstr "La gente deve pagare il prezzo per aver tagliato\ni ponti con un'organizzazione come la nostra."

msgctxt "11||speech_list_cln||table||265||||4"
msgid "That applies to Joe, too. He might be a founder,\nbut he doesn't get a free pass."
msgstr "E questo vale anche per Joe. Sarà anche un fondatore,\nma non ha mica il lasciapassare."

msgctxt "11||speech_list_cln||table||266||||4"
msgid "JUSTIS is a huge organization, remember.\nWe've gotta set the right example."
msgstr "JUSTIS è una grossa organizzazione, ricordate.\nDobbiamo dare il giusto esempio."

msgctxt "11||speech_list_cln||table||267||||4"
msgid "You've got a point there. So?\nWhat's this little snag we hit?"
msgstr "Qui hai ragione. E quindi?\nQual è questo piccolo ostacolo in cui ci siamo imbattuti?"

msgctxt "11||speech_list_cln||table||268||||4"
msgid "In short..."
msgstr "In breve..."

msgctxt "11||speech_list_cln||table||269||||4"
msgid "Joe managed to defeat a large squadron\nI had sent out to destroy him."
msgstr "Joe è riuscito a sconfiggere un nutrito squadrone\nche avevo inviato per annientarlo."

msgctxt "11||speech_list_cln||table||270||||4"
msgid "What?"
msgstr "Cosa?"

msgctxt "11||speech_list_cln||table||271||||4"
msgid "After his defection, Joe returned\nto his hometown of Onomichi."
msgstr "Dopo la sua defezione, Joe è tornato\nnella sua città natale di Onomichi."

msgctxt "11||speech_list_cln||table||272||||4"
msgid "It appears as though some local friends\nof his helped push our forces back."
msgstr "Sembra che alcuni suoi amici locali\nlo abbiano aiutato a respingere le nostre forze."

msgctxt "11||speech_list_cln||table||273||||4"
msgid "This is no minor snag, Komei.\nIt's a total failure."
msgstr "Questo non è un piccolo ostacolo, Komei.\nÈ un fallimento totale."

msgctxt "11||speech_list_cln||table||274||||4"
msgid "You're draggin' the JUSTIS name through the mud!"
msgstr "Stai infangando il nome di JUSTIS!"

msgctxt "11||speech_list_cln||table||275||||4"
msgid "M-My apologies..."
msgstr "L-Le mie scuse..."

msgctxt "11||speech_list_cln||table||276||||4"
msgid "Yano."
msgstr "Yano."

msgctxt "11||speech_list_cln||table||277||||4"
msgid "Hm?"
msgstr "Mhm?"

msgctxt "11||speech_list_cln||table||278||||4"
msgid "Here are some funds."
msgstr "Ecco dei fondi."

msgctxt "11||speech_list_cln||table||279||||4"
msgid "Sorry, but I need you down in Onomichi."
msgstr "Scusami, ma ho bisogno di te giù a Onomichi."

msgctxt "11||speech_list_cln||table||280||||4"
msgid "C'mon, me again?\nGuess I can't say no, though."
msgstr "Andiamo, di nuovo io?\nImmagino di non poter dire di no, però."

msgctxt "11||speech_list_cln||table||281||||4"
msgid "But if there's any cash left... \nI'm ain't gonna hesitate to hit the town."
msgstr "Ma se avanzerà un po' di contante... \nNon esiterò a spassarmela in città."

msgctxt "11||speech_list_cln||table||282||||4"
msgid "Fine by me. However... You're one of\nthe Six Lunatics. Failure isn't an option."
msgstr "Per me va bene. Tuttavia... sei uno\ndei Sei Folli. Il fallimento non è contemplato."

msgctxt "11||speech_list_cln||table||283||||4"
msgid "If ya screw this one up,\nI'll be happy to kick your ass."
msgstr "Se fai un casino stavolta,\nsarò felice di prenderti a calci in culo."

msgctxt "11||speech_list_cln||table||284||||4"
msgid "What he means is, you're outta the group\nif you fail. Them's JUSTIS rules."
msgstr "Intende dire che sei fuori dal gruppo\nse fallisci. Queste sono le regole di JUSTIS."

msgctxt "11||speech_list_cln||table||285||||4"
msgid "I already know that, so shut the hell up.\nDon't recall asking for a reminder."
msgstr "Lo so già, quindi chiudete quella cazzo di bocca.\nNon ricordo di aver chiesto un promemoria."

msgctxt "11||speech_list_cln||table||286||||4"
msgid "Welp, guess I'll start packin' my things.\nMaybe I should get a travel book!"
msgstr "Beh, mi sa che inizierò a fare le valigie.\nForse dovrei comprarmi una guida turistica!"

msgctxt "11||speech_list_cln||table||287||||4"
msgid "You really messed this up, Joe..."
msgstr "Hai fatto davvero un bel casino, Joe..."

msgctxt "11||speech_list_cln||table||288||||4"
msgid "You wanna form a new team!?"
msgstr "Vuoi formare un nuovo gruppo!?"

msgctxt "11||speech_list_cln||table||289||||4"
msgid "Yeah. JUSTIS is gonna send the Six Lunatics\nafter us, without a doubt."
msgstr "Sì. JUSTIS manderà i Sei Folli\na cercarci, senza ombra di dubbio."

msgctxt "11||speech_list_cln||table||290||||4"
msgid "If we want to fight them off, we'll need to\ngather an army and form a defense force."
msgstr "Se vogliamo respingerli, dovremo radunare\nun esercito e formare una forza di difesa."

msgctxt "11||speech_list_cln||table||291||||4"
msgid "Right... I guess we can't turn back now.\nLet's do it! My mind's made up!"
msgstr "Giusto... Immagino che ormai non possiamo più tirarci indietro.\nFacciamolo! Ho preso la mia decisione!"

msgctxt "11||speech_list_cln||table||292||||4"
msgid "All right, let's make a new team with Joe as our\nleader! We're gonna be even bigger than JUSTIS!"
msgstr "D'accordo, creiamo un nuovo gruppo con Joe come nostro\nleader! Diventeremo ancora più grandi di JUSTIS!"

msgctxt "11||speech_list_cln||table||293||||4"
msgid "No, I'm no leader anymore."
msgstr "No, non sono più un leader."

msgctxt "11||speech_list_cln||table||294||||4"
msgid "Huh? But then..."
msgstr "Eh? Ma allora..."

msgctxt "11||speech_list_cln||table||295||||4"
msgid "Y-You can't mean..."
msgstr "N-Non vorrai dire che..."

msgctxt "11||speech_list_cln||table||296||||4"
msgid "Kiryu-san.\nWill you be our leader?"
msgstr "Kiryu-san.\nVuoi essere il nostro leader?"

msgctxt "11||speech_list_cln||table||297||||4"
msgid "You want me?"
msgstr "Volete me?"

msgctxt "11||speech_list_cln||table||298||||4"
msgid "Yeah. JUSTIS is massive, so we're gonna need\na team just as big if we want to fight them."
msgstr "Sì. JUSTIS è immensa, quindi avremo bisogno di\nun gruppo altrettanto grande se vogliamo combatterli."

msgctxt "11||speech_list_cln||table||299||||4"
msgid "I'm not too keen on managing people, though."
msgstr "Non vado pazzo per l'idea di dover gestire le persone, però."

msgctxt "11||speech_list_cln||table||300||||4"
msgid "Besides, I'm responsible for this in the first place."
msgstr "Inoltre, sono io il principale responsabile per tutto questo."

msgctxt "11||speech_list_cln||table||301||||4"
msgid "With me at the helm... there's no way we'd ever\nbe able to actually bring JUSTIS down."
msgstr "Con me al comando... non c'è possibilità che riusciamo\nmai a far crollare JUSTIS."

msgctxt "11||speech_list_cln||table||303||||4"
msgid "Plus, we almost definitely would've lost that\nbattle earlier if we didn't have your leadership."
msgstr "In più, avremmo quasi sicuramente perso quella battaglia\ndi prima se non ci fossi stato tu a guidarci."

msgctxt "11||speech_list_cln||table||304||||4"
msgid "If we wanna win...\nWe need your guidance, Kiryu-san!"
msgstr "Se vogliamo vincere...\nAbbiamo bisogno della tua guida, Kiryu-san!"

msgctxt "11||speech_list_cln||table||305||||4"
msgid "Please... Lend us your strength!"
msgstr "Ti prego... Prestaci la tua forza!"

msgctxt "11||speech_list_cln||table||306||||4"
msgid "I appreciate the offer, but there are other\nthings I need to be taking care of right now."
msgstr "Apprezzo l'offerta, ma ci sono altre\ncose di cui devo occuparmi in questo momento."

msgctxt "11||speech_list_cln||table||307||||4"
msgid "To be honest... I just don't have the time\nfor this conflict of yours."
msgstr "A dirla tutta... Non ho proprio tempo\nper questo vostro conflitto."

msgctxt "11||speech_list_cln||table||308||||4"
msgid "I figured you would say that."
msgstr "Immaginavo che avresti detto così."

msgctxt "11||speech_list_cln||table||309||||4"
msgid "But it really would be better if you stuck\naround with us, Kiryu-san!"
msgstr "Ma sarebbe davvero meglio se tu\nrimanessi con noi, Kiryu-san!"

msgctxt "11||speech_list_cln||table||310||||4"
msgid "And why's that?"
msgstr "E per quale motivo?"

msgctxt "11||speech_list_cln||table||311||||4"
msgid "Because, well... JUSTIS is gonna stop\nat nothing now to make sure you end up dead."
msgstr "Perché, beh... JUSTIS non si fermerà davanti a\nnulla per assicurarsi di vederti morto."

msgctxt "11||speech_list_cln||table||312||||4"
msgid "They'll keep sending team after team\nof men to hunt you down."
msgstr "Continueranno a mandare squadra dopo squadra\ndi uomini per darti la caccia."

msgctxt "11||speech_list_cln||table||313||||4"
msgid "You can't take them all on alone.\nEven you would wear down eventually."
msgstr "Non puoi affrontarli tutti da solo.\nPersino tu finiresti per stancarti, alla fine."

msgctxt "11||speech_list_cln||table||315||||4"
msgid "Kiryu-san... Sorry for dragging you into this."
msgstr "Kiryu-san... Scusa se ti abbiamo trascinato in tutto questo."

msgctxt "11||speech_list_cln||table||316||||4"
msgid "But I agree with Masao."
msgstr "Ma sono d'accordo con Masao."

msgctxt "11||speech_list_cln||table||317||||4"
msgid "You should probably stay with us...\nAt least to protect yourself from them."
msgstr "Probabilmente ti conviene restare con noi...\nSe non altro per proteggerti da loro."

msgctxt "11||speech_list_cln||table||318||||4"
msgid "Please."
msgstr "Per favore."

msgctxt "11||speech_list_cln||table||319||||4"
msgid "Come on..."
msgstr "Dai..."

msgctxt "11||speech_list_cln||table||320||||4"
msgid "Please. I know you're busy, but I need to set\nthings right. I need to wake Okada up."
msgstr "Ti prego. So che sei impegnato, ma devo sistemare le cose.\nDevo far svegliare Okada."

msgctxt "11||speech_list_cln||table||321||||4"
msgid "He's, well... He's my best friend. I know he's\nlost sight of his goals, but I can't abandon him."
msgstr "Lui è, beh... Lui è il mio migliore amico. So che ha perso\ndi vista i suoi obiettivi, ma non posso abbandonarlo."

msgctxt "11||speech_list_cln||table||322||||4"
msgid "That hits close to home..."
msgstr "Questo mi tocca da vicino..."

msgctxt "11||speech_list_cln||table||324||||4"
msgid "All right, then. I'll help you out.\nNow lift your head back up."
msgstr "E va bene. Vi darò una mano.\nOra rialzate la testa."

msgctxt "11||speech_list_cln||table||325||||4"
msgid "Seriously!? This is great, Joe-san!"
msgstr "Sul serio!? È fantastico, Joe-san!"

msgctxt "11||speech_list_cln||table||326||||4"
msgid "Kiryu-san..."
msgstr "Kiryu-san..."

msgctxt "11||speech_list_cln||table||327||||4"
msgid "As you said, it would be a real problem\nif I had to deal with JUSTIS alone."
msgstr "Come hai detto, sarebbe un vero problema\nse dovessi occuparmi di JUSTIS da solo."

msgctxt "11||speech_list_cln||table||328||||4"
msgid "Besides... I can understand how you\nmight feel about that friend of yours."
msgstr "E poi... posso capire come ti senti\nnei confronti del tuo amico."

msgctxt "11||speech_list_cln||table||329||||4"
msgid "Kiryu-san... Thanks a ton. With you by\nour side... this team's gonna be unstoppable!"
msgstr "Kiryu-san... Grazie infinite. Con te al nostro\nfianco... questo gruppo sarà inarrestabile!"

msgctxt "11||speech_list_cln||table||330||||4"
msgid "All right! We're gonna make the best team\never with Kiryu-san as our leader!"
msgstr "D'accordo! Formeremo la migliore squadra\ndi sempre con Kiryu-san come nostro leader!"

msgctxt "11||speech_list_cln||table||331||||4"
msgid "Yeah!"
msgstr "Sì!"

msgctxt "11||speech_list_cln||table||332||||4"
msgid "Oh! What do we wanna do about our name?\nSomething cool would be good, right?"
msgstr "Oh! Che facciamo per il nome?\nQualcosa di figo sarebbe l'ideale, no?"

msgctxt "11||speech_list_cln||table||333||||4"
msgid "Wait, we need a name?"
msgstr "Aspetta, ci serve un nome?"

msgctxt "11||speech_list_cln||table||334||||4"
msgid "Think about it. Every famous team\nhas to be recognizable somehow."
msgstr "Pensaci. Ogni squadra famosa\ndeve essere riconoscibile in qualche modo."

msgctxt "11||speech_list_cln||table||335||||4"
msgid "We've gotta make sure ours is good, though.\nMaybe we could use English like JUSTIS did..."
msgstr "Dobbiamo assicurarci che il nostro sia all'altezza, però.\nForse potremmo usare l'inglese, come ha fatto JUSTIS..."

msgctxt "11||speech_list_cln||table||336||||4"
msgid "Hm... We should probably let our leader decide."
msgstr "Mhm... Forse dovremmo far decidere al nostro leader."

msgctxt "11||speech_list_cln||table||337||||4"
msgid "Me...?"
msgstr "Io...?"

msgctxt "11||speech_list_cln||table||338||||4"
msgid "Yeah. You're the head of our team, Kiryu-san,\nso our name should represent that somehow."
msgstr "Sì. Sei a capo della nostra squadra, Kiryu-san,\nquindi il nostro nome dovrebbe rispecchiare la cosa in qualche modo."

msgctxt "11||speech_list_cln||table||339||||4"
msgid "We could go with K-2016. Or the Kiryu Revolution\nArmy! That might be too old-school, though..."
msgstr "Potremmo chiamarci K-2016. Oppure Esercito\nRivoluzionario di Kiryu! Forse è troppo vecchio stile, però..."

msgctxt "11||speech_list_cln||table||340||||4"
msgid "Hm... A team name that includes my own..."
msgstr "Mhm... Un nome per la squadra che includa il mio..."

msgctxt "11||speech_list_cln||table||341||||4"
msgid "What about the Kiryu Clan?"
msgstr "Che ne dite di Clan Kiryu?"

msgctxt "11||speech_list_cln||table||342||||4"
msgid "K-Kiryu Clan?"
msgstr "C-Clan Kiryu?"

msgctxt "11||speech_list_cln||table||343||||4"
msgid "......"
msgstr "......"

msgctxt "11||speech_list_cln||table||344||||4"
msgid "What's wrong with that? I thought these kinds\nof groups were always clans or families."
msgstr "Che c'è di strano? Pensavo che questo genere\ndi gruppi fosse sempre diviso in clan o famiglie."

msgctxt "11||speech_list_cln||table||345||||4"
msgid "It's not that weird, really."
msgstr "Non è poi così strano, in fondo."

msgctxt "11||speech_list_cln||table||346||||4"
msgid "Y-Yeah, I guess you're not wrong...\nBut it's pretty yakuza sounding..."
msgstr "S-Sì, immagino che tu non abbia torto...\nMa suona un po' da yakuza..."

msgctxt "11||speech_list_cln||table||347||||4"
msgid "Well, I think it's great.\nOur leader has some excellent taste."
msgstr "Beh, a me sembra fantastico.\nIl nostro leader ha un gusto eccellente."

msgctxt "11||speech_list_cln||table||348||||4"
msgid "You can't be serious..."
msgstr "Non puoi dire sul serio..."

msgctxt "11||speech_list_cln||table||349||||4"
msgid "This is the beginning of the Kiryu Clan,\nthe ones who will bring JUSTIS to its knees."
msgstr "Questo è l'inizio del Clan Kiryu,\ncoloro che metteranno in ginocchio JUSTIS."

msgctxt "11||speech_list_cln||table||350||||4"
msgid "Not only are we gonna protect our hometown\nof Onomichi... But we're gonna wake Okada up, too!"
msgstr "Non ci limiteremo a proteggere la nostra città,\nOnomichi... Sveglieremo anche Okada!"

msgctxt "11||speech_list_cln||table||351||||4"
msgid "All right! Let's do this!"
msgstr "D'accordo! Diamoci dentro!"

msgctxt "11||speech_list_cln||table||352||||4"
msgid "Heh... Here goes nothing..."
msgstr "Ah, che seccatura."

msgctxt "11||speech_list_cln||table||353||||4"
msgid "So... I know I'm the team leader,\nbut what exactly does that entail?"
msgstr "Quindi... so di essere il leader del gruppo,\nma cosa comporta, di preciso?"

msgctxt "11||speech_list_cln||table||354||||4"
msgid "Give us orders in battle, Kiryu-san.\nJust like what you did for us earlier."
msgstr "Darci ordini in battaglia, Kiryu-san.\nProprio come hai fatto prima per noi."

msgctxt "11||speech_list_cln||table||355||||4"
msgid "Beyond that... It's up to you\nto organize the Kiryu Clan."
msgstr "Oltre a questo... sta a te\norganizzare il Clan Kiryu."

msgctxt "11||speech_list_cln||table||356||||4"
msgid "Organize it...?"
msgstr "Organizzarlo...?"

msgctxt "11||speech_list_cln||table||357||||4"
msgid "Yes. We don't have many members at the moment,\nbut we'll start growing any minute now."
msgstr "Esatto. Al momento non abbiamo molti membri,\nma inizieremo a espanderci da un momento all'altro."

msgctxt "11||speech_list_cln||table||358||||4"
msgid "And when we do, we'll need a strong leader to\nkeep things orderly. That's where you come in."
msgstr "E quando lo faremo, avremo bisogno di un leader forte per\nmantenere l'ordine. Ed è qui che entri in gioco tu."

msgctxt "11||speech_list_cln||table||359||||4"
msgid "You'll need to put your strength to good use and\norganize the team to be most efficient, Kiryu-san."
msgstr "Dovrai usare la tua forza a fin di bene e organizzare\nil gruppo perché sia il più efficiente possibile, Kiryu-san."

msgctxt "11||speech_list_cln||table||360||||4"
msgid "Hey, why do I have to do everything...?"
msgstr "Ehi, perché devo fare tutto io...?"

msgctxt "11||speech_list_cln||table||361||||4"
msgid "Don't worry about it. Just make positions\nand assign people like at a company."
msgstr "Non preoccuparti. Ti basta creare delle posizioni e\nassegnare le persone, proprio come in un'azienda."

msgctxt "11||speech_list_cln||table||362||||4"
msgid "I don't really understand how that stuff works...\nBut it would be great if you could do it!"
msgstr "Non capisco proprio come funzionino queste cose...\nMa sarebbe fantastico se te ne occupassi tu!"

msgctxt "11||speech_list_cln||table||363||||4"
msgid "...Fine."
msgstr "...E va bene."

msgctxt "11||speech_list_cln||table||364||||4"
msgid "But I have a pretty biased understanding of the world."
msgstr "Ma ho una visione del mondo piuttosto parziale."

msgctxt "11||speech_list_cln||table||365||||4"
msgid "Anyway, I'll probably structure our team based on\nmy former workplace. Think that would be okay?"
msgstr "Ad ogni modo, probabilmente strutturerò il nostro gruppo in base\nal mio precedente posto di lavoro. Pensi che andrà bene?"

msgctxt "11||speech_list_cln||table||366||||4"
msgid "Yeah, whatever you wanna do! By the way,\nKiryu-san, where exactly did you work?"
msgstr "Sì, fai pure quello che ritieni opportuno! A proposito,\nKiryu-san, dove lavoravi esattamente?"

msgctxt "11||speech_list_cln||table||367||||4"
msgid "Heh... Best that you don't know."
msgstr "Heh... È meglio che tu non lo sappia."

msgctxt "11||speech_list_cln||table||368||||4"
msgid "Oh yeah? Eh, fine by me.\nNow then, it's up to you to organize the Kiryu Clan!"
msgstr "Ah sì? Eh, per me va bene.\nAllora tocca a te organizzare il Clan Kiryu!"

msgctxt "11||speech_list_cln||table||369||||4"
msgid "If you ever want to start a mission or change\nthe team structure, just let me know."
msgstr "Se ti va di iniziare una missione o di modificare\nla struttura del gruppo, fammelo sapere."

msgctxt "11||speech_list_cln||table||370||||4"
msgid "This is real bad, Kiryu-san!\nJUSTIS is sending a swarm of guys our way!"
msgstr "Questa ci voleva proprio, Kiryu-san!\nJUSTIS ci sta mandando contro uno sciame di uomini!"

msgctxt "11||speech_list_cln||table||371||||4"
msgid "So they're finally fighting back."
msgstr "Quindi alla fine hanno reagito."

msgctxt "11||speech_list_cln||table||372||||4"
msgid "There shouldn't be too many here yet.\nLet's attack now while we still can."
msgstr "Non dovrebbero essercene ancora molti da queste\nparti. Attacchiamo ora che possiamo."

msgctxt "11||speech_list_cln||table||373||||4"
msgid "Totally! We're gonna wreck 'em!"
msgstr "Certamente! Li distruggeremo!"

msgctxt "11||speech_list_cln||table||374||||4"
msgid "All right... Let's move."
msgstr "D'accordo... Muoviamoci."

msgctxt "11||speech_list_cln||table||375||||4"
msgid "Look at how many guys they've\nalready sent down here..."
msgstr "Guarda quanti uomini hanno\ngià mandato quaggiù..."

msgctxt "11||speech_list_cln||table||376||||4"
msgid "Compared to the full JUSTIS\nnumbers, this is nothing."
msgstr "Paragonato ai ranghi completi\ndi JUSTIS, questo è niente."

msgctxt "11||speech_list_cln||table||377||||4"
msgid "If we can't win this little skirmish,\nthe war is good as lost."
msgstr "Se non riusciamo a vincere questa piccola scaramuccia,\nla guerra è bella che persa."

msgctxt "11||speech_list_cln||table||378||||4"
msgid "I already knew they were strong...\nbut JUSTIS is even tougher than I imagined."
msgstr "Sapevo già che erano forti...\nma JUSTIS è persino più tosta di quanto immaginassi."

msgctxt "11||speech_list_cln||table||379||||4"
msgid "Maybe, but we still have to take them down.\nIt doesn't matter who they are."
msgstr "Forse, ma dobbiamo comunque abbatterli.\nNon importa chi siano."

msgctxt "11||speech_list_cln||table||380||||4"
msgid "That's what men do, right?"
msgstr "È questo che fanno gli uomini, vero?"

msgctxt "11||speech_list_cln||table||381||||4"
msgid "Yeah, something like that."
msgstr "Sì, qualcosa del genere."

msgctxt "11||speech_list_cln||table||382||||4"
msgid "Anyway, that's enough talk.\nCome on... Let's do this!"
msgstr "Comunque sia, basta chiacchiere.\nAndiamo... Facciamogli vedere chi siamo!"

msgctxt "11||speech_list_cln||table||383||||4"
msgid "Okay!"
msgstr "Ricevuto!"

msgctxt "11||speech_list_cln||table||384||||4"
msgid "Gotcha!"
msgstr "Ricevuto!"

msgctxt "11||speech_list_cln||table||385||||4"
msgid "Aw yeah! Kiryu-san, Joe-san!\nWe did it!"
msgstr "Oh, sì! Kiryu-san, Joe-san!\nCe l'abbiamo fatta!"

msgctxt "11||speech_list_cln||table||386||||4"
msgid "Looks like we're at least strong enough\nto take down some two-bit thugs."
msgstr "Sembra che siamo almeno abbastanza forti\nda sconfiggere dei teppistelli da due soldi."

msgctxt "11||speech_list_cln||table||387||||4"
msgid "Bravo, bravo!\nExcellent work, you guys!"
msgstr "Bravi, bravi!\nOttimo lavoro, ragazzi!"

msgctxt "11||speech_list_cln||table||388||||4"
msgid "Hm?"
msgstr "Mhm?"

msgctxt "11||speech_list_cln||table||389||||4"
msgid "That voice..."
msgstr "Questa voce..."

msgctxt "11||speech_list_cln||table||390||||4"
msgid "I knew it... Yano."
msgstr "Lo sapevo... Yano."

msgctxt "11||speech_list_cln||table||391||||4"
msgid "Long time no see, Joe-kun."
msgstr "Da quanto tempo, Joe-kun."

msgctxt "11||speech_list_cln||table||392||||4"
msgid "Didn't think you'd go runnin' back home.\nKinda pathetic, don't ya think?"
msgstr "Non pensavo che saresti scappato a casa con la coda\ntra le gambe. Piuttosto patetico, non credi?"

msgctxt "11||speech_list_cln||table||393||||4"
msgid "Who is this guy?"
msgstr "Chi è questo tizio?"

msgctxt "11||speech_list_cln||table||394||||4"
msgid "So you're old man Kiryu, huh?"
msgstr "Quindi tu sei il vecchio Kiryu, eh?"

msgctxt "11||speech_list_cln||table||395||||4"
msgid "Nice to meet ya! I'm one of the most\ntalented producers for JUSTIS."
msgstr "Piacere di conoscerti! Sono uno dei produttori\npiù talentuosi di JUSTIS."

msgctxt "11||speech_list_cln||table||396||||4"
msgid "Toru Yano!"
msgstr "Toru Yano!"

msgctxt "11||speech_list_cln||table||397||||4"
msgid "That's my name.\nIt's a pleasure to meet ya."
msgstr "Questo è il mio nome.\nÈ un piacere conoscerti."

msgctxt "11||speech_list_cln||table||398||||4"
msgid "What's this guy's deal?"
msgstr "Qual è il problema di questo tizio?"

msgctxt "11||speech_list_cln||table||399||||4"
msgid "He's one of the Six Lunatics, Toru Yano. He's\ncalled the \"raid commander\" over at JUSTIS."
msgstr "Lui è uno dei Sei Folli, Toru Yano. Su a\nJUSTIS lo chiamano il \"comandante delle incursioni\"."

msgctxt "11||speech_list_cln||table||400||||4"
msgid "He used to be an expert thief and fraudster,\nat least until Okada took him in."
msgstr "Era un ladro esperto e un truffatore,\nalmeno finché Okada non l'ha preso con sé."

msgctxt "11||speech_list_cln||table||401||||4"
msgid "Now he's the guy in charge of all their petty crimes.\nA horrible, deceitful man, if you ask me."
msgstr "Ora è l'uomo incaricato di tutti i loro piccoli crimini.\nUn uomo orribile e disonesto, se me lo chiedi."

msgctxt "11||speech_list_cln||table||402||||4"
msgid "Whoa, whoa, whoa! That's pretty\nnasty stuff to say about an old friend."
msgstr "Whoa, whoa, whoa! Queste sono cose\npiuttosto cattive da dire su un vecchio amico."

msgctxt "11||speech_list_cln||table||403||||4"
msgid "Besides, I thought I just said I'm a producer."
msgstr "Inoltre, pensavo di aver appena detto di essere un produttore."

msgctxt "11||speech_list_cln||table||404||||4"
msgid "I work day and night producin' methods for\nthe younger boys to bring in cash."
msgstr "Lavoro giorno e notte per produrre metodi\ncon cui i ragazzi più giovani possano fare soldi."

msgctxt "11||speech_list_cln||table||405||||4"
msgid "Producer, my ass."
msgstr "Produttore un cazzo."

msgctxt "11||speech_list_cln||table||406||||4"
msgid "You know how many people've gotten\nsent to prison because of you?"
msgstr "Hai idea di quante persone siano finite\nin prigione a causa tua?"

msgctxt "11||speech_list_cln||table||407||||4"
msgid "Don't gimme that!\nYou're thinking too small!"
msgstr "Risparmiami le prediche!\nPensi troppo in piccolo!"

msgctxt "11||speech_list_cln||table||408||||4"
msgid "The only reason JUSTIS is profitin' is\nbecause I'm rakin' in the dough, right?"
msgstr "L'unica ragione per cui JUSTIS sta guadagnando è\nperché io sto portando a casa la grana, giusto?"

msgctxt "11||speech_list_cln||table||409||||4"
msgid "I don't care about their profits.\nYou're here to fight us, aren't you?"
msgstr "A me non importano i loro profitti.\nSei qui per combatterci, non è vero?"

msgctxt "11||speech_list_cln||table||410||||4"
msgid "Now, now. Chill out, bro. I just got here.\nI'm not lookin' to fight just yet."
msgstr "Andiamo, su. Datti una calmata, fratello. Sono appena\narrivato. Non sto ancora cercando di combattere."

msgctxt "11||speech_list_cln||table||411||||4"
msgid "I mean, it's my first time in Onomichi. I was\nthinkin' I'd grab some ramen and take in the sights."
msgstr "Voglio dire, è la mia prima volta a Onomichi. Pensavo\ndi prendermi un ramen e ammirare il panorama."

msgctxt "11||speech_list_cln||table||412||||4"
msgid "I'm down to spare you guys...\nFor the time bein'."
msgstr "Sono disposto a risparmiarvi...\nPer il momento."

msgctxt "11||speech_list_cln||table||413||||4"
msgid "By the way, these fools you just beat\nwere just a nice little sampler for ya."
msgstr "A proposito, questi idioti che avete appena battuto\nerano solo un piccolo antipasto per voi."

msgctxt "11||speech_list_cln||table||414||||4"
msgid "From now on it's going to\nbe wave after wave."
msgstr "Da adesso in poi ci sarà\nun'ondata dopo l'altra."

msgctxt "11||speech_list_cln||table||415||||4"
msgid "Hope ya tire yourselves out tryin'\nto deal with all of 'em."
msgstr "Spero vi stanchiate bene nel tentativo\ndi sbarazzarvi di tutti loro."

msgctxt "11||speech_list_cln||table||416||||4"
msgid "And once you're nice n' exhausted,\nI'll come in and take out the trash."
msgstr "E una volta che sarete belli ed esausti,\ninterverrò io e butterò fuori la spazzatura."

msgctxt "11||speech_list_cln||table||417||||4"
msgid "You bastard...!"
msgstr "Bastardo...!"

msgctxt "11||speech_list_cln||table||418||||4"
msgid "I ain't like the other Lunatics. I'm smart, y'know.\nThat's just how I do things."
msgstr "Io non sono come gli altri Folli. Sono un dritto, sai.\nÈ semplicemente il modo in cui faccio le cose."

msgctxt "11||speech_list_cln||table||419||||4"
msgid "Anyway, try to stay alive 'til\nI'm ready for ya, okay?"
msgstr "Ad ogni modo, cercate di restare vivi finché\nnon sarò pronto per voi, okay?"

msgctxt "11||speech_list_cln||table||421||||4"
msgid "That guy really pisses me off.\nIs he seriously that tough?"
msgstr "Quel tizio mi fa davvero incazzare.\nÈ sul serio così forte?"

msgctxt "11||speech_list_cln||table||422||||4"
msgid "He is. His appearance hides his true skill.\nIf we want to beat him, we'll need to prepare."
msgstr "Lo è. L'aspetto nasconde la sua vera abilità.\nSe vogliamo batterlo, dovremo prepararci a dovere."

msgctxt "11||speech_list_cln||table||424||||4"
msgid "Hot damn, you guys're kinda tough."
msgstr "Porca puttana, ragazzi, siete un po' tostarelli."

msgctxt "11||speech_list_cln||table||425||||4"
msgid "Yano..."
msgstr "Yano..."

msgctxt "11||speech_list_cln||table||426||||4"
msgid "Oh! Glad you remembered me.\nThat's my name."
msgstr "Oh! Mi fa piacere che ti sia ricordato di me.\nÈ il mio nome."

msgctxt "11||speech_list_cln||table||427||||4"
msgid "Toru Yano!"
msgstr "Toru Yano!"

msgctxt "11||speech_list_cln||table||428||||4"
msgid "Sorry to keep ya waitin', Kiryu-san!"
msgstr "Scusa per l'attesa, Kiryu-san!"

msgctxt "11||speech_list_cln||table||429||||4"
msgid "I wasn't holding my breath."
msgstr "Non stavo trattenendo il fiato."

msgctxt "11||speech_list_cln||table||430||||4"
msgid "C'monnn, man. Eh, whatevs.\nI just stopped by today for my last warning."
msgstr "Daiii, amico. Vabbe', fa lo stesso.\nOggi sono passato per il mio ultimo avvertimento."

msgctxt "11||speech_list_cln||table||431||||4"
msgid "My whirlwind tour of Onomichi's finally over.\nIt's goddamn beautiful here."
msgstr "Il mio tour lampo di Onomichi è finalmente giunto\nal termine. È un posto fottutamente bellissimo."

msgctxt "11||speech_list_cln||table||432||||4"
msgid "Makes sense that your bastard friend Joe\nwould run for his life to a place like this."
msgstr "Ha senso che quel tuo amico bastardo di Joe\nsia fuggito per salvarsi la vita in un posto del genere."

msgctxt "11||speech_list_cln||table||433||||4"
msgid "You..."
msgstr "Tu..."

msgctxt "11||speech_list_cln||table||434||||4"
msgid "I wish I could relax a bit more, but the Lunatics\nkeep yappin' about how I need to hurry things up."
msgstr "Vorrei potermi rilassare un po' di più, ma i Folli\ncontinuano a blaterare che devo sbrigarmi."

msgctxt "11||speech_list_cln||table||435||||4"
msgid "Next time we meet, you're gonna be up against me.\nThat'll be the day y'all die."
msgstr "La prossima volta che ci incontreremo, sarò io il vostro\navversario. Sarà il giorno in cui morirete tutti."

msgctxt "11||speech_list_cln||table||436||||4"
msgid "Ya better be ready for the Six Lunatics.\nThe hammer of JUSTIS is comin' down on you!"
msgstr "Sarebbe meglio che foste pronti per i Sei Folli.\nIl martello di JUSTIS sta per abbattersi su di voi!"

msgctxt "11||speech_list_cln||table||437||||4"
msgid "You're not gonna know what hit ya!\nFools!"
msgstr "Non saprete nemmeno cosa vi ha colpito!\nIdioti!"

msgctxt "11||speech_list_cln||table||438||||4"
msgid "So Yano is our next opponent..."
msgstr "Quindi Yano è il nostro prossimo avversario..."

msgctxt "11||speech_list_cln||table||439||||4"
msgid "Yeah. He's strong, but the Kiryu Clan\nhas grown a lot stronger lately, too."
msgstr "Sì. È forte, ma anche il Clan Kiryu\nè diventato molto più forte ultimamente."

msgctxt "11||speech_list_cln||table||440||||4"
msgid "Let's take him down, Kiryu-san."
msgstr "Sconfiggiamolo, Kiryu-san."

msgctxt "11||speech_list_cln||table||441||||4"
msgid "Right."
msgstr "D'accordo."

msgctxt "11||speech_list_cln||table||442||||4"
msgid "Toru Yano... He's no ordinary man."
msgstr "Toru Yano... Non è un uomo comune."

msgctxt "11||speech_list_cln||table||443||||4"
msgid "It's finally time for our fight against Yano.\nHe's gonna be miles ahead of our competition so far."
msgstr "È finalmente giunto il momento del nostro scontro con Yano.\nSarà spanne sopra qualsiasi avversario affrontato finora."

msgctxt "11||speech_list_cln||table||444||||4"
msgid "Kiryu-san... Let's give this all we've got!"
msgstr "Kiryu-san... Diamo il massimo!"

msgctxt "11||speech_list_cln||table||445||||4"
msgid "Yeah, let's get going. It's time we show\nhim what true strength looks like."
msgstr "Sì, muoviamoci. È ora di mostrargli\nche aspetto ha la vera forza."

msgctxt "11||speech_list_cln||table||446||||4"
msgid "Right!"
msgstr "Esatto!"

msgctxt "11||speech_list_cln||table||447||||4"
msgid "Gotcha!"
msgstr "Ricevuto!"

msgctxt "11||speech_list_cln||table||448||||4"
msgid "It's about time y'all showed, Kiryu Clan."
msgstr "Era ora che vi faceste vivi, Clan Kiryu."

msgctxt "11||speech_list_cln||table||449||||4"
msgid "I hope you're ready for us!"
msgstr "Spero tu sia pronto per noi!"

msgctxt "11||speech_list_cln||table||450||||4"
msgid "If we manage to bring Yano down, that should\nstrike a huge blow right to the heart of JUSTIS."
msgstr "Se riusciamo a sconfiggere Yano, dovrebbe\nessere un duro colpo inferto al cuore di JUSTIS."

msgctxt "11||speech_list_cln||table||451||||4"
msgid "Beating one of the Six Lunatics will be\na stepping stone for our future."
msgstr "Sconfiggere uno dei Sei Folli sarà\nun trampolino di lancio per il nostro futuro."

msgctxt "11||speech_list_cln||table||452||||4"
msgid "If we can win this... who knows what'll happen.\nLet's give this everything we have, Kiryu-san."
msgstr "Se riusciamo a vincere... chissà cosa succederà.\nMettiamocela tutta, Kiryu-san."

msgctxt "11||speech_list_cln||table||453||||4"
msgid "Yeah. We've let this guy run his mouth at us\nfor long enough. It's time we shut him up."
msgstr "Sì. Abbiamo lasciato che questo tizio sputasse veleno su\ndi noi per fin troppo tempo. È ora di chiudergli la bocca."

msgctxt "11||speech_list_cln||table||454||||4"
msgid "Y'all ready? We are..."
msgstr "Siete pronti? Noi lo siamo..."

msgctxt "11||speech_list_cln||table||455||||4"
msgid "Toru Yano!"
msgstr "Toru Yano!"

msgctxt "11||speech_list_cln||table||456||||4"
msgid "Toru Yano!"
msgstr "Toru Yano!"

msgctxt "11||speech_list_cln||table||457||||4"
msgid "Toru Yano!"
msgstr "Toru Yano!"

msgctxt "11||speech_list_cln||table||458||||4"
msgid "Toru Yano!"
msgstr "Toru Yano!"

msgctxt "11||speech_list_cln||table||459||||4"
msgid "Kill them all!"
msgstr "Uccideteli tutti!"

msgctxt "11||speech_list_cln||table||460||||4"
msgid "Here we go. Kiryu Clan, move out!\nLet's do this!"
msgstr "Ci siamo. Clan Kiryu, in posizione!\nFacciamogli vedere chi siamo!"

msgctxt "11||speech_list_cln||table||461||||4"
msgid "All right!"
msgstr "Sì!"

msgctxt "11||speech_list_cln||table||462||||4"
msgid "Hell yeah!"
msgstr "Sì, cazzo!"

msgctxt "11||speech_list_cln||table||463||||4"
msgid "I don't get it...\nWe had way more guys than you."
msgstr "Non lo capisco...\nAvevamo molti più uomini di voi."

msgctxt "11||speech_list_cln||table||464||||4"
msgid "You've lost, Yano. This town is our home.\nNow take your men and get out of here."
msgstr "Hai perso, Yano. Questa città è casa nostra.\nOra prendi i tuoi uomini e sparisci da qui."

msgctxt "11||speech_list_cln||table||465||||4"
msgid "It ain't gonna be that easy to make me leave."
msgstr "Non sarà così facile farmi andare via."

msgctxt "11||speech_list_cln||table||466||||4"
msgid "Loss isn't an option for one of the Six Lunatics.\nIf I went back now, they'd totally kick me out!"
msgstr "Perdere non è un'opzione per uno dei Sei Folli.\nSe tornassi indietro ora, mi caccerebbero a calci!"

msgctxt "11||speech_list_cln||table||467||||4"
msgid "Sorry, but I'm gonna have to kick your\nguys' asses. That's my only choice."
msgstr "Scusate, ma dovrò farvi il culo.\nÈ la mia unica opzione."

msgctxt "11||speech_list_cln||table||469||||4"
msgid "Playtime's over, buddy. Time to show ya\nthe real might of the Six Lunatics!"
msgstr "La ricreazione è finita, bello. È tempo di\nmostrarvi la vera forza dei Sei Folli!"

msgctxt "11||speech_list_cln||table||470||||4"
msgid "Here I come!"
msgstr "Arrivo!"

msgctxt "11||speech_list_cln||table||471||||4"
msgid "The hell, man?\nHow're you so strong?"
msgstr "Che diavolo, amico?\nCome fate a essere così forti?"

msgctxt "11||speech_list_cln||table||472||||4"
msgid "Hell yeah! We beat one of the Six Lunatics!\nWe took down Yano!"
msgstr "Oh sì! Abbiamo sconfitto uno dei Sei Folli!\nAbbiamo messo k.o. Yano!"

msgctxt "11||speech_list_cln||table||473||||4"
msgid "Mhm. I bet this'll ruffle\nJUSTIS's feathers a bit."
msgstr "Mhm. Scommetto che questo scompiglierà\nun po' le piume a JUSTIS."

msgctxt "11||speech_list_cln||table||474||||4"
msgid "You really think losing Yano'll make us sweat?"
msgstr "Pensate davvero che la sconfitta di Yano ci farà sudare?"

msgctxt "11||speech_list_cln||table||475||||4"
msgid "If anything... you're the hombre\nunder pressure here, Joe."
msgstr "Se non altro... sei tu l'hombre\nsotto pressione qui, Joe."

msgctxt "11||speech_list_cln||table||476||||4"
msgid "You're..."
msgstr "Tu sei..."

msgctxt "11||speech_list_cln||table||477||||4"
msgid "Tranquilo, Joe!\nChill out."
msgstr "Tranquilo, Joe!\nRilassati."

msgctxt "11||speech_list_cln||table||478||||4"
msgid "Is he another one of the Lunatics?"
msgstr "È un altro dei Folli?"

msgctxt "11||speech_list_cln||table||479||||4"
msgid "That's another Lunatic... Naito.\nThey say he's just as strong as Okada himself."
msgstr "È un altro Folle... Naito.\nDicono che sia forte quanto Okada in persona."

msgctxt "11||speech_list_cln||table||480||||4"
msgid "I can't believe they're already\nthrowing Naito at us."
msgstr "Non riesco a credere che ci\nstiano già scagliando contro Naito."

msgctxt "11||speech_list_cln||table||481||||4"
msgid "Excuse me? Look here. Don't go making it\nsound like I got ordered to come here."
msgstr "Come, scusa? Stammi a sentire. Non farlo\nsembrare come se avessi ricevuto l'ordine di venire qui."

msgctxt "11||speech_list_cln||table||482||||4"
msgid "I'm here 'cause I wanna be here.\nNobody told me to do it. Not even Okada."
msgstr "Sono qui perché voglio esserci.\nNessuno mi ha detto di farlo. Nemmeno Okada."

msgctxt "11||speech_list_cln||table||483||||4"
msgid "Truth is, I've got a reason for\ntrekking all the way to Onomichi."
msgstr "La verità è che ho un motivo per essere\nvenuto fin qui a Onomichi."

msgctxt "11||speech_list_cln||table||484||||4"
msgid "Kiryu-san... That reason is you.\nYou're a muy interesante fellow."
msgstr "Kiryu-san... Quel motivo sei tu.\nSei un tizio muy interesante."

msgctxt "11||speech_list_cln||table||485||||4"
msgid "Me...?"
msgstr "Io...?"

msgctxt "11||speech_list_cln||table||486||||4"
msgid "The former Tojo Clan fourth chairman, and\nthe renowned Dragon of Dojima... Kazuma Kiryu."
msgstr "L'ex quarto presidente del Clan Tojo, nonché\nil rinomato Drago di Dojima... Kazuma Kiryu."

msgctxt "11||speech_list_cln||table||487||||4"
msgid "Huh!? The Tojo Clan? Um, Kiryu-san...\nYou're in the yakuza?"
msgstr "Eh!? Il Clan Tojo? Ehm, Kiryu-san...\nSei nella yakuza?"

msgctxt "11||speech_list_cln||table||488||||4"
msgid "Used to be.\nI'm just a civilian now."
msgstr "Lo ero.\nOra sono solo un civile."

msgctxt "11||speech_list_cln||table||489||||4"
msgid "I've got tons of yakuza and mafia amigos floating\naround, so the name Kiryu immediately rang a bell."
msgstr "Ho un sacco di amigos nella yakuza e nella mafia lì\nfuori, quindi il nome Kiryu mi ha subito fatto scattare un campanello."

msgctxt "11||speech_list_cln||table||490||||4"
msgid "In case you forgot... I'm Naito.\nBuenas noches, Kiryu-san."
msgstr "Nel caso te ne fossi scordato... sono Naito.\nBuenas noches, Kiryu-san."

msgctxt "11||speech_list_cln||table||492||||4"
msgid "Guess you and me don't gel too good, huh?"
msgstr "Immagino che io e te non andiamo troppo d'accordo, eh?"

msgctxt "11||speech_list_cln||table||493||||4"
msgid "The legends about you are muy grande, though.\nEvery time I hear one, I feel like I'm gonna puke."
msgstr "Ciononostante le leggende su di te sono muy grande.\nOgni volta che ne sento una, mi viene voglia di vomitare."

msgctxt "11||speech_list_cln||table||494||||4"
msgid "Guys like you and Joe are the worst. Always trying\nto act the hero for some bullshit sense of honor."
msgstr "I tizi come te e Joe sono i peggiori. Che cercano sempre\ndi fare gli eroi per un patetico senso dell'onore."

msgctxt "11||speech_list_cln||table||495||||4"
msgid "I've always wanted to knock you guys down a peg.\nNever thought I'd actually get the chance."
msgstr "Ho sempre voluto abbassare la cresta a tipi come voi.\nNon avrei mai creduto di averne l'occasione."

msgctxt "11||speech_list_cln||table||496||||4"
msgid "So you want to fight?"
msgstr "Quindi vuoi combattere?"

msgctxt "11||speech_list_cln||table||497||||4"
msgid "Tranquilo, Kiryu-san!\nChill out."
msgstr "Tranquilo, Kiryu-san!\nRilassati."

msgctxt "11||speech_list_cln||table||498||||4"
msgid "Didn't you just finish fighting Yano? It'd be way too\nboring to beat you when you're not at your peak."
msgstr "Non hai appena finito di combattere contro Yano? Sarebbe\ntroppo noioso batterti quando non sei al massimo della forma."

msgctxt "11||speech_list_cln||table||499||||4"
msgid "Besides, I'm not interested in just fighting\none-on-one with no clear purpose."
msgstr "E poi, non mi interessa un semplice\ncombattimento uno contro uno senza uno scopo chiaro."

msgctxt "11||speech_list_cln||table||500||||4"
msgid "I'd rather squash all your little friends... then\ntake my sweet time with the head honcho."
msgstr "Preferirei piuttosto schiacciare tutti i tuoi piccoli amichetti...\ne poi prendermi tutto il tempo con il pezzo grosso."

msgctxt "11||speech_list_cln||table||501||||4"
msgid "Adios."
msgstr "Adios."

msgctxt "11||speech_list_cln||table||502||||4"
msgid "Wait."
msgstr "Aspetta."

msgctxt "11||speech_list_cln||table||503||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "11||speech_list_cln||table||504||||4"
msgid "Your friend is hurt here.\nAt least take him with you."
msgstr "Il tuo compagno qui è ferito.\nAlmeno portalo via con te."

msgctxt "11||speech_list_cln||table||506||||4"
msgid "Huh. Y'know, friend is way too strong a word.\nBesides, we don't need failures in the Lunatics."
msgstr "Eh. Sai, amico è una parola troppo grossa.\nE poi, non abbiamo bisogno di fallimenti nei Folli."

msgctxt "11||speech_list_cln||table||507||||4"
msgid "No point bringing him back now.\nMight as well end things clean and simple."
msgstr "Non c'è motivo di portarlo indietro, ora.\nTanto vale finire le cose in modo pulito e semplice."

msgctxt "11||speech_list_cln||table||508||||4"
msgid "You bastard... Naito..."
msgstr "Brutto bastardo... Naito..."

msgctxt "11||speech_list_cln||table||509||||4"
msgid "Don't do it, Naito."
msgstr "Non farlo, Naito."

msgctxt "11||speech_list_cln||table||510||||4"
msgid "You never change, Joe. Okada's the same way.\nSeriously makes me wanna barf."
msgstr "Non cambi mai, Joe. Okada è uguale.\nMi fate davvero venire il voltastomaco."

msgctxt "11||speech_list_cln||table||511||||4"
msgid "Looks like Kiryu's not gonna be flying solo\nin the afterlife now. You get to join him, Joe."
msgstr "Sembra che Kiryu non farà il viaggio da solo verso\nl'aldilà ora. Andrai a fargli compagnia, Joe."

msgctxt "11||speech_list_cln||table||512||||4"
msgid "You'll see."
msgstr "Lo vedrai presto."

msgctxt "11||speech_list_cln||table||513||||4"
msgid "Naito..."
msgstr "Naito..."

msgctxt "11||speech_list_cln||table||514||||4"
msgid "I just can't believe you're\nreally a famous yakuza, Kiryu-san."
msgstr "Non riesco a credere che tu sia\ndavvero un famoso yakuza, Kiryu-san."

msgctxt "11||speech_list_cln||table||515||||4"
msgid "It's all in the past."
msgstr "È tutto nel passato."

msgctxt "11||speech_list_cln||table||516||||4"
msgid "But you were some kinda chairman, right?\nNo surprise you're good at leading a team."
msgstr "Ma eri una specie di presidente, giusto?\nNon mi sorprende che tu sia bravo a guidare un gruppo."

msgctxt "11||speech_list_cln||table||517||||4"
msgid "We trust you no matter what, Kiryu-san.\nYour past life doesn't change that."
msgstr "Noi ci fidiamo di te, non importa come stiano le cose, Kiryu-san.\nLa tua vita passata non cambia nulla."

msgctxt "11||speech_list_cln||table||518||||4"
msgid "If anything, I'm glad to know you're on our side\nand not theirs. We have a lot to learn from you."
msgstr "Semmai, sono felice di sapere che sei dalla nostra parte e non\ndalla loro. Abbiamo un sacco di cose da imparare da te."

msgctxt "11||speech_list_cln||table||519||||4"
msgid "I'm not all that special.\nYou shouldn't put me on a pedestal like that."
msgstr "Non sono nulla di speciale.\nNon dovreste mettermi su un piedistallo del genere."

msgctxt "11||speech_list_cln||table||520||||4"
msgid "That's a lot of bull! Have a bit more\nconfidence in yourself, Kiryu-chan!"
msgstr "Tutte stronzate! Abbi un po' più\ndi fiducia in te stesso, Kiryu-chan!"

msgctxt "11||speech_list_cln||table||521||||4"
msgid "You sure about this? I dunno if I really\nwant this guy on our team..."
msgstr "Ne siete sicuri? Non so se voglio\ndavvero questo tizio nel nostro gruppo..."

msgctxt "11||speech_list_cln||table||522||||4"
msgid "It's fine by me."
msgstr "Per me va bene."

msgctxt "11||speech_list_cln||table||523||||4"
msgid "He did say he was turning over a new leaf."
msgstr "Ha detto che stava iniziando un nuovo capitolo."

msgctxt "11||speech_list_cln||table||524||||4"
msgid "Hell yeah! JUSTIS is the worst of the worst! I knew\nKiryu-chan was my man the moment we locked fists!"
msgstr "Sì, cazzo! JUSTIS è il peggio del peggio! Ho capito che Kiryu-chan\nera l'uomo giusto nel momento in cui abbiamo incrociato i pugni!"

msgctxt "11||speech_list_cln||table||525||||4"
msgid "We're gonna make a great team!\nGood shit!"
msgstr "Faremo una squadra fantastica!\nCazzo, sì!"

msgctxt "11||speech_list_cln||table||526||||4"
msgid "This guy is bonkers..."
msgstr "Questo tizio è pazzo da legare..."

msgctxt "11||speech_list_cln||table||527||||4"
msgid "He's definitely strong, though. If we want\nto beat Naito, we'll need people like him."
msgstr "È indubbiamente forte, però. Se vogliamo\nsconfiggere Naito, avremo bisogno di gente come lui."

msgctxt "11||speech_list_cln||table||528||||4"
msgid "I got this. I don't feel a shred of remorse about\nJUSTIS, by the way. It's nothing but hate now."
msgstr "Ci penso io. A proposito, non provo un briciolo di rimorso nei\nconfronti di JUSTIS. Ora non c'è nient'altro che odio."

msgctxt "11||speech_list_cln||table||529||||4"
msgid "I mean, I'm a proud dude.\nI'll do whatever it takes to bring 'em down."
msgstr "Voglio dire, sono un tipo orgoglioso.\nFarò tutto ciò che serve per sconfiggerli."

msgctxt "11||speech_list_cln||table||530||||4"
msgid "Right. I appreciate the help."
msgstr "D'accordo. Apprezzo il tuo aiuto."

msgctxt "11||speech_list_cln||table||531||||4"
msgid "Toru Yano!\nI'm on the case!"
msgstr "Toru Yano!\nSono sul caso!"

msgctxt "11||speech_list_cln||table||532||||4"
msgid "As for our next guy, Naito... Apparently he's got\na pretty crazy number of followers on his side."
msgstr "Per quanto riguarda il nostro prossimo avversario, Naito... A quanto\npare ha dalla sua un numero incredibile di seguaci."

msgctxt "11||speech_list_cln||table||533||||4"
msgid "He was saying he's got ties to mafia and yakuza\ngroups, too. Pretty shady, if you ask me."
msgstr "Diceva di avere legami anche con mafia e\nyakuza. Abbastanza losco, se me lo chiedete."

msgctxt "11||speech_list_cln||table||534||||4"
msgid "I dunno what he's doin' with the Lunatics...\nBut apparently Okada pays him the big bucks."
msgstr "Non so che ci faccia con i Folli...\nMa a quanto pare Okada lo copre di soldi."

msgctxt "11||speech_list_cln||table||535||||4"
msgid "His group's way different than the rat pack\nI shuffled on down here with, too."
msgstr "E poi, il suo gruppo è molto diverso dal branco di ratti\ncon cui sono venuto giù io."

msgctxt "11||speech_list_cln||table||536||||4"
msgid "Ya better watch your backs. Things're gonna\nget tough if you don't prepare for him."
msgstr "Vi conviene guardarvi le spalle. Le cose si faranno\ndure se non vi preparerete a dovere."

msgctxt "11||speech_list_cln||table||537||||4"
msgid "Got it."
msgstr "Ricevuto."

msgctxt "11||speech_list_cln||table||538||||4"
msgid "Not bad, though unsurprising from the fourth chairman.\nFor the time you've had, your team is muy bueno."
msgstr "Niente male, anche se non mi sorprende, venendo dal quarto presidente.\nPer il poco tempo che hai avuto, la tua squadra è muy buena."

msgctxt "11||speech_list_cln||table||539||||4"
msgid "Naito..."
msgstr "Naito..."

msgctxt "11||speech_list_cln||table||540||||4"
msgid "At first these little battles were real entertaining.\nBut now... they're just starting to bore me."
msgstr "All'inizio queste piccole scaramucce erano davvero divertenti.\nMa ora... stanno solo cominciando ad annoiarmi."

msgctxt "11||speech_list_cln||table||541||||4"
msgid "So the next one's gonna be the last."
msgstr "Perciò la prossima sarà l'ultima."

msgctxt "11||speech_list_cln||table||542||||4"
msgid "If you guys manage to beat me...\nI'll take JUSTIS forces out of Onomichi."
msgstr "Se voi ragazzi riuscite a battermi...\nPorterò le forze di JUSTIS fuori da Onomichi."

msgctxt "11||speech_list_cln||table||543||||4"
msgid "You mean it?"
msgstr "Dici sul serio?"

msgctxt "11||speech_list_cln||table||544||||4"
msgid "Si. No way you're gonna win against me, though."
msgstr "Sí. Ma non c'è possibilità che vinciate contro di me."

msgctxt "11||speech_list_cln||table||545||||4"
msgid "I've just been messing with you guys so far.\nI'm gonna give you all I got from now on."
msgstr "Finora ho solo scherzato con voi ragazzi.\nDa ora in poi vi darò tutto quello che ho."

msgctxt "11||speech_list_cln||table||546||||4"
msgid "Once I take your newly formed team down a notch,\nyou're all gonna be muy muerto. I can see it now."
msgstr "Non appena abbasserò le arie alla vostra nuova squadra,\nsarete tutti muy muerto. Lo vedo già."

msgctxt "11||speech_list_cln||table||547||||4"
msgid "I can't wait to make it happen for real."
msgstr "Non vedo l'ora di farlo avverare."

msgctxt "11||speech_list_cln||table||548||||4"
msgid "Hey, Naito."
msgstr "Ehi, Naito."

msgctxt "11||speech_list_cln||table||549||||4"
msgid "Hm?"
msgstr "Mhm?"

msgctxt "11||speech_list_cln||table||550||||4"
msgid "Tranquilo."
msgstr "Tranquilo."

msgctxt "11||speech_list_cln||table||551||||4"
msgid "Chill out."
msgstr "Rilassati."

msgctxt "11||speech_list_cln||table||552||||4"
msgid "You bastard... Just you wait."
msgstr "Bastardo... Aspetta e vedrai."

msgctxt "11||speech_list_cln||table||553||||4"
msgid "So our next battle is a showdown with Naito.\nWe need to make sure we're ready to rumble."
msgstr "Quindi la nostra prossima battaglia sarà la resa dei conti con\nNaito. Dobbiamo assicurarci di essere pronti per lo scontro."

msgctxt "11||speech_list_cln||table||554||||4"
msgid "Right."
msgstr "Esatto."

msgctxt "11||speech_list_cln||table||555||||4"
msgid "It's just about time to take on Naito."
msgstr "È quasi giunto il momento di affrontare Naito."

msgctxt "11||speech_list_cln||table||556||||4"
msgid "He said he'd pull outta Onomichi if we win...\nYou think he meant it?"
msgstr "Ha detto che se ne andrà da Onomichi se vinceremo...\nCredi che dicesse sul serio?"

msgctxt "11||speech_list_cln||table||557||||4"
msgid "I would assume he did.\nHe's not the kinda guy to go back on his word."
msgstr "Suppongo di sì.\nNon è il tipo da rimangiarsi la parola data."

msgctxt "11||speech_list_cln||table||558||||4"
msgid "Besides, JUSTIS would have no business sending guys\ndown here with both Naito and Yano out of the picture."
msgstr "Inoltre, per JUSTIS non avrebbe senso mandare uomini quaggiù\ncon sia Naito che Yano fuori dai giochi."

msgctxt "11||speech_list_cln||table||559||||4"
msgid "They shouldn't even be sending guys down to\nOnomichi in that kinda situation."
msgstr "Non dovrebbero nemmeno inviare i loro ragazzi giù a\nOnomichi in una situazione del genere."

msgctxt "11||speech_list_cln||table||560||||4"
msgid "They'll probably just focus on solidifying\ntheir forces in Kamurocho instead."
msgstr "Probabilmente preferiranno concentrarsi per rafforzare\nle loro difese a Kamurocho."

msgctxt "11||speech_list_cln||table||561||||4"
msgid "Right. Guess we'd just had to focus on\nthose remaining guys after that, then."
msgstr "Certo. Immagino che dopo ci resterà\nsolo da concentrarci sui tizi rimasti."

msgctxt "11||speech_list_cln||table||562||||4"
msgid "Sounds like this is a major turning point, then."
msgstr "Sembra che questo sia un punto di svolta decisivo, allora."

msgctxt "11||speech_list_cln||table||563||||4"
msgid "That's right.\nWe need to win this, no matter what."
msgstr "Esatto.\nDobbiamo vincere, a ogni costo."

msgctxt "11||speech_list_cln||table||564||||4"
msgid "All right, everyone.\nIt's time we move out!"
msgstr "Va bene, ragazzi.\nÈ ora di muoversi!"

msgctxt "11||speech_list_cln||table||565||||4"
msgid "Hell yeah! We're gonna smoosh Naito\nlike a dumb little bug! C'mon, you guys!"
msgstr "Oh, sì! Schiacceremo Naito come uno\nstupido insetto! Andiamo, ragazzi!"

msgctxt "11||speech_list_cln||table||566||||4"
msgid "R-Right..."
msgstr "G-Giusto..."

msgctxt "11||speech_list_cln||table||567||||4"
msgid "Buenas noches!\nKiryu-san, Joe."
msgstr "Buenas noches!\nKiryu-san, Joe."

msgctxt "11||speech_list_cln||table||568||||4"
msgid "We're here, just like you asked.\nNow let's finish this."
msgstr "Siamo qui, proprio come hai chiesto.\nOra finiamola."

msgctxt "11||speech_list_cln||table||569||||4"
msgid "No need to remind me. I remember."
msgstr "Non serve che me lo ricordi. Me ne ricordo."

msgctxt "11||speech_list_cln||table||570||||4"
msgid "As a sign of my respect to you,\nI brought along my elite squad."
msgstr "Come segno del mio rispetto nei vostri confronti,\nho portato con me la mia squadra d'élite."

msgctxt "11||speech_list_cln||table||571||||4"
msgid "Sorry, but this is the Kiryu Clan's last fight."
msgstr "Mi spiace, ma questo sarà l'ultimo combattimento del Clan Kiryu."

msgctxt "11||speech_list_cln||table||572||||4"
msgid "We'll see about that."
msgstr "Questo lo vedremo."

msgctxt "11||speech_list_cln||table||573||||4"
msgid "Bring it on.\nLet's get this fiesta started!"
msgstr "Fatti sotto.\nDiamo inizio alla fiesta!"

msgctxt "11||speech_list_cln||table||574||||4"
msgid "Huh, I didn't think you'd be this strong.\nGuess I underestimated you a bit."
msgstr "Wow, non pensavo che foste così forti.\nCredo di avervi sottovalutato un po'."

msgctxt "11||speech_list_cln||table||575||||4"
msgid "Now then...\nHow about a one-on-one with me?"
msgstr "E adesso...\nChe ne dici di un uno-contro-uno con me?"

msgctxt "11||speech_list_cln||table||576||||4"
msgid "That's what you wanted, right?"
msgstr "È questo che volevi, giusto?"

msgctxt "11||speech_list_cln||table||577||||4"
msgid "You sure?"
msgstr "Ne sei sicuro?"

msgctxt "11||speech_list_cln||table||578||||4"
msgid "You've still got hombres left standing. It'd be\neasier for you to just come at me with everyone."
msgstr "Ti rimangono ancora degli hombres in piedi. Sarebbe più\nfacile per te semplicemente attaccarmi con tutti i tuoi uomini."

msgctxt "11||speech_list_cln||table||579||||4"
msgid "That's not really my style. I'd rather fight\nwith honor than crush you unfairly."
msgstr "Non è proprio il mio stile. Preferirei combattere con\nonore piuttosto che schiacciarvi ingiustamente."

msgctxt "11||speech_list_cln||table||580||||4"
msgid "Aha. So that must be what keeps\ndrawing all these people to you."
msgstr "Aha. Deve essere questo che continua\nad attirare tutte queste persone a te."

msgctxt "11||speech_list_cln||table||581||||4"
msgid "I've gotta say, you make me sick.\nBut I'm no idiota. I'll take you up on your offer."
msgstr "Devo dire che mi fai venire la nausea.\nMa non sono un idiota. Accetterò la tua offerta."

msgctxt "11||speech_list_cln||table||582||||4"
msgid "Kiryu-san... It's time to fight, mano a mano."
msgstr "Kiryu-san... È l'ora di combattere, mano a mano."

msgctxt "11||speech_list_cln||table||583||||4"
msgid "Right. Let's get it over with, Naito."
msgstr "D'accordo. Facciamola finita, Naito."

msgctxt "11||speech_list_cln||table||584||||4"
msgid "Tranquilo! Chill out, Kiryu!"
msgstr "Tranquilo! Rilassati, Kiryu!"

msgctxt "11||speech_list_cln||table||587||||4"
msgid "Oh my god!\nKiryu-san, you beat Naito!"
msgstr "Mio Dio!\nKiryu-san, hai sconfitto Naito!"

msgctxt "11||speech_list_cln||table||588||||4"
msgid "Are you okay?"
msgstr "Tutto bene?"

msgctxt "11||speech_list_cln||table||589||||4"
msgid "Yeah, I think so."
msgstr "Sì, direi di sì."

msgctxt "11||speech_list_cln||table||590||||4"
msgid "I totally lost...\nYou're really something, Kazuma Kiryu."
msgstr "Ho totalmente perso...\nSei davvero in gamba, Kazuma Kiryu."

msgctxt "11||speech_list_cln||table||591||||4"
msgid "You promised. \nPull your JUSTIS goons out of Onomichi."
msgstr "Hai fatto una promessa.\nRichiama i tuoi scagnozzi di JUSTIS fuori da Onomichi."

msgctxt "11||speech_list_cln||table||592||||4"
msgid "Don't worry about that. With Yano and I beat, JUSTIS\nwon't have the cajones to be sending guys down here."
msgstr "Non preoccuparti per quello. Con me e Yano sconfitti, JUSTIS\nnon avrà i cajones per mandare altri uomini quaggiù."

msgctxt "11||speech_list_cln||table||593||||4"
msgid "Besides, a promise is a promise.\nThe Onomichi invasion's over."
msgstr "E poi, una promessa è una promessa.\nL'invasione di Onomichi è finita."

msgctxt "11||speech_list_cln||table||594||||4"
msgid "All right! We protected Onomichi,\njust like we set out to do!"
msgstr "Fantastico! Abbiamo protetto Onomichi,\nproprio come ci eravamo prefissati!"

msgctxt "11||speech_list_cln||table||595||||4"
msgid "All we can do now is head up to Kamurocho."
msgstr "L'unica cosa che ci resta da fare è andare a Kamurocho."

msgctxt "11||speech_list_cln||table||596||||4"
msgid "Okada... I'm coming for you."
msgstr "Okada... Sto venendo a prenderti."

msgctxt "11||speech_list_cln||table||597||||4"
msgid "All right. Let's head back to the hideout\nand plan our next attack."
msgstr "Va bene. Torniamo al nascondiglio\ne pianifichiamo il nostro prossimo attacco."

msgctxt "11||speech_list_cln||table||598||||4"
msgid "Hey, Kiryu-san."
msgstr "Ehi, Kiryu-san."

msgctxt "11||speech_list_cln||table||599||||4"
msgid "Hm?"
msgstr "Mhm?"

msgctxt "11||speech_list_cln||table||600||||4"
msgid "Uh... Take me with you."
msgstr "Ehm... Portami con te."

msgctxt "11||speech_list_cln||table||601||||4"
msgid "What was that?"
msgstr "Come, scusa?"

msgctxt "11||speech_list_cln||table||602||||4"
msgid "I used to think I couldn't stand self-righteous,\nchivalrous bastards like you and Joe."
msgstr "Pensavo di non sopportare i bastardi perbenisti e\ncavallereschi come te e Joe."

msgctxt "11||speech_list_cln||table||603||||4"
msgid "But y'know, beneath that hate...\nwas admiration."
msgstr "Ma sai, sotto quell'odio...\nc'era dell'ammirazione."

msgctxt "11||speech_list_cln||table||604||||4"
msgid "Kazuma Kiryu.\nI wanna learn to be more like you."
msgstr "Kazuma Kiryu.\nVoglio imparare a essere più come te."

msgctxt "11||speech_list_cln||table||605||||4"
msgid "Let me join you guys.\nI wanna be your pareja."
msgstr "Permettimi di unirmi a voi.\nVoglio essere la tua pareja."

msgctxt "11||speech_list_cln||table||606||||4"
msgid "......"
msgstr "......"

msgctxt "11||speech_list_cln||table||607||||4"
msgid "Naito on our team? Who knows when\nhe'd turn on us. I can't trust him!"
msgstr "Naito nella nostra squadra? Chissà quando ci\nvolterà le spalle. Non posso fidarmi di lui!"

msgctxt "11||speech_list_cln||table||608||||4"
msgid "No, he's being genuine. I get how\nhe can be so drawn to Kiryu-san..."
msgstr "No, è sincero. Capisco come\npossa essere così attratto da Kiryu-san..."

msgctxt "11||speech_list_cln||table||609||||4"
msgid "Joe-san, I didn't know you swing that way..."
msgstr "Joe-san, non sapevo che giocassi per quell'altra squadra..."

msgctxt "11||speech_list_cln||table||610||||4"
msgid "D-Don't be an ass!"
msgstr "N-Non fare l'idiota!"

msgctxt "11||speech_list_cln||table||611||||4"
msgid "I'm not really sure what pareja means...\nbut you can come along if you want."
msgstr "Non so di preciso cosa significhi pareja...\nma puoi venire con noi se vuoi."

msgctxt "11||speech_list_cln||table||612||||4"
msgid "We'll be heading to Kamurocho next.\nUntil then, try to heal up."
msgstr "La nostra prossima destinazione sarà Kamurocho.\nFino ad allora, cerca di rimetterti in sesto."

msgctxt "11||speech_list_cln||table||613||||4"
msgid "Tranquilo."
msgstr "Tranquilo."

msgctxt "11||speech_list_cln||table||614||||4"
msgid "Chill out."
msgstr "Rilassatevi."

msgctxt "11||speech_list_cln||table||615||||4"
msgid "Chill out."
msgstr "Rilassati."

msgctxt "11||speech_list_cln||table||618||||4"
msgid "It appears Naito has fallen as well."
msgstr "A quanto pare anche Naito è caduto."

msgctxt "11||speech_list_cln||table||619||||4"
msgid "I see. Figures."
msgstr "Capisco. Me l'aspettavo."

msgctxt "11||speech_list_cln||table||620||||4"
msgid "Shall we reconvene the whole\nof our army here in Kamurocho, then?"
msgstr "Dovremmo richiamare l'intero nostro\nesercito qui a Kamurocho, allora?"

msgctxt "11||speech_list_cln||table||621||||4"
msgid "Yes, get started.\nThe battle's moving to our home turf."
msgstr "Sì, procedi.\nLa battaglia si sposterà sul nostro territorio."

msgctxt "11||speech_list_cln||table||622||||4"
msgid "But it's just the beginning.\nSo let's make sure... they get a warm welcome."
msgstr "Ma è solo l'inizio.\nAssicuriamoci... di dargli un caloroso benvenuto."

msgctxt "11||speech_list_cln||table||623||||4"
msgid "Very well."
msgstr "Molto bene."

msgctxt "11||speech_list_cln||table||624||||4"
msgid "Joe... Kazuma Kiryu..."
msgstr "Joe... Kazuma Kiryu..."

msgctxt "11||speech_list_cln||table||625||||4"
msgid "Okada and Komei are the only ones left now."
msgstr "Sono rimasti solo Okada e Komei, ora."

msgctxt "11||speech_list_cln||table||626||||4"
msgid "They're up in Kamurocho."
msgstr "Sono a Kamurocho."

msgctxt "11||speech_list_cln||table||627||||4"
msgid "Next time you head up there,\nwe'll gladly join you."
msgstr "La prossima volta che ci andrai,\nci uniremo volentieri a te."

msgctxt "11||speech_list_cln||table||628||||4"
msgid "When you have the chance,\nstop by the hideout in Kamurocho."
msgstr "Quando ne hai l'occasione,\nfai un salto al nascondiglio a Kamurocho."

msgctxt "11||speech_list_cln||table||629||||4"
msgid "Looks like Onomichi's gonna be okay."
msgstr "Sembra che Onomichi sia al sicuro, ora."

msgctxt "11||speech_list_cln||table||630||||4"
msgid "The rest of the Six Lunatics are gonna\nbe waiting for us up in Kamurocho, though."
msgstr "Il resto dei Sei Folli ci\naspetterà su a Kamurocho, però."

msgctxt "11||speech_list_cln||table||631||||4"
msgid "Next time you head up there,\nwe'll gladly join you."
msgstr "La prossima volta che ci andrai,\nci uniremo volentieri a te."

msgctxt "11||speech_list_cln||table||632||||4"
msgid "When you have the chance,\nstop by the hideout in Kamurocho."
msgstr "Quando ne hai l'occasione,\nfai un salto al nascondiglio a Kamurocho."

msgctxt "11||speech_list_cln||table||633||||4"
msgid "Looks like Onomichi's gonna be okay."
msgstr "Sembra che Onomichi sia al sicuro, ora."

msgctxt "11||speech_list_cln||table||634||||4"
msgid "The rest of the Six Lunatics are gonna\nbe waiting for us up in Kamurocho, though."
msgstr "Il resto dei Sei Folli ci\naspetterà su a Kamurocho, però."

msgctxt "11||speech_list_cln||table||635||||4"
msgid "We don't know exactly when we're\ngonna have the chance to head up there."
msgstr "Non sappiamo di preciso quando avremo\nl'occasione di dirigerci là."

msgctxt "11||speech_list_cln||table||636||||4"
msgid "But for now, we should focus on building up\nthe team down here in Onomichi."
msgstr "Ma per ora, dovremmo concentrarci sul rafforzare\nil gruppo quaggiù a Onomichi."

msgctxt "11||speech_list_cln||table||637||||4"
msgid "We'd probably get our butts kicked in a second\nif we head up there without any preparation."
msgstr "Probabilmente ci faremmo prendere a calci in men che non si dica\nse ci spingessimo fino a lì senza la minima preparazione."

msgctxt "11||speech_list_cln||table||638||||4"
msgid "You're right. We should make sure we're\nready before we bring the team up to Kamurocho."
msgstr "Hai ragione. Dobbiamo assicurarci di essere\npronti prima di portare il gruppo a Kamurocho."

msgctxt "11||speech_list_cln||table||639||||4"
msgid "Kiryu-san!"
msgstr "Kiryu-san!"

msgctxt "11||speech_list_cln||table||640||||4"
msgid "Joe..."
msgstr "Joe..."

msgctxt "11||speech_list_cln||table||641||||4"
msgid "I could tell that was you from a mile away."
msgstr "L'ho capito da un miglio di distanza che eri tu."

msgctxt "11||speech_list_cln||table||642||||4"
msgid "Hold on, are you living here\nin the Navy Apartments, Kiryu-san?"
msgstr "Aspetta, per caso vivi qui,\nnegli Appartamenti Navy, Kiryu-san?"

msgctxt "11||speech_list_cln||table||643||||4"
msgid "I am. By the way, are you sure\nyou should be out and about like this?"
msgstr "Così è. A proposito, sei sicuro di potertene\nandare in giro in questo modo?"

msgctxt "11||speech_list_cln||table||644||||4"
msgid "It's not too big a deal, I don't think.\nWhat are you up to, Kiryu-san?"
msgstr "Non penso sia un problema così grande.\nCosa stai combinando, Kiryu-san?"

msgctxt "11||speech_list_cln||table||645||||4"
msgid "Well... I'm about to head up to Kamurocho."
msgstr "Beh... Sto per dirigermi a Kamurocho."

msgctxt "11||speech_list_cln||table||646||||4"
msgid "Huh?"
msgstr "Mhm?"

msgctxt "11||speech_list_cln||table||647||||4"
msgid "I'm leaving tomorrow.\nI'll be out of Onomichi for a while."
msgstr "Parto domani.\nStarò via da Onomichi per un po'."

msgctxt "11||speech_list_cln||table||648||||4"
msgid "Hold on, but Kamurocho...\nThat's where JUSTIS is based, you know."
msgstr "Aspetta, ma a Kamurocho...\nÈ lì che JUSTIS ha la sua base, lo sai, vero."

msgctxt "11||speech_list_cln||table||649||||4"
msgid "This has nothing to do with them.\nI have other business I need to take care of."
msgstr "Questa faccenda non ha nulla a che fare con loro.\nHo altri affari di cui occuparmi."

msgctxt "11||speech_list_cln||table||650||||4"
msgid "Oh. In that case..."
msgstr "Oh. In quel caso..."

msgctxt "11||speech_list_cln||table||651||||4"
msgid "Is something wrong?"
msgstr "C'è qualcosa che non va?"

msgctxt "11||speech_list_cln||table||652||||4"
msgid "No, I was just thinking of you spending time\nup in Kamurocho. It gave me an idea."
msgstr "No, stavo solo pensando al tempo che passerai\nsu a Kamurocho. Mi ha dato un'idea."

msgctxt "11||speech_list_cln||table||653||||4"
msgid "Hm?"
msgstr "Mhm?"

msgctxt "11||speech_list_cln||table||654||||4"
msgid "Well, I should go tell Masao and the others\nwhat you're gonna be up to. Later!"
msgstr "Beh, è meglio che vada a dire a Masao e agli altri\nche cosa stai per combinare. A più tardi!"

msgctxt "11||speech_list_cln||table||655||||4"
msgid "Kiryu-san. Good to see you."
msgstr "Kiryu-san. Che bello vederti."

msgctxt "11||speech_list_cln||table||656||||4"
msgid "What the? Joe!"
msgstr "Ma che? Joe!"

msgctxt "11||speech_list_cln||table||657||||4"
msgid "What are you doing here?\nI don't understand."
msgstr "Che cosa ci fate qui?\nNon capisco."

msgctxt "11||speech_list_cln||table||658||||4"
msgid "We were gonna have to make our way on up\nto Kamurocho at one point or another, right?"
msgstr "Prima o poi avremmo comunque dovuto far\nrotta per Kamurocho, non trovi?"

msgctxt "11||speech_list_cln||table||659||||4"
msgid "Coming up at the same time as you made the most\nsense. It was easy to get everyone on board, too."
msgstr "Salire assieme a te era la cosa che aveva\npiù senso. Ed è stato facile convincere tutti."

msgctxt "11||speech_list_cln||table||660||||4"
msgid "Everyone's here...?\nCome on."
msgstr "Ci sono tutti...?\nDai."

msgctxt "11||speech_list_cln||table||661||||4"
msgid "Isn't that a good thing?\nIt means we're all serious about this."
msgstr "Non è una buona cosa?\nSignifica che facciamo tutti sul serio."

msgctxt "11||speech_list_cln||table||662||||4"
msgid "Speaking of, we got hold of a store\nwe can use as a hideout while we're up here."
msgstr "A proposito, abbiamo trovato un locale che\npossiamo usare come nascondiglio mentre siamo qui."

msgctxt "11||speech_list_cln||table||663||||4"
msgid "It's a little shop inside the Millennium Tower\nbuilding called the M Side Cafe."
msgstr "È un piccolo locale all'interno della Millennium Tower,\nchiamato M Side Cafe."

msgctxt "11||speech_list_cln||table||664||||4"
msgid "Want to go see it?"
msgstr "Vuoi andarlo a vedere?"

msgctxt "11||speech_list_cln||table||665||||4"
msgid "I guess I have to...\nJust for a bit, though."
msgstr "Immagino di doverlo fare...\nMa solo per un attimo."

msgctxt "11||speech_list_cln||table||666||||4"
msgid "This is a pretty swanky place.\nAre you sure we'll be okay here?"
msgstr "È un posto piuttosto elegante.\nSiete sicuri che sia il posto adatto a noi?"

msgctxt "11||speech_list_cln||table||667||||4"
msgid "Well, the bartender down at La Pente apparently\nknows the owner. He helped negotiate for us."
msgstr "Beh, a quanto pare il barista del La Pente conosce\nil proprietario. Ha fatto da tramite per noi."

msgctxt "11||speech_list_cln||table||668||||4"
msgid "Seriously?\nWhat's up with that guy?"
msgstr "Sul serio?\nChe tipo è quel tizio?"

msgctxt "11||speech_list_cln||table||669||||4"
msgid "I wonder..."
msgstr "Mi domando..."

msgctxt "11||speech_list_cln||table||670||||4"
msgid "Hm?"
msgstr "Mhm?"

msgctxt "11||speech_list_cln||table||671||||4"
msgid "Look what the cat dragged in!\nYou're really here, Joe."
msgstr "Guarda un po' chi si vede!\nSei davvero qui, Joe."

msgctxt "11||speech_list_cln||table||672||||4"
msgid "It's you..."
msgstr "Siete voi..."

msgctxt "11||speech_list_cln||table||673||||4"
msgid "Ya can't hide from us.\nWe know your every move, Joe."
msgstr "Non puoi nasconderti da noi.\nConosciamo ogni tua mossa, Joe."

msgctxt "11||speech_list_cln||table||674||||4"
msgid "And you took time out of your day to welcome us?\nThat's a real nice gesture of you. Appreciate it."
msgstr "E vi siete presi del tempo libero solo per accoglierci?\nÈ un bel gesto da parte vostra. Lo apprezzo."

msgctxt "11||speech_list_cln||table||675||||4"
msgid "Joe. Now that you've come to Kamurocho,\ndon't expect any mercy from us."
msgstr "Joe. Ora che sei arrivato a Kamurocho,\nnon aspettarti alcuna pietà da parte nostra."

msgctxt "11||speech_list_cln||table||676||||4"
msgid "This is JUSTIS's home base. You won't have\nthe same freedom here as you did in Onomichi."
msgstr "Questa è la base operativa di JUSTIS. Qui non avrai\nla stessa libertà che avevi a Onomichi."

msgctxt "11||speech_list_cln||table||677||||4"
msgid "We know damn well where your base is.\nWe wouldn't be here otherwise."
msgstr "Sappiamo benissimo dove si trova la vostra base.\nAltrimenti non saremmo qui."

msgctxt "11||speech_list_cln||table||678||||4"
msgid "Anyway... Whaddya say?\nLet's fight, you and me. Like old times."
msgstr "Comunque... Che ne dici?\nCombattiamo, io e te. Come ai vecchi tempi."

msgctxt "11||speech_list_cln||table||679||||4"
msgid "Heh... Nope."
msgstr "Heh... Niente da fare."

msgctxt "11||speech_list_cln||table||680||||4"
msgid "This man is the renowned Rainmaker, remember?\nHe has no time for an insignificant whelp like you."
msgstr "Quest'uomo è il rinomato Rainmaker, ricordi?\nNon ha tempo per un insignificante cucciolo come te."

msgctxt "11||speech_list_cln||table||681||||4"
msgid "Besides... You have others in line waiting to fight you."
msgstr "Oltretutto... ci sono altri in fila che aspettano di affrontarti."

msgctxt "11||speech_list_cln||table||682||||4"
msgid "What?"
msgstr "Cosa?"

msgctxt "11||speech_list_cln||table||683||||4"
msgid "Don't go forgettin' about us, Joe."
msgstr "Non ti dimenticare di noi, Joe."

msgctxt "11||speech_list_cln||table||684||||4"
msgid "You get to deal with us next time.\nI've been damn bored lately. Entertain me."
msgstr "La prossima volta te la vedrai con noi.\nMi sono annoiato a morte ultimamente. Fammi divertire."

msgctxt "11||speech_list_cln||table||685||||4"
msgid "Tenzan, Kojima..."
msgstr "Tenzan, Kojima..."

msgctxt "11||speech_list_cln||table||686||||4"
msgid "Hey, Joe. Who are these guys?"
msgstr "Ehi, Joe. Chi sono questi tizi?"

msgctxt "11||speech_list_cln||table||687||||4"
msgid "The Six Lunatics tag team, Tenzan and Kojima.\nTenCozy for short."
msgstr "Il tag team dei Sei Folli, Tenzan e Kojima.\nTenCozy, per abbreviare."

msgctxt "11||speech_list_cln||table||688||||4"
msgid "They're part of the reason Okada and I formed\nJUSTIS to begin with. They were in the colors."
msgstr "Inizialmente, loro sono parte del motivo per cui io e Okada\nabbiamo creato JUSTIS. Erano nelle gang dei colori."

msgctxt "11||speech_list_cln||table||689||||4"
msgid "The color gangs?\nHow did they end up working with JUSTIS?"
msgstr "Le gang dei colori?\nE come sono finiti a lavorare per JUSTIS?"

msgctxt "11||speech_list_cln||table||690||||4"
msgid "Okada probably paid through the nose for them.\nThey're real assholes, but they're definitely strong."
msgstr "Okada li avrà probabilmente ricoperti d'oro.\nSono dei veri stronzi, ma sono indubbiamente forti."

msgctxt "11||speech_list_cln||table||691||||4"
msgid "Each is tough alone, but their power\nmultiplies when you pair them together."
msgstr "Ognuno è già tosto da solo, ma il loro potere\nsi moltiplica quando li metti insieme."

msgctxt "11||speech_list_cln||table||692||||4"
msgid "That's why they're TenCozy."
msgstr "Ecco perché sono TenCozy."

msgctxt "11||speech_list_cln||table||693||||4"
msgid "Not bad, Joe-kun.\nSounds like ya know your shit."
msgstr "Niente male, Joe-kun.\nSembra che tu sappia il fatto tuo."

msgctxt "11||speech_list_cln||table||694||||4"
msgid "You're right. We might've switched over to the side\nof JUSTIS, but we'll always be champs! Forever!"
msgstr "Hai ragione. Magari saremo passati dalla parte\ndi JUSTIS, ma noi restiamo i campioni! Per sempre!"

msgctxt "11||speech_list_cln||table||695||||4"
msgid "One plus one don't make two. For us, one plus one\nis two hundred! That's ten times better! Ten times!"
msgstr "Uno più uno non fa due. Per noi, uno più uno fa\nduecento! Cioè dieci volte meglio! Dieci volte!"

msgctxt "11||speech_list_cln||table||696||||4"
msgid "Hey... You wanna check that math?\nShouldn't it be one hundred times better?"
msgstr "Ehi... Vogliamo rivedere i calcoli?\nNon dovrebbe essere cento volte meglio?"

msgctxt "11||speech_list_cln||table||697||||4"
msgid "I don't care for your lip!\nIt's just a crapton more than two, alright!?"
msgstr "Non mi interessa della tua linguaccia!\nÈ semplicemente un fottìo più di due, chiaro!?"

msgctxt "11||speech_list_cln||table||698||||4"
msgid "If you're really givin' me shit for this,\nI'd be glad to rip ya a new one!"
msgstr "Se mi vuoi davvero dare addosso per questo,\nsarò ben felice di farti il culo a strisce!"

msgctxt "11||speech_list_cln||table||699||||4"
msgid "Try me."
msgstr "Provaci."

msgctxt "11||speech_list_cln||table||700||||4"
msgid "Huh!?"
msgstr "Cosa!?"

msgctxt "11||speech_list_cln||table||701||||4"
msgid "Now, now. We cannot allow one of our mighty\nSix Lunatics to sully himself with this garbage."
msgstr "Suvvia. Non possiamo permettere che uno dei nostri potenti\nSei Folli si sporchi le mani con questa spazzatura."

msgctxt "11||speech_list_cln||table||702||||4"
msgid "Stooping to his level is not the desired\noutcome. Isn't that right, Rainmaker?"
msgstr "Abbassarsi al suo livello non è il risultato\ndesiderato. Non è così, Rainmaker?"

msgctxt "11||speech_list_cln||table||703||||4"
msgid "Yeah, true."
msgstr "Sì, vero."

msgctxt "11||speech_list_cln||table||704||||4"
msgid "Though come to think of it,\nhave we met before?"
msgstr "Anche se, a pensarci bene,\nci siamo già incontrati?"

msgctxt "11||speech_list_cln||table||705||||4"
msgid "Yeah, I think we have."
msgstr "Sì, credo di sì."

msgctxt "11||speech_list_cln||table||706||||4"
msgid "Heh... What a coincidence this is."
msgstr "Heh... Ma guarda che coincidenza."

msgctxt "11||speech_list_cln||table||707||||4"
msgid "I have no ill will toward you... But if you\ntry to stop me, I'll crush you where you stand."
msgstr "Non nutro rancore verso di te... Ma se cercherai\ndi fermarmi, ti schiaccerò dove ti trovi."

msgctxt "11||speech_list_cln||table||708||||4"
msgid "Try me."
msgstr "Fatti sotto."

msgctxt "11||speech_list_cln||table||709||||4"
msgid "JUSTIS is the sole dominant force\nin Kamurocho at this point."
msgstr "A questo punto, JUSTIS è l'unica\nforza dominante a Kamurocho."

msgctxt "11||speech_list_cln||table||710||||4"
msgid "It's been ages since we've had a good fight.\nThis should be exciting."
msgstr "È da una vita che non facevamo una bella lotta.\nSarà entusiasmante."

msgctxt "11||speech_list_cln||table||711||||4"
msgid "I hope you provide us with some\nentertainment, Kiryu Clan. We must be off."
msgstr "Mi aspetto che ci facciate divertire un po',\nClan Kiryu. Noi togliamo il disturbo."

msgctxt "11||speech_list_cln||table||712||||4"
msgid "Watch your backs, bastards."
msgstr "Guardatevi le spalle, bastardi."

msgctxt "11||speech_list_cln||table||713||||4"
msgid "So those are the leaders of JUSTIS.\nSounds like more fights on the horizon."
msgstr "Quindi quelli sono i leader di JUSTIS.\nSi prospettano altre battaglie all'orizzonte."

msgctxt "11||speech_list_cln||table||714||||4"
msgid "Right. Anyway, this place is gonna be our\nhideout while we're up in Kamurocho."
msgstr "Certo. Comunque, questo posto sarà il\nnostro nascondiglio finché saremo a Kamurocho."

msgctxt "11||speech_list_cln||table||715||||4"
msgid "Come talk to me if you want to reorganize\nthe team or start a battle against JUSTIS, okay?"
msgstr "Vieni a parlarmi se vuoi riorganizzare il\ngruppo o avviare una battaglia contro JUSTIS, okay?"

msgctxt "11||speech_list_cln||table||716||||4"
msgid "Got it."
msgstr "Ricevuto."

msgctxt "11||speech_list_cln||table||717||||4"
msgid "You're actually kinda strong, Kiryu-san."
msgstr "Sei davvero forte, Kiryu-san."

msgctxt "11||speech_list_cln||table||718||||4"
msgid "It's been forever since I've had to put my all\ninto fightin' someone. Feels good."
msgstr "È da una vita che non dovevo mettercela tutta\nper combattere qualcuno. Ci voleva proprio."

msgctxt "11||speech_list_cln||table||719||||4"
msgid "Still, we're gonna have to settle this soon."
msgstr "Ciononostante, dobbiamo risolvere in fretta la faccenda."

msgctxt "11||speech_list_cln||table||720||||4"
msgid "Hey, Tenzan!"
msgstr "Ehi, Tenzan!"

msgctxt "11||speech_list_cln||table||721||||4"
msgid "We're gonna finish ya guys off next time.\nCome at us with all ya got, okay?"
msgstr "Vi finiremo la prossima volta.\nAttaccateci con tutto ciò che avete, okay?"

msgctxt "11||speech_list_cln||table||722||||4"
msgid "Me n' Kojima, the TenCozy tag team,\nare gonna dice y'all into tiny little pieces."
msgstr "Io e Kojima, il tag team TenCozy,\nvi faremo a pezzettini."

msgctxt "11||speech_list_cln||table||723||||4"
msgid "I don't care if I have to fight one or both of you.\nLet's just hurry up and get it over with."
msgstr "Non mi interessa se devo affrontarne uno o tutti e due.\nSbrighiamoci a farla finita."

msgctxt "11||speech_list_cln||table||724||||4"
msgid "Don't ya remember? For us, one plus one\nain't two. It's two hundred."
msgstr "Non te lo ricordi? Per noi uno più uno\nnon fa due. Fa duecento."

msgctxt "11||speech_list_cln||table||725||||4"
msgid "I remember. One plus one is two hundred.\nTen times more than normal, right?"
msgstr "Ricordo. Uno più uno fa duecento.\nDieci volte più del normale, no?"

msgctxt "11||speech_list_cln||table||726||||4"
msgid "Glad ya understand."
msgstr "Lieto che tu capisca."

msgctxt "11||speech_list_cln||table||727||||4"
msgid "We're gonna be puttin' all our effort into\nthis fight, so ya better return the favor."
msgstr "Ci metteremo tutto l'impegno in questo\nscontro, quindi vi conviene ricambiare il favore."

msgctxt "11||speech_list_cln||table||728||||4"
msgid "This JUSTIS bullshit ain't really our\ncup of tea, if I'm bein' honest."
msgstr "Se devo essere sincero, questa stronzata di\nJUSTIS non è proprio il nostro pane."

msgctxt "11||speech_list_cln||table||729||||4"
msgid "If we get good fights outta it,\nthat's all that matters."
msgstr "Se ne caviamo fuori qualche bella\nbattaglia, è tutto ciò che importa."

msgctxt "11||speech_list_cln||table||730||||4"
msgid "Ya guys better make it interesting.\nIf this's just another borin' slog..."
msgstr "Sarà meglio che lo rendiate interessante.\nSe sarà un'altra noiosa passeggiata..."

msgctxt "11||speech_list_cln||table||731||||4"
msgid "...We'll slaughter every last one of ya."
msgstr "...Vi massacreremo tutti fino all'ultimo."

msgctxt "11||speech_list_cln||table||732||||4"
msgid "So the TenCozy tag team is up next.\nThey won't be an easy opponent."
msgstr "Quindi i prossimi sono il tag team dei TenCozy.\nNon saranno un avversario facile."

msgctxt "11||speech_list_cln||table||733||||4"
msgid "Let's make sure we're ready\nbefore we fight them."
msgstr "Assicuriamoci di essere pronti prima\ndi incrociare i pugni con loro."

msgctxt "11||speech_list_cln||table||734||||4"
msgid "Right."
msgstr "Certo."

msgctxt "11||speech_list_cln||table||735||||4"
msgid "So we're finally going up\nagainst Tenzan and Kojima."
msgstr "Quindi finalmente ce la vedremo\ncontro Tenzan e Kojima."

msgctxt "11||speech_list_cln||table||736||||4"
msgid "Yeah. They're both strong on their own,\nbut their power multiplies when they're together."
msgstr "Già. Sono forti anche presi singolarmente, ma\nil loro potere si moltiplica quando sono insieme."

msgctxt "11||speech_list_cln||table||737||||4"
msgid "It's not gonna be as smooth as the other\nLunatics. We need to be ready."
msgstr "Non andrà liscia come con gli altri Folli.\nDobbiamo essere pronti."

msgctxt "11||speech_list_cln||table||738||||4"
msgid "Make sure you keep a careful eye on\ntheir movements, Kiryu-san."
msgstr "Assicurati di tenere d'occhio i\nloro movimenti, Kiryu-san."

msgctxt "11||speech_list_cln||table||739||||4"
msgid "All right."
msgstr "Ricevuto."

msgctxt "11||speech_list_cln||table||740||||4"
msgid "Kamurocho is JUSTIS's home base, remember.\nThings'll be way rougher than in Onomichi."
msgstr "Kamurocho è la base di JUSTIS, ricorda.\nSarà molto più dura che a Onomichi."

msgctxt "11||speech_list_cln||table||741||||4"
msgid "But if we can manage to win, that should really\nshake some things up in their organization."
msgstr "Ma se riusciremo a vincere, daremo un bello\nscossone alla loro organizzazione."

msgctxt "11||speech_list_cln||table||742||||4"
msgid "Once we win here, JUSTIS is gonna be totally\non the ropes. Let's give this all we got!"
msgstr "Una volta vinto qui, JUSTIS sarà definitivamente\nalle corde. Mettiamocela tutta!"

msgctxt "11||speech_list_cln||table||743||||4"
msgid "Got it!"
msgstr "Ci puoi contare!"

msgctxt "11||speech_list_cln||table||744||||4"
msgid "Glad to see ya here, Joe. I was thinkin'\nyou'd run with your tail between your legs."
msgstr "È bello vederti qui, Joe. Credevo fossi\nfuggito con la coda tra le gambe."

msgctxt "11||speech_list_cln||table||745||||4"
msgid "I'm not afraid of an idiot like you."
msgstr "Non ho paura di un idiota come te."

msgctxt "11||speech_list_cln||table||746||||4"
msgid "We're gonna beat you, then take down Okada,\nand destroy JUSTIS while we're at it!"
msgstr "Vi batteremo, per poi abbattere Okada,\ne già che ci siamo, distruggere JUSTIS!"

msgctxt "11||speech_list_cln||table||747||||4"
msgid "Ya sure you can do that? You've never won\na single fight against Okada, y'know."
msgstr "Sicuro di potercela fare? Non hai mai\nvinto un solo incontro contro Okada, sai."

msgctxt "11||speech_list_cln||table||748||||4"
msgid "Not yet I haven't.\nThings have changed, though."
msgstr "Non ancora.\nMa le cose sono cambiate."

msgctxt "11||speech_list_cln||table||749||||4"
msgid "Look at that.\nYou grew into a real bold little shit."
msgstr "Ma guarda un po'.\nSei diventato uno stronzetto bello sfrontato."

msgctxt "11||speech_list_cln||table||750||||4"
msgid "Fine. Show us how strong ya are now.\nIf ya want Okada, you gotta go through us!"
msgstr "Va bene. Mostraci la tua forza, ora.\nSe vuoi Okada, dovrai passare sul nostro corpo!"

msgctxt "11||speech_list_cln||table||751||||4"
msgid "We've beaten every last one of your men.\nNow just surrender, nice and easy."
msgstr "Abbiamo sconfitto tutti i vostri uomini, fino\nall'ultimo. Adesso arrendetevi, fate i bravi."

msgctxt "11||speech_list_cln||table||752||||4"
msgid "Surrender?\nThe hell're you sayin'?"
msgstr "Arrenderci?\nMa che cazzo dici?"

msgctxt "11||speech_list_cln||table||753||||4"
msgid "Group battles ain't our bag. We're not too big\non commandin' other people, y'know."
msgstr "Le battaglie di gruppo non fanno per noi. Non\nandiamo pazzi per comandare gli altri, sapete."

msgctxt "11||speech_list_cln||table||754||||4"
msgid "We prefer talkin' with our fists.\nThat's the best way to settle shit."
msgstr "Noi preferiamo parlare con i pugni.\nÈ il modo migliore per risolvere i casini."

msgctxt "11||speech_list_cln||table||755||||4"
msgid "What he's sayin' is... we're just gettin' started."
msgstr "Quello che sta dicendo è... abbiamo appena iniziato."

msgctxt "11||speech_list_cln||table||756||||4"
msgid "We only got two of us left at this point,\nbut us two're all we need."
msgstr "A questo punto siamo rimasti solo noi due,\nma siamo tutto quello di cui abbiamo bisogno."

msgctxt "11||speech_list_cln||table||757||||4"
msgid "That's how the TenCozy tag team rolls!"
msgstr "È così che funziona il tag team TenCozy!"

msgctxt "11||speech_list_cln||table||758||||4"
msgid "Not bad. You know,\nI actually don't mind you guys."
msgstr "Niente male. Sapete,\nnon mi dispiacete voi due."

msgctxt "11||speech_list_cln||table||759||||4"
msgid "I have to agree. I'd much rather settle\nthings in a man-to-man fight, too."
msgstr "Sono d'accordo. Anch'io preferisco di gran\nlunga risolvere le cose in uno scontro tra uomini."

msgctxt "11||speech_list_cln||table||760||||4"
msgid "Perfect. How 'bout it, then?\nYou guys wanna throw down?"
msgstr "Perfetto. Che ne dite, allora?\nVi va di fare a botte?"

msgctxt "11||speech_list_cln||table||761||||4"
msgid "You n' Joe versus me n' Tenzan.\nIt'll be a four man deathmatch."
msgstr "Tu e Joe contro di me e Tenzan.\nSarà un deathmatch a quattro."

msgctxt "11||speech_list_cln||table||762||||4"
msgid "Sounds good to me.\nHow about you, Joe?"
msgstr "Per me va bene.\nTu che dici, Joe?"

msgctxt "11||speech_list_cln||table||763||||4"
msgid "You don't even have to ask.\nIf they wanna fight, I'll fight."
msgstr "Non devi nemmeno chiederlo.\nSe vogliono fare a botte, li accontenteremo."

msgctxt "11||speech_list_cln||table||764||||4"
msgid "Hell yeah! Let's do it, Koji!"
msgstr "Cazzo, sì! Facciamolo, Koji!"

msgctxt "11||speech_list_cln||table||765||||4"
msgid "Uh-huh! Ya better be ready for us!"
msgstr "Uh-huh! Vi conviene tenervi pronti!"

msgctxt "11||speech_list_cln||table||767||||4"
msgid "You're strong...\nJoe, too. You've gotten real good."
msgstr "Siete forti...\nAnche tu, Joe. Sei diventato proprio in gamba."

msgctxt "11||speech_list_cln||table||768||||4"
msgid "I didn't think I'd ever hear that from you."
msgstr "Non avrei mai pensato di sentirvelo dire."

msgctxt "11||speech_list_cln||table||769||||4"
msgid "Man, ya bastards brought down the TenCozy tag team...\nNobody's done that since Okada took us on."
msgstr "Cazzo, avete battuto il tag team dei TenCozy...\nNessuno c'era più riuscito da quando Okada ci ha sfidato."

msgctxt "11||speech_list_cln||table||770||||4"
msgid "Before you guys joined JUSTIS, you were\nin the color gangs, weren't you?"
msgstr "Prima che vi uniste a JUSTIS, eravate\nnelle gang dei colori, non è vero?"

msgctxt "11||speech_list_cln||table||771||||4"
msgid "Yeah. Your friend Joe here and Okada\nhated the color gangs with a burnin' passion."
msgstr "Già. Il tuo amico Joe e Okada odiavano\nle gang dei colori in maniera viscerale."

msgctxt "11||speech_list_cln||table||772||||4"
msgid "That's why they made JUSTIS, y'know.\nThey wanted to crush the color gangs."
msgstr "È per questo che hanno creato JUSTIS, sai.\nVolevano distruggere le gang dei colori."

msgctxt "11||speech_list_cln||table||773||||4"
msgid "We weren't expectin' to lose, though."
msgstr "Non ci aspettavamo di perdere, però."

msgctxt "11||speech_list_cln||table||774||||4"
msgid "And once you lost to them, you disbanded."
msgstr "E quando hanno avuto la meglio su di voi,\nvi siete sciolti."

msgctxt "11||speech_list_cln||table||775||||4"
msgid "Went extinct's more like it.\nThey pounded us into the goddamn ground."
msgstr "Ci hanno annientato, direi.\nCi hanno letteralmente spazzato via."

msgctxt "11||speech_list_cln||table||776||||4"
msgid "But y'know, we can't help followin' someone\nwho's stronger than us. It's our policy."
msgstr "Ma sai, non possiamo fare a meno di seguire qualcuno\nche sia più forte di noi. È la nostra politica."

msgctxt "11||speech_list_cln||table||777||||4"
msgid "Right. We lost to Okada, so we ditched our colors\nand moved over to JUSTIS. That's the short of it."
msgstr "Giusto. Abbiamo perso contro Okada, così abbiamo mollato\ni nostri colori e siamo passati a JUSTIS. In parole povere."

msgctxt "11||speech_list_cln||table||778||||4"
msgid "Which brings us to today,\nn' our loss to the Kiryu Clan."
msgstr "Il che ci porta a oggi, e alla\nnostra sconfitta contro il Clan Kiryu."

msgctxt "11||speech_list_cln||table||779||||4"
msgid "Yup, guess we don't got much choice.\nWe'll be followin' our policy n' joinin' you guys."
msgstr "Già, immagino che non abbiamo molta scelta.\nSeguiremo la nostra politica e ci uniremo a voi."

msgctxt "11||speech_list_cln||table||780||||4"
msgid "What!?"
msgstr "Cosa!?"

msgctxt "11||speech_list_cln||table||781||||4"
msgid "We just told ya we follow whoever's stronger than us!\nYa guys won, so we're on your side now."
msgstr "Vi abbiamo appena detto che seguiamo chiunque sia più forte di\nnoi! Voi avete vinto, perciò ora stiamo dalla vostra parte."

msgctxt "11||speech_list_cln||table||782||||4"
msgid "You're not allowed to say no. This's our policy,\nso we've gotta do it no matter what."
msgstr "Non vi è permesso rifiutare. È la nostra politica,\nquindi dobbiamo farlo, a ogni costo."

msgctxt "11||speech_list_cln||table||783||||4"
msgid "Plus now that we lost to ya,\nwe're totally gettin' kicked outta JUSTIS."
msgstr "Inoltre, ora che abbiamo perso contro di voi,\nverremo sbattuti fuori a calci da JUSTIS."

msgctxt "11||speech_list_cln||table||784||||4"
msgid "What do you think...?"
msgstr "Che ne pensi...?"

msgctxt "11||speech_list_cln||table||785||||4"
msgid "It should be fine.\nThere's a weird sort of logic to it."
msgstr "Credo possa andare bene.\nC'è una strana logica, in tutto questo."

msgctxt "11||speech_list_cln||table||786||||4"
msgid "Reminds me of myself in a way."
msgstr "Mi ricorda in parte me stesso."

msgctxt "11||speech_list_cln||table||787||||4"
msgid "Glad ya get us, Kiryu-san."
msgstr "Felice che tu ci capisca, Kiryu-san."

msgctxt "11||speech_list_cln||table||788||||4"
msgid "Let's kick some ass, yeah?\nN' don't worry, we won't hold ya back."
msgstr "Spacchiamo qualche culo, ok?\nE non temete, non vi saremo d'intralcio."

msgctxt "11||speech_list_cln||table||789||||4"
msgid "I know."
msgstr "Ne sono certo."

msgctxt "11||speech_list_cln||table||790||||4"
msgid "Hm?"
msgstr "Mhm?"

msgctxt "11||speech_list_cln||table||791||||4"
msgid "Tanahashi..."
msgstr "Tanahashi..."

msgctxt "11||speech_list_cln||table||792||||4"
msgid "Joe."
msgstr "Joe."

msgctxt "11||speech_list_cln||table||794||||4"
msgid "Who is that?"
msgstr "Chi è quello?"

msgctxt "11||speech_list_cln||table||795||||4"
msgid "Another Lunatic, Tanahashi. He was a good friend.\nOne of the only ones who ever understood me."
msgstr "Un altro Folle, Tanahashi. Era un buon amico.\nUno dei pochi ad avermi mai capito."

msgctxt "11||speech_list_cln||table||796||||4"
msgid "Huh, is that so?"
msgstr "Ah, davvero?"

msgctxt "11||speech_list_cln||table||797||||4"
msgid "Honestly, I'd rather not fight him if I can help it...\nBut we don't have much choice here."
msgstr "Onestamente, preferirei non affrontarlo, se potessi\nevitare... Ma non abbiamo molta scelta."

msgctxt "11||speech_list_cln||table||798||||4"
msgid "Man, there's nothing harder than\nhaving to fight your friends."
msgstr "Cavoli, non c'è cosa più dura del\ndover combattere contro i propri amici."

msgctxt "11||speech_list_cln||table||800||||4"
msgid "Maybe so. But sometimes it's easier\nto let your fists express how you feel."
msgstr "Forse sì. Ma a volte è più facile\nlasciar esprimere ai pugni ciò che si prova."

msgctxt "11||speech_list_cln||table||801||||4"
msgid "I hope that's the case for you and Okada.\nIt would be nice if you two made up."
msgstr "Spero sia questo il caso, per te e Okada.\nSarebbe bello se voi due vi riconciliaste."

msgctxt "11||speech_list_cln||table||802||||4"
msgid "Yeah..."
msgstr "Sì..."

msgctxt "11||speech_list_cln||table||803||||4"
msgid "Your men are strong, Kiryu Clan."
msgstr "I tuoi uomini sono forti, Clan Kiryu."

msgctxt "11||speech_list_cln||table||804||||4"
msgid "Tana..."
msgstr "Tana..."

msgctxt "11||speech_list_cln||table||805||||4"
msgid "Color me impressed, Joe. You've grown\nquite a bit since leaving the JUSTIS ranks."
msgstr "Considerami impressionato, Joe. Sei cresciuto\nparecchio da quando hai lasciato i ranghi di JUSTIS."

msgctxt "11||speech_list_cln||table||806||||4"
msgid "I don't care about that."
msgstr "Non mi interessa questo."

msgctxt "11||speech_list_cln||table||807||||4"
msgid "Tana. Don't you realize? JUSTIS is no different\nfrom the shitty color gangs back in the day."
msgstr "Tana. Non te ne rendi conto? JUSTIS non è per niente\ndiversa dalle luride gang dei colori di un tempo."

msgctxt "11||speech_list_cln||table||808||||4"
msgid "...I know."
msgstr "...Lo so."

msgctxt "11||speech_list_cln||table||809||||4"
msgid "Then why are you throwing your weight behind\nOkada? We need to show him this is wrong!"
msgstr "Allora perché continui a schierarti dalla parte di\nOkada? Dobbiamo fargli capire che si sta sbagliando!"

msgctxt "11||speech_list_cln||table||810||||4"
msgid "You're right.\nHe may well be out of line."
msgstr "Hai ragione.\nEgli potrebbe benissimo aver superato il limite."

msgctxt "11||speech_list_cln||table||811||||4"
msgid "Even so, I promised I would follow him...\nand I intend to keep that promise."
msgstr "Ciononostante, ho promesso che lo avrei seguito...\ne intendo mantenere tale promessa."

msgctxt "11||speech_list_cln||table||812||||4"
msgid "But why!?"
msgstr "Ma perché!?"

msgctxt "11||speech_list_cln||table||813||||4"
msgid "Answer me this. Have you ever considered\nhow it is he grew to be this way?"
msgstr "Rispondimi a questo. Hai mai considerato come\nsia potuto diventare in questo modo?"

msgctxt "11||speech_list_cln||table||814||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "11||speech_list_cln||table||815||||4"
msgid "It may seem evil from your point of view."
msgstr "Dal tuo punto di vista potrebbe sembrare malvagio."

msgctxt "11||speech_list_cln||table||816||||4"
msgid "But to him,\nit's his own personal brand of justice."
msgstr "Ma per lui,\nè la sua personalissima forma di giustizia."

msgctxt "11||speech_list_cln||table||817||||4"
msgid "And I agree with it."
msgstr "E io la condivido appieno."

msgctxt "11||speech_list_cln||table||818||||4"
msgid "......"
msgstr "......"

msgctxt "11||speech_list_cln||table||819||||4"
msgid "Anyway, I think that's enough for now.\nWe can end here for today."
msgstr "Comunque, credo che per ora possa bastare.\nPossiamo chiudere qui, per oggi."

msgctxt "11||speech_list_cln||table||820||||4"
msgid "Remember, we're enemies.\nOur next meeting will be in battle."
msgstr "Ricorda, siamo nemici.\nIl nostro prossimo incontro avverrà in battaglia."

msgctxt "11||speech_list_cln||table||821||||4"
msgid "Hold on, Tana!"
msgstr "Aspetta, Tana!"

msgctxt "11||speech_list_cln||table||822||||4"
msgid "What is it?"
msgstr "Che c'è?"

msgctxt "11||speech_list_cln||table||823||||4"
msgid "I need to know. What changed\nOkada into the man he is now?"
msgstr "Devo saperlo. Che cosa ha trasformato\nOkada nell'uomo che è adesso?"

msgctxt "11||speech_list_cln||table||824||||4"
msgid "Didn't we crush the color gangs?\nWhy does he need more power than that?"
msgstr "Non abbiamo distrutto le gang dei colori?\nPerché ha bisogno di maggior potere, ora?"

msgctxt "11||speech_list_cln||table||825||||4"
msgid "And also... Why do you stand by him?"
msgstr "E inoltre... Perché continui a stare dalla sua parte?"

msgctxt "11||speech_list_cln||table||826||||4"
msgid "If you want to know... You'll have to defeat me.\nGoodbye."
msgstr "Se lo vuoi sapere... Dovrai prima sconfiggermi.\nAddio."

msgctxt "11||speech_list_cln||table||827||||4"
msgid "Goddammit.\nHow did things turn out like this?"
msgstr "Maledizione.\nCome siamo potuti arrivare a questo?"

msgctxt "11||speech_list_cln||table||828||||4"
msgid "Joe..."
msgstr "Joe..."

msgctxt "11||speech_list_cln||table||829||||4"
msgid "It's time for the next Lunatic, Tanahashi."
msgstr "È arrivato il momento del prossimo Folle, Tanahashi."

msgctxt "11||speech_list_cln||table||830||||4"
msgid "Yeah... But I'm not really feeling it."
msgstr "Sì... Ma non mi sento tanto bene al riguardo."

msgctxt "11||speech_list_cln||table||831||||4"
msgid "Tana was my friend. And he's\nevery bit as strong as Okada."
msgstr "Tana era mio amico. Ed è\nforte in tutto e per tutto quanto Okada."

msgctxt "11||speech_list_cln||table||832||||4"
msgid "This is gonna be a struggle, then."
msgstr "Sarà uno scontro difficile, allora."

msgctxt "11||speech_list_cln||table||833||||4"
msgid "Tanahashi... He looked like he was\nan incredibly reserved man."
msgstr "Tanahashi... Sembrava un uomo\nincredibilmente riservato."

msgctxt "11||speech_list_cln||table||834||||4"
msgid "You know, he didn't use to be so serious."
msgstr "Sai, non è mai stato così serio in passato."

msgctxt "11||speech_list_cln||table||835||||4"
msgid "He used to play a real mean air guitar, or would shout\n\"I love you!\" for no reason. Pretty weird, huh?"
msgstr "Suonava benissimo la air guitar e urlava \"Vi amo!\"\nsenza alcun motivo. Piuttosto strano, eh?"

msgctxt "11||speech_list_cln||table||836||||4"
msgid "That's a bit of an understatement."
msgstr "È un eufemismo."

msgctxt "11||speech_list_cln||table||837||||4"
msgid "He really is a great person deep down, though.\nHe's never been as restrained as he is now."
msgstr "In fondo è davvero una brava persona, però.\nNon è mai stato così trattenuto come lo è ora."

msgctxt "11||speech_list_cln||table||838||||4"
msgid "When exactly did he start changing?"
msgstr "Quand'è che ha iniziato a cambiare, di preciso?"

msgctxt "11||speech_list_cln||table||839||||4"
msgid "Probably around the same time as Okada. Something\nmust have happened between the two of them."
msgstr "Probabilmente nello stesso periodo di Okada. Dev'essere\nsuccesso qualcosa tra loro due."

msgctxt "11||speech_list_cln||table||842||||4"
msgid "Hey, if we beat this Tanahashi guy, he's gonna\ntell us everything that happened, right?"
msgstr "Ehi, se sconfiggiamo questo tizio Tanahashi, ci\ndirà tutto ciò che è accaduto, giusto?"

msgctxt "11||speech_list_cln||table||843||||4"
msgid "Yeah. We can't afford to lose."
msgstr "Sì. Non possiamo permetterci di perdere."

msgctxt "11||speech_list_cln||table||844||||4"
msgid "Hearing what he has to say will be the first step\ntoward learning the truth about Okada."
msgstr "Ascoltare ciò che ha da dire sarà il primo passo\nper scoprire la verità su Okada."

msgctxt "11||speech_list_cln||table||845||||4"
msgid "All right! We gotta make sure\nwe give this our all, then!"
msgstr "D'accordo! Allora dovremo assicurarci\ndi dare il tutto per tutto!"

msgctxt "11||speech_list_cln||table||846||||4"
msgid "Damn right."
msgstr "Puoi dirlo forte."

msgctxt "11||speech_list_cln||table||847||||4"
msgid "I never thought the day would come\nthat we'd have to fight, Tana."
msgstr "Non avrei mai creduto che un giorno\navremmo dovuto combattere, Tana."

msgctxt "11||speech_list_cln||table||848||||4"
msgid "Same goes for me, Joe.\nWe... used to be so close."
msgstr "Lo stesso vale per me, Joe.\nEravamo... così uniti un tempo."

msgctxt "11||speech_list_cln||table||849||||4"
msgid "Don't forget your promise. If we beat you here,\nyou'll tell us whatever we want to know."
msgstr "Non dimenticare la promessa. Se ti batteremo,\nci dirai tutto ciò che vogliamo sapere."

msgctxt "11||speech_list_cln||table||850||||4"
msgid "Yeah, a deal is a deal.\nI'm warning you, though. It won't be easy."
msgstr "Sì, un patto è un patto.\nVi avverto, però. Non sarà affatto facile."

msgctxt "11||speech_list_cln||table||851||||4"
msgid "I'm going to devote every ounce\nof my strength to winning here today."
msgstr "Ho intenzione di dedicare ogni grammo\ndella mia forza per vincere qui, oggi."

msgctxt "11||speech_list_cln||table||852||||4"
msgid "Even against you...\nI don't plan on holding back."
msgstr "Persino contro di te...\nNon intendo trattenermi."

msgctxt "11||speech_list_cln||table||853||||4"
msgid "Don't give me that. You've never really been\none for self-restraint in the past."
msgstr "Risparmiami le manfrine. In passato non\nsei mai stato il tipo da trattenersi."

msgctxt "11||speech_list_cln||table||854||||4"
msgid "I guess you're right, Joe.\nYou know me well."
msgstr "Hai proprio ragione, Joe.\nMi conosci bene."

msgctxt "11||speech_list_cln||table||855||||4"
msgid "I love that side of you.\nHonestly, Joe."
msgstr "Amo quel tuo lato.\nSinceramente, Joe."

msgctxt "11||speech_list_cln||table||856||||4"
msgid "Hmph."
msgstr "Mpf."

msgctxt "11||speech_list_cln||table||857||||4"
msgid "Now then, the time for talking is over. Let's begin.\nI'm going to show you the strength of the Six Lunatics!"
msgstr "Dunque, il momento delle chiacchiere è terminato. Iniziamo.\nVi mostrerò la vera forza dei Sei Folli!"

msgctxt "11||speech_list_cln||table||858||||4"
msgid "You're pretty tough, Joe."
msgstr "Sei un osso duro, Joe."

msgctxt "11||speech_list_cln||table||859||||4"
msgid "Same to you, Tana.\nWe've got you cornered, though."
msgstr "Vale lo stesso per te, Tana.\nMa ti abbiamo messo all'angolo."

msgctxt "11||speech_list_cln||table||860||||4"
msgid "Not yet you don't.\nI was just giving you a little handicap."
msgstr "Ancora no, direi.\nVi stavo solo concedendo un piccolo vantaggio."

msgctxt "11||speech_list_cln||table||861||||4"
msgid "Let's settle this one-on-one.\nSee who comes out on top."
msgstr "Risolviamo la questione in un uno contro uno.\nVediamo chi avrà la meglio."

msgctxt "11||speech_list_cln||table||862||||4"
msgid "Yeah!"
msgstr "Sì!"

msgctxt "11||speech_list_cln||table||863||||4"
msgid "Tanahashi!"
msgstr "Tanahashi!"

msgctxt "11||speech_list_cln||table||864||||4"
msgid "Hm?"
msgstr "Mhm?"

msgctxt "11||speech_list_cln||table||865||||4"
msgid "How pathetic, being defeated by these fools.\nIt seems we'll have to clean up your mess for you."
msgstr "Che patetico, farsi sconfiggere da questi idioti.\nSembra che dovremo pulire il tuo pasticcio per te."

msgctxt "11||speech_list_cln||table||866||||4"
msgid "Now then... Beat these two to death!"
msgstr "Molto bene... Massacrate a morte questi due!"

msgctxt "11||speech_list_cln||table||867||||4"
msgid "You can't just butt in when we're about\nto settle things. This isn't your fight."
msgstr "Non potete intromettervi ora che stiamo per\nrisolvere la faccenda. Questa non è la vostra battaglia."

msgctxt "11||speech_list_cln||table||868||||4"
msgid "There are tons of them...\nKiryu-san, you gonna be okay?"
msgstr "Ce ne sono una valanga...\nKiryu-san, andrà tutto bene?"

msgctxt "11||speech_list_cln||table||869||||4"
msgid "Absolutely. What about you?"
msgstr "Assolutamente sì. E tu?"

msgctxt "11||speech_list_cln||table||870||||4"
msgid "Absolutely."
msgstr "Assolutamente sì."

msgctxt "11||speech_list_cln||table||871||||4"
msgid "Good. Watch my back, okay?"
msgstr "Bene. Guardami le spalle, okay?"

msgctxt "11||speech_list_cln||table||872||||4"
msgid "Yeah. I won't let you down!"
msgstr "Sì. Non ti deluderò!"

msgctxt "11||speech_list_cln||table||873||||4"
msgid "You've done well to reach this point.\nHowever, it's just about time to wrap up this party."
msgstr "Vi siete difesi bene fino ad ora.\nTuttavia, è arrivato il momento di chiudere la festa."

msgctxt "11||speech_list_cln||table||874||||4"
msgid "Move out! Slice these two to pieces!"
msgstr "Muovetevi! Fate a pezzi questi due!"

msgctxt "11||speech_list_cln||table||875||||4"
msgid "Let's do this!"
msgstr "Facciamoli fuori!"

msgctxt "11||speech_list_cln||table||876||||4"
msgid "Right!"
msgstr "Certo!"

msgctxt "11||speech_list_cln||table||878||||4"
msgid "Guess I lose, Joe."
msgstr "Immagino di aver perso, Joe."

msgctxt "11||speech_list_cln||table||879||||4"
msgid "You really are strong though, Tana."
msgstr "Ma sei davvero un osso duro, Tana."

msgctxt "11||speech_list_cln||table||880||||4"
msgid "What useless garbage."
msgstr "Che inutile spazzatura."

msgctxt "11||speech_list_cln||table||881||||4"
msgid "You promised. Tell me everything\nyou know about Okada."
msgstr "Hai fatto una promessa. Dimmi\ntutto quello che sai su Okada."

msgctxt "11||speech_list_cln||table||882||||4"
msgid "Right. Honestly, I wanted to\nfind a way to talk about this sooner."
msgstr "Certo. Onestamente, avrei tanto voluto trovare un\nmodo per poterne parlare prima di adesso."

msgctxt "11||speech_list_cln||table||883||||4"
msgid "That's my cue to leave."
msgstr "Questo è il mio segnale per togliere il disturbo."

msgctxt "11||speech_list_cln||table||884||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "11||speech_list_cln||table||885||||4"
msgid "This should stay between friends. I'm sure you\ntwo have a lot to catch up on. Take your time."
msgstr "La conversazione dovrebbe rimanere tra amici. Sono certo che abbiate\nmolte cose da dirvi. Prendetevi tutto il tempo che vi serve."

msgctxt "11||speech_list_cln||table||886||||4"
msgid "I'll be waiting back at the hideout."
msgstr "Vi aspetterò al nascondiglio."

msgctxt "11||speech_list_cln||table||887||||4"
msgid "Kiryu-san... Thank you."
msgstr "Kiryu-san... Grazie."

msgctxt "11||speech_list_cln||table||888||||4"
msgid "Welcome back, Joe.\nDid Tanahashi fill you in?"
msgstr "Bentornato, Joe.\nTanahashi ti ha messo al corrente?"

msgctxt "11||speech_list_cln||table||889||||4"
msgid "Yeah. He told me everything."
msgstr "Sì. Mi ha detto ogni cosa."

msgctxt "11||speech_list_cln||table||890||||4"
msgid "Well? Let's hear it."
msgstr "Ebbene? Raccontami."

msgctxt "11||speech_list_cln||table||891||||4"
msgid "Hm, where should I start?"
msgstr "Mhm, da dove dovrei iniziare?"

msgctxt "11||speech_list_cln||table||892||||4"
msgid "I told you how the reason we made JUSTIS to begin\nwith was to take down the color gangs, right?"
msgstr "Ti ho detto che il motivo per cui avevamo fondato JUSTIS, agli\ninizi, era proprio sgominare le gang dei colori, te lo ricordi?"

msgctxt "11||speech_list_cln||table||893||||4"
msgid "Yeah."
msgstr "Sì."

msgctxt "11||speech_list_cln||table||894||||4"
msgid "At the start, JUSTIS was a tiny organization.\nWe quickly gained followers, though."
msgstr "All'inizio, JUSTIS era un'organizzazione minuscola.\nIn breve tempo, però, ottenemmo molti seguaci."

msgctxt "11||speech_list_cln||table||895||||4"
msgid "People all over the city were upset\nwith the color gangs reign of terror."
msgstr "La gente di tutta la città era insofferente\nnei confronti del regno di terrore delle gang dei colori."

msgctxt "11||speech_list_cln||table||896||||4"
msgid "Thanks to Okada's charisma, we had\na pretty constant stream of new members."
msgstr "E grazie al carisma di Okada, avevamo\nun flusso alquanto costante di nuovi membri."

msgctxt "11||speech_list_cln||table||897||||4"
msgid "We were lacking in numbers,\nbut had a wealth of team unity."
msgstr "Non facevamo certo la forza nei numeri,\nma godevamo di un forte senso di coesione."

msgctxt "11||speech_list_cln||table||898||||4"
msgid "And once we grew big enough...\nwe finally took the color gangs out."
msgstr "E una volta che crescemmo a sufficienza...\nSgominammo finalmente le gang dei colori."

msgctxt "11||speech_list_cln||table||899||||4"
msgid "Things were still going well at that point, then."
msgstr "E a quel punto le cose sembravano ancora andare bene, insomma."

msgctxt "11||speech_list_cln||table||900||||4"
msgid "But soon after, Okada changed and turned\nJUSTIS into the gang it is today."
msgstr "Sì, ma poco dopo, Okada è cambiato e ha\ntrasformato JUSTIS nella gang che è oggi."

msgctxt "11||speech_list_cln||table||901||||4"
msgid "Yeah."
msgstr "Già."

msgctxt "11||speech_list_cln||table||902||||4"
msgid "And the reason for that?\nDid he give you one?"
msgstr "E qual è stato il motivo per tutto questo?\nTe ne ha dato almeno uno?"

msgctxt "11||speech_list_cln||table||903||||4"
msgid "We destroyed the color gangs, but I guess the\nguys pulling the strings were none too happy."
msgstr "Abbiamo distrutto le gang dei colori, ma deduco che i\ntizi che ne tiravano le fila non fossero troppo contenti."

msgctxt "11||speech_list_cln||table||904||||4"
msgid "The ones pulling the strings?"
msgstr "Quelli che tiravano le fila?"

msgctxt "11||speech_list_cln||table||906||||4"
msgid "Yakuza and mafia guys, no doubt. The gangs were\njust proxies for them to commit their crimes."
msgstr "Senza dubbio, tizi della yakuza e della mafia. Le gang erano solo i\nburattini di cui si servivano per compiere i loro crimini."

msgctxt "11||speech_list_cln||table||907||||4"
msgid "And once the pawns were removed...\nThey were probably furious, I'd guess."
msgstr "E una volta che i pedoni sono stati rimossi dalla scacchiera...\nSaranno andati su tutte le furie, suppongo."

msgctxt "11||speech_list_cln||table||908||||4"
msgid "So they wanted retaliation for what you did..."
msgstr "Così hanno cercato una ritorsione per quello che avevate fatto..."

msgctxt "11||speech_list_cln||table||909||||4"
msgid "Yeah. And the one they went after...\nwas Okada."
msgstr "Sì. E l'obiettivo contro cui hanno puntato il mirino...\nera Okada."

msgctxt "11||speech_list_cln||table||910||||4"
msgid "Yeah. They got hold of Okada soon after.\nPut him through some horrible torture."
msgstr "Già. Sono riusciti a mettere le mani su Okada poco dopo.\nE gli hanno fatto subire delle tremende torture."

msgctxt "11||speech_list_cln||table||911||||4"
msgid "It wasn't just him, though. They apparently\neven scarred up his girlfriend real bad."
msgstr "Ma non hanno preso solo lui, però. A quanto pare,\nhanno sfregiato malamente anche la sua fidanzata."

msgctxt "11||speech_list_cln||table||912||||4"
msgid "That's horrible."
msgstr "Che cosa terribile."

msgctxt "11||speech_list_cln||table||913||||4"
msgid "Yeah."
msgstr "Puoi ben dirlo."

msgctxt "11||speech_list_cln||table||914||||4"
msgid "And after all that happened,\nOkada didn't tell any of you about it?"
msgstr "E dopo che è successa una cosa del genere,\nOkada non vi ha detto nulla al riguardo?"

msgctxt "11||speech_list_cln||table||915||||4"
msgid "Yeah. If we knew how bad it was, we would\nhave definitely tried to fight back."
msgstr "No. Se ne avessimo anche solo intuito la gravità, ci\nsaremmo sicuramente organizzati per reagire."

msgctxt "11||speech_list_cln||table||916||||4"
msgid "But if we had, more and more people\nwould've been tortured just like Okada was."
msgstr "Ma se l'avessimo fatto, sempre più persone sarebbero\nstate torturate, proprio come era successo ad Okada."

msgctxt "11||speech_list_cln||table||917||||4"
msgid "I think that's why he stayed quiet."
msgstr "Penso che sia per questo che è rimasto in silenzio."

msgctxt "11||speech_list_cln||table||918||||4"
msgid "Tanahashi figured it all out, though. Accidentally\nwalked in on Okada crying about his girlfriend."
msgstr "Tanahashi lo aveva capito da tempo, però. Ha visto\naccidentalmente Okada in lacrime per la sua ragazza."

msgctxt "11||speech_list_cln||table||919||||4"
msgid "Once he witnessed that, he felt like\nhe had to stand by Okada no matter what."
msgstr "Una volta che fu testimone di quella scena, sentì di\ndover stare accanto ad Okada, a qualsiasi costo."

msgctxt "11||speech_list_cln||table||920||||4"
msgid "So that's how it happened..."
msgstr "Quindi è così che sono andate le cose..."

msgctxt "11||speech_list_cln||table||921||||4"
msgid "That's right. I'd known him for years at that point,\nbut I'd never seen him look so somber before."
msgstr "Esatto. Lo conoscevo da anni, a quel punto della nostra amicizia,\nma non l'avevo mai visto assumere uno sguardo così tetro."

msgctxt "11||speech_list_cln||table||922||||4"
msgid "Tanahashi..."
msgstr "Tanahashi..."

msgctxt "11||speech_list_cln||table||923||||4"
msgid "That day... That's when Okada changed."
msgstr "È in quel giorno... che Okada è cambiato per sempre."

msgctxt "11||speech_list_cln||table||924||||4"
msgid "He formed JUSTIS to protect what was important\nto him, but he couldn't even keep his girlfriend safe..."
msgstr "Ha formato JUSTIS per proteggere ciò che era importante\nper lui, ma non è riuscito a tenere al sicuro neanche la sua ragazza..."

msgctxt "11||speech_list_cln||table||925||||4"
msgid "Okada took the blame for that personally.\nHe thought JUSTIS wasn't strong enough."
msgstr "Okada se ne è fatto una colpa.\nPensava che JUSTIS non fosse abbastanza forte."

msgctxt "11||speech_list_cln||table||926||||4"
msgid "Strength became his only goal. So, he brought in\nanyone he deemed strong, even if they were evil."
msgstr "La forza è diventata il suo unico obiettivo. Così, ha reclutato\nchiunque ritenesse forte, anche i peggiori criminali."

msgctxt "11||speech_list_cln||table||927||||4"
msgid "The brawny Tenzan and Kojima. The secretive Naito.\nKomei for military, and Yano for fundraising."
msgstr "I muscolosi Tenzan e Kojima. Il misterioso Naito.\nKomei per la strategia militare e Yano per i fondi."

msgctxt "11||speech_list_cln||table||928||||4"
msgid "But that ruined him."
msgstr "Ma questo lo ha rovinato."

msgctxt "11||speech_list_cln||table||929||||4"
msgid "His team no longer stood for justice..."
msgstr "La sua squadra non rappresentava più la giustizia..."

msgctxt "11||speech_list_cln||table||930||||4"
msgid "Exactly."
msgstr "Esatto."

msgctxt "11||speech_list_cln||table||931||||4"
msgid "And all I've done is talk about his wrongdoing,\nbut I didn't know the heavy burden he shouldered."
msgstr "E io non ho fatto altro che parlare dei suoi errori,\nsenza conoscere il pesante fardello che si portava dietro."

msgctxt "11||speech_list_cln||table||932||||4"
msgid "I'm a failure of a friend."
msgstr "Sono un pessimo amico."

msgctxt "11||speech_list_cln||table||933||||4"
msgid "So what are you going to do?\nDo you want to stop going after JUSTIS?"
msgstr "Allora, cosa hai intenzione di fare?\nVuoi smettere di dare la caccia a JUSTIS?"

msgctxt "11||speech_list_cln||table||935||||4"
msgid "No. I won't stop."
msgstr "No. Non mi fermerò."

msgctxt "11||speech_list_cln||table||936||||4"
msgid "I... I think I know how Okada felt.\nHe must have been sad. Depressed, even."
msgstr "Io... credo di capire come si sentisse Okada.\nDeve essere stato triste. Depresso, persino."

msgctxt "11||speech_list_cln||table||937||||4"
msgid "Even so, what Okada's been doing now is no better\nthan the torture those guys inflicted on him."
msgstr "Eppure, quello che Okada sta facendo ora non è migliore\ndelle torture che quei tizi gli hanno inflitto."

msgctxt "11||speech_list_cln||table||938||||4"
msgid "He gained power to protect the people around him,\nbut he's hurting others at the same time."
msgstr "Ha ottenuto potere per proteggere le persone intorno a lui,\nma allo stesso tempo sta ferendo gli altri."

msgctxt "11||speech_list_cln||table||939||||4"
msgid "He's brought forth a second and third\nterrible version of himself."
msgstr "Ha generato una seconda e una terza\nversione terribile di sé stesso."

msgctxt "11||speech_list_cln||table||940||||4"
msgid "Joe..."
msgstr "Joe..."

msgctxt "11||speech_list_cln||table||941||||4"
msgid "He's strong, though. And charismatic.\nNot only was he a friend, but a role model, too."
msgstr "Però è forte. E carismatico.\nNon era solo un amico, ma anche un modello da seguire."

msgctxt "11||speech_list_cln||table||942||||4"
msgid "That's why... I need to get him back."
msgstr "Ecco perché... devo farlo tornare in sé."

msgctxt "11||speech_list_cln||table||943||||4"
msgid "It's my job as a friend.\nI need to correct his wrongdoing."
msgstr "È il mio compito come amico.\nDevo correggere i suoi errori."

msgctxt "11||speech_list_cln||table||944||||4"
msgid "Joe... You've really grown."
msgstr "Joe... sei davvero cresciuto."

msgctxt "11||speech_list_cln||table||945||||4"
msgid "Kiryu-san..."
msgstr "Kiryu-san..."

msgctxt "11||speech_list_cln||table||946||||4"
msgid "You're right."
msgstr "Hai ragione."

msgctxt "11||speech_list_cln||table||947||||4"
msgid "Joe. Being friends with someone is more\nthan just fun and games all the time."
msgstr "Joe. Essere amici di qualcuno è molto più\nche divertirsi e basta tutto il tempo."

msgctxt "11||speech_list_cln||table||948||||4"
msgid "If they do something wrong, you get mad at them.\nIf they lose control, you do what it takes to stop them."
msgstr "Se fanno qualcosa di sbagliato, ti arrabbi con loro.\nSe perdono il controllo, fai il possibile per fermarli."

msgctxt "11||speech_list_cln||table||949||||4"
msgid "Most importantly, you have to be willing to drop\neverything for them. That's what a true friend does."
msgstr "Ma soprattutto, devi essere disposto a mollare\ntutto per loro. È questo che fa un vero amico."

msgctxt "11||speech_list_cln||table||950||||4"
msgid "Kiryu-san..."
msgstr "Kiryu-san..."

msgctxt "11||speech_list_cln||table||951||||4"
msgid "We've gotten all different types in the\nKiryu Clan, but only you can stop him."
msgstr "Abbiamo accolto ogni tipo di persona nel\nClan Kiryu, ma solo tu puoi fermarlo."

msgctxt "11||speech_list_cln||table||952||||4"
msgid "Don't forget that. And...\nMake sure your emotions get through to him."
msgstr "Non dimenticarlo. E...\nAssicurati che i tuoi sentimenti lo raggiungano."

msgctxt "11||speech_list_cln||table||953||||4"
msgid "Make sure you're ready for\nwhatever happens, Joe. Understood?"
msgstr "Assicurati di essere pronto a\nqualsiasi cosa, Joe. Intesi?"

msgctxt "11||speech_list_cln||table||954||||4"
msgid "Kiryu-san..."
msgstr "Kiryu-san..."

msgctxt "11||speech_list_cln||table||955||||4"
msgid "Joe. Kiryu-san.\nPlease let me help you."
msgstr "Joe. Kiryu-san.\nVi prego, lasciatemi aiutare."

msgctxt "11||speech_list_cln||table||956||||4"
msgid "You sure?"
msgstr "Sei sicuro?"

msgctxt "11||speech_list_cln||table||957||||4"
msgid "As I was listening to the two\nof you talk, I realized something."
msgstr "Mentre ascoltavo voi due\nparlare, ho capito una cosa."

msgctxt "11||speech_list_cln||table||958||||4"
msgid "Even though I thought I was supporting Okada...\nI think I was cornering him the whole time."
msgstr "Anche se credevo di sostenere Okada...\npenso di averlo messo all'angolo per tutto il tempo."

msgctxt "11||speech_list_cln||table||959||||4"
msgid "Tana..."
msgstr "Tana..."

msgctxt "11||speech_list_cln||table||960||||4"
msgid "A true pal would stop his friend from doing\nsomething wrong. That's clear to me now."
msgstr "Un vero compagno fermerebbe un amico che sta facendo\nqualcosa di sbagliato. Ora mi è chiaro."

msgctxt "11||speech_list_cln||table||961||||4"
msgid "And... Okada's definitely one of my friends.\nLet's bring him down together."
msgstr "E... Okada è indubbiamente un mio amico.\nSconfiggiamolo insieme."

msgctxt "11||speech_list_cln||table||962||||4"
msgid "Tana... Thank you."
msgstr "Tana... Grazie."

msgctxt "11||speech_list_cln||table||964||||4"
msgid "Huh, I think some of my energy's coming back.\nIt's almost like my old self's gonna pop right out of me."
msgstr "Ehi, mi sa che mi sta tornando un po' di energia.\nÈ quasi come se il mio vecchio me stesse per uscirmi dal corpo."

msgctxt "11||speech_list_cln||table||965||||4"
msgid "That sounds kinda gross, Tana.\nThough... I'm glad to hear you're back."
msgstr "È una cosa un po' schifosa, Tana.\nPerò... sono felice di sentirti di nuovo in forma."

msgctxt "11||speech_list_cln||table||966||||4"
msgid "All right! Now that I'm joining up with you guys,\nI've gotta make sure you know how I feel!"
msgstr "Va bene! Ora che mi unisco a voi,\ndevo farvi capire come mi sento!"

msgctxt "11||speech_list_cln||table||967||||4"
msgid "Everyone in the Kiryu Clan!"
msgstr "A tutti i membri del Clan Kiryu!"

msgctxt "11||speech_list_cln||table||968||||4"
msgid "I love you!"
msgstr "Vi amo!"

msgctxt "11||speech_list_cln||table||969||||4"
msgid "What's with this guy?"
msgstr "Ma che ha questo tizio?"

msgctxt "11||speech_list_cln||table||970||||4"
msgid "Sorry. This is more like how Tana usually is."
msgstr "Scusate. Questo è più o meno il solito Tana."

msgctxt "11||speech_list_cln||table||971||||4"
msgid "Hmph. I guess if nothing else, he'll bring\na little bit of cheer to our side."
msgstr "Uhm. Immagino che, se non altro, porterà\nun po' di allegria dalla nostra parte."

msgctxt "11||speech_list_cln||table||972||||4"
msgid "Yeah."
msgstr "Già."

msgctxt "11||speech_list_cln||table||973||||4"
msgid "Kiryu-san. I'm going to save Okada,\nno matter what."
msgstr "Kiryu-san. Salverò Okada,\ncosti quel che costi."

msgctxt "11||speech_list_cln||table||974||||4"
msgid "He's... a close friend, after all."
msgstr "Dopotutto... è un caro amico."

msgctxt "11||speech_list_cln||table||975||||4"
msgid "Please lend me your strength,\nat least until then."
msgstr "Per favore, prestami la tua forza,\nalmeno fino ad allora."

msgctxt "11||speech_list_cln||table||976||||4"
msgid "Of course. If it means keeping your\nfriendship alive, I'll do whatever it takes."
msgstr "Certo. Se serve a mantenere viva la vostra\namicizia, farò tutto il necessario."

msgctxt "11||speech_list_cln||table||977||||4"
msgid "Thank you."
msgstr "Grazie."

msgctxt "11||speech_list_cln||table||978||||4"
msgid "Oh, such a pretty little lady!\nI love you!"
msgstr "Oh, che bella signorina!\nVi amo!"

msgctxt "11||speech_list_cln||table||979||||4"
msgid "Huh!? Who the heck is this guy!?"
msgstr "Eh!? Ma chi cavolo è questo tizio!?"

msgctxt "11||speech_list_cln||table||980||||4"
msgid "......"
msgstr "......"

msgctxt "11||speech_list_cln||table||981||||4"
msgid "......"
msgstr "......"

msgctxt "11||speech_list_cln||table||982||||4"
msgid "The only ones left in Kamurocho\nat this point are Okada and Komei."
msgstr "A questo punto, gli unici rimasti a\nKamurocho sono Okada e Komei."

msgctxt "11||speech_list_cln||table||983||||4"
msgid "There are still some JUSTIS guys down in Onomichi,\nthough. Let's focus on getting rid of them first."
msgstr "Ci sono ancora dei tizi di JUSTIS giù a Onomichi,\nperò. Concentriamoci prima a sbarazzarci di loro."

msgctxt "11||speech_list_cln||table||984||||4"
msgid "Next time you head back down there,\nwe'll be following right behind you."
msgstr "La prossima volta che tornate laggiù,\nvi seguiremo a ruota."

msgctxt "11||speech_list_cln||table||985||||4"
msgid "When you have the chance,\nstop by the hideout in Onomichi."
msgstr "Quando ne avete l'occasione,\npassate dal nascondiglio a Onomichi."

msgctxt "11||speech_list_cln||table||986||||4"
msgid "Got it."
msgstr "Ricevuto."

msgctxt "11||speech_list_cln||table||987||||4"
msgid "Who the heck are<symbol=em_dash_with_outline>"
msgstr "Chi cavolo siete<symbol=em_dash_with_outline>"

msgctxt "11||speech_list_cln||table||988||||4"
msgid "Masao!"
msgstr "Masao!"

msgctxt "11||speech_list_cln||table||989||||4"
msgid "How lovely it is to see you, Kiryu Clan.\nWe appreciate the welcome party, truly."
msgstr "Che piacere vedervi, Clan Kiryu.\nApprezziamo il comitato di accoglienza, davvero."

msgctxt "11||speech_list_cln||table||990||||4"
msgid "Okada..."
msgstr "Okada..."

msgctxt "11||speech_list_cln||table||991||||4"
msgid "Been a while, Joe."
msgstr "È passato un po' di tempo, Joe."

msgctxt "11||speech_list_cln||table||992||||4"
msgid "Okada. Can we go somewhere else?\nI want to talk to you in private."
msgstr "Okada. Possiamo andare da un'altra parte?\nVoglio parlarti in privato."

msgctxt "11||speech_list_cln||table||993||||4"
msgid "What a brazen fool you are.\nRainmaker has no need to speak to you!"
msgstr "Che sfacciato idiota. Rainmaker\nnon ha alcun bisogno di parlarti!"

msgctxt "11||speech_list_cln||table||994||||4"
msgid "Now then, we are not here to\ntrade idle barbs with you buffoons."
msgstr "Dunque, non siamo qui per scambiare\ninutili frecciatine con voi buffoni."

msgctxt "11||speech_list_cln||table||995||||4"
msgid "We've come to deliver your final warning."
msgstr "Siamo venuti a consegnarvi un ultimo avvertimento."

msgctxt "11||speech_list_cln||table||996||||4"
msgid "Final warning?"
msgstr "Ultimo avvertimento?"

msgctxt "11||speech_list_cln||table||997||||4"
msgid "Indeed. The stage is set for the ultimate battle\nbetween you miscreants and the forces of JUSTIS."
msgstr "Proprio così. Il palcoscenico è pronto per la battaglia\nfinale tra voi miscredenti e le forze di JUSTIS."

msgctxt "11||speech_list_cln||table||998||||4"
msgid "To be honest, I didn't expect Joe and a washed-up\nyakuza would ever manage to make it this far."
msgstr "A dire il vero, non mi sarei mai aspettato che Joe e\nuno yakuza fallito arrivassero fino a questo punto."

msgctxt "11||speech_list_cln||table||999||||4"
msgid "But your glory days are coming to an end.\nJUSTIS will bring the curtain down on your lives."
msgstr "Ma i vostri giorni di gloria stanno per finire.\nJUSTIS farà calare il sipario sulle vostre vite."

msgctxt "11||speech_list_cln||table||1000||||4"
msgid "While you have focused on expanding influence,\nwe instead chose to solidify our core."
msgstr "Mentre voi vi siete concentrati sull'espandere la vostra\ninfluenza, noi abbiamo scelto di consolidare il nostro nucleo."

msgctxt "11||speech_list_cln||table||1001||||4"
msgid "We are stronger now than we've ever been before."
msgstr "Siamo più forti che mai."

msgctxt "11||speech_list_cln||table||1002||||4"
msgid "Furthermore, all that strength is concentrated in\nKamurocho. You have no hope of victory."
msgstr "Inoltre, tutta questa forza è concentrata a\nKamurocho. Non avete alcuna speranza di vittoria."

msgctxt "11||speech_list_cln||table||1003||||4"
msgid "We are on a far higher level than you rats!\nDo you understand!?"
msgstr "Siamo a un livello nettamente superiore al vostro, ratti!\nLo capite!?"

msgctxt "11||speech_list_cln||table||1004||||4"
msgid "We'll never know if that's true unless we fight."
msgstr "Non sapremo mai se è vero a meno di non combattere."

msgctxt "11||speech_list_cln||table||1005||||4"
msgid "How can you even begin to think that!?\nThat's why you're nothing but a fool!"
msgstr "Come puoi anche solo pensare una cosa del genere!?\nEcco perché non sei altro che uno sciocco!"

msgctxt "11||speech_list_cln||table||1006||||4"
msgid "The only foolish thing possible would be\ngiving up without even trying to win."
msgstr "L'unica cosa sciocca sarebbe arrendersi\nsenza aver nemmeno provato a vincere."

msgctxt "11||speech_list_cln||table||1007||||4"
msgid "Kazuma Kiryu... This is all your fault."
msgstr "Kazuma Kiryu... È tutta colpa tua."

msgctxt "11||speech_list_cln||table||1008||||4"
msgid "Joe coming back. The Six Lunatics failing me.\nYou are to blame for every last thing."
msgstr "Il ritorno di Joe. Il fallimento dei Sei Folli.\nLa colpa di ogni singola cosa è solo tua."

msgctxt "11||speech_list_cln||table||1009||||4"
msgid "The way you cling to your beliefs\nso tightly... It makes me sick."
msgstr "Il modo in cui ti aggrappi così forte\nalle tue convinzioni... Mi fa venire il voltastomaco."

msgctxt "11||speech_list_cln||table||1010||||4"
msgid "This next battle will be when the Kiryu Clan\ndraws its final breath. I hope you're ready."
msgstr "Questa prossima battaglia sarà quando il Clan Kiryu\nesalerà il suo ultimo respiro. Spero siate pronti."

msgctxt "11||speech_list_cln||table||1011||||4"
msgid "Hey, Okada."
msgstr "Ehi, Okada."

msgctxt "11||speech_list_cln||table||1012||||4"
msgid "What is it?\nDragon of Dojima, Kazuma Kiryu-san..."
msgstr "Cosa c'è?\nDrago di Dojima, Kazuma Kiryu-san..."

msgctxt "11||speech_list_cln||table||1013||||4"
msgid "You already know the truth, don't you?\nWhat you're doing is wrong."
msgstr "Tu sai già la verità, non è vero?\nQuello che stai facendo è sbagliato."

msgctxt "11||speech_list_cln||table||1015||||4"
msgid "I don't get it.\nWhat's your angle?"
msgstr "Non capisco.\nDove vuoi arrivare?"

msgctxt "11||speech_list_cln||table||1016||||4"
msgid "Would you ask me this?"
msgstr "Mi chiederesti davvero questo?"

msgctxt "11||speech_list_cln||table||1017||||4"
msgid "Kazuma Kiryu-san..."
msgstr "Kazuma Kiryu-san..."

msgctxt "11||speech_list_cln||table||1018||||4"
msgid "I have no angle."
msgstr "Non ho doppi fini."

msgctxt "11||speech_list_cln||table||1020||||4"
msgid "The final battle between JUSTIS and the Kiryu Clan\nis fast approaching. Let's settle this, once and for all."
msgstr "La battaglia finale tra JUSTIS e il Clan Kiryu\nsi avvicina rapidamente. Chiudiamo la faccenda una volta per tutte."

msgctxt "11||speech_list_cln||table||1021||||4"
msgid "Oh, I almost forgot. Joe, Kiryu-san."
msgstr "Oh, quasi dimenticavo. Joe, Kiryu-san."

msgctxt "11||speech_list_cln||table||1022||||4"
msgid "Don't forget to bring your umbrellas."
msgstr "Non dimenticatevi di portare l'ombrello."

msgctxt "11||speech_list_cln||table||1023||||4"
msgid "What?"
msgstr "Cosa?"

msgctxt "11||speech_list_cln||table||1024||||4"
msgid "You heard me. I'm going to\nmake it rain here in Kamurocho."
msgstr "Mi avete sentito. Farò in modo che\npiova qui a Kamurocho."

msgctxt "11||speech_list_cln||table||1025||||4"
msgid "Not with money... but with blood."
msgstr "Non con i soldi... ma col sangue."

msgctxt "11||speech_list_cln||table||1026||||4"
msgid "After all, I'm the Rainmaker."
msgstr "Dopotutto, sono il Rainmaker."

msgctxt "11||speech_list_cln||table||1027||||4"
msgid "Goodbye."
msgstr "Addio."

msgctxt "11||speech_list_cln||table||1028||||4"
msgid "So this is really the final battle.\nGuess we're gonna end this for good."
msgstr "Quindi questa è davvero la battaglia finale.\nImmagino che la chiuderemo per sempre."

msgctxt "11||speech_list_cln||table||1029||||4"
msgid "Sounds like it's gonna be epic.\nCan't wait to bust some skulls."
msgstr "Sembra che sarà epico.\nNon vedo l'ora di spaccare qualche cranio."

msgctxt "11||speech_list_cln||table||1030||||4"
msgid "I've been feelin' outta shape lately, too.\nBut that's gonna change now. Let's do this shit!"
msgstr "Anche io mi sentivo fuori forma ultimamente.\nMa le cose stanno per cambiare. Facciamolo, cazzo!"

msgctxt "11||speech_list_cln||table||1031||||4"
msgid "Come on, you guys.\nTranquilo! Chill out!"
msgstr "Andiamo, ragazzi.\nTranquilo! Rilassatevi!"

msgctxt "11||speech_list_cln||table||1032||||4"
msgid "This is gonna be the end. We don't need to rush,\nso just make sure you're ready first."
msgstr "Questa sarà la fine. Non c'è bisogno di correre,\nassicuratevi solo di essere pronti prima."

msgctxt "11||speech_list_cln||table||1033||||4"
msgid "Eh, we don't gotta worry about those weirdos.\nThere's a real genius among our ranks."
msgstr "Eh, non dobbiamo preoccuparci di quegli sfigati.\nC'è un vero genio tra i nostri ranghi."

msgctxt "11||speech_list_cln||table||1034||||4"
msgid "Toru Yano!"
msgstr "Toru Yano!"

msgctxt "11||speech_list_cln||table||1035||||4"
msgid "Me, I mean."
msgstr "Io, intendo."

msgctxt "11||speech_list_cln||table||1036||||4"
msgid "All right, I'm feeling real good about this!\nLet's get pumped up together, for old time's sake!"
msgstr "Bene, mi sento davvero carico per questa roba!\nCarichiamoci insieme, per i vecchi tempi!"

msgctxt "11||speech_list_cln||table||1037||||4"
msgid "Everyone in the Kiryu Clan!"
msgstr "A tutti i membri del Clan Kiryu!"

msgctxt "11||speech_list_cln||table||1038||||4"
msgid "I love you!"
msgstr "Vi amo!"

msgctxt "11||speech_list_cln||table||1039||||4"
msgid "The hell? Why didn't anyone do it!?"
msgstr "Che diavolo? Perché nessuno l'ha fatto!?"

msgctxt "11||speech_list_cln||table||1040||||4"
msgid "Who'd do that stupid shit?"
msgstr "Chi farebbe una stronzata del genere?"

msgctxt "11||speech_list_cln||table||1041||||4"
msgid "No way that's ever gonna catch on, man."
msgstr "Non prenderà mai piede, amico."

msgctxt "11||speech_list_cln||table||1042||||4"
msgid "You guys are brutal..."
msgstr "Siete brutali, ragazzi..."

msgctxt "11||speech_list_cln||table||1043||||4"
msgid "Okada. We're gonna wake you up for sure!"
msgstr "Okada. Ti daremo una svegliata, è una promessa!"

msgctxt "11||speech_list_cln||table||1044||||4"
msgid "Joe. It's almost time."
msgstr "Joe. È quasi ora."

msgctxt "11||speech_list_cln||table||1045||||4"
msgid "Yeah. It's only because of you that\nwe've come this far, Kiryu-san."
msgstr "Già. È solo grazie a te se\nsiamo arrivati fin qui, Kiryu-san."

msgctxt "11||speech_list_cln||table||1046||||4"
msgid "This will be the final battle."
msgstr "Questa sarà la battaglia finale."

msgctxt "11||speech_list_cln||table||1047||||4"
msgid "Right."
msgstr "Certo."

msgctxt "11||speech_list_cln||table||1048||||4"
msgid "All right, everyone. It's time for our showdown\nwith JUSTIS. Are you all ready?"
msgstr "Bene, ragazzi. È arrivato il momento della resa dei\nconti con JUSTIS. Siete pronti?"

msgctxt "11||speech_list_cln||table||1049||||4"
msgid "Course we are! We've come this far,\nso we're totally gonna win!"
msgstr "Certo che lo siamo! Siamo arrivati fin qui,\nquindi vinceremo di sicuro!"

msgctxt "11||speech_list_cln||table||1050||||4"
msgid "Do you have anything to say, Joe?"
msgstr "Hai qualcosa da dire, Joe?"

msgctxt "11||speech_list_cln||table||1051||||4"
msgid "I never expected we'd actually be able to go\ntoe-to-toe with a powerful enemy like JUSTIS."
msgstr "Non mi sarei mai aspettato di poter affrontare\nun nemico potente come JUSTIS ad armi pari."

msgctxt "11||speech_list_cln||table||1053||||4"
msgid "We're only here because of all of you."
msgstr "Siamo qui solo grazie a tutti voi."

msgctxt "11||speech_list_cln||table||1054||||4"
msgid "And because of Kiryu-san, who took it upon\nhimself to knock me back into shape."
msgstr "E grazie a Kiryu-san, che si è preso la briga\ndi rimettermi in sesto."

msgctxt "11||speech_list_cln||table||1056||||4"
msgid "As one of JUSTIS's founders, I have to\ntake responsibility. I'll destroy them!"
msgstr "Come uno dei fondatori di JUSTIS, devo\nprendermi le mie responsabilità. Li distruggerò!"

msgctxt "11||speech_list_cln||table||1057||||4"
msgid "Now, this is our last fight. Please lend me\nyour strength, just a little longer!"
msgstr "Questa è la nostra ultima battaglia. Vi prego di\nprestarmi la vostra forza, solo per un altro po'!"

msgctxt "11||speech_list_cln||table||1058||||4"
msgid "Right!"
msgstr "Agli ordini!"

msgctxt "11||speech_list_cln||table||1059||||4"
msgid "We're gonna give 'em all we got!"
msgstr "Gli daremo tutto ciò che abbiamo!"

msgctxt "11||speech_list_cln||table||1060||||4"
msgid "Hell yeah! Let's crush these shits, Koji!"
msgstr "Cazzo sì! Schiacciamo queste merde, Koji!"

msgctxt "11||speech_list_cln||table||1061||||4"
msgid "Damn straight!"
msgstr "Puoi dirlo forte!"

msgctxt "11||speech_list_cln||table||1062||||4"
msgid "Come on, Kiryu-san!"
msgstr "Andiamo, Kiryu-san!"

msgctxt "11||speech_list_cln||table||1063||||4"
msgid "Okay. Kiryu Clan... Move out!"
msgstr "Okay. Clan Kiryu... All'attacco!"

msgctxt "11||speech_list_cln||table||1064||||4"
msgid "Gotcha!"
msgstr "Ricevuto!"

msgctxt "11||speech_list_cln||table||1065||||4"
msgid "Okay!"
msgstr "Okay!"

msgctxt "11||speech_list_cln||table||1066||||4"
msgid "Yeah!"
msgstr "Sì!"

msgctxt "11||speech_list_cln||table||1067||||4"
msgid "Mhm!"
msgstr "Mhm!"

msgctxt "11||speech_list_cln||table||1068||||4"
msgid "Si!"
msgstr "Si!"

msgctxt "11||speech_list_cln||table||1069||||4"
msgid "Good to see you, my Kiryu Clan friends."
msgstr "Che bello vedervi, amici del Clan Kiryu."

msgctxt "11||speech_list_cln||table||1070||||4"
msgid "I expected you all to run far, far away, but\nit seems your stupidity has gotten the best of you."
msgstr "Mi aspettavo che sareste fuggiti lontano, ma\nsembra che la vostra stupidità abbia avuto la meglio."

msgctxt "11||speech_list_cln||table||1071||||4"
msgid "......"
msgstr "......"

msgctxt "11||speech_list_cln||table||1072||||4"
msgid "Okada..."
msgstr "Okada..."

msgctxt "11||speech_list_cln||table||1073||||4"
msgid "Now then... It's almost time to bring Kiryu Clan\nblood raining down on the streets of Kamurocho."
msgstr "E ora... è quasi giunto il momento di far piovere il\nsangue del Clan Kiryu sulle strade di Kamurocho."

msgctxt "11||speech_list_cln||table||1074||||4"
msgid "Is there anything you'd like to say\nbefore we begin, Rainmaker?"
msgstr "C'è qualcosa che vorresti dire\nprima di iniziare, Rainmaker?"

msgctxt "11||speech_list_cln||table||1075||||4"
msgid "Nah... I'm good."
msgstr "Nah... Sto a posto così."

msgctxt "11||speech_list_cln||table||1076||||4"
msgid "Just as I would have thought. \nAre you ready, Kiryu Clan? It's time to die!"
msgstr "Proprio come pensavo. \nSiete pronti, Clan Kiryu? È ora di morire!"

msgctxt "11||speech_list_cln||table||1077||||4"
msgid "I-Impossible! Our military strength should\nhave overwhelmed them easily... Why!?"
msgstr "I-Impossibile! La nostra potenza militare avrebbe dovuto\nsopraffarli facilmente... Perché!?"

msgctxt "11||speech_list_cln||table||1078||||4"
msgid "There's more to a team than just\nhow many members you have."
msgstr "Una squadra è molto più del semplice\nnumero dei suoi membri."

msgctxt "11||speech_list_cln||table||1079||||4"
msgid "You have to like them, trust them,\nform bonds with them."
msgstr "Devi volergli bene, fidarti di loro,\ncreare dei legami con loro."

msgctxt "11||speech_list_cln||table||1080||||4"
msgid "If you do that, one plus one will be more than two.\nIt'll reach one or two hundred."
msgstr "Se lo fai, uno più uno farà più di due.\nArriverà a cento o duecento."

msgctxt "11||speech_list_cln||table||1081||||4"
msgid "Your inability to see the value in that\nis why you lost here today."
msgstr "La tua incapacità di capirne il valore\nè il motivo per cui hai perso qui oggi."

msgctxt "11||speech_list_cln||table||1083||||4"
msgid "Komei..."
msgstr "Komei..."

msgctxt "11||speech_list_cln||table||1084||||4"
msgid "Y-Yes?"
msgstr "S-Sì?"

msgctxt "11||speech_list_cln||table||1085||||4"
msgid "Come here."
msgstr "Vieni qui."

msgctxt "11||speech_list_cln||table||1086||||4"
msgid "Huh? A-Are you sure that's what you want?"
msgstr "Eh? S-Sei sicuro di volerlo?"

msgctxt "11||speech_list_cln||table||1087||||4"
msgid "Yes. It's up to you now."
msgstr "Sì. Ora tocca a te."

msgctxt "11||speech_list_cln||table||1088||||4"
msgid "O-Okay."
msgstr "O-Okay."

msgctxt "11||speech_list_cln||table||1089||||4"
msgid "Joe. Kiryu-san."
msgstr "Joe. Kiryu-san."

msgctxt "11||speech_list_cln||table||1090||||4"
msgid "You two are something special."
msgstr "Voi due siete davvero speciali."

msgctxt "11||speech_list_cln||table||1091||||4"
msgid "I sold my soul to the devil for JUSTIS,\nbut you still managed to stop me."
msgstr "Ho venduto l'anima al diavolo per JUSTIS,\nma siete comunque riusciti a fermarmi."

msgctxt "11||speech_list_cln||table||1092||||4"
msgid "And... you did it with true justice\nby your side. I envy that."
msgstr "E... l'avete fatto avendo dalla vostra parte\nla vera giustizia. Vi invidio per questo."

msgctxt "11||speech_list_cln||table||1093||||4"
msgid "Kazuchika..."
msgstr "Kazuchika..."

msgctxt "11||speech_list_cln||table||1094||||4"
msgid "However, I have my own way of doing things.\nIt's not time to surrender to you yet."
msgstr "Tuttavia, ho un mio modo di fare le cose.\nNon è ancora il momento di arrendermi a voi."

msgctxt "11||speech_list_cln||table||1095||||4"
msgid "Kazuchika. Tana told me about\neverything that happened to you."
msgstr "Kazuchika. Tana mi ha raccontato\ntutto quello che ti è successo."

msgctxt "11||speech_list_cln||table||1096||||4"
msgid "I'm sorry I wasn't there to help.\nI wish I had realized sooner."
msgstr "Mi dispiace di non essere stato lì ad aiutarti.\nAvrei voluto capirlo prima."

msgctxt "11||speech_list_cln||table||1097||||4"
msgid "But no matter what happened, resorting to\nthe same shit the colors did isn't right!"
msgstr "Ma non importa cosa sia successo, ricorrere alle stesse\nstronzate delle gang dei colori non è giusto!"

msgctxt "11||speech_list_cln||table||1098||||4"
msgid "Let's start fresh, Kazuchika! JUSTIS can work\nfor the good of Kamurocho, like it did before!"
msgstr "Ripartiamo da zero, Kazuchika! JUSTIS può lavorare\nper il bene di Kamurocho, come faceva prima!"

msgctxt "11||speech_list_cln||table||1099||||4"
msgid "Are you finished?"
msgstr "Hai finito?"

msgctxt "11||speech_list_cln||table||1100||||4"
msgid "Okada..."
msgstr "Okada..."

msgctxt "11||speech_list_cln||table||1101||||4"
msgid "Joe. There's something I still need to do."
msgstr "Joe. C'è qualcosa che devo ancora fare."

msgctxt "11||speech_list_cln||table||1102||||4"
msgid "And in order to do it...\nI need to defeat you."
msgstr "E per poterlo fare...\ndevo sconfiggerti."

msgctxt "11||speech_list_cln||table||1103||||4"
msgid "This is my last stand.\nTry to stop me, Kiryu Clan."
msgstr "Questa è la mia ultima resistenza.\nCercate di fermarmi, Clan Kiryu."

msgctxt "11||speech_list_cln||table||1104||||4"
msgid "If you really think you can defeat\nRainmaker, come on and fight me!"
msgstr "Se pensate davvero di poter sconfiggere\nil Rainmaker, venite a sfidarmi!"

msgctxt "11||speech_list_cln||table||1105||||4"
msgid "Fine, then."
msgstr "D'accordo, allora."

msgctxt "11||speech_list_cln||table||1106||||4"
msgid "It looks like talking isn't going to get us anywhere.\nWe'll have to let our fists show him how we feel."
msgstr "A quanto pare parlare non ci porterà da nessuna parte.\nDovremo mostragli i nostri sentimenti a suon di pugni."

msgctxt "11||speech_list_cln||table||1107||||4"
msgid "Kiryu-san. Let's take them down."
msgstr "Kiryu-san. Mettiamoli al tappeto."

msgctxt "11||speech_list_cln||table||1108||||4"
msgid "No need to tell me twice.\nI've never turned down a fight in my life."
msgstr "Non c'è bisogno di dirmelo due volte.\nNon mi sono mai tirato indietro in uno scontro."

msgctxt "11||speech_list_cln||table||1109||||4"
msgid "Let's do this!"
msgstr "Facciamolo!"

msgctxt "11||speech_list_cln||table||1110||||4"
msgid "Bring it on, Kazuchika!"
msgstr "Fatti sotto, Kazuchika!"

msgctxt "11||speech_list_cln||table||1115||||4"
msgid "I've lost, Joe."
msgstr "Ho perso, Joe."

msgctxt "11||speech_list_cln||table||1116||||4"
msgid "In all the fights we've had,\nthis is the first time I've won."
msgstr "In tutti gli scontri che abbiamo avuto,\nquesta è la prima volta che vinco."

msgctxt "11||speech_list_cln||table||1117||||4"
msgid "Is it, now?"
msgstr "Dici davvero?"

msgctxt "11||speech_list_cln||table||1118||||4"
msgid "Losers tend to remember their losses, you know?"
msgstr "I perdenti tendono a ricordare le loro sconfitte, sai?"

msgctxt "11||speech_list_cln||table||1119||||4"
msgid "I see... I suppose I'll always \nremember this day, then."
msgstr "Capisco... Suppongo che ricorderò \nsempre questo giorno, allora."

msgctxt "11||speech_list_cln||table||1120||||4"
msgid "Hey, Kazuchika. JUSTIS is finished."
msgstr "Ehi, Kazuchika. JUSTIS è finito."

msgctxt "11||speech_list_cln||table||1121||||4"
msgid "So I'm going to ask you again.\nLet's start over, together."
msgstr "Quindi te lo chiedo di nuovo.\nRicominciamo da capo, insieme."

msgctxt "11||speech_list_cln||table||1122||||4"
msgid "We can fight with justice on our side.\nYou down?"
msgstr "Possiamo combattere con la giustizia dalla nostra parte.\nCi stai?"

msgctxt "11||speech_list_cln||table||1123||||4"
msgid "No, not yet."
msgstr "No, non ancora."

msgctxt "11||speech_list_cln||table||1124||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "11||speech_list_cln||table||1125||||4"
msgid "There's still something I need to do.\nIt's almost time."
msgstr "C'è ancora una cosa che devo fare.\nÈ quasi ora."

msgctxt "11||speech_list_cln||table||1126||||4"
msgid "What do you mean?"
msgstr "Cosa intendi?"

msgctxt "11||speech_list_cln||table||1127||||4"
msgid "You really think JUSTIS is finished?\nThat's quite a foolish thing to say, Joe!"
msgstr "Pensi davvero che JUSTIS sia finito?\nÈ una cosa alquanto sciocca da dire, Joe!"

msgctxt "11||speech_list_cln||table||1128||||4"
msgid "Komei!"
msgstr "Komei!"

msgctxt "11||speech_list_cln||table||1129||||4"
msgid "From now on, I'm in charge."
msgstr "Da questo momento in poi, comando io."

msgctxt "11||speech_list_cln||table||1130||||4"
msgid "What?"
msgstr "Cosa?"

msgctxt "11||speech_list_cln||table||1131||||4"
msgid "Don't you see?\nThe era of Rainmaker is over."
msgstr "Non lo vedete?\nL'era del Rainmaker è finita."

msgctxt "11||speech_list_cln||table||1132||||4"
msgid "As the leader of JUSTIS, I will rule over\nKamurocho with the city's gangs at my feet!"
msgstr "Come leader di JUSTIS, dominerò Kamurocho\ncon le gang della città ai miei piedi!"

msgctxt "11||speech_list_cln||table||1133||||4"
msgid "What are you taking about?\nThere's nobody left in JUSTIS!"
msgstr "Di cosa stai parlando?\nNon è rimasto nessuno in JUSTIS!"

msgctxt "11||speech_list_cln||table||1134||||4"
msgid "Oh, I suppose I did say we used all our forces.\nThat was nothing but a lie, though."
msgstr "Oh, suppongo di avervi detto di aver usato tutte\nle nostre forze. Ma era solo una menzogna."

msgctxt "11||speech_list_cln||table||1135||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "11||speech_list_cln||table||1136||||4"
msgid "In truth, I've been buying the loyalty of\nJUSTIS's members with the help of a wealthy patron."
msgstr "In verità, ho comprato la fedeltà dei membri di\nJUSTIS con l'aiuto di un ricco mecenate."

msgctxt "11||speech_list_cln||table||1137||||4"
msgid "Buying them?"
msgstr "Comprato?"

msgctxt "11||speech_list_cln||table||1138||||4"
msgid "Yes. Our organization consists of countless youths\nwho only came onboard after being charmed by Okada."
msgstr "Sì. La nostra organizzazione è formata da innumerevoli\ngiovani che si sono uniti solo perché affascinati da Okada."

msgctxt "11||speech_list_cln||table||1139||||4"
msgid "But after slipping them a little bit of cash,\nit was simple getting them to join my cause instead."
msgstr "Ma facendogli scivolare qualche soldo,\nè stato facile portarli dalla mia parte."

msgctxt "11||speech_list_cln||table||1140||||4"
msgid "The ones you've beaten so far are only those\nwho refused me and stayed loyal to Okada."
msgstr "Quelli che avete sconfitto finora sono solo coloro che\nmi hanno rifiutato e sono rimasti fedeli a Okada."

msgctxt "11||speech_list_cln||table||1141||||4"
msgid "A large portion of the team has betrayed Okada.\nTheir allegiance now rests with me."
msgstr "Una grossa fetta della squadra ha tradito Okada.\nLa loro lealtà ora appartiene a me."

msgctxt "11||speech_list_cln||table||1142||||4"
msgid "JUSTIS isn't over yet. If anything, we're only\nnow beginning as a new organization."
msgstr "JUSTIS non è ancora finito. Se non altro, stiamo\nappena iniziando come una nuova organizzazione."

msgctxt "11||speech_list_cln||table||1143||||4"
msgid "You bastard."
msgstr "Bastardo."

msgctxt "11||speech_list_cln||table||1144||||4"
msgid "What about that wealthy patron\nyou were talking about? Who is he?"
msgstr "E quel ricco mecenate di cui parlavi?\nChi è?"

msgctxt "11||speech_list_cln||table||1145||||4"
msgid "As for that wealthy patron of mine,\nallow me to introduce him to you."
msgstr "Per quanto riguarda il mio ricco mecenate,\npermettetemi di presentarvelo."

msgctxt "11||speech_list_cln||table||1146||||4"
msgid "Please step over here, Satsuki-san."
msgstr "Prego, da questa parte, Satsuki-san."

msgctxt "11||speech_list_cln||table||1147||||4"
msgid "Long time no see, Okada."
msgstr "Quanto tempo, Okada."

msgctxt "11||speech_list_cln||table||1148||||4"
msgid "You..."
msgstr "Tu..."

msgctxt "11||speech_list_cln||table||1149||||4"
msgid "Kazuchika... Who is this guy?"
msgstr "Kazuchika... Chi è questo tizio?"

msgctxt "11||speech_list_cln||table||1150||||4"
msgid "He's the one who tortured me. And the one\nwho assaulted my girlfriend."
msgstr "È lui che mi ha torturato. Ed è lui\nche ha aggredito la mia ragazza."

msgctxt "11||speech_list_cln||table||1151||||4"
msgid "Guess I went a bit overboard back then.\nI feel bad. Hurts the heart, you know?"
msgstr "Immagino di aver esagerato un po' all'epoca.\nMi dispiace davvero. Mi fa male il cuore, sapete?"

msgctxt "11||speech_list_cln||table||1152||||4"
msgid "Although, that pain's what pushed you to\nturn JUSTIS into what it is today."
msgstr "Eppure, è proprio quel dolore che ti ha spinto\na trasformare JUSTIS in quello che è oggi."

msgctxt "11||speech_list_cln||table||1153||||4"
msgid "If anything, you should be thanking me."
msgstr "Semmai, dovresti ringraziarmi."

msgctxt "11||speech_list_cln||table||1154||||4"
msgid "Although... I'll be taking back JUSTIS\nnow, if you don't mind."
msgstr "Anche se... mi riprenderò JUSTIS\nora, se non ti dispiace."

msgctxt "11||speech_list_cln||table||1155||||4"
msgid "What a sad end for you, Rainmaker."
msgstr "Che triste fine per te, Rainmaker."

msgctxt "11||speech_list_cln||table||1156||||4"
msgid "I will take control of JUSTIS and\nserve together with Satsuki-san."
msgstr "Prenderò io il controllo di JUSTIS e\nlavorerò fianco a fianco con Satsuki-san."

msgctxt "11||speech_list_cln||table||1157||||4"
msgid "Satsuki-san has a great many connections with\nthe yakuza and mafia organizations of this town."
msgstr "Satsuki-san ha moltissimi contatti con le organizzazioni\nyakuza e mafiose di questa città."

msgctxt "11||speech_list_cln||table||1158||||4"
msgid "As long as I have his backing, JUSTIS will grow\nto be the strongest gang in all of Japan."
msgstr "Finché avrò il suo sostegno, JUSTIS crescerà fino a\ndiventare la gang più forte di tutto il Giappone."

msgctxt "11||speech_list_cln||table||1159||||4"
msgid "Komei... Has this been your plan all along?"
msgstr "Komei... È sempre stato questo il tuo piano?"

msgctxt "11||speech_list_cln||table||1160||||4"
msgid "That's right. The only reason I joined JUSTIS\nto begin with was to eventually lay claim to it."
msgstr "Esatto. L'unico motivo per cui mi sono unito a JUSTIS\nfin dall'inizio era per potermene appropriare."

msgctxt "11||speech_list_cln||table||1161||||4"
msgid "I wanted to use Okada to make JUSTIS bigger,\nthen snatch it away from him once it got there."
msgstr "Volevo usare Okada per far crescere JUSTIS, per\npoi portarglielo via una volta raggiunto lo scopo."

msgctxt "11||speech_list_cln||table||1162||||4"
msgid "Then by using JUSTIS, I was going to\nget rich beyond your wildest imagination."
msgstr "E poi, usando JUSTIS, sarei diventato\npiù ricco di quanto possiate mai immaginare."

msgctxt "11||speech_list_cln||table||1163||||4"
msgid "That was our plan."
msgstr "Questo era il nostro piano."

msgctxt "11||speech_list_cln||table||1164||||4"
msgid "Though... I didn't even have to take it from him.\nOkada handed me the reins willingly."
msgstr "Anche se... non ho nemmeno dovuto portarglielo via.\nOkada mi ha ceduto le redini di sua spontanea volontà."

msgctxt "11||speech_list_cln||table||1165||||4"
msgid "What? So when he whispered in your ear..."
msgstr "Cosa? Quindi quando ti ha sussurrato all'orecchio..."

msgctxt "11||speech_list_cln||table||1166||||4"
msgid "Yeah."
msgstr "Già."

msgctxt "11||speech_list_cln||table||1167||||4"
msgid "You proved a vital asset to my plan, Okada. Things\nwould have been far tougher without your trust."
msgstr "Sei stato una risorsa vitale per il mio piano, Okada. Le cose\nsarebbero state molto più difficili senza la tua fiducia."

msgctxt "11||speech_list_cln||table||1168||||4"
msgid "Your ignorance to my traitorous nature gave me the\ntime I needed to plan this coup. I truly appreciate it."
msgstr "La tua ignoranza sulla mia natura da traditore mi ha dato il\ntempo necessario per organizzare questo golpe. Lo apprezzo molto."

msgctxt "11||speech_list_cln||table||1169||||4"
msgid "You're dumb, though. By not figuring out what was\ngoing on, you only propped up my plot."
msgstr "Però sei stupido. Non accorgendoti di cosa stesse\nsuccedendo, hai solo favorito il mio complotto."

msgctxt "11||speech_list_cln||table||1170||||4"
msgid "You may have charisma, but you clearly\nlack the leadership skills to match."
msgstr "Avrai anche carisma, ma chiaramente ti\nmancano le doti di comando per gestirlo."

msgctxt "11||speech_list_cln||table||1171||||4"
msgid "Such a shame, Rainmaker!\nThe only rain that will be falling today is your tears!"
msgstr "Che peccato, Rainmaker!\nL'unica pioggia che cadrà oggi saranno le tue lacrime!"

msgctxt "11||speech_list_cln||table||1173||||4"
msgid "Kazuchika..."
msgstr "Kazuchika..."

msgctxt "11||speech_list_cln||table||1176||||4"
msgid "What's wrong?\nHas my brilliance driven you mad?"
msgstr "Che c'è?\nLa mia genialità ti ha fatto impazzire?"

msgctxt "11||speech_list_cln||table||1177||||4"
msgid "You two are the ones who have been tricked."
msgstr "Siete voi due a essere stati ingannati."

msgctxt "11||speech_list_cln||table||1178||||4"
msgid "Everything I've done to make JUSTIS what it is now...\nIt was all to draw you out, Satsuki."
msgstr "Tutto ciò che ho fatto per rendere JUSTIS quello che è ora...\nEra solo per farti uscire allo scoperto, Satsuki."

msgctxt "11||speech_list_cln||table||1179||||4"
msgid "What?"
msgstr "Cosa?"

msgctxt "11||speech_list_cln||table||1180||||4"
msgid "I couldn't forgive you for what you did to me.\nI've always vowed to get my revenge."
msgstr "Non potevo perdonarti per quello che mi hai fatto.\nHo sempre giurato di vendicarmi."

msgctxt "11||speech_list_cln||table||1181||||4"
msgid "But those who live in the shadows are hard to\ntrack down. I couldn't begin to get a read on you."
msgstr "Ma chi vive nell'ombra è difficile da scovare.\nNon riuscivo in alcun modo a rintracciarti."

msgctxt "11||speech_list_cln||table||1182||||4"
msgid "I had to figure out a way to lure you into the open.\nThat was how I developed this plan."
msgstr "Dovevo trovare un modo per attirarti allo scoperto.\nÈ così che ho architettato questo piano."

msgctxt "11||speech_list_cln||table||1183||||4"
msgid "To start, I knew you had an affinity for violent\ngangs like the way the colors were before us."
msgstr "Per prima cosa, sapevo che avevi un'affinità per le gang\nviolente, come lo erano le gang dei colori prima di noi."

msgctxt "11||speech_list_cln||table||1184||||4"
msgid "So, if I made another gang similar to them..."
msgstr "Così, se avessi creato un'altra gang simile a loro..."

msgctxt "11||speech_list_cln||table||1185||||4"
msgid "...You'd come crawling back out of your hole."
msgstr "...saresti strisciato fuori dalla tua tana."

msgctxt "11||speech_list_cln||table||1186||||4"
msgid "What?"
msgstr "Cosa?"

msgctxt "11||speech_list_cln||table||1187||||4"
msgid "I'm surprised you actually fell for it, though.\nYou're not as clever as I thought."
msgstr "Sono sorpreso che ci siate cascati, però.\nNon siete così intelligenti come pensavo."

msgctxt "11||speech_list_cln||table||1189||||4"
msgid "I didn't make JUSTIS for the money or the power."
msgstr "Non ho creato JUSTIS per i soldi o per il potere."

msgctxt "11||speech_list_cln||table||1190||||4"
msgid "It was all so I could get my revenge on you."
msgstr "L'ho fatto solo per potermi vendicare di te."

msgctxt "11||speech_list_cln||table||1191||||4"
msgid "Huh. So that was your plan, Kazuchika..."
msgstr "Ah. Quindi era questo il tuo piano, Kazuchika..."

msgctxt "11||speech_list_cln||table||1192||||4"
msgid "S-So then, you already knew I was working\nwith Satsuki-san behind your back...?"
msgstr "Q-Quindi, sapevi già che stavo lavorando\ncon Satsuki-san alle tue spalle...?"

msgctxt "11||speech_list_cln||table||1193||||4"
msgid "Exactly. He knew, and still chose\nto let you do your thing."
msgstr "Esatto. Lo sapeva, e ha comunque scelto\ndi lasciarti fare il tuo gioco."

msgctxt "11||speech_list_cln||table||1194||||4"
msgid "Kazuchika clearly knew everything you were up\nto, including what you were doing with Satsuki."
msgstr "Kazuchika sapeva chiaramente tutto quello che stavi\nfacendo, incluso ciò che tramavi con Satsuki."

msgctxt "11||speech_list_cln||table||1195||||4"
msgid "Right. I suspected every detail."
msgstr "Giusto. Sospettavo ogni minimo dettaglio."

msgctxt "11||speech_list_cln||table||1196||||4"
msgid "Then why... Why did you say you'd\nhand me the reins of JUSTIS?"
msgstr "Allora perché... Perché hai detto che\nmi avresti ceduto le redini di JUSTIS?"

msgctxt "11||speech_list_cln||table||1197||||4"
msgid "Don't you understand, Komei?\nYou're just a pawn for Satsuki."
msgstr "Non capisci, Komei?\nSei solo una pedina per Satsuki."

msgctxt "11||speech_list_cln||table||1198||||4"
msgid "If you didn't have control off the group,\nhe'd just cut you off and stay in hiding."
msgstr "Se non avessi avuto il controllo del gruppo,\nti avrebbe scaricato e sarebbe rimasto nascosto."

msgctxt "11||speech_list_cln||table||1199||||4"
msgid "So that's why... It was so Satsuki-san\nwould keep supporting me..."
msgstr "Ecco perché... Era perché Satsuki-san\ncontinuasse a sostenermi..."

msgctxt "11||speech_list_cln||table||1200||||4"
msgid "That's probably it. It would've been a real pain\nif Satsuki got away when we were so close."
msgstr "Probabilmente è così. Sarebbe stata una vera seccatura se\nSatsuki fosse scappato quando eravamo così vicini."

msgctxt "11||speech_list_cln||table||1201||||4"
msgid "As long as you had control of JUSTIS,\nKazuchika's plan was still in motion."
msgstr "Finché tu avevi il controllo di JUSTIS,\nil piano di Kazuchika era ancora in atto."

msgctxt "11||speech_list_cln||table||1202||||4"
msgid "Instead of gaining any real power though,\nyou just led us straight to your leader."
msgstr "Invece di ottenere del vero potere, però,\nci hai guidati dritti dal tuo capo."

msgctxt "11||speech_list_cln||table||1203||||4"
msgid "You may be the best strategist around, but\nyou clearly don't have the leadership to match."
msgstr "Sarai anche il miglior stratega in circolazione, ma\nchiaramente ti mancano le doti di comando per esserlo."

msgctxt "11||speech_list_cln||table||1204||||4"
msgid "Damn you!"
msgstr "Maledetti!"

msgctxt "11||speech_list_cln||table||1209||||4"
msgid "I don't care about any of this bullshit, as long as\nI have obedient soldiers working under me."
msgstr "Non mi importa niente di tutte queste stronzate, finché\nho soldati obbedienti che lavorano per me."

msgctxt "11||speech_list_cln||table||1210||||4"
msgid "Kiryu-san... You head up the Kiryu Clan, yes?"
msgstr "Kiryu-san... Sei tu a capo del Clan Kiryu, giusto?"

msgctxt "11||speech_list_cln||table||1211||||4"
msgid "Yeah, that's right."
msgstr "Già, proprio così."

msgctxt "11||speech_list_cln||table||1212||||4"
msgid "How about you come work for me?"
msgstr "Che ne dici di venire a lavorare per me?"

msgctxt "11||speech_list_cln||table||1213||||4"
msgid "Excuse me?"
msgstr "Come scusa?"

msgctxt "11||speech_list_cln||table||1214||||4"
msgid "This fool Komei couldn't manage JUSTIS if his life\ndepended on it. Your team is much more promising."
msgstr "Questo sciocco di Komei non riuscirebbe a gestire JUSTIS\nnemmeno per salvarsi la vita. La tua squadra è molto più promettente."

msgctxt "11||speech_list_cln||table||1215||||4"
msgid "As long as you promise obedience...\nYou'll find the compensation to your liking. Well?"
msgstr "Finché promettete obbedienza...\nTroverete la ricompensa di vostro gradimento. Allora?"

msgctxt "11||speech_list_cln||table||1216||||4"
msgid "You really expect me to agree to that?"
msgstr "Ti aspetti davvero che accetti una cosa del genere?"

msgctxt "11||speech_list_cln||table||1217||||4"
msgid "Yeah, I guess you're right."
msgstr "Sì, immagino tu abbia ragione."

msgctxt "11||speech_list_cln||table||1218||||4"
msgid "As expected of the Dragon of Dojima, Kazuma Kiryu.\nI apologize for the foolish question."
msgstr "Come ci si aspetterebbe dal Drago di Dojima, Kazuma Kiryu.\nMi scuso per la domanda sciocca."

msgctxt "11||speech_list_cln||table||1219||||4"
msgid "In that case, JUSTIS will have the honor of working\nwith me. Together we'll eliminate the Kiryu Clan."
msgstr "In tal caso, JUSTIS avrà l'onore di lavorare\ncon me. Insieme elimineremo il Clan Kiryu."

msgctxt "11||speech_list_cln||table||1220||||4"
msgid "And once we do, we'll make sure every suitable\nyoung person in Kamurocho joins the JUSTIS cause."
msgstr "E una volta fatto, ci assicureremo che ogni giovane\nadatto a Kamurocho si unisca alla causa di JUSTIS."

msgctxt "11||speech_list_cln||table||1221||||4"
msgid "They'll become our infantry squad,\ncarrying out crimes that rake in the cash."
msgstr "Diventeranno la nostra squadra di fanteria,\ncommettendo crimini che faranno piovere soldi."

msgctxt "11||speech_list_cln||table||1222||||4"
msgid "And if any of them get caught, they'll take the fall\nfor me. I'll go back to my shadows."
msgstr "E se qualcuno di loro dovesse essere catturato, si prenderà\nla colpa al posto mio. Io tornerò nell'ombra."

msgctxt "11||speech_list_cln||table||1223||||4"
msgid "There's no way...\nWe won't let that happen!"
msgstr "Non se ne parla...\nNon permetteremo che accada!"

msgctxt "11||speech_list_cln||table||1224||||4"
msgid "Try to stop me, if you can."
msgstr "Cercate di fermarmi, se ci riuscite."

msgctxt "11||speech_list_cln||table||1225||||4"
msgid "Immature little punk.\nYou shouldn't look down at your elders."
msgstr "Teppistello immaturo.\nNon dovresti guardare dall'alto in basso chi è più vecchio di te."

msgctxt "11||speech_list_cln||table||1226||||4"
msgid "I won't run anymore.\nWe'll settle this next time."
msgstr "Non scapperò più.\nSistemeremo la faccenda la prossima volta."

msgctxt "11||speech_list_cln||table||1227||||4"
msgid "With my own Satsuki Clan forces and JUSTIS\ncombined, we'll utterly crush you fools!"
msgstr "Con le mie forze del Clan Satsuki e quelle di JUSTIS\ncombinate, vi annienteremo, stolti!"

msgctxt "11||speech_list_cln||table||1228||||4"
msgid "Go ahead and try."
msgstr "Fatti avanti e prova."

msgctxt "11||speech_list_cln||table||1229||||4"
msgid "I'm old, too. You'll be in trouble if you\nlook down on this immature punk, I promise."
msgstr "Anch'io sono vecchio. Ti troverai nei guai se guardi\ndall'alto in basso questo teppistello immaturo, te lo prometto."

msgctxt "11||speech_list_cln||table||1230||||4"
msgid "Thanks for the advice."
msgstr "Grazie per il consiglio."

msgctxt "11||speech_list_cln||table||1231||||4"
msgid "Let's go."
msgstr "Andiamo."

msgctxt "11||speech_list_cln||table||1232||||4"
msgid "Y-Yes, sir!"
msgstr "S-Sissignore!"

msgctxt "11||speech_list_cln||table||1233||||4"
msgid "So the true mastermind has finally arrived."
msgstr "Quindi il vero burattinaio è finalmente arrivato."

msgctxt "11||speech_list_cln||table||1234||||4"
msgid "Joe. I'm sorry about this."
msgstr "Joe. Mi dispiace per tutto questo."

msgctxt "11||speech_list_cln||table||1235||||4"
msgid "If we don't stop him, the youth of this city will\nbe at that fool's beck and call forever."
msgstr "Se non lo fermiamo, i giovani di questa città\nsaranno alla mercé di quel pazzo per sempre."

msgctxt "11||speech_list_cln||table||1236||||4"
msgid "No matter what it takes, I need to\nmake sure that doesn't happen."
msgstr "Costi quel che costi, devo assicurarmi\nche questo non accada."

msgctxt "11||speech_list_cln||table||1237||||4"
msgid "I'm really sorry."
msgstr "Mi dispiace davvero."

msgctxt "11||speech_list_cln||table||1238||||4"
msgid "Kazuchika..."
msgstr "Kazuchika..."

msgctxt "11||speech_list_cln||table||1239||||4"
msgid "I should be the one apologizing. I couldn't figure\nout your true motive in all this... I'm a terrible friend."
msgstr "Sono io a dovermi scusare. Non sono riuscito a capire le\ntue vere motivazioni in tutto questo... Sono un pessimo amico."

msgctxt "11||speech_list_cln||table||1240||||4"
msgid "Don't be ridiculous."
msgstr "Non dire assurdità."

msgctxt "11||speech_list_cln||table||1241||||4"
msgid "Besides, I always believed you would\nattempt to stop JUSTIS in order to help me."
msgstr "Inoltre, ho sempre creduto che avresti\ntentato di fermare JUSTIS per aiutarmi."

msgctxt "11||speech_list_cln||table||1242||||4"
msgid "What?"
msgstr "Cosa?"

msgctxt "11||speech_list_cln||table||1243||||4"
msgid "You mean you planned my part in this, too?"
msgstr "Vuoi dire che hai pianificato anche la mia parte in tutto questo?"

msgctxt "11||speech_list_cln||table||1244||||4"
msgid "More or less. I figured if you shook things up, Komei\nand Satsuki would show themselves eventually."
msgstr "Più o meno. Ho immaginato che se tu avessi smosso le acque,\nKomei e Satsuki si sarebbero infine fatti vedere."

msgctxt "11||speech_list_cln||table||1245||||4"
msgid "That's why I forced you out of JUSTIS.\nTo make sure you had the motivation."
msgstr "Ecco perché ti ho costretto a lasciare JUSTIS.\nPer assicurarmi che avessi la giusta motivazione."

msgctxt "11||speech_list_cln||table||1246||||4"
msgid "Man, you're incredible.\nAre you a fortune teller or something?"
msgstr "Amico, sei incredibile.\nSei un veggente o cosa?"

msgctxt "11||speech_list_cln||table||1247||||4"
msgid "Not quite. Not even I could foresee the\nlegendary Dragon of Dojima joining you."
msgstr "Non esattamente. Neanche io potevo prevedere che il\nleggendario Drago di Dojima si sarebbe unito a te."

msgctxt "11||speech_list_cln||table||1249||||4"
msgid "Kiryu-san. My apologies for everything."
msgstr "Kiryu-san. Le mie scuse per ogni cosa."

msgctxt "11||speech_list_cln||table||1250||||4"
msgid "If it's all right with you,\nI'd like to join your team."
msgstr "Se per te va bene,\nvorrei unirmi alla tua squadra."

msgctxt "11||speech_list_cln||table||1251||||4"
msgid "I need to defeat that man.\nI... I need to get my revenge."
msgstr "Devo sconfiggere quell'uomo.\nIo... devo avere la mia vendetta."

msgctxt "11||speech_list_cln||table||1252||||4"
msgid "Okada..."
msgstr "Okada..."

msgctxt "11||speech_list_cln||table||1253||||4"
msgid "Okay, then.\nLet's take him down together."
msgstr "D'accordo, allora.\nMettiamolo al tappeto insieme."

msgctxt "11||speech_list_cln||table||1254||||4"
msgid "Thank you very much, Kiryu-san."
msgstr "Molte grazie, Kiryu-san."

msgctxt "11||speech_list_cln||table||1255||||4"
msgid "All right. This next battle will be our last."
msgstr "Molto bene. La prossima battaglia sarà l'ultima."

msgctxt "11||speech_list_cln||table||1256||||4"
msgid "With the Kiryu Clan behind us,\nwe'll destroy them!"
msgstr "Con il Clan Kiryu alle nostre spalle,\nli distruggeremo!"

msgctxt "11||speech_list_cln||table||1257||||4"
msgid "You two should get ready, okay?"
msgstr "Voi due dovreste prepararvi, d'accordo?"

msgctxt "11||speech_list_cln||table||1258||||4"
msgid "Of course."
msgstr "Certo."

msgctxt "11||speech_list_cln||table||1259||||4"
msgid "Yeah!"
msgstr "Sì!"

msgctxt "11||speech_list_cln||table||1260||||4"
msgid "All right, our battle with Satsuki is finally here.\nAre you ready, everyone?"
msgstr "Bene, la battaglia contro Satsuki è finalmente giunta.\nSiete tutti pronti?"

msgctxt "11||speech_list_cln||table||1261||||4"
msgid "Yeah."
msgstr "Sì."

msgctxt "11||speech_list_cln||table||1262||||4"
msgid "Yes."
msgstr "Sì."

msgctxt "11||speech_list_cln||table||1263||||4"
msgid "This really will be the final battle.\nI want to thank you all for trusting in me so far."
msgstr "Questa sarà davvero la battaglia finale.\nVoglio ringraziarvi tutti per aver creduto in me finora."

msgctxt "11||speech_list_cln||table||1264||||4"
msgid "However, failure here means losing everything."
msgstr "Tuttavia, fallire qui significherebbe perdere tutto."

msgctxt "11||speech_list_cln||table||1265||||4"
msgid "If they win, they'll carry out their plan to turn\nthe youth of this city into an army of criminal soldiers."
msgstr "Se vincono, porteranno a termine il loro piano per trasformare\ni giovani di questa città in un esercito di soldati criminali."

msgctxt "11||speech_list_cln||table||1266||||4"
msgid "Under no circumstance can we let that happen."
msgstr "Non possiamo assolutamente permettere che accada."

msgctxt "11||speech_list_cln||table||1267||||4"
msgid "We're going to win... And we're going to\ndrive them out of Kamurocho for good."
msgstr "Vinceremo... E li cacceremo\nda Kamurocho per sempre."

msgctxt "11||speech_list_cln||table||1268||||4"
msgid "Its future rests in our hands. The young people here\nshould be out making friends, not committing crimes."
msgstr "Il suo futuro è nelle nostre mani. I giovani di questa città\ndovrebbero farsi degli amici, non commettere crimini."

msgctxt "11||speech_list_cln||table||1269||||4"
msgid "Kiryu-san... I'm so thankful I met you."
msgstr "Kiryu-san... Sono così grato di averti incontrato."

msgctxt "11||speech_list_cln||table||1270||||4"
msgid "Same for me!"
msgstr "Lo stesso vale per me!"

msgctxt "11||speech_list_cln||table||1271||||4"
msgid "Now let's go. The final battle awaits!"
msgstr "Ora andiamo. La battaglia finale ci attende!"

msgctxt "11||speech_list_cln||table||1272||||4"
msgid "Right. Kiryu Clan, move out!"
msgstr "Ricevuto. Clan Kiryu, all'attacco!"

msgctxt "11||speech_list_cln||table||1273||||4"
msgid "Okay!"
msgstr "Okay!"

msgctxt "11||speech_list_cln||table||1274||||4"
msgid "There are so many of them."
msgstr "Sono tantissimi."

msgctxt "11||speech_list_cln||table||1275||||4"
msgid "I guess they're the combined forces of\nJUSTIS and the Satsuki Clan, after all."
msgstr "Immagino siano le forze combinate di\nJUSTIS e del Clan Satsuki, dopotutto."

msgctxt "11||speech_list_cln||table||1276||||4"
msgid "What's wrong? Are you nervous?"
msgstr "Che c'è? Sei nervoso?"

msgctxt "11||speech_list_cln||table||1277||||4"
msgid "Not at all.\nIf anything, I'm excited."
msgstr "Per niente.\nSemmai, sono eccitato."

msgctxt "11||speech_list_cln||table||1278||||4"
msgid "I'm really looking forward to fighting\nalongside my friend here again."
msgstr "Non vedo l'ora di combattere\ndi nuovo al fianco del mio amico."

msgctxt "11||speech_list_cln||table||1279||||4"
msgid "You better not slow me down, Joe."
msgstr "Vedi di non rallentarmi, Joe."

msgctxt "11||speech_list_cln||table||1280||||4"
msgid "I should be saying that to you."
msgstr "Sono io a doverlo dire a te."

msgctxt "11||speech_list_cln||table||1281||||4"
msgid "Nice to see you, my Kiryu Clan friends.\nToday is the day that all of you die!"
msgstr "Che piacere vedervi, amici del Clan Kiryu.\nOggi è il giorno in cui morirete tutti!"

msgctxt "11||speech_list_cln||table||1282||||4"
msgid "Kamurocho will be taken by myself and Satsuki-san!"
msgstr "Kamurocho sarà conquistata da me e da Satsuki-san!"

msgctxt "11||speech_list_cln||table||1283||||4"
msgid "Dreams... Bonds... Admiration..."
msgstr "Sogni... Legami... Ammirazione..."

msgctxt "11||speech_list_cln||table||1284||||4"
msgid "By outwardly espousing those foolish ideals,\nwe'll form the largest gang in all of Japan."
msgstr "Sposando apertamente questi sciocchi ideali,\nformeremo la gang più grande di tutto il Giappone."

msgctxt "11||speech_list_cln||table||1285||||4"
msgid "And as the first step toward that ultimate goal,\nwe'll be using you Kiryu Clan buffoons as a sacrifice!"
msgstr "E come primo passo verso questo obiettivo finale,\nuseremo voi buffoni del Clan Kiryu come sacrificio!"

msgctxt "11||speech_list_cln||table||1286||||4"
msgid "Now then, the last dance is finally beginning.\nGo! Tear the Kiryu Clan to shreds!"
msgstr "E ora, l'ultimo ballo sta finalmente per iniziare.\nAndate! Fate a pezzi il Clan Kiryu!"

msgctxt "11||speech_list_cln||table||1287||||4"
msgid "We have him on the ropes."
msgstr "Lo abbiamo messo alle corde."

msgctxt "11||speech_list_cln||table||1288||||4"
msgid "I've waited a long time for this day."
msgstr "Ho aspettato a lungo questo giorno."

msgctxt "11||speech_list_cln||table||1289||||4"
msgid "My grudge against you is finally going to be repaid."
msgstr "Il mio rancore nei tuoi confronti sta finalmente per essere ripagato."

msgctxt "11||speech_list_cln||table||1290||||4"
msgid "We'll see about that."
msgstr "Staremo a vedere."

msgctxt "11||speech_list_cln||table||1291||||4"
msgid "There's still more of them."
msgstr "Ce ne sono ancora degli altri."

msgctxt "11||speech_list_cln||table||1292||||4"
msgid "Okada. You think you're the king of the world,\nbut you're just a little brat in the end."
msgstr "Okada. Pensi di essere il re del mondo,\nma alla fine sei solo un ragazzino insolente."

msgctxt "11||speech_list_cln||table||1293||||4"
msgid "You have no idea how dangerous the world\nof men can truly be. I'll have to show you myself."
msgstr "Non hai idea di quanto il mondo degli adulti possa essere\ndavvero pericoloso. Dovrò mostrartelo di persona."

msgctxt "11||speech_list_cln||table||1294||||4"
msgid "Just like I did so many years ago!"
msgstr "Proprio come ho fatto tanti anni fa!"

msgctxt "11||speech_list_cln||table||1295||||4"
msgid "You bastard!"
msgstr "Bastardo!"

msgctxt "11||speech_list_cln||table||1296||||4"
msgid "And as for this \"justice\" you guys talk so highly of...\nYou're going to see just how ineffective it really is."
msgstr "E riguardo a questa \"giustizia\" di cui parlate tanto bene...\nVedrete quanto sia davvero inefficace."

msgctxt "11||speech_list_cln||table||1297||||4"
msgid "You're going to pay for what you did."
msgstr "Pagherai per quello che hai fatto."

msgctxt "11||speech_list_cln||table||1298||||4"
msgid "I'm here to help, friend."
msgstr "Sono qui per aiutarti, amico mio."

msgctxt "11||speech_list_cln||table||1299||||4"
msgid "Heh... You two remind me a bit of\nmyself when I was your age."
msgstr "Heh... Voi due mi ricordate un po'\nme stesso quando avevo la vostra età."

msgctxt "11||speech_list_cln||table||1300||||4"
msgid "Huh? Really?"
msgstr "Eh? Davvero?"

msgctxt "11||speech_list_cln||table||1301||||4"
msgid "Yeah. When you asked me to be the leader of\nyou kids, I thought it was just more trouble."
msgstr "Sì. Quando mi avete chiesto di essere il capo di voi\nragazzini, ho pensato che fosse solo un'altra seccatura."

msgctxt "11||speech_list_cln||table||1302||||4"
msgid "I wasn't into the idea of sticking my neck out,\nbut I did, because you made me want to."
msgstr "Non mi entusiasmava l'idea di rischiare la pelle,\nma l'ho fatto, perché mi avete fatto venire voglia di farlo."

msgctxt "11||speech_list_cln||table||1303||||4"
msgid "You reminded me of the values I've always\nheld at my core."
msgstr "Mi avete ricordato i valori che ho\nsempre custodito dentro di me."

msgctxt "11||speech_list_cln||table||1304||||4"
msgid "The importance of friends, the justice within us...\nThey might sound childish, but they're vital."
msgstr "L'importanza degli amici, la giustizia dentro di noi...\nPotranno sembrare cose infantili, ma sono vitali."

msgctxt "11||speech_list_cln||table||1305||||4"
msgid "I must have forgotten over the years, but those things\nare clear to me again because of you. Thanks for that."
msgstr "Devo essermene dimenticato con gli anni, ma ora queste cose\nmi sono di nuovo chiare grazie a voi. Grazie di cuore."

msgctxt "11||speech_list_cln||table||1306||||4"
msgid "Kiryu-san..."
msgstr "Kiryu-san..."

msgctxt "11||speech_list_cln||table||1307||||4"
msgid "Even after this battle ends, make sure\nyou remember the value of those concepts."
msgstr "Anche dopo la fine di questa battaglia, assicuratevi di\nricordare sempre il valore di questi concetti."

msgctxt "11||speech_list_cln||table||1308||||4"
msgid "Once you forget them, you tend to age a lot quicker.\nTrust me on that."
msgstr "Una volta che li dimentichi, tendi a invecchiare molto più in fretta.\nFidatevi di me."

msgctxt "11||speech_list_cln||table||1309||||4"
msgid "Right! I'll remember both you and\nthe events of today, for as long as I live!"
msgstr "Certo! Ricorderò sia te che\ngli eventi di oggi per il resto della mia vita!"

msgctxt "11||speech_list_cln||table||1310||||4"
msgid "Then we'll have to make it a memory worth keeping.\nCome on! Let's stop this madman in his tracks!"
msgstr "Allora dovremo far sì che sia un ricordo da custodire.\nForza! Fermiamo questo pazzo!"

msgctxt "11||speech_list_cln||table||1311||||4"
msgid "You wanna disband the Kiryu Clan!?\nAre you being serious right now!?"
msgstr "Vuoi sciogliere il Clan Kiryu!?\nDici sul serio!?"

msgctxt "11||speech_list_cln||table||1312||||4"
msgid "Yeah. Not only did we beat JUSTIS,\nbut their mastermind Satsuki as well."
msgstr "Sì. Non solo abbiamo battuto JUSTIS,\nma anche la loro mente, Satsuki."

msgctxt "11||speech_list_cln||table||1313||||4"
msgid "Thanks to Satsuki's arrest, the police have\nmanaged to round up most of his followers as well."
msgstr "Grazie all'arresto di Satsuki, la polizia è riuscita a\ncatturare anche la maggior parte dei suoi seguaci."

msgctxt "11||speech_list_cln||table||1314||||4"
msgid "It just doesn't seem necessary to continue on\nwith the Kiryu Clan at this point. Am I wrong?"
msgstr "A questo punto, non mi sembra più necessario\ncontinuare con il Clan Kiryu. Mi sbaglio?"

msgctxt "11||speech_list_cln||table||1315||||4"
msgid "Way too wrong! What're you thinking!?\nThe Kiryu Clan's where all of us belong now!"
msgstr "Ti sbagli di grosso! Che ti salta in mente!?\nIl Clan Kiryu è la nostra casa, ormai!"

msgctxt "11||speech_list_cln||table||1316||||4"
msgid "Really...?"
msgstr "Davvero...?"

msgctxt "11||speech_list_cln||table||1317||||4"
msgid "Yeah, that's right! We can't just let it fade away\nnow that we've fulfilled our initial goal!"
msgstr "Già, esatto! Non possiamo lasciare che svanisca così\nora che abbiamo raggiunto il nostro obiettivo iniziale!"

msgctxt "11||speech_list_cln||table||1318||||4"
msgid "The Kiryu Clan's, well... I dunno how to put this...\nIt's like some kinda family to me!"
msgstr "Il Clan Kiryu è, insomma... non so come dirlo...\nÈ come una specie di famiglia per me!"

msgctxt "11||speech_list_cln||table||1319||||4"
msgid "Well said, Masao-kun."
msgstr "Ben detto, Masao-kun."

msgctxt "11||speech_list_cln||table||1320||||4"
msgid "Really?"
msgstr "Davvero?"

msgctxt "11||speech_list_cln||table||1321||||4"
msgid "I've gotta agree with him, Kiryu-san.\nLet's keep the Kiryu Clan going for a while."
msgstr "Devo dargli ragione, Kiryu-san.\nFacciamo andare avanti il Clan Kiryu ancora per un po'."

msgctxt "11||speech_list_cln||table||1322||||4"
msgid "Kamurocho isn't known for its tranquility.\nAnother Satsuki or JUSTIS will sprout up eventually."
msgstr "Kamurocho non è nota per la sua tranquillità.\nPrima o poi spunterà un altro Satsuki o un altro JUSTIS."

msgctxt "11||speech_list_cln||table||1323||||4"
msgid "We can be a place to protect the youth from bastards\nlike that. That's why we need the Kiryu Clan to continue."
msgstr "Possiamo essere il luogo in cui proteggere i giovani da bastardi\ndel genere. Ecco perché il Clan Kiryu deve andare avanti."

msgctxt "11||speech_list_cln||table||1324||||4"
msgid "I want to build the organization Kazuchika\nand I strived for. The original JUSTIS."
msgstr "Voglio costruire l'organizzazione per cui Kazuchika\ne io abbiamo lottato. Il vero JUSTIS."

msgctxt "11||speech_list_cln||table||1325||||4"
msgid "A team with justice at their side... JUSTIS..."
msgstr "Una squadra con la giustizia dalla sua parte... JUSTIS..."

msgctxt "11||speech_list_cln||table||1326||||4"
msgid "Okay. If it's that important to you,\nI'm okay with keeping the Kiryu Clan intact."
msgstr "D'accordo. Se per voi è così importante,\nmi sta bene mantenere intatto il Clan Kiryu."

msgctxt "11||speech_list_cln||table||1327||||4"
msgid "Hell yeah!\nThanks for understanding, Kiryu-san!"
msgstr "Cazzo, sì!\nGrazie per averci capiti, Kiryu-san!"

msgctxt "11||speech_list_cln||table||1328||||4"
msgid "Kiryu-san! I love you!"
msgstr "Kiryu-san! Vi amo!"

msgctxt "11||speech_list_cln||table||1329||||4"
msgid "We're gonna be part of something special\ntogether for years to come, Kiryu-san."
msgstr "Faremo parte di qualcosa di speciale\ninsieme per molti anni a venire, Kiryu-san."

msgctxt "11||speech_list_cln||table||1330||||4"
msgid "Yeah. By the way, there's something I've\nbeen wondering for a long time now."
msgstr "Già. A proposito, c'è una cosa che\nmi chiedo da molto tempo."

msgctxt "11||speech_list_cln||table||1331||||4"
msgid "What's that?"
msgstr "Di che si tratta?"

msgctxt "11||speech_list_cln||table||1332||||4"
msgid "The spelling of JUSTIS.\nI mean, shouldn't it be j-u-s-t-i-c-e?"
msgstr "Come si scrive JUSTIS.\nInsomma, non dovrebbe essere j-u-s-t-i-c-e?"

msgctxt "11||speech_list_cln||table||1333||||4"
msgid "Why'd you choose j-u-s-t-i-s?\nIt was intentional, right...?"
msgstr "Perché avete scelto j-u-s-t-i-s?\nEra intenzionale, vero...?"

msgctxt "11||speech_list_cln||table||1334||||4"
msgid "Huh? Wait, did we misspell it?\nHoly shit... That's lame..."
msgstr "Eh? Aspetta, l'abbiamo scritto male?\nPorca puttana... Che figuraccia..."

msgctxt "11||speech_list_cln||table||1335||||4"
msgid "What? You seriously just spelled it wrong?"
msgstr "Cosa? Lo avete davvero scritto male?"

msgctxt "11||speech_list_cln||table||1336||||4"
msgid "Y-Yeah. We really messed up, Kazuchika."
msgstr "S-Sì. Abbiamo proprio fatto un casino, Kazuchika."

msgctxt "11||speech_list_cln||table||1337||||4"
msgid "I-I guess so."
msgstr "M-Mi sa di sì."

msgctxt "11||speech_list_cln||table||1338||||4"
msgid "Well, maybe Kiryu-san has it wrong..."
msgstr "Beh, forse è Kiryu-san a sbagliarsi..."

msgctxt "11||speech_list_cln||table||1339||||4"
msgid "My English is nothing to write home about,\nbut even I know that word."
msgstr "Il mio inglese non è niente di eccezionale,\nma conosco persino io quella parola."

msgctxt "11||speech_list_cln||table||1340||||4"
msgid "It's pretty common in song lyrics, you know.\nI'm sure I'm right."
msgstr "È piuttosto comune nei testi delle canzoni, sapete.\nSono sicuro di aver ragione."

msgctxt "11||speech_list_cln||table||1341||||4"
msgid "How didn't anyone notice this before now!?\nGood thing we disbanded JUSTIS then, huh?"
msgstr "Come ha fatto nessuno a non accorgersene prima di adesso!?\nMeno male che abbiamo sciolto JUSTIS, eh?"

msgctxt "11||speech_list_cln||table||1342||||4"
msgid "Yeah."
msgstr "Già."

msgctxt "11||speech_list_cln||table||1343||||4"
msgid "Hey hey, what're you little idiots\nchattin' about over here?"
msgstr "Ehi ehi, di cosa state chiacchierando\nqui, piccoli idioti?"

msgctxt "11||speech_list_cln||table||1344||||4"
msgid "What's up, Yano?"
msgstr "Che succede, Yano?"

msgctxt "11||speech_list_cln||table||1345||||4"
msgid "Some of those mastermind guy's followers\nand leftover JUSTIS shits're causin' some trouble."
msgstr "Alcuni dei seguaci di quel tizio e i rimasugli\ndi quelle merde di JUSTIS stanno causando dei problemi."

msgctxt "11||speech_list_cln||table||1346||||4"
msgid "So there're still a few left."
msgstr "Quindi ne è rimasto ancora qualcuno."

msgctxt "11||speech_list_cln||table||1347||||4"
msgid "C'mon, Koji!\nWe're gonna crush 'em all!"
msgstr "Andiamo, Koji!\nLi schiacceremo tutti!"

msgctxt "11||speech_list_cln||table||1348||||4"
msgid "Tranquilo! Chill out, guys."
msgstr "Tranquilo! Rilassatevi, ragazzi."

msgctxt "11||speech_list_cln||table||1349||||4"
msgid "Kiryu-san's our leader, remember?\nIt's his choice if we're going or not."
msgstr "Kiryu-san è il nostro capo, ricordate?\nSpetta a lui decidere se andremo o no."

msgctxt "11||speech_list_cln||table||1350||||4"
msgid "So Kiryu-san? Whaddya say?"
msgstr "Quindi Kiryu-san? Che ci dici?"

msgctxt "11||speech_list_cln||table||1351||||4"
msgid "We don't have much choice."
msgstr "Non abbiamo molta scelta."

msgctxt "11||speech_list_cln||table||1352||||4"
msgid "Looks like we have some garbage to clean up."
msgstr "Sembra che abbiamo un po' di spazzatura da ripulire."

msgctxt "11||speech_list_cln||table||1353||||4"
msgid "To bring our justice out into the world,\nand to protect the youth of this country..."
msgstr "Per portare la nostra giustizia nel mondo,\ne per proteggere i giovani di questo paese..."

msgctxt "11||speech_list_cln||table||1354||||4"
msgid "...Kiryu Clan, move out!"
msgstr "...Clan Kiryu, all'attacco!"

msgctxt "11||speech_list_cln||table||1355||||4"
msgid "Okay!"
msgstr "Okay!"

msgctxt "11||speech_list_cln||table||1356||||4"
msgid "Okay!"
msgstr "Okay!"

msgctxt "11||speech_list_cln||table||1357||||4"
msgid "Okay!"
msgstr "Okay!"

msgctxt "11||speech_list_cln||table||1358||||4"
msgid "Okay!"
msgstr "Okay!"

msgctxt "11||speech_list_cln||table||1359||||4"
msgid "Okay!"
msgstr "Okay!"

msgctxt "11||speech_list_cln||table||1360||||4"
msgid "Okay!"
msgstr "Okay!"

msgctxt "11||speech_list_cln||table||1361||||4"
msgid "Okay!"
msgstr "Okay!"

msgctxt "11||speech_list_cln||table||1362||||4"
msgid "Okay!"
msgstr "Okay!"

msgctxt "11||speech_list_cln||table||1363||||4"
msgid "Kiryu-san, um... I really have to thank you\nfor coming to save me earlier."
msgstr "Kiryu-san, ehm... devo davvero ringraziarti\nper essere venuto a salvarmi prima."

msgctxt "11||speech_list_cln||table||1364||||4"
msgid "It was nothing. I'm just glad you're safe."
msgstr "Non è stato niente. Sono solo contento che tu stia bene."

msgctxt "11||speech_list_cln||table||1365||||4"
msgid "Me too! Anyway, um... Joe-san and my brother\nreally forced you into this team thing. Sorry."
msgstr "Anche io! Comunque, ehm... Joe-san e mio fratello\nti hanno praticamente costretto in questa storia della squadra. Scusa."

msgctxt "11||speech_list_cln||table||1366||||4"
msgid "Yeah I don't mind, though.\nI've already agreed, so I'll figure something out."
msgstr "Non mi dispiace, però.\nHo già accettato, quindi mi inventerò qualcosa."

msgctxt "11||speech_list_cln||table||1367||||4"
msgid "Although, this is my first time dealing with young\nguys like this. How do I attract new members...?"
msgstr "Anche se è la prima volta che ho a che fare con ragazzi\ngiovani come loro. Come faccio ad attirare nuovi membri...?"

msgctxt "11||speech_list_cln||table||1368||||4"
msgid "Oh! I think the bartender would know!"
msgstr "Oh! Penso che il barista lo sappia!"

msgctxt "11||speech_list_cln||table||1369||||4"
msgid "Really...?"
msgstr "Davvero...?"

msgctxt "11||speech_list_cln||table||1370||||4"
msgid "He was the leader of a humongous team\nback in his days as a thug on the street!"
msgstr "È stato il leader di una squadra enorme\nai tempi in cui era un teppista di strada!"

msgctxt "11||speech_list_cln||table||1371||||4"
msgid "Huh... He sounds experienced."
msgstr "Ah... Sembra avere molta esperienza."

msgctxt "11||speech_list_cln||table||1372||||4"
msgid "Isn't that right?"
msgstr "Non è vero?"

msgctxt "11||speech_list_cln||table||1373||||4"
msgid "Sachiko... How can you be so disrespectful?\nI'm gonna have to sue you for slander, y'know."
msgstr "Sachiko... Come puoi essere così irrispettosa?\nDovrò farti causa per diffamazione, sai."

msgctxt "11||speech_list_cln||table||1374||||4"
msgid "But Kiryu-san said he needs to scrape\ntogether some new members for his team."
msgstr "Ma Kiryu-san ha detto che ha bisogno di raccogliere\nqualche nuovo membro per la sua squadra."

msgctxt "11||speech_list_cln||table||1375||||4"
msgid "Oh yeah? That's a cinch.\nJust give 'em a good whack on the head!"
msgstr "Ah sì? È un gioco da ragazzi.\nBasta dargli una bella botta in testa!"

msgctxt "11||speech_list_cln||table||1376||||4"
msgid "You want me to hit them?"
msgstr "Vuoi che li picchi?"

msgctxt "11||speech_list_cln||table||1377||||4"
msgid "Heck yeah. Some of the kids around these parts\nact like they own the goddamn place."
msgstr "Cazzo sì. Alcuni ragazzini da queste parti\nsi comportano come se fossero i fottuti padroni."

msgctxt "11||speech_list_cln||table||1378||||4"
msgid "It's one of the flaws of the countryside. They all\nthink they're the strongest little shit around."
msgstr "È uno dei difetti della campagna. Pensano tutti\ndi essere la merdina più forte in circolazione."

msgctxt "11||speech_list_cln||table||1379||||4"
msgid "Ugh, so they're just puffed up idiots."
msgstr "Ugh, quindi sono solo degli idioti gonfiati."

msgctxt "11||speech_list_cln||table||1380||||4"
msgid "Yeah. I'm pretty sure they'll follow anyone\nwho can prove they're stronger, though."
msgstr "Sì. Però sono abbastanza sicuro che seguiranno\nchiunque riesca a dimostrare di essere più forte."

msgctxt "11||speech_list_cln||table||1381||||4"
msgid "So if you knock them flat on their asses, Kiryu-san,\nI bet they'll follow you no questions asked."
msgstr "Quindi se li butti giù col culo per terra, Kiryu-san,\nscommetto che ti seguiranno senza fare domande."

msgctxt "11||speech_list_cln||table||1382||||4"
msgid "Huh!? That's kinda violent, isn't it?"
msgstr "Eh!? È un po' violento, non ti pare?"

msgctxt "11||speech_list_cln||table||1383||||4"
msgid "That's right. I'm not the young guy I used to be.\nI can't just go around punching people nowadays."
msgstr "Esatto. Non sono più il giovane di una volta.\nNon posso semplicemente andare in giro a prendere a pugni la gente oggigiorno."

msgctxt "11||speech_list_cln||table||1384||||4"
msgid "I don't think you'll need to worry about that."
msgstr "Non credo che dovrai preoccuparti di questo."

msgctxt "11||speech_list_cln||table||1385||||4"
msgid "Why do you say that?"
msgstr "Perché dici questo?"

msgctxt "11||speech_list_cln||table||1386||||4"
msgid "These guys'll come to you once\nthey see how strong you are."
msgstr "Questi ragazzi verranno da te una volta\nche avranno visto quanto sei forte."

msgctxt "11||speech_list_cln||table||1387||||4"
msgid "Huh!? Are you sure!?"
msgstr "Eh!? Ne sei sicuro!?"

msgctxt "11||speech_list_cln||table||1388||||4"
msgid "Kiryu-san, you're a damn skilled fighter.\nThat's clear as day to anyone with experience."
msgstr "Kiryu-san, sei un combattente dannatamente abile.\nÈ chiaro come il sole per chiunque abbia esperienza."

msgctxt "11||speech_list_cln||table||1389||||4"
msgid "If someone who's itching for a fight catches sight\nof you, there's no way they'll be able to resist."
msgstr "Se qualcuno a cui prudono le mani dovesse posare gli occhi\nsu di te, non riuscirà in alcun modo a resistere."

msgctxt "11||speech_list_cln||table||1390||||4"
msgid "You think so? I can't really tell."
msgstr "Dici? Io non saprei."

msgctxt "11||speech_list_cln||table||1391||||4"
msgid "Absolutely! Even I'm getting in the mood..."
msgstr "Assolutamente! Mi sta venendo voglia persino a me..."

msgctxt "11||speech_list_cln||table||1392||||4"
msgid "Huh? This is no time for that!"
msgstr "Eh? Non è il momento!"

msgctxt "11||speech_list_cln||table||1393||||4"
msgid "I'm just joking around! But seriously, try it out.\nYou'll find potential members all over town."
msgstr "Sto solo scherzando! Ma seriamente, fai una prova.\nTroverai potenziali membri in tutta la città."

msgctxt "11||speech_list_cln||table||1394||||4"
msgid "Got it."
msgstr "Ricevuto."

msgctxt "11||speech_list_cln||table||1395||||4"
msgid "You used to live in Tokyo, right Kiryu-san?\nI'm so jealous..."
msgstr "Prima vivevi a Tokyo, vero Kiryu-san?\nSono così gelosa..."

msgctxt "11||speech_list_cln||table||1396||||4"
msgid "Tokyo's really an incredible place, huh?\nIt's so different from Onomichi..."
msgstr "Tokyo è davvero un posto incredibile, eh?\nÈ così diversa da Onomichi..."

msgctxt "11||speech_list_cln||table||1397||||4"
msgid "Tokyo's such an amazing place.\nMaybe I'll apply to universities up there..."
msgstr "Tokyo è un posto fantastico.\nForse farò domanda per l'università lassù..."

msgctxt "11||speech_list_cln||table||1398||||4"
msgid "Kiryu-san! Look after my brother again today!"
msgstr "Kiryu-san! Tieni d'occhio mio fratello anche oggi!"

msgctxt "11||speech_list_cln||table||1399||||4"
msgid "Welcome, Kiryu-san!"
msgstr "Benvenuto, Kiryu-san!"

msgctxt "11||speech_list_cln||table||1400||||4"
msgid "Thanks a bunch!"
msgstr "Grazie mille!"

msgctxt "11||speech_list_cln||table||1401||||4"
msgid "Please come back soon."
msgstr "Torna a trovarci presto."

msgctxt "11||speech_list_cln||table||1402||||4"
msgid "Everything the bartender cooks up is so tasty!\nHe might look scary, but he has tons of skill."
msgstr "Tutto ciò che cucina il barista è così gustoso!\nPotrà anche avere un aspetto spaventoso, ma è pieno di talento."

msgctxt "11||speech_list_cln||table||1403||||4"
msgid "Kiryu-san! Please take this!"
msgstr "Kiryu-san! Prendi questo, per favore!"

msgctxt "11||speech_list_cln||table||1404||||4"
msgid "Good luck out there!"
msgstr "Buona fortuna là fuori!"

msgctxt "11||speech_list_cln||table||1405||||4"
msgid "Kiryu-san! What do you want to do today?"
msgstr "Kiryu-san! Cosa vuoi fare oggi?"

msgctxt "11||speech_list_cln||table||1406||||4"
msgid "Huh? The shit you think you're looking at?"
msgstr "Eh? Che cazzo ti guardi?"

msgctxt "11||speech_list_cln||table||1407||||4"
msgid "You look kinda strong for an old fuck, though.\nShow me what you got!"
msgstr "Sembri piuttosto forte per essere un vecchio di merda, però.\nFammi vedere che sai fare!"

msgctxt "11||speech_list_cln||table||1408||||4"
msgid "Wh-Whoa... I had no idea people\nthat strong even existed..."
msgstr "W-Whoa... Non avevo idea che esistessero\npersone così forti..."

msgctxt "11||speech_list_cln||table||1409||||4"
msgid "I wanna be just like you, old man.\nPlease lemme be your apprentice!"
msgstr "Voglio essere proprio come te, vecchio.\nTi prego, fammi essere il tuo apprendista!"

msgctxt "11||speech_list_cln||table||1410||||4"
msgid "Huh? What're ya lookin' at, old man?"
msgstr "Eh? Che cazzo guardi, vecchio?"

msgctxt "11||speech_list_cln||table||1411||||4"
msgid "Oh, you actually look pretty tough. I'm kinda bored.\nHow 'bout you help me kill some time?"
msgstr "Oh, sembri un tipo tosto. Mi sto un po' annoiando.\nChe ne dici di aiutarmi a far passare il tempo?"

msgctxt "11||speech_list_cln||table||1412||||4"
msgid "You're damn strong..."
msgstr "Sei dannatamente forte..."

msgctxt "11||speech_list_cln||table||1413||||4"
msgid "Sorry 'bout that. Here, I'll fight for ya\nto make up for it. Just forgive me, yeah?"
msgstr "Scusa per prima. Senti, combatterò per te\nper farmi perdonare. Perdonami e basta, ok?"

msgctxt "11||speech_list_cln||table||1414||||4"
msgid "Huh? Who the hell're you?"
msgstr "Eh? E tu chi diavolo sei?"

msgctxt "11||speech_list_cln||table||1415||||4"
msgid "If you got something you want from me...\nyou're gonna have to fight me first!"
msgstr "Se vuoi qualcosa da me...\nprima dovrai batterti con me!"

msgctxt "11||speech_list_cln||table||1416||||4"
msgid "H-Holy shit, you're strong.\nI'm so sorry..."
msgstr "P-Porca puttana, sei fortissimo.\nMi dispiace tanto..."

msgctxt "11||speech_list_cln||table||1417||||4"
msgid "I-I'll do anything ya want.\nPlease teach me how to be stronger!"
msgstr "F-Farò tutto quello che vuoi.\nTi prego, insegnami a diventare più forte!"

msgctxt "11||speech_list_cln||table||1418||||4"
msgid "Sup, grampa?\nYou wanna pick a fight with me?"
msgstr "Che c'è, nonno?\nVuoi attaccare briga con me?"

msgctxt "11||speech_list_cln||table||1419||||4"
msgid "How 'bout that. I've been lookin' for\nsomeone who'll make me break a sweat! C'mon!"
msgstr "Che mi dici di questo. Stavo cercando\nqualcuno che mi facesse sudare un po'! Fatti sotto!"

msgctxt "11||speech_list_cln||table||1420||||4"
msgid "I-I give. Just forgive me."
msgstr "M-Mi arrendo. Perdonami."

msgctxt "11||speech_list_cln||table||1421||||4"
msgid "You're real tough, man. With you teaching me,\nwho knows how strong I'll get!"
msgstr "Sei davvero tosto, amico. Con i tuoi insegnamenti,\nchissà quanto diventerò forte!"

msgctxt "11||speech_list_cln||table||1422||||4"
msgid "Hey, you. The hell do you want?\nYou trying to pick a fight or something?"
msgstr "Ehi, tu. Che diavolo vuoi?\nStai cercando rogne o cosa?"

msgctxt "11||speech_list_cln||table||1423||||4"
msgid "Fine by me. I'm the strongest in all of Onomichi.\nI'm gonna beat you to a bloody pulp!"
msgstr "Per me va bene. Sono il più forte di tutta Onomichi.\nTi ridurrò in poltiglia!"

msgctxt "11||speech_list_cln||table||1424||||4"
msgid "Damn, that's some strength.\nYou're incredible. Admirable, even."
msgstr "Dannazione, che forza.\nSei incredibile. Persino ammirevole."

msgctxt "11||speech_list_cln||table||1425||||4"
msgid "My motto's always been to follow anyone stronger\nthan me, so... I guess I'll be sticking by you for a while."
msgstr "Il mio motto è sempre stato seguire chiunque sia più forte\ndi me, quindi... immagino che starò con te per un po'."

msgctxt "11||speech_list_cln||table||1426||||4"
msgid "And who might you be?\nDo you have a problem with me?"
msgstr "E tu chi saresti?\nHai qualche problema con me?"

msgctxt "11||speech_list_cln||table||1427||||4"
msgid "You have a strong air about you. I expect\nyou'll be a tough opponent. Fight me."
msgstr "Hai un'aura di forza. Immagino\nche sarai un avversario tosto. Combatti."

msgctxt "11||speech_list_cln||table||1428||||4"
msgid "What impressive strength...\nIt appears I need far more training."
msgstr "Che forza impressionante...\nSembra che io abbia bisogno di molto più allenamento."

msgctxt "11||speech_list_cln||table||1429||||4"
msgid "Would it be all right if I came to train under you?\nI would love to grow stronger."
msgstr "Andrebbe bene se venissi ad allenarmi con te?\nMi piacerebbe molto diventare più forte."

msgctxt "11||speech_list_cln||table||1430||||4"
msgid "Look what we got here! Some kinda outsider, huh!?"
msgstr "Ma guarda un po' chi c'è! Una specie di forestiero, eh!?"

msgctxt "11||speech_list_cln||table||1431||||4"
msgid "Y'shouldn't be walkin' around here lookin' so tough!\nYer gonna have t'pay the price, with yer body!"
msgstr "Non dovresti andare in giro a fare il duro da queste parti!\nDovrai pagarne il prezzo, sulla tua pelle!"

msgctxt "11||speech_list_cln||table||1432||||4"
msgid "What the hell are ya!?\nNobody in Onomichi's anywhere close t'ya."
msgstr "Che diavolo sei!?\nNessuno a Onomichi si avvicina minimamente a te."

msgctxt "11||speech_list_cln||table||1433||||4"
msgid "Maybe I can get stronger if I join up with ya.\nAll right, my mind's made up!"
msgstr "Forse posso diventare più forte se mi unisco a te.\nD'accordo, ho deciso!"

msgctxt "11||speech_list_cln||table||1434||||4"
msgid "Who're you? I don't recognize your face."
msgstr "Chi sei? Non riconosco la tua faccia."

msgctxt "11||speech_list_cln||table||1435||||4"
msgid "You look like you've seen a bit of blood\nin your day, though. This should be fun... Let's fight!"
msgstr "Sembra che tu abbia visto un po' di sangue\nai tuoi tempi, però. Sarà divertente... Combattiamo!"

msgctxt "11||speech_list_cln||table||1436||||4"
msgid "You're strong, man. It's been ages since\nI've enjoyed myself in a fight this much."
msgstr "Sei forte, amico. È da una vita che\nnon mi divertivo così tanto in un combattimento."

msgctxt "11||speech_list_cln||table||1437||||4"
msgid "I bet I'll have tons more fun if I join you.\nSorry, but you'll be seeing a lot more of me."
msgstr "Scommetto che mi divertirò un sacco se mi unisco a te.\nScusa, ma mi vedrai molto spesso d'ora in poi."

msgctxt "11||speech_list_cln||table||1438||||4"
msgid "Oooh. You look damn tough, man."
msgstr "Oooh. Sembri dannatamente tosto, amico."

msgctxt "11||speech_list_cln||table||1439||||4"
msgid "I've been real bored fighting weak shits lately.\nSorry, but you're gonna have to liven things up a bit!"
msgstr "Mi sono davvero annoiato a picchiare delle mezze seghe ultimamente.\nScusa, ma dovrai ravvivare un po' la situazione!"

msgctxt "11||speech_list_cln||table||1440||||4"
msgid "I lost... Never thought I'd find someone\nstronger than me in this small-time town."
msgstr "Ho perso... Non avrei mai pensato di trovare qualcuno\npiù forte di me in questa cittadina di provincia."

msgctxt "11||speech_list_cln||table||1441||||4"
msgid "Thanks for showing me the light, buddy.\nI'll gladly help you out when you need it."
msgstr "Grazie per avermi mostrato la via, amico.\nTi darò volentieri una mano quando ne avrai bisogno."

msgctxt "11||speech_list_cln||table||1442||||4"
msgid "Oh? You've got a pretty tough-looking body."
msgstr "Oh? Hai un fisico che sembra piuttosto robusto."

msgctxt "11||speech_list_cln||table||1443||||4"
msgid "Great. You're the perfect guy to test my strength with!"
msgstr "Ottimo. Sei il tipo perfetto con cui mettere alla prova la mia forza!"

msgctxt "11||speech_list_cln||table||1444||||4"
msgid "Holy crap... You're so strong.\nI've gotta admit, I admire that."
msgstr "Porca miseria... Sei fortissimo.\nDevo ammetterlo, lo ammiro."

msgctxt "11||speech_list_cln||table||1445||||4"
msgid "I wanna be strong just like you.\nHow about you teach me the ropes a bit?"
msgstr "Voglio essere forte proprio come te.\nChe ne dici di insegnarmi un po' i trucchi del mestiere?"

msgctxt "11||speech_list_cln||table||1446||||4"
msgid "Hey, do you have a minute?"
msgstr "Ehi, hai un minuto?"

msgctxt "11||speech_list_cln||table||1447||||4"
msgid "Can I ask you something?"
msgstr "Posso chiederti una cosa?"

msgctxt "11||speech_list_cln||table||1448||||4"
msgid "I know this might seem random...\nbut do you want to join my team?"
msgstr "So che potrebbe sembrare una cosa improvvisa...\nma vuoi unirti alla mia squadra?"

msgctxt "11||speech_list_cln||table||1449||||4"
msgid "Then join my team."
msgstr "Allora unisciti alla mia squadra."

msgctxt "11||speech_list_cln||table||1450||||4"
msgid "Dammit. We couldn't break through their ranks.\nGuess we should just withdraw for now, huh?"
msgstr "Maledizione. Non siamo riusciti a sfondare i loro ranghi.\nImmagino che per ora dovremmo ritirarci, eh?"

msgctxt "11||speech_list_cln||table||1451||||4"
msgid "Let's regroup and try to take them on again soon."
msgstr "Riorganizziamoci e proviamo ad affrontarli di nuovo al più presto."

msgctxt "11||speech_list_cln||table||1452||||4"
msgid "Those guys are strong... They might've\nreally killed us if we hadn't run away."
msgstr "Quei tizi sono forti... Ci avrebbero\ndavvero ammazzati se non fossimo scappati."

msgctxt "11||speech_list_cln||table||1453||||4"
msgid "Let's regroup and try to take them on again soon."
msgstr "Riorganizziamoci e proviamo ad affrontarli di nuovo al più presto."

msgctxt "11||speech_list_cln||table||1454||||4"
msgid "Yo, Kiryu-san. Thanks for keeping an eye\non these punks. I appreciate it."
msgstr "Ehi, Kiryu-san. Grazie per aver tenuto d'occhio\nquesti teppistelli. Lo apprezzo."

msgctxt "11||speech_list_cln||table||1455||||4"
msgid "It's nothing."
msgstr "Di niente."

msgctxt "11||speech_list_cln||table||1456||||4"
msgid "I didn't think they'd actually end up\nhelping you out though, Kiryu-san."
msgstr "Non pensavo che avrebbero davvero finito\nper darti una mano però, Kiryu-san."

msgctxt "11||speech_list_cln||table||1457||||4"
msgid "To be honest, they kinda remind me\nof me back when I was a kid."
msgstr "Ad essere onesto, mi ricordano un po'\nme stesso quando ero un ragazzino."

msgctxt "11||speech_list_cln||table||1458||||4"
msgid "Makes me feel all warm n' fuzzy inside.\nThat's why I let them use my place as a hideout."
msgstr "Mi scalda il cuore.\nÈ per questo che li lascio usare il mio locale come covo."

msgctxt "11||speech_list_cln||table||1459||||4"
msgid "Sheesh... I put so much effort making this place\nbeautiful, but they just go and cramp my style."
msgstr "Cavolo... Ci ho messo tanto impegno per rendere bello\nquesto posto, ma loro mi rovinano l'atmosfera."

msgctxt "11||speech_list_cln||table||1460||||4"
msgid "You're not wrong there."
msgstr "Non hai tutti i torti."

msgctxt "11||speech_list_cln||table||1461||||4"
msgid "You're different from them though, Kiryu-san.\nYou actually order stuff, and even pay for it."
msgstr "Tu sei diverso da loro, però, Kiryu-san.\nTu ordini effettivamente qualcosa, e la paghi anche."

msgctxt "11||speech_list_cln||table||1462||||4"
msgid "It's a real help. You're basically\none o' my regulars at this point."
msgstr "È un grande aiuto. Praticamente sei\nuno dei miei clienti abituali a questo punto."

msgctxt "11||speech_list_cln||table||1463||||4"
msgid "I guess you're right."
msgstr "Immagino che tu abbia ragione."

msgctxt "11||speech_list_cln||table||1464||||4"
msgid "Oh yeah. I was thinking of ways I could\nmaybe try n' repay you for that."
msgstr "Oh già. Stavo pensando a dei modi in cui potrei\nmagari provare a sdebitarmi per questo."

msgctxt "11||speech_list_cln||table||1465||||4"
msgid "And well, how 'bout I lend\na hand with the Kiryu Clan?"
msgstr "E beh, che ne diresti se dessi\nuna mano al Clan Kiryu?"

msgctxt "11||speech_list_cln||table||1466||||4"
msgid "What?"
msgstr "Cosa?"

msgctxt "11||speech_list_cln||table||1467||||4"
msgid "Haven't ya heard? I used to be legendary 'round here.\nThough I've been getting kinda rusty lately."
msgstr "Non l'hai saputo? Ero una leggenda da queste parti.\nAnche se ultimamente mi sono un po' arrugginito."

msgctxt "11||speech_list_cln||table||1468||||4"
msgid "Honestly, seeing these punks do their thing takes me\nway back to how I used to be when I was young."
msgstr "Sinceramente, vedere questi teppistelli in azione mi riporta\nindietro a come ero io da giovane."

msgctxt "11||speech_list_cln||table||1469||||4"
msgid "I'm kinda jealous that you get to be a part\nof their whole shindig, Kiryu-san."
msgstr "Sono un po' invidioso che tu faccia parte\ndi tutto questo loro casino, Kiryu-san."

msgctxt "11||speech_list_cln||table||1470||||4"
msgid "All right, then."
msgstr "D'accordo, allora."

msgctxt "11||speech_list_cln||table||1471||||4"
msgid "Hope I'm not too much trouble.\nI'll try not to slow ya guys down."
msgstr "Spero di non essere troppo un peso.\nCercherò di non rallentarvi, ragazzi."

msgctxt "11||speech_list_cln||table||1472||||4"
msgid "N' I'll still be able to run the shop\neven if I break all my bones. Don't worry."
msgstr "E sarò ancora in grado di gestire il locale\nanche se mi rompessi tutte le ossa. Non preoccuparti."

msgctxt "11||speech_list_cln||table||1473||||4"
msgid "This is gonna be good, leader."
msgstr "Ci sarà da divertirsi, capo."

msgctxt "11||speech_list_cln||table||1474||||4"
msgid "Sorry, but we don't actually have\nenough members yet."
msgstr "Scusa, ma a dire il vero non abbiamo\nancora abbastanza membri."

msgctxt "11||speech_list_cln||table||1475||||4"
msgid "Give us a little more time, then come back. Okay?"
msgstr "Dacci ancora un po' di tempo, poi torna. Okay?"

msgctxt "11||speech_list_cln||table||1476||||4"
msgid "Kiryu-san! The Kiryu Clan's getting real big!"
msgstr "Kiryu-san! Il Clan Kiryu sta diventando davvero grande!"

msgctxt "11||speech_list_cln||table||1477||||4"
msgid "Yeah, you're right."
msgstr "Già, hai ragione."

msgctxt "11||speech_list_cln||table||1478||||4"
msgid "If you wanna try fighting against other clans,\ntalk to Joe. He said he'll help you out."
msgstr "Se vuoi provare a combattere contro altri clan,\nparla con Joe. Ha detto che ti darà una mano."

msgctxt "11||speech_list_cln||table||1479||||4"
msgid "Really?"
msgstr "Davvero?"

msgctxt "11||speech_list_cln||table||1480||||4"
msgid "Yeah. He's pretty damn popular, so he's got\nall sortsa special connections."
msgstr "Sì. È dannatamente popolare, quindi ha\nogni sorta di aggancio speciale."

msgctxt "11||speech_list_cln||table||1481||||4"
msgid "Try it out if you're ever feeling up to it!"
msgstr "Fai una prova se te la senti!"

msgctxt "11||speech_list_cln||table||1482||||4"
msgid "I forgot to mention, Kiryu-san.\nYou got any interest in the black market?"
msgstr "Dimenticavo di dirtelo, Kiryu-san.\nTi interessa il mercato nero?"

msgctxt "11||speech_list_cln||table||1483||||4"
msgid "Uh, guess I should explain first. It's basically a place\nyou can go for some... contraband merchandise."
msgstr "Uh, immagino di doverti prima dare delle spiegazioni. È in\nsintesi un posto dove trovare... merce di contrabbando."

msgctxt "11||speech_list_cln||table||1484||||4"
msgid "A friend of mine's in the biz, so I thought\nyou might wanna meet up with him, Kiryu-san."
msgstr "Un mio amico è nel giro, quindi ho pensato\nche avresti voluto incontrarlo, Kiryu-san."

msgctxt "11||speech_list_cln||table||1485||||4"
msgid "He's got tons of stuff great for fighting.\nProbably a perfect kinda shop for you."
msgstr "Ha un sacco di roba ottima per combattere.\nProbabilmente è il negozio perfetto per te."

msgctxt "11||speech_list_cln||table||1486||||4"
msgid "I was thinking you'd get some serious use outta\na place like that, so whaddya say? Want an intro?"
msgstr "Pensavo che avresti tratto grande vantaggio da un posto\ndel genere, quindi che ne dici? Vuoi che vi presenti?"

msgctxt "11||speech_list_cln||table||1487||||4"
msgid "Sure."
msgstr "Certo."

msgctxt "11||speech_list_cln||table||1488||||4"
msgid "Okay, I'll get in touch with him for you."
msgstr "Okay, mi metterò in contatto con lui per te."

msgctxt "11||speech_list_cln||table||1489||||4"
msgid "This is where he is. Try heading there."
msgstr "Si trova qui. Prova ad andarci."

msgctxt "11||speech_list_cln||table||1490||||4"
msgid "I'll let you know where he's at once\nhe says he's cool with meeting you."
msgstr "Ti farò sapere dov'è non appena\nmi dirà che gli va bene incontrarti."

msgctxt "11||speech_list_cln||table||1491||||4"
msgid "All right."
msgstr "D'accordo."

msgctxt "11||speech_list_cln||table||1492||||4"
msgid "Oh! You must be Kiryu-san, huh?\nThe La Pente bartender told me about you."
msgstr "Oh! Tu devi essere Kiryu-san, eh?\nIl barista del La Pente mi ha parlato di te."

msgctxt "11||speech_list_cln||table||1493||||4"
msgid "I usually don't deal to people on our first meeting,\nbut I'll make an exception for friends of his."
msgstr "Di solito non faccio affari con la gente al primo incontro,\nma farò un'eccezione per un suo amico."

msgctxt "11||speech_list_cln||table||1494||||4"
msgid "You could say we go back a ways.\nUsed to get into all sortsa shit together."
msgstr "Si può dire che ci conosciamo da molto.\nCi cacciavamo in un sacco di casini insieme."

msgctxt "11||speech_list_cln||table||1495||||4"
msgid "I never would have guessed."
msgstr "Non l'avrei mai detto."

msgctxt "11||speech_list_cln||table||1496||||4"
msgid "By the way, I heard you've been spending\nsome time up in Kamurocho, too."
msgstr "A proposito, ho sentito che passi\nun po' di tempo anche su a Kamurocho."

msgctxt "11||speech_list_cln||table||1497||||4"
msgid "I've got a friend up there running a similar outfit.\nI'll let him know about you if you wanna check it out."
msgstr "Ho un amico lassù che gestisce un'attività simile.\nGli parlerò di te se vuoi darci un'occhiata."

msgctxt "11||speech_list_cln||table||1498||||4"
msgid "The bartender'll message you the location."
msgstr "Il barista ti invierà la posizione con un messaggio."

msgctxt "11||speech_list_cln||table||1499||||4"
msgid "All right."
msgstr "D'accordo."

msgctxt "11||speech_list_cln||table||1500||||4"
msgid "Now then... Check out the goods."
msgstr "Dunque... Dai un'occhiata alla merce."

msgctxt "11||speech_list_cln||table||1501||||4"
msgid "Come again sometime."
msgstr "Torna a trovarmi."

msgctxt "11||speech_list_cln||table||1502||||4"
msgid "Yo, how 'bout a look?"
msgstr "Ehi, che ne dici di dare un'occhiata?"

msgctxt "11||speech_list_cln||table||1503||||4"
msgid "Thanks."
msgstr "Grazie."

msgctxt "11||speech_list_cln||table||1504||||4"
msgid "Hey, I got some good stuff in."
msgstr "Ehi, mi è arrivata della roba buona."

msgctxt "11||speech_list_cln||table||1505||||4"
msgid "I'm out of that. Sorry."
msgstr "Ho finito quella roba. Scusa."

msgctxt "11||speech_list_cln||table||1506||||4"
msgid "Hm? You're...\nOh, you must be Kiryu-san."
msgstr "Uhm? Tu sei...\nOh, devi essere Kiryu-san."

msgctxt "11||speech_list_cln||table||1507||||4"
msgid "I heard about you.\nGot some special stuff for ya."
msgstr "Ho sentito parlare di te.\nHo della roba speciale per te."

msgctxt "11||speech_list_cln||table||1508||||4"
msgid "So, whaddya want?"
msgstr "Allora, cosa vuoi?"

msgctxt "11||speech_list_cln||table||1509||||4"
msgid "Hope to see you again."
msgstr "Spero di rivederti."

msgctxt "11||speech_list_cln||table||1510||||4"
msgid "Yo, check this out."
msgstr "Ehi, dai un'occhiata qua."

msgctxt "11||speech_list_cln||table||1511||||4"
msgid "Thanks a ton."
msgstr "Grazie mille."

msgctxt "11||speech_list_cln||table||1512||||4"
msgid "Hey, I got some good stuff in."
msgstr "Ehi, mi è arrivata della roba buona."

msgctxt "11||speech_list_cln||table||1513||||4"
msgid "I'm out of that. Sorry."
msgstr "Ho finito quella roba. Scusa."

msgctxt "12||speech_list_imssn||table||0||||4"
msgid "Here, let me thank you."
msgstr "Ecco, lascia che ti ringrazi."

msgctxt "12||speech_list_imssn||table||1||||4"
msgid "Hey, can you bring this to me?"
msgstr "Ehi, puoi portarmi questa cosa?"

msgctxt "12||speech_list_imssn||table||2||||4"
msgid "I wish I had one of these..."
msgstr "Magari avessi uno di questi..."

msgctxt "12||speech_list_imssn||table||3||||4"
msgid "Yes, this is it!"
msgstr "Sì, è proprio questo!"

msgctxt "12||speech_list_imssn||table||4||||4"
msgid "Yes, that's right!"
msgstr "Sì, esatto!"

msgctxt "12||speech_list_imssn||table||5||||4"
msgid "This is incredible!"
msgstr "È incredibile!"

msgctxt "12||speech_list_imssn||table||6||||4"
msgid "No, this isn't what I want..."
msgstr "No, non è questo che voglio..."

msgctxt "12||speech_list_imssn||table||7||||4"
msgid "No, this isn't right at all..."
msgstr "No, non è per niente giusto..."

msgctxt "12||speech_list_imssn||table||8||||4"
msgid "That's just not possible."
msgstr "Non è semplicemente possibile."

msgctxt "12||speech_list_imssn||table||9||||4"
msgid "You're right!"
msgstr "Hai ragione!"

msgctxt "12||speech_list_imssn||table||10||||4"
