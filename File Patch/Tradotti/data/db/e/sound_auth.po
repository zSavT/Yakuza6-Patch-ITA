msgstr "Devo capire come spegnere quell'incendio..."

msgctxt "12||speech_list_imssn||table||2242||||4"
msgid "(I'm hungry. Maybe I should go\ngrab something at a restaurant.)"
msgstr "(Ho fame. Forse dovrei andare\na prendere qualcosa in un ristorante.)"

msgctxt "12||speech_list_imssn||table||2243||||4"
msgid "(Mm, that was nice. Satisfying, too.)"
msgstr "(Mhm, è stato buono. E anche appagante.)"

msgctxt "12||speech_list_imssn||table||2244||||4"
msgid "(I don't feel great... I should have\nsome medicine, though.)"
msgstr "(Non mi sento molto bene... dovrei\nperò prendere una medicina.)"

msgctxt "12||speech_list_imssn||table||2245||||4"
msgid "(Ahhh, that worked wonders.\nI feel much better now.)"
msgstr "(Ahhh, ha fatto miracoli.\nMi sento molto meglio adesso.)"

msgctxt "12||speech_list_imssn||table||2246||||4"
msgid "(I'm starving. Maybe I should eat something...)"
msgstr "(Muoio di fame. Forse dovrei mangiare qualcosa...)"

msgctxt "12||speech_list_imssn||table||2247||||4"
msgid "(As good as I expected.)"
msgstr "(Buono come mi aspettavo.)"

msgctxt "12||speech_list_imssn||table||2248||||4"
msgid "(Maybe I should go here...)"
msgstr "(Forse dovrei andare qui...)"

msgctxt "12||speech_list_imssn||table||2249||||4"
msgid "All right, this is the place."
msgstr "D'accordo, questo è il posto."

msgctxt "12||speech_list_imssn||table||2250||||4"
msgid "Exactly as planned..."
msgstr "Esattamente come previsto..."

msgctxt "12||speech_list_imssn||table||2251||||4"
msgid "This is a good piece of info..."
msgstr "Questa è una buona informazione..."

msgctxt "12||speech_list_imssn||table||2252||||4"
msgid "Huh!? A pickpocket?"
msgstr "Eh!? Un borseggiatore?"

msgctxt "12||speech_list_imssn||table||2253||||4"
msgid "Wait, my wallet's gone!\nI must've been pickpocketed!"
msgstr "Aspetta, il mio portafogli è sparito!\nDevo essere stato borseggiato!"

msgctxt "12||speech_list_imssn||table||2254||||4"
msgid "Hey, you're the one who took my wallet!"
msgstr "Ehi, sei tu che hai preso il mio portafogli!"

msgctxt "12||speech_list_imssn||table||2255||||4"
msgid "Huh!? A shoplifter?"
msgstr "Eh!? Un taccheggiatore?"

msgctxt "12||speech_list_imssn||table||2256||||4"
msgid "Hey, you're that shoplifter!"
msgstr "Ehi, tu sei quel taccheggiatore!"

msgctxt "12||speech_list_imssn||table||2257||||4"
msgid "Huh!? A burglar!?"
msgstr "Eh!? Un ladro d'appartamento!?"

msgctxt "12||speech_list_imssn||table||2258||||4"
msgid "Hey, you shouldn't resort to burglary."
msgstr "Ehi, non dovresti ricorrere ai furti in casa."

msgctxt "12||speech_list_imssn||table||2259||||4"
msgid "Huh!? A dine-and-dasher!?"
msgstr "Eh!? Uno scroccone che scappa!?"

msgctxt "12||speech_list_imssn||table||2260||||4"
msgid "You think you can leave without paying!?"
msgstr "Credi di potertene andare senza pagare!?"

msgctxt "12||speech_list_imssn||table||2261||||4"
msgid "This is... a calling card!?"
msgstr "Questo è... un biglietto da visita!?"

msgctxt "12||speech_list_imssn||table||2262||||4"
msgid "Did you send that calling card!?"
msgstr "Hai mandato tu quel biglietto da visita!?"

msgctxt "12||speech_list_imssn||table||2263||||4"
msgid "I delivered all the packages you asked me to."
msgstr "Ho consegnato tutti i pacchi che mi hai chiesto."

msgctxt "12||speech_list_imssn||table||2264||||4"
msgid "(That guy... Is he drawing graffiti over there?)"
msgstr "(Quel tizio... Sta facendo dei graffiti laggiù?)"

msgctxt "12||speech_list_imssn||table||2265||||4"
msgid "(It looks like this is pretty rare...)"
msgstr "(Sembra che questo sia piuttosto raro...)"

msgctxt "12||speech_list_imssn||table||2266||||4"
msgid "(This doesn't seem like too much...)"
msgstr "(Questo non sembra un granché...)"

msgctxt "12||speech_list_imssn||table||2267||||4"
msgid "(I think there's something here...)"
msgstr "(Credo che ci sia qualcosa qui...)"

msgctxt "12||speech_list_imssn||table||2268||||4"
msgid "(What is this...?)"
msgstr "(Che cos'è questo...?)"

msgctxt "12||speech_list_imssn||table||2269||||4"
msgid "(All right, that's a pretty good shot.)"
msgstr "(D'accordo, è una foto piuttosto buona.)"

msgctxt "12||speech_list_imssn||table||2270||||4"
msgid "(I think I messed up...)"
msgstr "(Credo di aver fatto un pasticcio...)"

msgctxt "12||speech_list_imssn||table||2271||||4"
msgid "(Hm, that's not bad...)"
msgstr "(Mhm, non è male...)"

msgctxt "12||speech_list_imssn||table||2272||||4"
msgid "(That's obstruction of traffic...)"
msgstr "(È intralcio al traffico...)"

msgctxt "12||speech_list_imssn||table||2273||||4"
msgid "Can't you see you're blocking people from\ngetting through? You don't own the road, you know."
msgstr "Non vedi che impedisci alla gente di\npassare? Non sei il padrone della strada, sai."

msgctxt "12||speech_list_imssn||table||2274||||4"
