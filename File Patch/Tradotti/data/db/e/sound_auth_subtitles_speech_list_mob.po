msgctxt "0||||4"
msgid "Oh..."
msgstr "Oh..."

msgctxt "1||||4"
msgid "Sorry to barge in on you.\r\nDon't mind me."
msgstr "Scusa l'intrusione.\r\nFai come se non ci fossi."

msgctxt "2||||4"
msgid "Huh...?"
msgstr "Eh...?"

msgctxt "3||||4"
msgid "Um, it's nothing."
msgstr "Ehm, non è niente."

msgctxt "4||||4"
msgid "What's your problem?"
msgstr "Che problema hai?"

msgctxt "5||||4"
msgid "...Never mind."
msgstr "...Lascia perdere."

