msgctxt "1||homerun_elementary||text_2"
msgid "In this course, you'll face some basic breaking balls!\r\n[Pitch Type] <color=batting_pitch_white>Fastball</color> / <color=batting_pitch_red>Curveball</color> / <color=batting_pitch_red>Slider</color> / <color=batting_pitch_blue>Forkball</color>"
msgstr "In questo percorso, affronterai alcune palle a effetto base!\r\n[Lanci] <color=batting_pitch_white>Palla veloce</color> / <color=batting_pitch_red>Palla curva</color> / <color=batting_pitch_red>Slider</color> / <color=batting_pitch_blue>Forkball</color>"

msgctxt "2||homerun_intermediate||text_2"
msgid "In this course, you'll face breaking balls that curve slightly near your hands!\r\n[Pitch Type] <color=batting_pitch_white>Two-seam</color> / <color=batting_pitch_white>One-seam</color> / <color=batting_pitch_red>Cutter</color> / <color=batting_pitch_blue>Splitter</color>"
msgstr "In questo percorso, affronterai palle a effetto che curvano leggermente vicino alle mani!\r\n[Lanci] <color=batting_pitch_white>Two-seamer</color> / <color=batting_pitch_white>One-seamer</color> / <color=batting_pitch_red>Cutter</color> / <color=batting_pitch_blue>Splitter</color>"

msgctxt "3||homerun_senior||text_2"
msgid "In this course, you'll face pitches that fluctuate in speed!\r\n[Pitch Type] <color=batting_pitch_white>Fastball</color> / <color=batting_pitch_red>Curveball</color> / <color=batting_pitch_blue>Change-up</color> / <color=batting_pitch_yellow>Sinker</color>"
msgstr "In questo percorso, affronterai lanci che variano in velocità!\r\n[Lanci] <color=batting_pitch_white>Palla veloce</color> / <color=batting_pitch_red>Palla curva</color> / <color=batting_pitch_blue>Change-up</color> / <color=batting_pitch_yellow>Sinker</color>"

msgctxt "4||homerun_super||text_2"
msgid "In this course, you'll face all sorts of breaking balls!\r\n[Pitch Type] Mystery!"
msgstr "In questo percorso, affronterai tutti i tipi di palle a effetto!\r\n[Lanci] Mistero!"

msgctxt "5||challenge_elementary_1||text_2"
msgid "In this course, you'll face only fastballs!\r\n[Pitch Type] <color=batting_pitch_white>Fastball</color>"
msgstr "In questo percorso, affronterai solo palle veloci!\r\n[Lanci] <color=batting_pitch_white>Palla veloce</color>"

msgctxt "6||challenge_elementary_2||text_2"
msgid "In this course, you'll face fastballs and curveballs!\r\n[Pitch Type] <color=batting_pitch_white>Fastball</color> / <color=batting_pitch_red>Curveball</color>"
msgstr "In questo percorso, affronterai palle veloci e palle curve!\r\n[Lanci] <color=batting_pitch_white>Palla veloce</color> / <color=batting_pitch_red>Palla curva</color>"

msgctxt "7||challenge_elementary_3||text_2"
msgid "In this course, you'll face curveballs and sinkers!\r\n[Pitch Type] <color=batting_pitch_red>Curveball</color> / <color=batting_pitch_yellow>Sinker</color>"
msgstr "In questo percorso, affronterai palle curve e sinker!\r\n[Lanci] <color=batting_pitch_red>Palla curva</color> / <color=batting_pitch_yellow>Sinker</color>"

msgctxt "8||challenge_intermediate_1||text_2"
msgid "In this course, you'll face breaking balls that curve slightly!\r\n[Pitch Type] <color=batting_pitch_white>Two-seam</color> / <color=batting_pitch_white>One-seam</color> / <color=batting_pitch_red>Cutter</color> / <color=batting_pitch_blue>Splitter</color>"
msgstr "In questo percorso, affronterai palle a effetto che curvano leggermente!\r\n[Lanci] <color=batting_pitch_white>Two-seamer</color> / <color=batting_pitch_white>One-seamer</color> / <color=batting_pitch_red>Cutter</color> / <color=batting_pitch_blue>Splitter</color>"

msgctxt "9||challenge_intermediate_2||text_2"
msgid "In this course, you'll face three types of breaking balls!\r\n[Pitch Type] <color=batting_pitch_white>Fastball</color> / <color=batting_pitch_red>Slider</color> / <color=batting_pitch_blue>Forkball</color> / <color=batting_pitch_yellow>Shoot</color>"
msgstr "In questo percorso, affronterai tre tipi di palle a effetto!\r\n[Lanci] <color=batting_pitch_white>Palla veloce</color> / <color=batting_pitch_red>Slider</color> / <color=batting_pitch_blue>Forkball</color> / <color=batting_pitch_yellow>Shootball</color>"

msgctxt "10||challenge_intermediate_3||text_2"
msgid "In this course, you'll face pitches that fluctuate in speed!\r\n[Pitch Type] <color=batting_pitch_white>Fastball</color> / <color=batting_pitch_red>Curveball</color> / <color=batting_pitch_blue>Change-up</color> / <color=batting_pitch_yellow>Sinker</color>"
msgstr "In questo percorso, affronterai lanci che variano in velocità!\r\n[Lanci] <color=batting_pitch_white>Palla veloce</color> / <color=batting_pitch_red>Palla curva</color> / <color=batting_pitch_blue>Change-up</color> / <color=batting_pitch_yellow>Sinker</color>"

msgctxt "11||challenge_senior_1||text_2"
msgid "In this course, you'll face pitches that break horizontally!\r\n[Pitch Type] <color=batting_pitch_white>Two-seam</color> / <color=batting_pitch_red>Slider</color> / <color=batting_pitch_red>Cutter</color> / <color=batting_pitch_yellow>Shoot</color>"
msgstr "In questo percorso, affronterai lanci che curvano orizzontalmente!\r\n[Lanci] <color=batting_pitch_white>Two-seamer</color> / <color=batting_pitch_red>Slider</color> / <color=batting_pitch_red>Cutter</color> / <color=batting_pitch_yellow>Shootball</color>"

msgctxt "12||challenge_senior_2||text_2"
msgid "In this course, you'll face pitches that break vertically!\r\n[Pitch Type] <color=batting_pitch_white>One-seam</color> / <color=batting_pitch_blue>Forkball</color> / <color=batting_pitch_blue>Splitter</color> / <color=batting_pitch_blue>Change-up</color>"
msgstr "In questo percorso, affronterai lanci che curvano verticalmente!\r\n[Lanci] <color=batting_pitch_white>One-seamer</color> / <color=batting_pitch_blue>Forkball</color> / <color=batting_pitch_blue>Splitter</color> / <color=batting_pitch_blue>Change-up</color>"

msgctxt "13||challenge_senior_3||text_2"
msgid "In this course, you'll face pitches that break diagonally!\r\n[Pitch Type] <color=batting_pitch_white>Two-seam</color> / <color=batting_pitch_white>One-seam</color> / <color=batting_pitch_red>Curveball</color> / <color=batting_pitch_yellow>Sinker</color>"
msgstr "In questo percorso, affronterai lanci che curvano diagonalmente!\r\n[Lanci] <color=batting_pitch_white>Two-seamer</color> / <color=batting_pitch_white>One-seamer</color> / <color=batting_pitch_red>Palla curva</color> / <color=batting_pitch_yellow>Sinker</color>"

msgctxt "14||challenge_super_1||text_2"
msgid "In this course, you'll face all sorts of breaking balls!\r\n[Pitch Type] Mystery!"
msgstr "In questo percorso, affronterai tutti i tipi di palle a effetto!\r\n[Lanci] Mistero!"

