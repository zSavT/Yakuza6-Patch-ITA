msgctxt "1||homerun_elementary||text_2"
msgid "In this course, you'll face some basic breaking balls!\r\n[Pitch Type] <color=batting_pitch_white>Fastball</color> / <color=batting_pitch_red>Curveball</color> / <color=batting_pitch_red>Slider</color> / <color=batting_pitch_blue>Forkball</color>"
msgstr ""

msgctxt "2||homerun_intermediate||text_2"
msgid "In this course, you'll face breaking balls that curve slightly near your hands!\r\n[Pitch Type] <color=batting_pitch_white>Two-seam</color> / <color=batting_pitch_white>One-seam</color> / <color=batting_pitch_red>Cutter</color> / <color=batting_pitch_blue>Splitter</color>"
msgstr ""

msgctxt "3||homerun_senior||text_2"
msgid "In this course, you'll face pitches that fluctuate in speed!\r\n[Pitch Type] <color=batting_pitch_white>Fastball</color> / <color=batting_pitch_red>Curveball</color> / <color=batting_pitch_blue>Change-up</color> / <color=batting_pitch_yellow>Sinker</color>"
msgstr ""

msgctxt "4||homerun_super||text_2"
msgid "In this course, you'll face all sorts of breaking balls!\r\n[Pitch Type] Mystery!"
msgstr ""

msgctxt "5||challenge_elementary_1||text_2"
msgid "In this course, you'll face only fastballs!\r\n[Pitch Type] <color=batting_pitch_white>Fastball</color>"
msgstr ""

msgctxt "6||challenge_elementary_2||text_2"
msgid "In this course, you'll face fastballs and curveballs!\r\n[Pitch Type] <color=batting_pitch_white>Fastball</color> / <color=batting_pitch_red>Curveball</color>"
msgstr ""

msgctxt "7||challenge_elementary_3||text_2"
msgid "In this course, you'll face curveballs and sinkers!\r\n[Pitch Type] <color=batting_pitch_red>Curveball</color> / <color=batting_pitch_yellow>Sinker</color>"
msgstr ""

msgctxt "8||challenge_intermediate_1||text_2"
msgid "In this course, you'll face breaking balls that curve slightly!\r\n[Pitch Type] <color=batting_pitch_white>Two-seam</color> / <color=batting_pitch_white>One-seam</color> / <color=batting_pitch_red>Cutter</color> / <color=batting_pitch_blue>Splitter</color>"
msgstr ""

msgctxt "9||challenge_intermediate_2||text_2"
msgid "In this course, you'll face three types of breaking balls!\r\n[Pitch Type] <color=batting_pitch_white>Fastball</color> / <color=batting_pitch_red>Slider</color> / <color=batting_pitch_blue>Forkball</color> / <color=batting_pitch_yellow>Shoot</color>"
msgstr ""

msgctxt "10||challenge_intermediate_3||text_2"
msgid "In this course, you'll face pitches that fluctuate in speed!\r\n[Pitch Type] <color=batting_pitch_white>Fastball</color> / <color=batting_pitch_red>Curveball</color> / <color=batting_pitch_blue>Change-up</color> / <color=batting_pitch_yellow>Sinker</color>"
msgstr ""

msgctxt "11||challenge_senior_1||text_2"
