msgid ""
msgstr ""
"Project-Id-Version: Yakuza 6 Translation\n"
"Last-Translator: SavT\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Language: it\n"

msgctxt "0||||4"
msgid "Please. After you, Aniki."
msgstr "Prego. Dopo di te, Aniki."

msgctxt "1||||4"
msgid "Huh!? What the hell? Cap?\r\nThis guy is<symbol=em_dash_with_outline>"
msgstr "Eh!? Che diavolo? Capitano?\r\nQuesto tizio è<symbol=em_dash_with_outline>"

msgctxt "2||||4"
msgid "Shut yer trap!\r\nY'oughta be showin' some respect!"
msgstr "Chiudi quella fogna!\r\nDovresti portare un po' di rispetto!"

msgctxt "3||||4"
msgid "This guy's my aniki now!\r\nAnd you fools'll call him aniki too!"
msgstr "Questo tizio è il mio aniki, ora!\r\nE anche voi idioti lo chiamerete aniki!"

msgctxt "4||||4"
msgid "What!?"
msgstr "Cosa!?"

msgctxt "5||||4"
msgid "Aniki, this is the Hirose Family office.\r\nY'can use it however y'want."
msgstr "Aniki, questo è l'ufficio della Famiglia Hirose.\r\nPuoi usarlo come ti pare."

msgctxt "6||||4"
msgid "Hey Cap, is it true what Ino-san said\r\nabout Masuzoe gettin' the drop on you?"
msgstr "Ehi Capitano, è vero quello che ha detto Ino-san\r\nsul fatto che Masuzoe ti ha preso alla sprovvista?"

msgctxt "7||||4"
msgid "Now ain't the time fer that, Yuta!\r\nGo n' grab us some drinks!"
msgstr "Non è il momento per questo, Yuta!\r\nVai a prenderci da bere!"

msgctxt "8||||4"
msgid "Uh, right..."
msgstr "Uh, certo..."

msgctxt "9||||4"
msgid "Oh, that a light on?\r\nIs the patriarch here?"
msgstr "Oh, c'è la luce accesa?\r\nIl patriarca è qui?"

msgctxt "10||||4"
msgid "Yeah, he said he's free for a bit."
msgstr "Sì, ha detto che è libero per un po'."

msgctxt "11||||4"
msgid "Now that's good timin'."
msgstr "Ottimo tempismo."

msgctxt "12||||4"
msgid "Aniki, lemme introduce ya t'our\r\npatriarch. C'mon in."
msgstr "Aniki, lascia che ti presenti al nostro\r\npatriarca. Entra."

msgctxt "13||||4"
msgid "Hold on, Nagumo. You're not going to\r\nask me to swear an oath, right?"
msgstr "Frena, Nagumo. Non mi chiederai\r\ndi prestare giuramento, vero?"

msgctxt "14||||4"
msgid "I only came to say hi."
msgstr "Sono solo passato a salutare."

msgctxt "15||||4"
msgid "I know that.\r\nNow, go on."
msgstr "Lo so bene.\r\nForza, vai."

msgctxt "16||||4"
msgid "What's goin' on? Yer embarrassin'\r\nus in front of our guest."
msgstr "Che sta succedendo? Ci stai mettendo\r\nin imbarazzo davanti al nostro ospite."

msgctxt "17||||4"
msgid "Huh? You all good, Tagashira?\r\nYer nose's bleedin'."
msgstr "Eh? Tutto bene, Tagashira?\r\nTi sanguina il naso."

msgctxt "18||||4"
msgid "It's Matsunaga-aniki. There's a gang\r\nof dudes startin' a ruckus."
msgstr "È Matsunaga-aniki. C'è una banda\r\ndi tizi che sta piantando un casino."

msgctxt "19||||4"
msgid "We gotta go help 'im."
msgstr "Dobbiamo andare ad aiutarlo."

msgctxt "20||||4"
msgid "Huh? What happened?"
msgstr "Eh? Che è successo?"

msgctxt "21||||4"
msgid "These customers were talkin' shit on us."
msgstr "Quei clienti stavano spalando merda su di noi."

msgctxt "22||||4"
msgid "Sayin' the food sucks, it's too expensive,\r\nthe women're ugly..."
msgstr "Dicevano che il cibo fa schifo, che è troppo caro,\r\nche le donne sono brutte..."

msgctxt "23||||4"
msgid "And? Ain't that all true?"
msgstr "E allora? Non è tutto vero?"

msgctxt "24||||4"
msgid "Well yeah, but it got t'Matsunaga-aniki."
msgstr "Beh sì, ma Matsunaga-aniki se l'è presa."

msgctxt "25||||4"
msgid "He punched one of 'em right in the face."
msgstr "Ha tirato un pugno in faccia a uno di loro."

msgctxt "26||||4"
msgid "What was he thinkin' doin' that!?\r\nY'can't just smack yer customers around."
msgstr "A che cazzo pensava!?\r\nNon puoi prendere a sberle i clienti così."

msgctxt "27||||4"
msgid "I can explain, Cap."
msgstr "Posso spiegare, Capitano."

msgctxt "28||||4"
msgid "Earlier today, we got our asses\r\nhanded to us by Kiryu-san here."
msgstr "Oggi le abbiamo prese di santa ragione\r\nda Kiryu-san, qui."

msgctxt "29||||4"
msgid "Well, news of that's been spreading."
msgstr "Beh, la notizia si è sparsa."

msgctxt "30||||4"
msgid "Matsunaga-aniki couldn't just stand by while\r\nthey mocked the family, and he snapped."
msgstr "Matsunaga-aniki non poteva restare a guardare mentre\r\nderidevano la famiglia, e ha sbroccato."

msgctxt "32||||4"
msgid "I ain't helpin'."
msgstr "Non vi aiuterò."

msgctxt "33||||4"
msgid "Y'can't run a bar if yer gonna beat yer\r\ncustomers up over every little thing."
msgstr "Non puoi gestire un bar se picchi\r\ni clienti per ogni minima cazzata."

msgctxt "34||||4"
msgid "This is on Matsunaga.\r\nLet 'em hit 'im."
msgstr "È colpa di Matsunaga.\r\nLasciate che lo menino."

msgctxt "35||||4"
msgid "Y'can't be serious!"
msgstr "Non farai sul serio!"

msgctxt "36||||4"
msgid "He's goin' up against ten guys!\r\nThey're gonna kill him!"
msgstr "Se la sta vedendo contro dieci tizi!\r\nLo ammazzeranno!"

msgctxt "37||||4"
msgid "Cap, we need to help Matsunaga-aniki!"
msgstr "Capitano, dobbiamo aiutare Matsunaga-aniki!"

msgctxt "38||||4"
msgid "I said, I ain't gonna go.\r\nOh, by the way, Tagashira..."
msgstr "Ho detto che non ci andrò.\r\nOh, a proposito, Tagashira..."

msgctxt "39||||4"
msgid "This guy's my new aniki, Kiryu-san.\r\nY'better treat him like family."
msgstr "Questo tizio è il mio nuovo aniki, Kiryu-san.\r\nVedi di trattarlo come uno di famiglia."

msgctxt "40||||4"
msgid "Then screw it!"
msgstr "E allora al diavolo!"

msgctxt "41||||4"
msgid "We'll have'ta save 'im jus' the two of us!\r\nC'mon, Yuta!"
msgstr "Dovremo salvarlo solo noi due!\r\nAndiamo, Yuta!"

msgctxt "42||||4"
msgid "Coming!"
msgstr "Arrivo!"

msgctxt "43||||4"
msgid "Sheesh. Sorry 'bout that, Aniki."
msgstr "Mamma mia. Scusa per questo, Aniki."

msgctxt "44||||4"
msgid "They don't got a lick of sense\r\nwhen it comes t'manners."
msgstr "Non hanno un briciolo di buonsenso\r\nquando si parla di buone maniere."

msgctxt "45||||4"
msgid "You're gonna let them go?"
msgstr "Li lasci andare così?"

msgctxt "46||||4"
msgid "The younger guy had a knife on him."
msgstr "Il più giovane aveva un coltello con sé."

msgctxt "47||||4"
msgid "Yeah, it's all good."
msgstr "Sì, va bene così."

msgctxt "48||||4"
msgid "Y'remember Matsunaga, right?"
msgstr "Ti ricordi di Matsunaga, vero?"

msgctxt "49||||4"
msgid "He was over with me n' Yuta\r\nwhen we were playin' baseball."
msgstr "Era con me e Yuta\r\nquando stavamo giocando a baseball."

msgctxt "50||||4"
msgid "Right, I remember fighting three of you."
msgstr "Certo, ricordo di aver affrontato tre di voi."

msgctxt "51||||4"
msgid "Well, Matsunaga's been runnin'\r\na bar called Moreno fer a while now."
msgstr "Beh, Matsunaga gestisce\r\nun bar chiamato Moreno da un bel po'."

msgctxt "52||||4"
msgid "He's always gettin' uppity at his customers."
msgstr "Si incazza sempre con i suoi clienti."

msgctxt "53||||4"
msgid "This shit happens jus' about every day."
msgstr "Questa merda succede praticamente ogni giorno."

msgctxt "54||||4"
msgid "Is this Moreno near here?"
msgstr "Questo Moreno è qui vicino?"

msgctxt "55||||4"
msgid "Huh? Yeah..."
msgstr "Eh? Sì..."

msgctxt "56||||4"
msgid "It's 'cross the bar district,\r\njust a hair in front o' the arcade."
msgstr "È dall'altra parte del quartiere dei bar,\r\nun pelo più avanti della sala giochi."

msgctxt "58||||4"
msgid "By the way, Aniki...\r\nI'm the captain o' this family."
msgstr "A proposito, Aniki...\r\nIo sono il capitano di questa famiglia."

msgctxt "59||||4"
msgid "I'll keep everyone in line, y'hear?"
msgstr "Metterò tutti in riga, mi hai sentito?"

msgctxt "60||||4"
msgid "Oh, and think o' this place\r\nas yer home, Aniki. It ain't so bad."
msgstr "Oh, e considera questo posto\r\ncome casa tua, Aniki. Non è poi così male."

msgctxt "61||||4"
msgid "If yer includin' me n' Hirose-san, there're\r\nonly five o' us in the whole family."
msgstr "Se conti me e Hirose-san, siamo\r\nsolo in cinque in tutta la famiglia."

msgctxt "63||||4"
msgid "Y'can relax here whenever y'want."
msgstr "Puoi rilassarti qui quando vuoi."

msgctxt "64||||4"
msgid "Aniki? Where're y'goin'?"
msgstr "Aniki? Dove vai?"

msgctxt "65||||4"
msgid "(So this is Moreno.\r\nMatsunaga should be in here...)"
msgstr "(Quindi questo è il Moreno.\r\nMatsunaga dovrebbe essere qui...)"

msgctxt "66||||4"
msgid "Wh-Who is this guy...?"
msgstr "Ch-Chi è questo tizio...?"

msgctxt "67||||4"
msgid "Man, that's Kiryu-aniki fer ya!\r\nIncredible. Y'really showed 'em!"
msgstr "Cavolo, questo è Kiryu-aniki per te!\r\nIncredibile. Gli hai fatto vedere i sorci verdi!"

msgctxt "68||||4"
msgid "You're a little late, Nagumo."
msgstr "Sei in leggero ritardo, Nagumo."

msgctxt "69||||4"
msgid "Well, I can't go 'round beatin' up\r\nour payin' customers."
msgstr "Beh, non posso andare in giro a picchiare\r\ni clienti paganti."

msgctxt "70||||4"
msgid "Sorry fer not helpin'."
msgstr "Scusa se non vi ho aiutato."

msgctxt "72||||4"
msgid "Hey, Matsunaga.\r\nY'doin' okay?"
msgstr "Ehi, Matsunaga.\r\nTutto a posto?"

msgctxt "73||||4"
msgid "I was worried about ya, y'know?\r\nDon't that make ya happy?"
msgstr "Ero preoccupato per te, sai?\r\nNon ti fa piacere?"

msgctxt "74||||4"
msgid "Anyway, Kiryu-aniki was real\r\nnice in drivin' those bastards off."
msgstr "Comunque, Kiryu-aniki è stato un\r\nsignore a cacciare via quei bastardi."

msgctxt "75||||4"
msgid "Y'oughta be more grateful."
msgstr "Dovresti essergli più grato."

msgctxt "76||||4"
msgid "K... Kiryu?"
msgstr "K... Kiryu?"

msgctxt "78||||4"
msgid "Yer that guy from the baseball game!"
msgstr "Sei quel tizio della partita di baseball!"

msgctxt "79||||4"
msgid "Yep."
msgstr "Già."

msgctxt "80||||4"
msgid "Forget about all that, Matsunaga.\r\nKiryu here's my aniki now."
msgstr "Lascia perdere quella storia, Matsunaga.\r\nKiryu qui ora è il mio aniki."

msgctxt "81||||4"
msgid "He's gonna be hanging 'round our\r\noffice now n' again, too."
msgstr "E passerà anche dal nostro\r\nufficio ogni tanto."

msgctxt "82||||4"
msgid "Y'best be givin' him the respect\r\nhe deserves, y'hear?"
msgstr "Vedi di portargli tutto il rispetto\r\nche merita, intesi?"

msgctxt "83||||4"
msgid "What're y'sayin', Cap!?"
msgstr "Che stai dicendo, Capitano!?"

msgctxt "84||||4"
msgid "Y'can't just let him in like this!\r\nAin't he s'posed to be our enemy?"
msgstr "Non puoi portarlo dentro così!\r\nNon dovrebbe essere un nostro nemico?"

msgctxt "85||||4"
msgid "Shut it! Yesterday's enemy is today's aniki.\r\nGet yer head 'round that."
msgstr "Piantala! Il nemico di ieri è l'aniki di oggi.\r\nFattelo entrare in testa."

msgctxt "86||||4"
msgid "Or are ya sayin' y'can't follow orders?"
msgstr "O stai forse dicendo che non sai seguire gli ordini?"

msgctxt "87||||4"
msgid "This ain't any ol' order!"
msgstr "Questo non è un ordine qualsiasi!"

msgctxt "88||||4"
msgid "Jus' today, you picked a fight with\r\nthis guy. We backed ya up, too!"
msgstr "Proprio oggi, hai attaccato briga con\r\nquesto tizio. E ti abbiamo pure coperto le spalle!"

msgctxt "89||||4"
msgid "Y'can't change yer mind that easy, Cap."
msgstr "Non puoi farti un'idea diversa così su due piedi, Capitano."

msgctxt "90||||4"
msgid "How y'expect us to keep up!?"
msgstr "Come ti aspetti che ti stiamo dietro!?"

msgctxt "91||||4"
msgid "Ya selfish ingrate!"
msgstr "Brutto ingrato egoista!"

msgctxt "92||||4"
msgid "Maybe consider who saved\r\nyer sorry ass jus' now!"
msgstr "Forse dovresti pensare a chi ti\r\nha appena parato il culo!"

msgctxt "93||||4"
msgid "If it weren't for Kiryu-aniki..."
msgstr "Se non fosse stato per Kiryu-aniki..."

msgctxt "94||||4"
msgid "...Who knows what kinda shape\r\nyou'd be in if he hadn't."
msgstr "...Chissà in che stato saresti\r\nse non fosse intervenuto."

msgctxt "95||||4"
msgid "Clear?"
msgstr "Chiaro?"

msgctxt "96||||4"
msgid "This is my bar, y'know.\r\nY'can't talk to me like that here."
msgstr "Questo è il mio bar, sai.\r\nNon puoi parlarmi così qui dentro."

msgctxt "97||||4"
msgid "It ain't yours."
msgstr "Non è il tuo."

msgctxt "98||||4"
msgid "I'm jus' lettin' you run it for me."
msgstr "Ti sto solo lasciando gestirlo per me."

msgctxt "99||||4"
msgid "'Sides..."
msgstr "E poi..."

msgctxt "100||||4"
msgid "...Weren't those customers\r\na buncha ship buildin' types?"
msgstr "...Quei clienti non erano forse\r\ndei tipi dei cantieri navali?"

msgctxt "101||||4"
msgid "Y'know we can't raise our fists at 'em."
msgstr "Lo sai che non possiamo alzare le mani su di loro."

msgctxt "102||||4"
msgid "They could bring us all down with a\r\nflick of the wrist if they wanted, right?"
msgstr "Potrebbero distruggerci tutti con uno\r\nschiocco di dita se volessero, no?"

msgctxt "103||||4"
msgid "Ya think y'could face Hirose-san\r\nif that happened?"
msgstr "Pensi che potresti guardare in faccia Hirose-san\r\nse accadesse?"

msgctxt "104||||4"
msgid "Um, Cap..."
msgstr "Ehm, Capitano..."

msgctxt "105||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "106||||4"
msgid "Wait, Aniki!\r\nWhere're ya goin'?"
msgstr "Aspetta, Aniki!\r\nDove stai andando?"

msgctxt "107||||4"
msgid "I haven't finished introducin' ya."
msgstr "Non avevo finito le presentazioni."

msgctxt "108||||4"
msgid "I left my baby over at Kiyomi's bar."
msgstr "Ho lasciato il bambino al bar di Kiyomi."

msgctxt "109||||4"
msgid "Sorry, but I've gotta get back."
msgstr "Scusate, ma devo tornare."

msgctxt "110||||4"
msgid "Oh. In that case, can y'cruise on by\r\nour office tomorrow?"
msgstr "Oh. In quel caso, puoi fare un salto\r\nal nostro ufficio domani?"

msgctxt "111||||4"
msgid "I'll be waitin' by the door for ya,\r\nso come whenever's good."
msgstr "Ti aspetterò sulla porta,\r\nquindi vieni quando ti fa più comodo."

msgctxt "112||||4"
msgid "Sure. I'll see you then."
msgstr "Certo. Ci vediamo domani."

msgctxt "113||||4"
msgid "Aniki! Thanks fer everythin'!\r\nStay safe on yer way home!"
msgstr "Aniki! Grazie di tutto!\r\nStai attento mentre torni a casa!"

msgctxt "114||||4"
msgid "This is kinda pathetic..."
msgstr "È un po' patetico..."

msgctxt "115||||4"
msgid "For real..."
msgstr "Davvero..."

msgctxt "116||||4"
msgid "(It's gotten late. I should go\r\npick up Haruto from Kiyomi's bar...)"
msgstr "(Si è fatto tardi. Dovrei andare a\r\nriprendere Haruto dal bar di Kiyomi...)"

msgctxt "117||||4"
msgid "Kiryu-san! Are you okay?\r\nHow's Nagumo-kun?"
msgstr "Kiryu-san! Stai bene?\r\nCome sta Nagumo-kun?"

msgctxt "118||||4"
msgid "He's doing fine.\r\nSorry I was gone so long."
msgstr "Sta bene.\r\nScusa se sono stato via così tanto."

msgctxt "119||||4"
msgid "Don't worry about it. I'm just\r\nglad you're back in one piece."
msgstr "Non preoccuparti. Sono solo\r\nfelice che tu sia tornato intero."

msgctxt "120||||4"
msgid "Sorry again."
msgstr "Scusa ancora."

msgctxt "121||||4"
msgid "So, what happened out there?"
msgstr "Allora, cos'è successo là fuori?"

msgctxt "123||||4"
msgid "Hold on, Kiryu-san.\r\nYou're joining the Hirose Family?"
msgstr "Frena, Kiryu-san.\r\nTi unisci alla Famiglia Hirose?"

msgctxt "124||||4"
msgid "What gave you that impression?\r\nThat's not it at all."
msgstr "Cosa ti ha dato questa impressione?\r\nNon è affatto così."

msgctxt "125||||4"
msgid "They just had me over as a guest.\r\nI'm not joining up."
msgstr "Mi hanno solo ospitato per un po'.\r\nNon mi unisco a loro."

msgctxt "126||||4"
msgid "Hm... Honestly, I'm not sure\r\nI see the difference."
msgstr "Mh... Onestamente, non sono sicura\r\ndi cogliere la differenza."

msgctxt "127||||4"
msgid "But you at least buried the hatchet\r\nwith Nagumo-kun, right?"
msgstr "Ma se non altro hai seppellito l'ascia di guerra\r\ncon Nagumo-kun, giusto?"

msgctxt "128||||4"
msgid "That's good to hear."
msgstr "Mi fa piacere sentirlo."

msgctxt "129||||4"
msgid "You know, he really saw you as\r\nhis enemy, Kiryu-san."
msgstr "Sai, ti vedeva davvero come\r\nil suo nemico, Kiryu-san."

msgctxt "130||||4"
msgid "Yeah, I know."
msgstr "Sì, lo so."

msgctxt "131||||4"
msgid "Just so you know, I'm heading to\r\nthe Hirose office again tomorrow."
msgstr "Per tua informazione, domani andrò\r\ndi nuovo all'ufficio della Hirose."

msgctxt "132||||4"
msgid "With everything that happened, I never\r\ngot to ask about Haruka or Haruto's dad."
msgstr "Con tutto quello che è successo, non ho mai\r\npotuto fare domande su Haruka o il padre di Haruto."

msgctxt "133||||4"
msgid "Oh, so that's why you're\r\nspending time with them?"
msgstr "Oh, quindi è per questo che\r\npassi del tempo con loro?"

msgctxt "134||||4"
msgid "This honestly isn't how\r\nI expected things to go..."
msgstr "Onestamente non era così che\r\nmi aspettavo andassero le cose..."

msgctxt "135||||4"
msgid "...But I guess that's life."
msgstr "...Ma immagino che la vita sia questa."

msgctxt "137||||4"
msgid "Well, we should get going."
msgstr "Beh, noi dovremmo andare."

msgctxt "138||||4"
msgid "Of course. Come back anytime."
msgstr "Certamente. Torna quando vuoi."

msgctxt "139||||4"
msgid "(I should head back to the apartment.\r\nIt's been a long night...)"
msgstr "(Dovrei tornare all'appartamento.\r\nÈ stata una lunga notte...)"

msgctxt "140||||4"
msgid "(I'm exhausted.\r\nI should probably get to sleep.)"
msgstr "(Sono esausto.\r\nForse dovrei andare a dormire.)"

msgctxt "141||||4"
msgid "(Maybe I'll explore the town\r\na little longer first.)"
msgstr "(Forse esplorerò la città\r\nancora per un po', prima.)"

msgctxt "142||||4"
msgid "(All right. Time for bed.)"
msgstr "(D'accordo. È ora di andare a letto.)"

msgctxt "143||||4"
msgid "(I should stop by the Hirose Family office.\r\nSomeone there might recognize Haruka.)"
msgstr "(Dovrei passare dall'ufficio della Famiglia Hirose.\r\nQualcuno lì potrebbe riconoscere Haruka.)"

msgctxt "144||||4"
msgid "Aniki! An honor to have ya back!"
msgstr "Aniki! Un onore riaverti qui!"

msgctxt "145||||4"
msgid "Good to see you again."
msgstr "Bello rivedervi."

msgctxt "146||||4"
msgid "Yo."
msgstr "Ehi."

msgctxt "147||||4"
msgid "Hey."
msgstr "Ehi."

msgctxt "148||||4"
msgid "Don't give yer guest that half-assed crap!"
msgstr "Non accogliete l'ospite così alla cazzo!"

msgctxt "149||||4"
msgid "I've been wonderin' something, though."
msgstr "Mi stavo chiedendo una cosa, però."

msgctxt "150||||4"
msgid "What's the deal with that baby?"
msgstr "Qual è la storia di quel bambino?"

msgctxt "151||||4"
msgid "I'll just say he's not my kid,\r\nand he's not my grandkid either."
msgstr "Dirò solo che non è mio figlio,\r\ne nemmeno mio nipote."

msgctxt "152||||4"
msgid "Sooo... Y'kidnapped him?"
msgstr "Quindiii... L'hai rapito?"

msgctxt "153||||4"
msgid "'Course he didn't, ya numbnuts!"
msgstr "Certo che no, rincoglionito!"

msgctxt "154||||4"
msgid "What kinda guy d'ya think Aniki is!?"
msgstr "Che razza di persona credi che sia Aniki!?"

msgctxt "155||||4"
msgid "Uh, I can't actually deny that."
msgstr "Ehm, in realtà non posso negarlo."

msgctxt "156||||4"
msgid "Huh!?"
msgstr "Eh!?"

msgctxt "157||||4"
msgid "Anyway, this is Haruto.\r\nI'm looking for his father."
msgstr "Comunque, questo è Haruto.\r\nSto cercando suo padre."

msgctxt "158||||4"
msgid "That's what brought me to town."
msgstr "È per questo che sono venuto in città."

msgctxt "159||||4"
msgid "Can ya give us some details?"
msgstr "Ci puoi dare qualche dettaglio in più?"

msgctxt "160||||4"
msgid "Take a seat first, Aniki.\r\nY'can tell us all about the kid after."
msgstr "Accomodati prima, Aniki.\r\nPotrai dirci tutto sul bambino dopo."

msgctxt "161||||4"
msgid "(I should check in with the family patriarch.\r\nWould be rude not to at least say hello.)"
msgstr "(Dovrei fare un salto dal patriarca della famiglia.\r\nSarebbe scortese non fare almeno un saluto.)"

msgctxt "162||||4"
msgid "Is that our Tokyo man?"
msgstr "È quello il nostro uomo di Tokyo?"

msgctxt "163||||4"
msgid "Yeah. I was in the neighborhood."
msgstr "Sì. Ero nei paraggi."

msgctxt "164||||4"
msgid "C'mon in."
msgstr "Entra pure."

msgctxt "165||||4"
msgid "Hm? And who's this?"
msgstr "Mh? E lui chi è?"

msgctxt "166||||4"
msgid "Hey, Haruto!"
msgstr "Ehi, Haruto!"

msgctxt "167||||4"
msgid "Don't worry 'bout it."
msgstr "Non ti preoccupare."

msgctxt "168||||4"
msgid "How've you been?"
msgstr "Come sei stato?"

msgctxt "169||||4"
msgid "My boys givin' ya any trouble?"
msgstr "I miei ragazzi ti danno problemi?"

msgctxt "170||||4"
msgid "You've raised a good crew."
msgstr "Hai cresciuto un buon gruppo."

msgctxt "171||||4"
msgid "Heh, right."
msgstr "Heh, già."

msgctxt "173||||4"
msgid "Nagumo told me about how you two met."
msgstr "Nagumo mi ha raccontato di come vi siete incontrati."

msgctxt "174||||4"
msgid "Y'really saved his skin back there."
msgstr "Gli hai davvero salvato la pelle, là fuori."

msgctxt "175||||4"
msgid "Though 'cause of that, things're iffy\r\nwith the Masuzoe Family now."
msgstr "Anche se, per colpa di quello, ora le cose\r\nsono po' incerte con la Famiglia Masuzoe."

msgctxt "176||||4"
msgid "You know they're lookin' into you now?"
msgstr "Lo sai che ora stanno indagando su di te?"

msgctxt "177||||4"
msgid "Are they?"
msgstr "Davvero?"

msgctxt "178||||4"
msgid "I'm just a regular civilian, though."
msgstr "Io però sono solo un normale civile."

msgctxt "179||||4"
msgid "I'll try not to make any more\r\ntrouble for your family."
msgstr "Cercherò di non causare altri problemi\r\nalla tua famiglia."

msgctxt "180||||4"
msgid "Nagumo invited you in to make up\r\nfor how he treated you before."
msgstr "Nagumo ti ha invitato qui per rimediare\r\na come ti ha trattato in precedenza."

msgctxt "181||||4"
msgid "I think he's ready to deal with\r\nwhatever consequences that brings."
msgstr "Credo che sia pronto ad affrontare\r\nqualsiasi conseguenza."

msgctxt "182||||4"
msgid "Y'like sitting on grandpa's lap, huh?"
msgstr "Ti piace stare seduto in braccio al nonno, eh?"

msgctxt "183||||4"
msgid "Sorry about him."
msgstr "Scusa per il suo comportamento."

msgctxt "184||||4"
msgid "Here, go on back to yer pa."
msgstr "Tieni, torna dal tuo papà."

msgctxt "185||||4"
msgid "Well, I should be going now."
msgstr "Beh, dovrei andare, adesso."

msgctxt "186||||4"
msgid "Already? Come back soon then."
msgstr "Di già? Allora torna presto."

msgctxt "187||||4"
msgid "I've done nothing but sit around\r\nsince getting out of the hospital."
msgstr "Non ho fatto altro che stare seduto\r\nda quando sono uscito dall'ospedale."

msgctxt "188||||4"
msgid "Livin' off insurance is boring."
msgstr "Vivere di assicurazioni è noioso."

msgctxt "189||||4"
msgid "I'll stop by some other time, then.\r\nGoodbye then, Patriarch."
msgstr "Passerò un'altra volta, allora.\r\nArrivederci, Patriarca."

msgctxt "190||||4"
msgid "Aniki, y'leavin' already?"
msgstr "Aniki, te ne vai di già?"

msgctxt "191||||4"
msgid "I am. Thanks for having me over."
msgstr "Sì. Grazie per avermi ospitato."

msgctxt "192||||4"
msgid "Are y'gonna keep lookin'\r\nfer the kid's dad?"
msgstr "Continuerai a cercare\r\nil padre del bambino?"

msgctxt "193||||4"
msgid "You can forget about that now."
msgstr "Te lo puoi scordare, adesso."

msgctxt "194||||4"
msgid "Huh? And, uh...\r\nWhy's that?"
msgstr "Eh? E, ehm...\r\nPerché dici questo?"

msgctxt "195||||4"
msgid "Don't worry.\r\nSee you later."
msgstr "Non preoccuparti.\r\nCi vediamo dopo."

msgctxt "197||||4"
msgid "Oh, Kiryu-san!\r\nThere you are."
msgstr "Oh, Kiryu-san!\r\nEccoti qua."

msgctxt "198||||4"
msgid "Hm?"
msgstr "Mh?"

msgctxt "199||||4"
msgid "Those Masuzoe Family guys from\r\nlast night were just over by my bar."
msgstr "Quei tizi della Famiglia Masuzoe\r\ndi ieri notte erano appena fuori dal mio bar."

msgctxt "200||||4"
msgid "They said they're looking\r\nfor you, Kiryu-san."
msgstr "Hanno detto che stanno\r\ncercando te, Kiryu-san."

msgctxt "201||||4"
msgid "You came all the way here\r\njust to tell me that?"
msgstr "Sei venuta fin qui solo\r\nper dirmi questo?"

msgctxt "202||||4"
msgid "Isn't it important enough?"
msgstr "Non è abbastanza importante?"

msgctxt "203||||4"
msgid "You don't want them picking fights\r\nwith you when Haruto's around."
msgstr "Non vuoi che ti attacchino briga\r\nmentre c'è Haruto nei paraggi."

msgctxt "204||||4"
msgid "I guess that's true."
msgstr "Immagino sia vero."

msgctxt "205||||4"
msgid "If we just stand here though,\r\nthey'll find us in no time."
msgstr "Se restiamo fermi qui però,\r\nci troveranno in un attimo."

msgctxt "206||||4"
msgid "This way."
msgstr "Da questa parte."

msgctxt "207||||4"
msgid "Let's take the back streets."
msgstr "Prendiamo le strade sul retro."

msgctxt "208||||4"
msgid "We can head up to Ryunan Shrine,\r\na quiet little spot on the hill."
msgstr "Possiamo salire al Santuario Ryunan,\r\nun posticino tranquillo sulla collina."

msgctxt "209||||4"
msgid "Kiryu-san. This way."
msgstr "Kiryu-san. Da questa parte."

msgctxt "210||||4"
msgid "Hurry up, Kiryu-san."
msgstr "Sbrigati, Kiryu-san."

msgctxt "211||||4"
msgid "Hold on, Kiryu-san.\r\nWhere are you going?"
msgstr "Aspetta, Kiryu-san.\r\nDove stai andando?"

msgctxt "212||||4"
msgid "The Masuzoe Family is going to\r\nfind you if we don't hurry up!"
msgstr "La Famiglia Masuzoe ti\r\ntroverà se non ci sbrighiamo!"

msgctxt "213||||4"
msgid "Hey, would y'take a look at that?\r\nA guy n' his baby!"
msgstr "Ehi, ma date un'occhiata a quello!\r\nUn tizio con il suo bambino!"

msgctxt "214||||4"
msgid "Kiryu-san! Be careful!"
msgstr "Kiryu-san! Fai attenzione!"

msgctxt "216||||4"
msgid "Can I help you?"
msgstr "Posso aiutarvi?"

msgctxt "217||||4"
msgid "Don't go playin' dumb with us."
msgstr "Non fare il finto tonto con noi."

msgctxt "218||||4"
msgid "Did y'forget what y'did last night?"
msgstr "Ti sei dimenticato cos'hai fatto ieri sera?"

msgctxt "219||||4"
msgid "We need t'borrow ya fer a bit."
msgstr "Dobbiamo prenderti in prestito per un po'."

msgctxt "220||||4"
msgid "But I guess we should probly\r\nrough ya up first."
msgstr "Ma mi sa che dovremmo prima\r\ndarti una bella raddrizzata."

msgctxt "221||||4"
msgid "Don't go makin' this hard fer yerself."
msgstr "Non rendere le cose più difficili."

msgctxt "222||||4"
msgid "Mama. Can you take Haruto for me?"
msgstr "Mama. Puoi tenere Haruto per me?"

msgctxt "223||||4"
msgid "Come on, Haruto-kun.\r\nOver here."
msgstr "Andiamo, Haruto-kun.\r\nVieni qui."

msgctxt "224||||4"
msgid "This guy ain't no ordinary grampa."
msgstr "Questo tizio non è il solito nonnetto."

msgctxt "225||||4"
msgid "Don't hold anythin' back!"
msgstr "Non trattenetevi!"

msgctxt "226||||4"
msgid "Kiryu-san... Are you okay?"
msgstr "Kiryu-san... Stai bene?"

msgctxt "227||||4"
msgid "Yeah.\r\nHaruto doing okay?"
msgstr "Sì.\r\nHaruto sta bene?"

msgctxt "228||||4"
msgid "Yeah, he's fine."
msgstr "Sì, sta bene."

msgctxt "229||||4"
msgid "Thanks."
msgstr "Grazie."

msgctxt "230||||4"
msgid "We should keep moving before\r\nmore of them come."
msgstr "Dovremmo continuare a muoverci prima\r\nche ne arrivino altri."

msgctxt "231||||4"
msgid "Ryunan Shrine.\r\nThis is it, huh?"
msgstr "Santuario Ryunan.\r\nEccolo qui, eh?"

msgctxt "232||||4"
msgid "Let's rest here for now.\r\nBut Kiryu-san, this is getting bad."
msgstr "Riposiamoci qui per ora.\r\nMa Kiryu-san, la cosa sta precipitando."

msgctxt "233||||4"
msgid "If the Masuzoe Family gets their hands\r\non you before you find Haruto's dad..."
msgstr "Se la Famiglia Masuzoe ti mette le mani\r\naddosso prima che tu trovi il padre di Haruto..."

msgctxt "234||||4"
msgid "I know."
msgstr "Lo so."

msgctxt "235||||4"
msgid "Honestly, things haven't looked good\r\never since I met Nagumo in your bar."
msgstr "Onestamente, le cose non hanno girato bene\r\nda quando ho incontrato Nagumo nel tuo bar."

msgctxt "237||||4"
msgid "But I did figure something out\r\nfrom talking to the Hirose Family."
msgstr "Ma ho capito una cosa\r\nparlando con la Famiglia Hirose."

msgctxt "238||||4"
msgid "It's about Haruka.\r\nShe was definitely here."
msgstr "Riguarda Haruka.\r\nÈ sicuramente stata qui."

msgctxt "239||||4"
msgid "Huh? What do you mean?"
msgstr "Eh? Che intendi dire?"

msgctxt "240||||4"
msgid "(Those guys are probably at Moreno...)"
msgstr "(Quei tizi probabilmente sono al Moreno...)"

msgctxt "241||||4"
msgid "Oh, Kiryu-aniki..."
msgstr "Oh, Kiryu-aniki..."

msgctxt "242||||4"
msgid "Um, thank you so much for saving me\r\nfrom those terrible thugs yesterday!"
msgstr "Ehm, grazie mille per avermi salvato\r\nda quei terribili criminali, ieri!"

msgctxt "243||||4"
msgid "I could really see myself falling\r\nfor a guy like you, Kiryu-san."
msgstr "Potrei davvero innamorarmi\r\ndi un uomo come te, Kiryu-san."

msgctxt "244||||4"
msgid "R-Right. That's okay..."
msgstr "G-Giusto. Così va bene..."

msgctxt "245||||4"
msgid "Can't y'see he ain't interested?"
msgstr "Non vedi che non è interessato?"

msgctxt "246||||4"
msgid "What's yer problem?"
msgstr "Qual è il tuo problema?"

msgctxt "247||||4"
msgid "If Matsunaga-aniki wants customers,\r\nhe oughta look for a hotter girl."
msgstr "Se Matsunaga-aniki vuole dei clienti,\r\ndovrebbe cercarsi una ragazza più sexy."

msgctxt "248||||4"
msgid "Fer some reason,\r\nhe likes 'em butch."
msgstr "Per qualche motivo,\r\ngli piacciono i maschiacci."

msgctxt "249||||4"
msgid "With our one hostess lookin' like that,\r\nthe place'll stay a ghost town."
msgstr "Con la nostra unica hostess conciata così,\r\nil posto rimarrà una città fantasma."

msgctxt "250||||4"
msgid "And where's Matsunaga now?"
msgstr "E dov'è Matsunaga, adesso?"

msgctxt "251||||4"
msgid "Jus' back there.\r\nGo ahead."
msgstr "Là dietro.\r\nVai pure."

msgctxt "252||||4"
msgid "Yamato... The biggest\r\nbattleship ever built."
msgstr "Yamato... La più grande\r\ncorazzata mai costruita."

msgctxt "253||||4"
msgid "It's a national treasure\r\nbuilt right here in Hiroshima."
msgstr "È un tesoro nazionale\r\ncostruito proprio qui a Hiroshima."

msgctxt "254||||4"
msgid "Looks almost done."
msgstr "Sembra quasi finita."

msgctxt "255||||4"
msgid "I didn't realize you were\r\ninterested in these."
msgstr "Non pensavo fossi\r\ninteressato a queste."

msgctxt "256||||4"
msgid "I was born in a shipbuildin' town. Every\r\nman, young or old, loves all sorts o' ships."
msgstr "Sono nato in una città navale. Ogni uomo,\r\ngiovane o vecchio, ama ogni tipo di nave."

msgctxt "257||||4"
msgid "I'm sorry for all the trouble\r\nI caused in here last night, Matsunaga."
msgstr "Mi dispiace per tutti i problemi\r\nche ho causato qui la scorsa notte, Matsunaga."

msgctxt "258||||4"
msgid "Y'were just tryin' to help, right?"
msgstr "Stavi solo cercando di aiutare, giusto?"

msgctxt "259||||4"
msgid "There's nothing to apologize about.\r\nDon't even sweat it."
msgstr "Non c'è niente di cui scusarsi.\r\nNon pensarci neanche."

msgctxt "260||||4"
msgid "But remember, I ain't your friend.\r\nNot yet."
msgstr "Ma ricorda, non sono un tuo amico.\r\nNon ancora."

msgctxt "262||||4"
msgid "I guess I'm a harder nut to\r\ncrack than Captain Nagumo."
msgstr "Immagino di essere un osso più\r\nduro da rodere del Capitano Nagumo."

msgctxt "263||||4"
msgid "Heh, noted."
msgstr "Heh, preso nota."

msgctxt "264||||4"
msgid "Matsunaga-aniki!"
msgstr "Matsunaga-aniki!"

msgctxt "265||||4"
msgid "Huh? What's up, Yuta?\r\nSomethin' happen?"
msgstr "Eh? Che c'è, Yuta?\r\nÈ successo qualcosa?"

msgctxt "266||||4"
msgid "Y'know those customers from last night?\r\nThe shipbuilders?"
msgstr "Hai presente quei clienti dell'altra sera?\r\nI costruttori navali?"

msgctxt "267||||4"
msgid "Yeah. What about 'em?"
msgstr "Sì. Che vogliono?"

msgctxt "268||||4"
msgid "Apparently they hightailed it to the Yomei\r\nAlliance to tattle on us."
msgstr "A quanto pare sono corsi all'Alleanza\r\nYomei a fare la spia su di noi."

msgctxt "269||||4"
msgid "The main family captain's over\r\nat our office now to settle things."
msgstr "Il capitano della famiglia principale è qui\r\nal nostro ufficio adesso per sistemare le cose."

msgctxt "270||||4"
msgid "Wait, their captain?\r\nShit, that's Koshimizu-san!"
msgstr "Aspetta, il loro capitano?\r\nMerda, è Koshimizu-san!"

msgctxt "271||||4"
msgid "He's not alone. Masuzoe's along too,\r\nfresh off his bruises from the cap."
msgstr "Non è solo. C'è anche Masuzoe, ancora fresco\r\ndei lividi che gli ha fatto il capitano."

msgctxt "272||||4"
msgid "I'd say they're like, 20 guys deep."
msgstr "Direi che sono, tipo, in 20."

msgctxt "273||||4"
msgid "Twenty guys? All at our place?"
msgstr "Venti tizi? Tutti da noi?"

msgctxt "275||||4"
msgid "Yeah."
msgstr "Sì."

msgctxt "276||||4"
msgid "Captain Nagumo said t'come\r\nget you, Matsunaga-aniki."
msgstr "Il Capitano Nagumo ha detto di\r\nvenirti a prendere, Matsunaga-aniki."

msgctxt "277||||4"
msgid "I see."
msgstr "Capisco."

msgctxt "278||||4"
msgid "I'm probly gonna have t'chop off\r\na pinky over this nonsense."
msgstr "Probabilmente dovrò mozzarmi\r\nun mignolo per questa stronzata."

msgctxt "279||||4"
msgid "But why you, Matsunaga-aniki?"
msgstr "Ma perché tu, Matsunaga-aniki?"

msgctxt "280||||4"
msgid "Y'weren't the one beatin'\r\non the customers last night."
msgstr "Non sei stato tu a picchiare\r\ni clienti ieri sera."

msgctxt "282||||4"
msgid "Don't be dumb.\r\nIt's a Hirose bar, and I run it."
msgstr "Non fare l'idiota.\r\nÈ un bar della Hirose, e lo gestisco io."

msgctxt "283||||4"
msgid "I've gotta take responsibility,\r\neven fer a fight between customers."
msgstr "Devo prendermi la responsabilità,\r\nanche per una rissa tra clienti."

msgctxt "284||||4"
msgid "I can't pin it all on Kiryu-san."
msgstr "Non posso dare tutta la colpa a Kiryu-san."

msgctxt "285||||4"
msgid "But y'know... Kiryu-san ain't\r\nfrom around here, right?"
msgstr "Ma sai... Kiryu-san non è\r\ndi queste parti, giusto?"

msgctxt "286||||4"
msgid "If we get him to apologize to 'em..."
msgstr "Se gli facciamo chiedere scusa..."

msgctxt "287||||4"
msgid "Y'think I'm gonna do somethin'\r\nthat pathetic? Huh!?"
msgstr "Credi che farei una cosa\r\ncosì patetica? Eh!?"

msgctxt "288||||4"
msgid "I know we're chumps for yakuza n' all,\r\nbut I ain't gonna sell Hirose short."
msgstr "Lo so che siamo degli yakuza da quattro soldi, ma\r\nnon sminuirò la famiglia Hirose."

msgctxt "289||||4"
msgid "Hold on. I have a question first."
msgstr "Aspettate. Prima ho una domanda."

msgctxt "290||||4"
msgid "How is a drunken brawl enough to bring their\r\ncaptain to a small family office like yours?"
msgstr "Com'è possibile che una rissa da ubriachi faccia\r\nvenire il loro capitano nell'ufficio di una piccola famiglia come la vostra?"

msgctxt "291||||4"
msgid "An outsider would never understand."
msgstr "Un estraneo non capirebbe mai."

msgctxt "292||||4"
msgid "This town's the home base\r\nfor Iwami Shipbuilding."
msgstr "Questa città è la sede principale\r\ndei Cantieri Navali Iwami."

msgctxt "293||||4"
msgid "Iwami Shipbuilding?"
msgstr "Cantieri Navali Iwami?"

msgctxt "294||||4"
msgid "It's where some o' the drunks\r\nfrom last night work."
msgstr "È dove lavorano alcuni degli ubriachi\r\ndi ieri notte."

msgctxt "295||||4"
msgid "Iwami's one o' the biggest shipbuildin'\r\nbusinesses the world over."
msgstr "La Iwami è una delle più grandi aziende\r\nnavali in tutto il mondo."

msgctxt "296||||4"
msgid "They got tonsa influence, 'specially\r\n'round here. Schools, hospitals, y'name it."
msgstr "Hanno un botto di influenza, specialmente qui.\r\nScuole, ospedali, chi più ne ha più ne metta."

msgctxt "297||||4"
msgid "Everyone in Hiroshima's connected\r\nto Iwami one way or another."
msgstr "Tutti a Hiroshima sono legati alla Iwami\r\nin un modo o nell'altro."

msgctxt "298||||4"
msgid "Anybody who dares to rise up at 'em,\r\nyer life in Hiroshima may as well be over."
msgstr "Chiunque osi mettersi contro di loro,\r\nla sua vita a Hiroshima è praticamente finita."

msgctxt "299||||4"
msgid "And even the Yomei Alliance bows to them?"
msgstr "E perfino l'Alleanza Yomei si inchina a loro?"

msgctxt "300||||4"
msgid "That's enough talk.\r\nThis don't concern ya, Kiryu-san."
msgstr "Adesso basta chiacchierare.\r\nQuesto non ti riguarda, Kiryu-san."

msgctxt "301||||4"
msgid "Jus' act like y'never heard\r\nany o' this. Now then..."
msgstr "Fai finta di non aver mai sentito\r\nniente. E ora..."

msgctxt "302||||4"
msgid "Matsunaga, don't pretend like you can\r\nhandle this alone. I'm going with you."
msgstr "Matsunaga, non fingere di poterla\r\ngestire da solo. Vengo con te."

msgctxt "303||||4"
msgid "Yuta. Tagashira.\r\nDon't let Kiryu-san leave this bar."
msgstr "Yuta. Tagashira.\r\nNon lasciate che Kiryu-san esca da questo bar."

msgctxt "304||||4"
msgid "What? But..."
msgstr "Cosa? Ma..."

msgctxt "305||||4"
msgid "That's an order from yer aniki.\r\nDon't make me repeat m'self."
msgstr "Questo è un ordine del vostro aniki.\r\nNon fatemelo ripetere."

msgctxt "306||||4"
msgid "These're Matsunaga-aniki's orders, Kiryu-san.\r\nJus' stay here and cool off fer a bit."
msgstr "Sono gli ordini di Matsunaga-aniki, Kiryu-san.\r\nResta qui e datti una calmata, per un po'."

msgctxt "308||||4"
msgid "Please. You need to stop sticking\r\nyer nose where it doesn't belong."
msgstr "Ti prego. Devi smetterla di ficcare\r\nil naso dove non ti compete."

msgctxt "309||||4"
msgid "Kiryu-san."
msgstr "Kiryu-san."

msgctxt "310||||4"
msgid "Looks like we really can't\r\ncall you our aniki."
msgstr "A quanto pare non possiamo\r\ndavvero chiamarti nostro aniki."

msgctxt "311||||4"
msgid "We're not quite like Captain Nagumo."
msgstr "Noi non siamo proprio come il Capitano Nagumo."

msgctxt "312||||4"
msgid "I understand the point you're trying\r\nto prove, but you need to step aside."
msgstr "Capisco cosa state cercando di dimostrare,\r\nma dovete farvi da parte."

msgctxt "313||||4"
msgid "Are y'trying to shame Matsunaga-aniki?"
msgstr "Vuoi forse mettere in imbarazzo Matsunaga-aniki?"

msgctxt "314||||4"
msgid "I started the fight last night."
msgstr "Ho iniziato io la rissa di ieri sera."

msgctxt "315||||4"
msgid "If anything, you're the ones\r\nwho should be staying out of this."
msgstr "Casomai, siete voi quelli\r\nche dovrebbero restarne fuori."

msgctxt "316||||4"
msgid "All you two did was sit around and\r\nget your punk asses beaten."
msgstr "Tutto quello che avete fatto è stato starvene lì\r\na farvi prendere a calci in culo."

msgctxt "317||||4"
msgid "What was that!?"
msgstr "Cos'hai detto!?"

msgctxt "318||||4"
msgid "Damn you!"
msgstr "Maledetto!"

msgctxt "319||||4"
msgid "Move."
msgstr "Spostatevi."

msgctxt "320||||4"
msgid "If I don't hurry, Matsunaga's done!"
msgstr "Se non mi sbrigato, Matsunaga è spacciato!"

msgctxt "321||||4"
msgid "You think you scare us!?\r\nBring it, old man!"
msgstr "Credi di farci paura!?\r\nFatti sotto, vecchio!"

msgctxt "322||||4"
msgid "Don't take this personally."
msgstr "Non prendetela sul personale."

msgctxt "323||||4"
msgid "W-Wait! Please, stop!"
msgstr "A-Aspetta! Ti prego, fermati!"

msgctxt "325||||4"
msgid "You're all alone. How do ya\r\nthink you're gonna settle this?"
msgstr "Sei tutto solo. Come pensi\r\ndi sistemare questa storia?"

msgctxt "326||||4"
msgid "You gonna offer up your pinky\r\nin Matsunaga-aniki's place?"
msgstr "Offrirai il tuo mignolo\r\nal posto di Matsunaga-aniki?"

msgctxt "327||||4"
msgid "I just want to talk to these Yomei guys.\r\nHow they respond is up to them."
msgstr "Voglio solo parlare con questi tizi della Yomei.\r\nCome risponderanno, dipenderà da loro."

msgctxt "328||||4"
msgid "Y'don't understand. They control\r\nevery last yakuza in Hiroshima."
msgstr "Tu non capisci. Controllano\r\nfino all'ultimo yakuza di Hiroshima."

msgctxt "329||||4"
msgid "Y'can't just go in swinging!\r\nDo you hear a word I'm saying!?"
msgstr "Non puoi solo entrare a far danni!\r\nHai capito una parola di quel che dico!?"

msgctxt "331||||4"
msgid "Sides, we jus' met ya!"
msgstr "Oltretutto, ci siamo appena conosciuti!"

msgctxt "332||||4"
msgid "And yer still tryin' to risk\r\nyer life to save Matsunaga-aniki?"
msgstr "E tu cerchi ancora di rischiare\r\nla vita per salvare Matsunaga-aniki?"

msgctxt "333||||4"
msgid "Why're y'doin' this!?"
msgstr "Perché lo fai!?"

msgctxt "334||||4"
msgid "You guys knew Haruka.\r\nAnd I know you're hiding it from me."
msgstr "Voi ragazzi conoscevate Haruka.\r\nE so che me lo state tenendo nascosto."

msgctxt "335||||4"
msgid "Wh-Where's this comin' from...?"
msgstr "Da d-dove ti esce adesso...?"

msgctxt "336||||4"
msgid "The more I help you, the more willing\r\nyou'll be to tell me what I want."
msgstr "Più vi aiuto, più sarete disposti\r\na dirmi quello che voglio."

msgctxt "337||||4"
msgid "I've got my own motives for doing this.\r\nAnd charity isn't one of them."
msgstr "Ho le mie ragioni per fare tutto questo.\r\nE la beneficenza non è una di queste."

msgctxt "339||||4"
msgid "Yeah, right."
msgstr "Sì, certo."

msgctxt "340||||4"
msgid "If info's all you wanted, you could've\r\njust beat on us 'til we talked."
msgstr "Se ti servivano solo informazioni, avresti potuto\r\ncontinuare a picchiarci finché non avessimo parlato."

msgctxt "341||||4"
msgid "Interesting. I never thought of that."
msgstr "Interessante. Non ci avevo pensato."

msgctxt "342||||4"
msgid "Wh-What's that s'posed t'mean...?"
msgstr "C-Che vorrebbe dire...?"

msgctxt "343||||4"
msgid "Seriously... What's the deal with him?"
msgstr "Sul serio... Qual è il suo problema?"

msgctxt "344||||4"
msgid "(Matsunaga should be at the Hirose office.\r\nI need to get there, and fast...)"
msgstr "(Matsunaga dovrebbe essere all'ufficio Hirose.\r\nDevo arrivarci, e in fretta...)"

msgctxt "345||||4"
msgid "Y'finally showed up.\r\nBeen lookin' fer ya... Kiryu."
msgstr "Ti sei finalmente fatto vivo.\r\nTi stavo cercando... Kiryu."

msgctxt "346||||4"
msgid "Masuzoe."
msgstr "Masuzoe."

msgctxt "347||||4"
msgid "I owe ya one fer last night."
msgstr "Te ne devo una per ieri sera."

msgctxt "348||||4"
msgid "But first, who in the hell are ya?\r\nWhat brought ya crawlin' into town?"
msgstr "Ma prima di tutto, chi diavolo sei?\r\nChe cosa ti ha portato a strisciare fin qui in città?"

msgctxt "349||||4"
msgid "My business here isn't with you."
msgstr "I miei affari non sono con te."

msgctxt "350||||4"
msgid "I heard there's a Yomei captain here.\r\nHe's the one I want, so get out of my way."
msgstr "Ho saputo che qui c'è un capitano della Yomei.\r\nÈ lui che cerco, quindi levati di mezzo."

msgctxt "351||||4"
msgid "Guess y'really don't understand\r\nwhat's goin' on here."
msgstr "Mi sa che non hai proprio capito\r\ncosa sta succedendo qui."

msgctxt "352||||4"
msgid "Yer 'bout to become history."
msgstr "Stai per diventare storia."

msgctxt "353||||4"
msgid "What y'do now determines\r\nwhether or not I let ya live."
msgstr "Ciò che farai adesso determinerà\r\nse ti lascerò vivere o meno."

msgctxt "354||||4"
msgid "That's funny.\r\nI was thinking the same thing."
msgstr "Divertente.\r\nStavo pensando la stessa cosa."

msgctxt "355||||4"
msgid "Step aside if you don't want to die.\r\nIf you leave now, I'll let this slide."
msgstr "Fatti da parte se non vuoi morire.\r\nSe te ne vai ora, farò finta di niente."

msgctxt "356||||4"
msgid "I'm sick o' yer smug bullshit. But that's gonna\r\nmake it even more satisfyin' to beat yer ass."
msgstr "Sono stanco delle tue stronzate da gradasso. Ma questo\r\nrenderà ancora più soddisfacente prenderti a calci in culo."

msgctxt "357||||4"
msgid "Time's up.\r\nLet's go!"
msgstr "Tempo scaduto.\r\nFacciamolo!"

msgctxt "358||||4"
msgid "Wait, the Tojo Clan Fourth Chairman?\r\nY'mean like, the Tojo Clan from Tokyo!?"
msgstr "Aspetta, il Quarto Presidente del Clan Tojo?\r\nIntendi il Clan Tojo di Tokyo!?"

msgctxt "359||||4"
msgid "That one."
msgstr "Quello."

msgctxt "361||||4"
msgid "Then... I know who y'are. The Dragon o' Dojima!\r\nI read about ya in a magazine once."
msgstr "Allora... so chi sei. Il Drago di Dojima!\r\nHo letto di te su una rivista, una volta."

msgctxt "362||||4"
msgid "Hey, what's up with y'guys?\r\nWhy aren't ya surprised?"
msgstr "Ehi, che avete voi altri?\r\nPerché non siete sorpresi?"

msgctxt "363||||4"
msgid "Is he really that famous?"
msgstr "È davvero così famoso?"

msgctxt "364||||4"
msgid "Huh? What're y'talkin' about!?\r\nHe's legendary fer bein' a ruthless yakuza!"
msgstr "Eh? Ma che state dicendo!?\r\nÈ una leggenda per essere uno yakuza spietato!"

msgctxt "365||||4"
msgid "This guy's incredible!"
msgstr "Questo tizio è incredibile!"

msgctxt "366||||4"
msgid "Kiryu-aniki. Why'd y'try to hide this\r\nfrom us? Y'should've told us way sooner."
msgstr "Kiryu-aniki. Perché hai cercato di nascondercelo?\r\nAvresti dovuto dircelo molto prima."

msgctxt "367||||4"
msgid "I left that life in the past.\r\nI'm just a civilian now."
msgstr "Mi sono lasciato quella vita alle spalle.\r\nOra sono solo un civile."

msgctxt "368||||4"
msgid "But I guess there's nothing left to hide."
msgstr "Ma immagino che non ci sia più niente da nascondere."

msgctxt "369||||4"
msgid "At least, <font_kind=yakuza_italic>I'm</font_kind> not hiding anything."
msgstr "Almeno, <font_kind=yakuza_italic>io</font_kind> non sto nascondendo nulla."

msgctxt "370||||4"
msgid "What d'ya mean, Kiryu-san?"
msgstr "Che vuoi dire, Kiryu-san?"

msgctxt "371||||4"
msgid "He means there's still\r\nsomethin' we're hiding from him."
msgstr "Intende che c'è ancora qualcosa\r\nche gli stiamo tenendo nascosto."

msgctxt "372||||4"
msgid "That's what he means."
msgstr "È quello che intende."

msgctxt "373||||4"
msgid "Oh..."
msgstr "Oh..."

msgctxt "374||||4"
msgid "Well, what're ya hiding?\r\nC'mon, Nagumo. I can keep a secret."
msgstr "Beh, cosa state nascondendo?\r\nAndiamo, Nagumo. So mantenere un segreto."

msgctxt "375||||4"
msgid "Huh? W-Well, uh..."
msgstr "Eh? B-Beh, ehm..."

msgctxt "377||||4"
msgid "It's fine. I'm heading home for tonight.\r\nI need to get back to Haruto."
msgstr "Non importa. Per stanotte torno a casa.\r\nDevo tornare da Haruto."

msgctxt "378||||4"
msgid "Hey, Nagumo.\r\nLet's hear this secret."
msgstr "Ehi, Nagumo.\r\nSentiamo questo segreto."

msgctxt "379||||4"
msgid "(Mama said she'd bring Haruto back to the\r\napartment. She's probably waiting there.)"
msgstr "(Mama ha detto che avrebbe riportato Haruto\r\nall'appartamento. Probabilmente sta aspettando lì.)"

msgctxt "380||||4"
msgid "Kiryu-san."
msgstr "Kiryu-san."

msgctxt "381||||4"
msgid "Hi there. Sorry I'm late.\r\nHave you been here long?"
msgstr "Salve. Scusa per il ritardo.\r\nSei qui da molto?"

msgctxt "382||||4"
msgid "Not really. Haruto-kun's fast asleep.\r\nHe's been in a great mood today, though."
msgstr "Non molto. Haruto-kun dorme profondamente.\r\nPerò è stato di ottimo umore oggi."

msgctxt "383||||4"
msgid "That's good. Did you want to\r\ncome inside for a bit?"
msgstr "Meno male. Volevi\r\nentrare per un po'?"

msgctxt "384||||4"
msgid "Oh no, it's getting late. Anyway,\r\nhow are things with the Masuzoe Family?"
msgstr "Oh no, si è fatto tardi. A ogni modo,\r\ncome vanno le cose con la Famiglia Masuzoe?"

msgctxt "385||||4"
msgid "Fine, for now at least."
msgstr "Bene, almeno per ora."

msgctxt "386||||4"
msgid "I'm glad to hear that.\r\nWell, here's Haruto-kun."
msgstr "Sono felice di sentirlo.\r\nBeh, ecco Haruto-kun."

msgctxt "387||||4"
msgid "I really shouldn't keep asking you\r\nto take care of him."
msgstr "Non dovrei davvero continuare a chiederti\r\ndi prenderti cura di lui."

msgctxt "388||||4"
msgid "What about the Hirose guys?\r\nDid they tell you anything about Haruka?"
msgstr "E i ragazzi della Hirose?\r\nTi hanno detto qualcosa su Haruka?"

msgctxt "389||||4"
msgid "No, I didn't get the chance to ask."
msgstr "No, non ne ho avuto l'occasione."

msgctxt "390||||4"
msgid "I'll give it some more time.\r\nI still think they'll come clean themselves."
msgstr "Gli darò ancora un po' di tempo.\r\nPenso ancora che sputeranno il rospo da soli."

msgctxt "392||||4"
msgid "Is something wrong?"
msgstr "C'è qualcosa che non va?"

msgctxt "393||||4"
msgid "No no, it's nothing.\r\nWell, good night."
msgstr "No, no, non è niente.\r\nBeh, buonanotte."

msgctxt "394||||4"
msgid "Same to you. Thanks again."
msgstr "Anche a te. Grazie ancora."

msgctxt "396||||4"
msgid "Aniki. It's Nagumo."
msgstr "Aniki. Sono Nagumo."

msgctxt "397||||4"
msgid "Nagumo...?"
msgstr "Nagumo...?"

msgctxt "398||||4"
msgid "Kiyo-chan told me where yer stayin'.\r\nI've got somethin' I wanna tell ya, Aniki."
msgstr "Kiyo-chan mi ha detto dove alloggi.\r\nHo una cosa da dirti, Aniki."

msgctxt "399||||4"
msgid "Haruto's sleeping, so let's talk outside.\r\nDo you mind?"
msgstr "Haruto sta dormendo, parliamo fuori.\r\nTi dispiace?"

msgctxt "400||||4"
msgid "Not a lick."
msgstr "Per niente."

msgctxt "401||||4"
msgid "As y'can probly guess,\r\nI came t'talk about Haruka-san."
msgstr "Come avrai già intuito,\r\nsono venuto per parlare di Haruka-san."

msgctxt "403||||4"
msgid "Truth is, everyone in the family\r\nknew Haruka-san when she was here."
msgstr "La verità è che tutta la famiglia\r\nconosceva Haruka-san quando era qui."

msgctxt "404||||4"
msgid "Soon as y'showed us that picture over at\r\nthe office, we figured out who y'were."
msgstr "Non appena ci hai mostrato quella foto in\r\nufficio, abbiamo capito chi eri."

msgctxt "405||||4"
msgid "Kiryu-aniki. Yer Haruka's guardian and the\r\nTojo Clan Fourth Chairman... Kazuma Kiryu."
msgstr "Kiryu-aniki. Sei il tutore di Haruka e il Quarto\r\nPresidente del Clan Tojo... Kazuma Kiryu."

msgctxt "407||||4"
msgid "Pretty sure Matsunaga didn't quite\r\nput the pieces together, though."
msgstr "Sono abbastanza sicuro che Matsunaga non\r\nabbia messo insieme tutti i pezzi, però."

msgctxt "408||||4"
msgid "Lemme tell ya, that thick skull o' his\r\nserves him good sometimes."
msgstr "Lascia che te lo dica, quella sua\r\ntesta dura a volte torna utile."

msgctxt "409||||4"
msgid "I see."
msgstr "Capisco."

msgctxt "410||||4"
msgid "Sorry fer how rude we were to ya.\r\nHope ya can accept my apology."
msgstr "Scusaci per quanto siamo stati maleducati con te.\r\nSpero tu possa accettare le mie scuse."

msgctxt "411||||4"
msgid "Oh, and there's a reason we didn't tell\r\nya 'bout us knowin' Haruka-san."
msgstr "Oh, e c'è una ragione se non ti abbiamo\r\ndetto che conoscevamo Haruka-san."

msgctxt "412||||4"
msgid "She never gave us permission."
msgstr "Non ci ha mai dato il permesso di farlo."

msgctxt "413||||4"
msgid "Go on."
msgstr "Continua."

msgctxt "414||||4"
msgid "Haruka-san blew in to town\r\nsomewhere 'round three years ago."
msgstr "Haruka-san è arrivata in città\r\ncirca tre anni fa."

msgctxt "415||||4"
msgid "At first, she didn't much feel like\r\ntalkin' about herself."
msgstr "All'inizio, non aveva molta voglia\r\ndi parlare di sé stessa."

msgctxt "416||||4"
msgid "She was always careful\r\no' who could've been around."
msgstr "Era sempre guardinga riguardo\r\na chi poteva averle intorno."

msgctxt "417||||4"
msgid "T'be honest, it looked kinda like\r\nshe'd ran away from home t'come here."
msgstr "A dirla tutta, sembrava quasi\r\nche fosse scappata di casa per venire qui."

msgctxt "419||||4"
msgid "Here in the sticks,\r\noutsiders stand out like a sore thumb."
msgstr "Qui in mezzo al nulla, i forestieri\r\nspiccano come mosche bianche."

msgctxt "420||||4"
msgid "But she was the cutest girl yokels like\r\nus'd ever seen. She got popular real quick."
msgstr "Ma era la ragazza più carina che noi bifolchi avessimo\r\nmai visto. È diventata popolare molto in fretta."

msgctxt "421||||4"
msgid "Whenever Haruka-san was 'round..."
msgstr "Ogni volta che c'era Haruka-san..."

msgctxt "422||||4"
msgid "...Everyone'd be on their best behavior.\r\nMy family, the shipbuilders, the fishermen."
msgstr "...Tutti si comportavano al meglio.\r\nLa mia famiglia, i costruttori navali, i pescatori."

msgctxt "423||||4"
msgid "Soon enough, people took t'thinkin' of her\r\nas a damn important part of Onomichi."
msgstr "Ben presto, la gente iniziò a considerarla una\r\nparte dannatamente importante di Onomichi."

msgctxt "424||||4"
msgid "Nobody could bring 'emselves to\r\nmention her past life as a celebrity."
msgstr "Nessuno se la sentiva di\r\nmenzionare la sua vita passata da celebrità."

msgctxt "425||||4"
msgid "So you did know."
msgstr "Quindi lo sapevate."

msgctxt "426||||4"
msgid "Don't even need to watch TV to\r\nsort that out."
msgstr "Non c'è nemmeno bisogno di guardare la TV\r\nper capirlo."

msgctxt "427||||4"
msgid "We knew Haruka-san was tryin'\r\nt'stay outta the public eye, too."
msgstr "Sapevamo che anche Haruka-san stava cercando\r\ndi rimanere lontana dagli occhi del pubblico."

msgctxt "429||||4"
msgid "We jus' wanted t'protect her from\r\nthe world she was hopin' to escape."
msgstr "Volevamo solo proteggerla dal\r\nmondo da cui sperava di fuggire."

msgctxt "430||||4"
msgid "That's why we were tryin' to hide\r\nwhat we knew about her."
msgstr "Ecco perché cercavamo di nascondere\r\nciò che sapevamo su di lei."

msgctxt "431||||4"
msgid "I know y'wanted info\r\non Haruka-san, Aniki..."
msgstr "Lo so che volevi informazioni\r\nsu Haruka-san, Aniki..."

msgctxt "432||||4"
msgid "...But we jus' couldn't do that t'her.\r\nThe whole town probly thought the same."
msgstr "...Ma semplicemente non potevamo farle questo.\r\nL'intera città la pensava così, probabilmente."

msgctxt "433||||4"
msgid "Huh, you're more considerate than I took\r\nyou for. I can see why Haruka felt at home."
msgstr "Huh, siete più premurosi di quanto pensassi.\r\nCapisco perché Haruka si sentisse a casa."

