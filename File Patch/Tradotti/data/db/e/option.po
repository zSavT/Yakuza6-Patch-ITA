msgctxt "1||difficulty||explanation"
msgid "You can set the difficulty."
msgstr "Imposta il livello di difficoltà."

msgctxt "3||free_camera_vertical||explanation"
msgid "Change how to move the camera vertically."
msgstr "Modifica il movimento verticale della telecamera."

msgctxt "4||free_camera_horizontal||explanation"
msgid "Change how to move the camera horizontally."
msgstr "Modifica il movimento orizzontale della telecamera."

msgctxt "11||brightness||explanation"
msgid "Slide the cursor to adjust the brightness."
msgstr "Scorri il cursore per regolare la luminosità."

msgctxt "12||gamma||explanation"
msgid "Slide the cursor to adjust the gamma correction."
msgstr "Scorri il cursore per regolare la correzione gamma."

msgctxt "13||camera_sensitivity||explanation"
msgid "Set the speed the camera moves at. \r\nSlide the cursor to adjust the speed."
msgstr "Imposta la velocità di movimento della telecamera. \r\nScorri il cursore per regolarla."

msgctxt "14||pov_camera_vertical||explanation"
msgid "Change how to move the first-person camera vertically."
msgstr "Modifica il movimento verticale della telecamera in prima persona."

msgctxt "15||pov_camera_horizontal||explanation"
msgid "Change how to move the first-person camera horizontally."
msgstr "Modifica il movimento orizzontale della telecamera in prima persona."

msgctxt "16||minimap_visible||explanation"
msgid "Switch on/off the minimap that appears in the lower\r\nleft part of the screen."
msgstr "Attiva/disattiva la minimappa che appare nella parte\r\ninferiore sinistra dello schermo."

msgctxt "17||blood_type||explanation"
msgid "Set the level of blood to display."
msgstr "Imposta il livello di sangue mostrato a schermo."

msgctxt "18||font_kind||explanation"
msgid "Change the font used during the game."
msgstr "Cambia il carattere usato nel gioco."

msgctxt "19||minimap_direction||explanation"
msgid "Switch on/off minimap rotation. If turned on,\r\nthe minimap will rotate with the camera."
msgstr "Attiva/disattiva la rotazione della minimappa. Se attivata,\r\nla minimappa ruoterà insieme alla telecamera."

msgctxt "20||subtitles_display||explanation"
msgid "Switch on/off subtitles for movie scenes."
msgstr "Attiva o disattiva i sottotitoli per i filmati."

msgctxt "25||speaker_type||explanation"
msgid "Select between stereo, surround 5.1 or surround 7.1 sound."
msgstr "Scegli tra audio stereo, surround 5.1 o surround 7.1."

msgctxt "26||speaker_front_angle||explanation"
msgid "Adjust to your speakers' angle for optimal quality."
msgstr "Regola l'angolazione dei tuoi altoparlanti per una qualità ottimale."

msgctxt "27||speaker_rear_angle||explanation"
msgid "Adjust to your speakers' angle for optimal quality."
msgstr "Regola l'angolazione dei tuoi altoparlanti per una qualità ottimale."

msgctxt "28||auto_camera||explanation"
msgid "The camera's point of view will move automatically\r\ndepending on the situation. If you select Off, it\r\nwill not move unless the player moves it themselves."
msgstr "La telecamera si sposterà automaticamente a seconda\r\ndella situazione. Se selezioni No, non si muoverà finché\r\nnon sarà il giocatore a farlo."

msgctxt "29||ringtone||explanation"
msgid "Change your smartphone's ringtone."
msgstr "Cambia la suoneria del tuo smartphone."

msgctxt "30||hud_enabled||explanation"
msgid "Toggle ingame HUD on or off."
msgstr "Attiva o disattiva l'HUD di gioco."

msgctxt "32||graphics_output||explanation"
msgid "Select output device for given adapter."
msgstr "Seleziona il dispositivo di uscita per l'adattatore indicato."

msgctxt "33||graphics_display_mode||explanation"
msgid "Set display mode for your device."
msgstr "Imposta la modalità schermo per il tuo dispositivo."

msgctxt "34||graphics_display_resolution||explanation"
msgid "Set display resolution for your device."
msgstr "Imposta la risoluzione video per il tuo dispositivo."

msgctxt "35||graphics_refresh_rate||explanation"
msgid "Set refresh rate of your display device."
msgstr "Imposta la frequenza d'aggiornamento del tuo schermo."

msgctxt "36||graphics_vertical_sync||explanation"
msgid "Set vertical synchronization for your display device."
msgstr "Imposta la sincronizzazione verticale per il tuo schermo."

msgctxt "37||graphics_quality_preset||explanation"
msgid "Use presets to easily control advanced graphics settings."
msgstr "Usa i preset per controllare facilmente le impostazioni grafiche avanzate."

msgctxt "38||graphics_fov||explanation"
msgid "Adjust field of view value."
msgstr "Regola il valore del campo visivo (FOV)."

msgctxt "39||graphics_fps||explanation"
msgid "Set FPS limit."
msgstr "Imposta il limite dei fotogrammi al secondo (FPS)."

msgctxt "40||graphics_texture_quality||explanation"
msgid "Set quality of textures."
msgstr "Imposta la qualità delle texture."

msgctxt "41||graphics_texture_filtering||explanation"
msgid "Set anisotropy texture filtering."
msgstr "Imposta il filtro anisotropico per le texture."

msgctxt "42||graphics_shadow_quality||explanation"
msgid "Set quality of shadows."
msgstr "Imposta la qualità delle ombre."

msgctxt "43||graphics_geometry_quality||explanation"
msgid "Set quality of geometry meshes."
msgstr "Imposta la qualità delle mesh geometriche."

msgctxt "44||graphics_realtime_reflections||explanation"
msgid "Enable or disable realtime reflections."
msgstr "Attiva o disattiva i riflessi in tempo reale."

msgctxt "45||graphics_motion_blur||explanation"
msgid "Enable or disable motion blur."
msgstr "Attiva o disattiva l'effetto motion blur."

msgctxt "46||graphics_ssao||explanation"
msgid "Enable or disable Screen Space Ambient Occlusion."
msgstr "Attiva o disattiva l'occlusione ambientale (SSAO)."

msgctxt "47||graphics_ssss||explanation"
msgid "Enable or disable subsurface scattering."
msgstr "Attiva o disattiva il subsurface scattering."

msgctxt "48||graphics_render_scale||explanation"
msgid "Adjust render scaling."
msgstr "Regola la scala di rendering."

msgctxt "49||graphics_advanced_button||explanation"
msgid "Go to advanced graphics settings."
msgstr "Vai alle impostazioni grafiche avanzate."

msgctxt "50||graphics_aa||explanation"
msgid "Set anti-aliasing type or disable it."
msgstr "Imposta il tipo di anti-aliasing o disabilitalo."

msgctxt "51||graphics_dof||explanation"
msgid "Enable or disable Depth of Field."
msgstr "Attiva o disattiva la profondità di campo."

msgctxt "52||volume_music||explanation"
msgid "Adjust music volume."
msgstr "Regola il volume della musica."

msgctxt "53||volume_effect||explanation"
msgid "Adjust effects volume."
msgstr "Regola il volume degli effetti sonori."

msgctxt "54||volume_dialog||explanation"
msgid "Adjust dialog volume."
msgstr "Regola il volume dei dialoghi."

msgctxt "55||volume_cinema||explanation"
msgid "Adjust cinema volume."
msgstr "Regola il volume dei filmati."

msgctxt "56||icon_select||explanation"
msgid "Option to choose what icons will be used."
msgstr "Opzione per scegliere quali icone tasti usare a schermo."

msgctxt "57||disable_windows_key||explanation"
msgid "Disable Windows Key while the game is running."
msgstr "Disabilita il tasto Windows mentre il gioco è in esecuzione."

msgctxt "58||tattoo_bars||explanation"
msgid "Enable or disable tattoo letterbox artwork\nused in aspect ratios different than 16:9."
msgstr "Attiva o disattiva le grafiche dei tatuaggi nelle bande\nletterbox su aspect ratio differenti dal 16:9."

msgctxt "59||mouse_cursor||explanation"
msgid "Set mouse pointer to game or system style."
msgstr "Imposta il puntatore del mouse sullo stile del gioco o del sistema."

msgctxt "60||controller_vibration||explanation"
msgid "Switch on/off the controller vibration."
msgstr "Attiva o disattiva la vibrazione del controller."

msgctxt "61||speaker_front_angle_7_1||explanation"
msgid "Adjust to your speakers' angle for optimal quality."
msgstr "Regola l'angolazione dei tuoi altoparlanti per una qualità ottimale."

msgctxt "62||speaker_surround_angle_5_1||explanation"
msgid "Adjust to your speakers' angle for optimal quality."
msgstr "Regola l'angolazione dei tuoi altoparlanti per una qualità ottimale."

msgctxt "63||speaker_surround_angle_7_1||explanation"
msgid "Adjust to your speakers' angle for optimal quality."
msgstr "Regola l'angolazione dei tuoi altoparlanti per una qualità ottimale."

msgctxt "64||speaker_rear_angle_7_1||explanation"
msgid "Adjust to your speakers' angle for optimal quality."
msgstr "Regola l'angolazione dei tuoi altoparlanti per una qualità ottimale."

msgctxt "65||volume_master||explanation"
msgid "Adjust master volume."
msgstr "Regola il volume principale."

msgctxt "66||graphics_ui_limit_ui||explanation"
msgid "Set maximum aspect ratio for the layout of UI elements.\nCan be used to shift UI from the edges toward the center \nof the screen."
msgstr "Imposta l'aspect ratio massimo per gli elementi dell'interfaccia.\nPuò essere usato per spostare l'UI dai bordi verso il centro\ndello schermo."

msgctxt "67||graphics_ui_limit_minigame||explanation"
msgid "Set aspect ratio of the middle display. Can be used to fit \nparts of the game entirely within the primary screen of \nthe multi-monitor configuration."
msgstr "Imposta l'aspect ratio dello schermo centrale. Può essere usato per far rientrare\nparti del gioco interamente nello schermo principale di una\nconfigurazione multi-monitor."

msgctxt "68||hide_skip_prompt||explanation"
msgid "Hides the Skip prompt in dialogues. \nSkipping dialogues is still possible."
msgstr "Nasconde il comando per saltare i dialoghi. \nSarà comunque possibile saltarli."

