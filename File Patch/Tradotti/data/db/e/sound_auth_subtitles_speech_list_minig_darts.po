msgctxt "0||||4"
msgid "Oh, Kiryu-chi.\r\nWanna play a game with me?"
msgstr ""

msgctxt "1||||4"
msgid "Damn right ya do!"
msgstr ""

msgctxt "2||||4"
msgid "Aw... Kinda lame, man."
msgstr ""

msgctxt "3||||4"
msgid "Well, gimme a rematch sometime!"
msgstr ""

msgctxt "4||||4"
msgid "Hmmm?\r\nYou want to play against <font_kind=yakuza_italic>me</font_kind>?"
msgstr ""

msgctxt "5||||4"
msgid "Sure! <symbol=note_with_outline>"
msgstr ""

msgctxt "6||||4"
msgid "What? Boooring!"
msgstr ""

msgctxt "7||||4"
msgid "Let's play again sometime!"
msgstr ""

msgctxt "8||||4"
msgid "My, are you perhaps inviting\r\nme to a darts match?"
msgstr ""

msgctxt "9||||4"
msgid "Sure.\r\nLet's have some fun. <symbol=heart_with_outline>"
msgstr ""

msgctxt "10||||4"
msgid "Oh. That's unfortunate..."
msgstr ""

msgctxt "11||||4"
msgid "See you next time. <symbol=heart_with_outline>"
msgstr ""

msgctxt "12||||4"
msgid "You wanna play, Kiryu-san?"
msgstr ""

msgctxt "13||||4"
msgid "This'll be my win."
msgstr ""

msgctxt "14||||4"
msgid "Rejection hurts, man."
msgstr ""

msgctxt "15||||4"
msgid "Holler at me anytime!"
msgstr ""

msgctxt "16||||4"
msgid "Oh? You want to play?"
msgstr ""

msgctxt "17||||4"
msgid "I'll take you on."
msgstr ""

msgctxt "18||||4"
msgid "That's too bad."
msgstr ""

msgctxt "19||||4"
msgid "Let's play again soon. <symbol=note_with_outline>"
msgstr ""

