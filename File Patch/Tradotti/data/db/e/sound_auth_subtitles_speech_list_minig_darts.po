msgctxt "0||||4"
msgid "Oh, Kiryu-chi.\r\nWanna play a game with me?"
msgstr "Oh, Kiryu-chi.\r\nVuoi farti una partita con me?"

msgctxt "1||||4"
msgid "Damn right ya do!"
msgstr "Ci puoi scommettere!"

msgctxt "2||||4"
msgid "Aw... Kinda lame, man."
msgstr "Uffa... Che noia, amico."

msgctxt "3||||4"
msgid "Well, gimme a rematch sometime!"
msgstr "Beh, dammi la rivincita qualche volta!"

msgctxt "4||||4"
msgid "Hmmm?\r\nYou want to play against <font_kind=yakuza_italic>me</font_kind>?"
msgstr "Mhm?\r\nVuoi giocare contro di <font_kind=yakuza_italic>me</font_kind>?"

msgctxt "5||||4"
msgid "Sure! <symbol=note_with_outline>"
msgstr "Certo! <symbol=note_with_outline>"

msgctxt "6||||4"
msgid "What? Boooring!"
msgstr "Cosa? Che noooia!"

msgctxt "7||||4"
msgid "Let's play again sometime!"
msgstr "Giochiamo di nuovo qualche volta!"

msgctxt "8||||4"
msgid "My, are you perhaps inviting\r\nme to a darts match?"
msgstr "Oh, mi stai forse invitando\r\na una partita a freccette?"

msgctxt "9||||4"
msgid "Sure.\r\nLet's have some fun. <symbol=heart_with_outline>"
msgstr "Certo.\r\nDivertiamoci un po'. <symbol=heart_with_outline>"

msgctxt "10||||4"
msgid "Oh. That's unfortunate..."
msgstr "Oh. È un vero peccato..."

msgctxt "11||||4"
msgid "See you next time. <symbol=heart_with_outline>"
msgstr "Alla prossima. <symbol=heart_with_outline>"

msgctxt "12||||4"
msgid "You wanna play, Kiryu-san?"
msgstr "Vuoi giocare, Kiryu-san?"

msgctxt "13||||4"
msgid "This'll be my win."
msgstr "Questa sarà la mia vittoria."

msgctxt "14||||4"
msgid "Rejection hurts, man."
msgstr "I rifiuti fanno male, amico."

msgctxt "15||||4"
msgid "Holler at me anytime!"
msgstr "Fai un fischio quando vuoi!"

msgctxt "16||||4"
msgid "Oh? You want to play?"
msgstr "Oh? Vuoi giocare?"

msgctxt "17||||4"
msgid "I'll take you on."
msgstr "Accetto la sfida."

msgctxt "18||||4"
msgid "That's too bad."
msgstr "Che peccato."

msgctxt "19||||4"
msgid "Let's play again soon. <symbol=note_with_outline>"
msgstr "Giochiamo di nuovo presto. <symbol=note_with_outline>"

