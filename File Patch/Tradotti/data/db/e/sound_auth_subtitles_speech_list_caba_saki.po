msgid ""
msgstr ""
"Project-Id-Version: Yakuza 6 Translation\n"
"Last-Translator: SavT\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Language: it\n"

msgctxt "0||||4"
msgid "Kiryu-san! Sorry I'm late. <symbol=note_with_outline>"
msgstr "Kiryu-san! Scusa il ritardo. <symbol=note_with_outline>"

msgctxt "1||||4"
msgid "Did you have to wait long...?"
msgstr "Hai aspettato molto...?"

msgctxt "2||||4"
msgid "Kiryu-san! I couldn't wait to see you again! <symbol=note_with_outline>"
msgstr "Kiryu-san! Non vedevo l'ora di rivederti! <symbol=note_with_outline>"

msgctxt "3||||4"
msgid "Where should we go?"
msgstr "Dove andiamo?"

msgctxt "4||||4"
msgid "Karaoke! Nice choice!"
msgstr "Karaoke! Ottima scelta!"

msgctxt "5||||4"
msgid "That sounds fun!\r\nI never really get to play darts."
msgstr "Sembra divertente!\r\nNon gioco quasi mai a freccette."

msgctxt "6||||4"
msgid "C'mon, let's go. <symbol=note_with_outline>"
msgstr "Forza, andiamo. <symbol=note_with_outline>"

msgctxt "7||||4"
msgid "I wonder what song you'll sing... <symbol=heart_with_outline>"
msgstr "Chissà che canzone canterai... <symbol=heart_with_outline>"

msgctxt "8||||4"
msgid "Let's see...\r\nWhat should I sing today? <symbol=note_with_outline>"
msgstr "Vediamo...\r\nCosa potrei cantare oggi? <symbol=note_with_outline>"

msgctxt "9||||4"
msgid "I'm not so hot at darts, so go easy on me!"
msgstr "Non sono molto brava a freccette, vacci piano!"

msgctxt "10||||4"
msgid "All right! Let's do this!"
msgstr "D'accordo! Facciamolo!"

msgctxt "11||||4"
msgid "W-Well, we're just getting started.\r\nWe can still have some fun, right...?"
msgstr "B-Beh, abbiamo appena iniziato.\r\nPossiamo ancora divertirci, giusto...?"

msgctxt "12||||4"
msgid "That was fun! <symbol=note_with_outline>\r\nWe should do this again sometime."
msgstr "È stato divertente! <symbol=note_with_outline>\r\nDovremmo rifarlo qualche volta."

msgctxt "13||||4"
msgid "That was so fun! <symbol=heart_with_outline> It's rare to have a\r\ncustomer who's so fun to hang out with!"
msgstr "È stato divertentissimo! <symbol=heart_with_outline> È raro trovare\r\nun cliente così di compagnia!"

msgctxt "14||||4"
msgid "Well, it's about that time.\r\nLet's head back to the club."
msgstr "Beh, si è fatta una certa ora.\r\nTorniamo al locale."

msgctxt "15||||4"
msgid "Oh, I love this song! <symbol=heart_with_outline>\r\nI want you to hear it. <symbol=note_with_outline>"
msgstr "Oh, adoro questa canzone! <symbol=heart_with_outline>\r\nVoglio fartela sentire. <symbol=note_with_outline>"

msgctxt "16||||4"
msgid "Cool, they have this song at karaoke? <symbol=note_with_outline>\r\nThat's the one I'm singing then."
msgstr "Forte, hanno questa canzone al karaoke? <symbol=note_with_outline>\r\nAllora canterò questa."

msgctxt "17||||4"
msgid "Hm... I'm having a hard time getting\r\nin the groove today..."
msgstr "Uhm... Faccio un po' fatica a prendere\r\nil ritmo, oggi..."

msgctxt "18||||4"
msgid "Kiryu-san! That's kinda distracting..."
msgstr "Kiryu-san! Mi distrai così..."

msgctxt "19||||4"
msgid "That was so fun!\r\nYou're great at getting the mood going. <symbol=heart_with_outline>"
msgstr "È stato divertentissimo!\r\nSei bravissimo a creare la giusta atmosfera. <symbol=heart_with_outline>"

msgctxt "20||||4"
msgid "I feel like I sang my heart out. <symbol=heart_with_outline>\r\nYou made me feel right at home. <symbol=note_with_outline>"
msgstr "Sento di aver cantato a squarciagola. <symbol=heart_with_outline>\r\nMi hai fatta sentire a casa. <symbol=note_with_outline>"

msgctxt "21||||4"
msgid "Hey, you're gonna sing something too, right? <symbol=note_with_outline>"
msgstr "Ehi, canterai qualcosa anche tu, vero? <symbol=note_with_outline>"

msgctxt "22||||4"
msgid "Aww... I wanted to hear what you sound like..."
msgstr "Aww... Volevo sentirti cantare..."

msgctxt "23||||4"
msgid "Um, well...\r\nI think I could tell what you were going for!"
msgstr "Uhm, beh...\r\nCredo di aver capito l'intenzione!"

msgctxt "24||||4"
msgid "You're a great singer! <symbol=note_with_outline>\r\nYou had me swept up in your voice."
msgstr "Sei un cantante fantastico! <symbol=note_with_outline>\r\nMi sono lasciata trasportare dalla tua voce."

msgctxt "25||||4"
msgid "How did you become such a good singer!?\r\nI just want to listen to you forever... <symbol=heart_with_outline>"
msgstr "Come fai a cantare così bene!?\r\nVorrei ascoltarti per sempre... <symbol=heart_with_outline>"

msgctxt "26||||4"
msgid "Huh? Really!?\r\nYou've got deep pockets. <symbol=heart_with_outline>"
msgstr "Eh? Davvero!?\r\nNon badi a spese. <symbol=heart_with_outline>"

msgctxt "27||||4"
msgid "Thank you."
msgstr "Grazie."

msgctxt "28||||4"
msgid "Huh?"
msgstr "Eh?"

msgctxt "29||||4"
msgid "Oh, that one's really good. <symbol=note_with_outline>\r\nI like it, too. <symbol=note_with_outline>"
msgstr "Oh, questa è bellissima. <symbol=note_with_outline>\r\nPiace molto anche a me. <symbol=note_with_outline>"

msgctxt "30||||4"
msgid "Excuse me."
msgstr "Permesso."

msgctxt "31||||4"
msgid "Nice to meet you.\r\nI'm Saki."
msgstr "Piacere di conoscerti.\r\nSono Saki."

msgctxt "32||||4"
msgid "Fun fact, I'm actually a pro wrestler."
msgstr "Curiosità: in realtà sono una wrestler professionista."

msgctxt "33||||4"
msgid "Huh. That's unusual.\r\nThis should be fun."
msgstr "Mh. Insolito.\r\nSarà divertente."

msgctxt "34||||4"
msgid "I'm glad to hear you say that.\r\nUm, can I ask what your name is?"
msgstr "Mi fa piacere sentirtelo dire.\r\nUhm, posso chiederti come ti chiami?"

msgctxt "35||||4"
msgid "Yeah. Kazuma Kiryu."
msgstr "Sì. Kazuma Kiryu."

msgctxt "36||||4"
msgid "Kiryu-san, then!\r\nLet's have some fun today then, hm? <symbol=note_with_outline>"
msgstr "Kiryu-san, allora!\r\nDivertiamoci un po' oggi, eh? <symbol=note_with_outline>"

msgctxt "37||||4"
msgid "Thanks for requesting me today. <symbol=heart_with_outline>\r\nThink you'll come back again...?"
msgstr "Grazie per avermi richiesta oggi. <symbol=heart_with_outline>\r\nPensi che tornerai ancora...?"

msgctxt "38||||4"
msgid "Yeah, I had a good time."
msgstr "Sì, mi sono divertito."

msgctxt "39||||4"
msgid "I'm happy to hear that."
msgstr "Sono felice di sentirtelo dire."

msgctxt "40||||4"
msgid "Kiryu-san, I'm glad you came back."
msgstr "Kiryu-san, sono felice che tu sia tornato."

msgctxt "41||||4"
msgid "Kiryu-san, I've been waiting for you. <symbol=note_with_outline>"
msgstr "Kiryu-san, ti stavo aspettando. <symbol=note_with_outline>"

msgctxt "42||||4"
msgid "Kiryu-san, I've been hoping you'd\r\nshow up... <symbol=heart_with_outline>"
msgstr "Kiryu-san, speravo proprio che ti\r\nfacessi vivo... <symbol=heart_with_outline>"

msgctxt "43||||4"
msgid "I'm glad we got to spend more time together\r\nthan usual today. <symbol=heart_with_outline>"
msgstr "Sono felice di aver passato più tempo\r\ndel solito con te, oggi. <symbol=heart_with_outline>"

msgctxt "44||||4"
msgid "Come on in."
msgstr "Vieni pure."

msgctxt "45||||4"
msgid "Kiryu-san!"
msgstr "Kiryu-san!"

msgctxt "46||||4"
msgid "Thanks for coming today.\r\nHope to see you again."
msgstr "Grazie per essere venuto oggi.\r\nSpero di rivederti."

msgctxt "47||||4"
msgid "Thanks for coming today. <symbol=note_with_outline>\r\nYou'd better come back, okay? <symbol=heart_with_outline>"
msgstr "Grazie per essere venuto oggi. <symbol=note_with_outline>\r\nVedi di tornare, okay? <symbol=heart_with_outline>"

msgctxt "48||||4"
msgid "Thank you, Kiryu-san. <symbol=note_with_outline>\r\nI want to see you again soon... <symbol=heart_with_outline>"
msgstr "Grazie, Kiryu-san. <symbol=note_with_outline>\r\nVoglio rivederti presto... <symbol=heart_with_outline>"

msgctxt "49||||4"
msgid "I'll see you later, Kiryu-san. <symbol=heart_with_outline>"
msgstr "Ci vediamo, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "50||||4"
msgid "Cheers!"
msgstr "Salute!"

msgctxt "51||||4"
msgid "Oh, Kiryu-san.\r\nDo you have a sec?"
msgstr "Oh, Kiryu-san.\r\nHai un secondo?"

msgctxt "52||||4"
msgid "Here's my number.\r\nI expect you to invite me out sometime, okay? <symbol=heart_with_outline>"
msgstr "Questo è il mio numero.\r\nMi aspetto che mi inviti a uscire qualche volta, okay? <symbol=heart_with_outline>"

msgctxt "53||||4"
msgid "It's almost time.\r\nWhat do you wanna do?"
msgstr "È quasi ora.\r\nChe vuoi fare?"

msgctxt "54||||4"
msgid "Time's up...\r\nThat really flew by."
msgstr "Il tempo è scaduto...\r\nÈ letteralmente volato."

msgctxt "55||||4"
msgid "Yay! I knew I could count on you, Kiryu-san. <symbol=heart_with_outline>"
msgstr "Evviva! Sapevo di poter contare su di te, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "56||||4"
msgid "Thanks a lot for today."
msgstr "Grazie mille per oggi."

msgctxt "57||||4"
msgid "Oh, that's true!"
msgstr "Oh, è vero!"

msgctxt "58||||4"
msgid "Yeah, I totally know what you mean!"
msgstr "Sì, so perfettamente cosa intendi!"

msgctxt "59||||4"
msgid "No doubt about it."
msgstr "Non c'è dubbio."

msgctxt "60||||4"
msgid "I agree!\r\nI feel the same way."
msgstr "Sono d'accordo!\r\nLa penso allo stesso modo."

msgctxt "61||||4"
msgid "Huh? I don't think so."
msgstr "Eh? Non credo."

msgctxt "62||||4"
msgid "Hmm... Really?"
msgstr "Mhm... Davvero?"

msgctxt "63||||4"
msgid "I don't think so..."
msgstr "Non credo..."

msgctxt "64||||4"
msgid "Sorry, I don't really get it."
msgstr "Scusa, non capisco cosa intendi."

msgctxt "65||||4"
msgid "Geez, what are you saying, Kiryu-san?"
msgstr "Cavoli, ma che vai dicendo, Kiryu-san?"

msgctxt "66||||4"
msgid "Yeah, that's right. <symbol=note_with_outline>"
msgstr "Sì, esatto. <symbol=note_with_outline>"

msgctxt "67||||4"
msgid "Wow, really?"
msgstr "Wow, davvero?"

msgctxt "68||||4"
msgid "I wonder..."
msgstr "Chissà..."

msgctxt "69||||4"
msgid "I have to say, it's rare for someone\r\nto be both a hostess and a pro wrestler."
msgstr "Devo dire che è raro che qualcuno\r\nsia sia una hostess che una wrestler."

msgctxt "70||||4"
msgid "Yeah, that's what everyone says."
msgstr "Già, lo dicono tutti."

msgctxt "71||||4"
msgid "How do you feel about that?"
msgstr "E tu come ti senti al riguardo?"

msgctxt "72||||4"
msgid "Guys request me for the novelty of it, but the\r\nreaction's not great if they wanted a \"traditional\" girl."
msgstr "I ragazzi mi scelgono per la novità, ma non la\r\nprendono bene se volevano una ragazza \"tradizionale\"."

msgctxt "73||||4"
msgid "Kinda makes me wonder... should I try to act\r\nmore feminine so I can be more popular?"
msgstr "Mi viene da chiedermi... dovrei provare a essere\r\npiù femminile per essere più popolare?"

msgctxt "74||||4"
msgid "You are who you are, right?"
msgstr "Tu sei quella che sei, no?"

msgctxt "75||||4"
msgid "Huh...?"
msgstr "Eh...?"

msgctxt "76||||4"
msgid "You shouldn't have to hide who you really are.\r\nYour physique sets you apart, as far as I'm concerned."
msgstr "Non dovresti nascondere la tua vera natura.\r\nIl tuo fisico ti distingue dalla massa, per me."

msgctxt "77||||4"
msgid "Kiryu-san..."
msgstr "Kiryu-san..."

msgctxt "78||||4"
msgid "Kiryu-san... Y-You're right!\r\nI was getting kinda self-conscious."
msgstr "Kiryu-san... H-Hai ragione!\r\nMi stavo facendo troppi complessi."

msgctxt "79||||4"
msgid "You sound more optimistic already."
msgstr "Sembri già più ottimista."

msgctxt "80||||4"
msgid "Yeah! I'll aim for the number one\r\nspot in my own way!"
msgstr "Sì! Punterò al primo\r\nposto a modo mio!"

msgctxt "81||||4"
msgid "Yeah, and I'll support you however I can."
msgstr "Già, e io ti sosterrò come posso."

msgctxt "82||||4"
msgid "Well, you are kind of manly."
msgstr "Beh, hai un fare un po' mascolino."

msgctxt "83||||4"
msgid "You're right... but guys do say it\r\nmakes me easier to talk to, though."
msgstr "Hai ragione... però i ragazzi dicono che\r\nquesto mi rende una persona alla mano."

msgctxt "84||||4"
msgid "Then, why not use that to your advantage?\r\nYou just have to own it and stay optimistic."
msgstr "Allora, perché non sfruttarlo a tuo vantaggio?\r\nDevi solo accettarlo e restare ottimista."

msgctxt "85||||4"
msgid "You're right. No point being indecisive!\r\nI'll try to be more optimistic!"
msgstr "Hai ragione. Inutile essere indecisi!\r\nCercherò di essere più ottimista!"

msgctxt "86||||4"
msgid "There you go.\r\nThat's a manly thing to say."
msgstr "Ecco fatto.\r\nQuesta sì che è una frase mascolina."

msgctxt "87||||4"
msgid "Come on, Kiryu-san.\r\nDon't tease me."
msgstr "Eddai, Kiryu-san.\r\nNon prendermi in giro."

msgctxt "88||||4"
msgid "I love... wrestling."
msgstr "Io amo... il wrestling."

msgctxt "89||||4"
msgid "What!? Pro wrestling?\r\nAren't you supposed to say you love me?"
msgstr "Cosa!? Il wrestling professionistico?\r\nNon dovresti dire che ami me?"

msgctxt "90||||4"
msgid "Just kidding. But I do think talking so\r\ncasually like this is part of your charm."
msgstr "Scherzavo. Ma penso che parlare in modo\r\ncosì disinvolto faccia parte del tuo fascino."

msgctxt "91||||4"
msgid "Kiryu-san... That's true.\r\nI do have my own way of doing things."
msgstr "Kiryu-san... È vero.\r\nHo un mio modo di fare le cose."

msgctxt "92||||4"
msgid "I'm feeling more optimistic now!\r\nThank you, Kiryu-san."
msgstr "Ora mi sento più ottimista!\r\nGrazie, Kiryu-san."

msgctxt "93||||4"
msgid "No problem. Good luck."
msgstr "Non c'è di che. Buona fortuna."

msgctxt "94||||4"
msgid "By the way, Saki, why'd you go into pro\r\nwrestling? What was your motivation?"
msgstr "Comunque, Saki, perché hai iniziato col\r\nwrestling? Qual è stata la tua motivazione?"

msgctxt "95||||4"
msgid "Actually I wasn't interested at all at first,\r\nbut the more I did it, the more I fell in love."
msgstr "A dire il vero all'inizio non m'interessava, ma\r\npiù ci provavo, più me ne innamoravo."

msgctxt "96||||4"
msgid "Before I realized it, going pro had its hooks\r\nin me. I've been working hard at it ever since!"
msgstr "Prima che me ne rendessi conto, l'idea di diventare pro\r\nmi aveva catturata. Da allora ci do dentro di brutto!"

msgctxt "97||||4"
msgid "There were some bumps in the road, but I managed\r\nto make connections and now I'm a pro wrestler."
msgstr "Ci sono stati un po' di ostacoli, ma sono riuscita a\r\nfarmi le giuste conoscenze e ora sono una wrestler."

msgctxt "98||||4"
msgid "Huh. So you didn't like it at the start."
msgstr "Mh. Quindi non ti piaceva, all'inizio."

msgctxt "99||||4"
msgid "Right. But I saw this match that really moved me.\r\nIt's like that match gave me a purpose in life."
msgstr "Esatto. Ma ho visto un match che mi ha commossa.\r\nÈ come se avesse dato uno scopo alla mia vita."

msgctxt "100||||4"
msgid "When I saw that, I decided I wanted to be able\r\nto move people in the same way."
msgstr "Quando l'ho visto, ho deciso che volevo\r\nessere in grado di emozionare le persone allo stesso modo."

msgctxt "101||||4"
msgid "That's great.\r\nI'd like to see if you stir my emotions, too."
msgstr "È fantastico.\r\nMi chiedo se riusciresti a far emozionare anche me."

msgctxt "102||||4"
msgid "Kiryu-san, you've got it. I'll work at it\r\nuntil I've met your expectations!"
msgstr "Kiryu-san, conta pure su di me. M'impegnerò al\r\nmassimo finché non sarò all'altezza delle tue aspettative!"

msgctxt "103||||4"
msgid "Someday maybe I'll let you\r\ntouch my championship belt."
msgstr "Un giorno potrei persino farti\r\ntoccare la mia cintura da campionessa."

msgctxt "104||||4"
msgid "Looking forward to it."
msgstr "Non vedo l'ora."

msgctxt "105||||4"
msgid "I'd like to move you, too."
msgstr "Piacerebbe anche a me farti emozionare."

msgctxt "106||||4"
msgid "Huh? Are you going to take up pro wrestling, too?\r\nYou do look capable enough..."
msgstr "Eh? Vuoi darti al wrestling anche tu?\r\nSembri avere il fisico adatto..."

msgctxt "107||||4"
msgid "No, you just looked so happy talking about your\r\ndreams. It made me feel like I have to keep up."
msgstr "No, è solo che sembravi così felice parlando dei tuoi\r\nsogni. Mi hai fatto sentire in dovere di non essere da meno."

msgctxt "108||||4"
msgid "In that sense...\r\nmaybe you've already moved me."
msgstr "In questo senso...\r\nforse mi hai già fatto emozionare."

msgctxt "109||||4"
msgid "Kiryu-san... That makes me so happy.\r\nI hope I can really stir your emotions someday!"
msgstr "Kiryu-san... Mi rende davvero felice.\r\nSpero di poterti emozionare per davvero, un giorno!"

msgctxt "110||||4"
msgid "Do one of your moves on me!"
msgstr "Fammi una delle tue mosse!"

msgctxt "111||||4"
msgid "Huh? Where'd that come from, Kiryu-san?"
msgstr "Eh? Da dove ti è uscita questa, Kiryu-san?"

msgctxt "112||||4"
msgid "Well, I just thought I'd get a taste of what you\r\nfelt if you did one of your moves on me."
msgstr "Beh, ho solo pensato che mi avrebbe fatto capire cosa hai\r\nprovato tu, se mi avessi fatto una delle tue mosse."

msgctxt "113||||4"
msgid "All you'd get from that is sore.\r\nIf you wanna be moved, come see a match sometime."
msgstr "Tutto quello che capiresti è solo il dolore.\r\nSe vuoi emozionarti, vieni a vedere un incontro, prima o poi."

msgctxt "114||||4"
msgid "Okay.\r\nLooking forward to it."
msgstr "D'accordo.\r\nNon vedo l'ora."

msgctxt "115||||4"
msgid "So now I know why you became a pro wrestler,\r\nbut what made you decide to become a hostess?"
msgstr "Ora so perché sei diventata una wrestler,\r\nma cosa ti ha spinto a fare la hostess?"

msgctxt "116||||4"
msgid "I'm a tomboy and I'm a pro wrestler on top of it,\r\nso I wanted to become more feminine."
msgstr "Sono un maschiaccio e per di più una wrestler,\r\nquindi volevo diventare più femminile."

msgctxt "117||||4"
msgid "I thought being a hostess might help me polish\r\nthat aspect of myself. Also... well, the money."
msgstr "Ho pensato che fare la hostess mi avrebbe aiutato a\r\nmigliorare questo mio aspetto. E poi... beh, per i soldi."

msgctxt "118||||4"
msgid "Money?"
msgstr "Soldi?"

msgctxt "119||||4"
msgid "Yeah. The team I'm on isn't very big,\r\nso we're pretty poor, if I'm being honest."
msgstr "Già. Il team in cui sto non è molto grande,\r\nquindi, a dire il vero, siamo abbastanza poveri."

msgctxt "120||||4"
msgid "Even when I fight, the money isn't very good.\r\nA lot of us have part-time jobs on the side."
msgstr "Anche quando combatto, non si guadagna molto.\r\nMolte di noi hanno dei lavori part-time."

msgctxt "121||||4"
msgid "And when you get hurt you have to pay for the\r\ntreatment... the costs really add up."
msgstr "E se ti fai male devi pagarti\r\nle cure... le spese si sommano."

msgctxt "122||||4"
msgid "I see... Sounds like being a pro wrestler\r\ncan be kind of rough."
msgstr "Capisco... Sembra che fare la wrestler\r\npossa essere piuttosto dura."

msgctxt "123||||4"
msgid "It is. Someday I'd like to be able\r\nto focus on just wrestling, though."
msgstr "Lo è. Un giorno però vorrei essere\r\nin grado di potermi concentrare solo sul wrestling."

msgctxt "124||||4"
msgid "It's great that you want to focus on wrestling,\r\nbut... that wouldn't be great for me."
msgstr "È fantastico che tu voglia concentrarti sul wrestling,\r\nma... non sarebbe il massimo per me."

msgctxt "125||||4"
msgid "Huh? Why's that?"
msgstr "Eh? Perché?"

msgctxt "126||||4"
msgid "Because I wouldn't be able\r\nto see you anymore, of course."
msgstr "Perché non potrei\r\npiù vederti, ovviamente."

msgctxt "127||||4"
msgid "Kiryu-san...\r\nGosh, what are you saying?"
msgstr "Kiryu-san...\r\nOddio, ma che dici?"

msgctxt "128||||4"
msgid "But, you're right. I've actually met a lot of\r\npeople here that I've turned into wrestling fans."
msgstr "Però, hai ragione. Qui ho conosciuto un sacco di\r\npersone che ho trasformato in appassionati di wrestling."

msgctxt "129||||4"
msgid "I should continue working here and aim for the\r\ntop for their sake!"
msgstr "Dovrei continuare a lavorare qui e puntare\r\nalla vetta per il loro bene!"

msgctxt "130||||4"
msgid "Nice. Wouldn't it be even better to aim\r\nfor the top in both jobs?"
msgstr "Bello. Non sarebbe ancora meglio puntare\r\nalla vetta in entrambi i lavori?"

msgctxt "131||||4"
msgid "Totally. I'll aim for the champion's\r\nbelt in the cabaret trade, too!"
msgstr "Assolutamente. Punterò alla cintura\r\nda campionessa anche nel mondo dei cabaret club!"

msgctxt "132||||4"
msgid "What if I supported you?"
msgstr "E se ti mantenessi io?"

msgctxt "133||||4"
msgid "Really? That's so nice of you.\r\nBut, I'm happy enough that you offered."
msgstr "Davvero? È molto carino da parte tua.\r\nMa mi basta anche solo il pensiero."

msgctxt "134||||4"
msgid "I want to at least be able\r\nto support my own lifestyle."
msgstr "Voglio almeno essere in grado\r\ndi potermi mantenere da sola."

msgctxt "135||||4"
msgid "I don't feel like I could entertain an audience\r\nif I were living off someone else's money."
msgstr "Non credo che riuscirei a intrattenere un pubblico\r\nse vivessi con i soldi di qualcun altro."

msgctxt "136||||4"
msgid "I like that determination.\r\nYou're a real professional, Saki."
msgstr "Mi piace la tua determinazione.\r\nSei una vera professionista, Saki."

msgctxt "137||||4"
msgid "Thank you."
msgstr "Grazie."

msgctxt "138||||4"
msgid "But, when I retire from wrestling and run\r\nout of money, maybe I'll come knocking, huh?"
msgstr "Però, quando mi ritirerò dal wrestling e rimarrò a\r\nsecco di soldi, potrei venire a bussare alla tua porta, eh?"

msgctxt "139||||4"
msgid "I'll think about it."
msgstr "Ci penserò."

msgctxt "140||||4"
msgid "Then you should just marry me."
msgstr "Allora dovresti semplicemente sposarmi."

msgctxt "141||||4"
msgid "Huh!? Kiryu-san, where'd that come from!?"
msgstr "Eh!? Kiryu-san, da dove ti è uscita!?"

msgctxt "142||||4"
msgid "Well, if we got married,\r\nI could support you as family."
msgstr "Beh, se ci sposassimo,\r\npotrei mantenerti come parte della mia famiglia."

msgctxt "143||||4"
msgid "Oh, I see.\r\nI didn't think of it that way..."
msgstr "Oh, capisco.\r\nNon l'avevo vista in questo modo..."

msgctxt "144||||4"
msgid "But sheesh... That caught me off guard.\r\nMy heart's still racing..."
msgstr "Però cavoli... Mi hai presa alla sprovvista.\r\nMi batte ancora il cuore a mille..."

msgctxt "145||||4"
msgid "It was just a what-if.\r\nSorry to make you panic."
msgstr "Era solo un'ipotesi.\r\nScusa se ti ho fatto prendere un colpo."

msgctxt "146||||4"
msgid "No, this'll make a great fantasy...\r\nThanks for the idea!"
msgstr "No, questa sarà un'ottima fantasia...\r\nGrazie per l'idea!"

msgctxt "147||||4"
msgid "Ooh, that's pretty good, too..."
msgstr "Ooh, anche questa è niente male..."

msgctxt "148||||4"
msgid "What happened?\r\nYou're grinning ear to ear."
msgstr "Che ti succede?\r\nSorridi a trentadue denti."

msgctxt "149||||4"
msgid "Oh, sorry!\r\nI was off in fantasy land."
msgstr "Oh, scusa!\r\nEro persa nelle mie fantasie."

msgctxt "150||||4"
msgid "Ohhh. Hm?\r\nIs that your fantasy notebook there?"
msgstr "Ohhh. Uhm?\r\nÈ quello il tuo taccuino delle fantasie?"

msgctxt "151||||4"
msgid "Yeah, it is. I write down my fantasy scenarios\r\nso I can come back to them later."
msgstr "Sì, lo è. Ci scrivo i miei scenari di fantasia\r\ncosì da poterli rileggere in futuro."

msgctxt "152||||4"
msgid "So diligent.\r\nWhy would you need to, though?"
msgstr "Che dedizione.\r\nMa perché ne avresti bisogno?"

msgctxt "153||||4"
msgid "So I can reuse them. That way I can enjoy\r\nthe same fantasy as many times as I want."
msgstr "Per poterle riutilizzare. In questo modo posso godermi\r\nla stessa fantasia tutte le volte che voglio."

msgctxt "154||||4"
msgid "Wow... There's all sorts of stuff in here.\r\nHmm? \"Kiryu-san Scenarios\"...?"
msgstr "Wow... C'è un sacco di roba qui dentro.\r\nUhm? \"Scenari su Kiryu-san\"...?"

msgctxt "155||||4"
msgid "Waaahhhhh! You can't look at that one!\r\nGeez, don't even open that, please!"
msgstr "Waaahhhhh! Quello non puoi guardarlo!\r\nCavoli, non aprirlo nemmeno, ti prego!"

msgctxt "156||||4"
msgid "O-Oh. Sorry."
msgstr "O-Oh. Scusa."

msgctxt "157||||4"
msgid "I can't let my guard down for\r\na second around you. Too close!"
msgstr "Non posso abbassare la guardia per\r\nun secondo con te. Ci è mancato poco!"

msgctxt "158||||4"
msgid "Being around you makes me think\r\nfantasizing might be kind of fun."
msgstr "Stare con te mi fa pensare\r\nche fantasticare possa essere divertente."

msgctxt "159||||4"
msgid "It is fun! I recommend it.\r\nWhat do you say we give it a try!?"
msgstr "È divertente! Te lo consiglio.\r\nChe ne dici di fare una prova!?"

msgctxt "160||||4"
msgid "So, Kiryu-san, what kind of scenario\r\nwould you imagine me in?"
msgstr "Quindi, Kiryu-san, in che tipo di\r\nscenario mi immagineresti?"

msgctxt "161||||4"
msgid "A pro wrestler, I guess?"
msgstr "In quello di una wrestler, credo?"

msgctxt "162||||4"
msgid "That's what I already am.\r\nPut some imagination into it, please!"
msgstr "Ma lo sono già.\r\nMettici un po' di fantasia, per favore!"

msgctxt "163||||4"
msgid "Hm... This is pretty hard."
msgstr "Uhm... È piuttosto difficile."

msgctxt "164||||4"
msgid "Sometimes I do find myself in\r\nfantasies based on reality, though."
msgstr "A dire il vero a volte mi ritrovo in\r\nfantasie basate sulla realtà, però."

msgctxt "165||||4"
msgid "Like, you invite me out on a date after work,\r\nand then you surprise me with a bouquet..."
msgstr "Tipo che mi inviti a un appuntamento dopo il lavoro,\r\ne poi mi sorprendi con un mazzo di fiori..."

msgctxt "166||||4"
msgid "Hey, I thought I was supposed\r\nto be the one fantasizing."
msgstr "Ehi, pensavo che toccasse a\r\nme fantasticare."

msgctxt "167||||4"
msgid "My wife, I guess."
msgstr "Mia moglie, credo."

msgctxt "168||||4"
msgid "Wha!? Um...\r\nYou mean we'd be... married?"
msgstr "Cosa!? Uhm...\r\nIntendi che saremmo... sposati?"

msgctxt "169||||4"
msgid "Yeah. It's fun talking with you,\r\nso it's not hard to imagine us married."
msgstr "Già. È divertente parlare con te, quindi non\r\nè difficile immaginarci come marito e moglie."

msgctxt "170||||4"
msgid "Kiryu-san... Oh man, this is kind of\r\nembarrassing. But, I'm really happy..."
msgstr "Kiryu-san... Oh cavoli, è un po'\r\nimbarazzante. Ma sono davvero felice..."

msgctxt "171||||4"
msgid "You know, you don't have to let it end as a\r\nfantasy... We could make it a reality... Maybe?"
msgstr "Sai, non deve per forza finire come una\r\nfantasia... Potremmo trasformarla in realtà... Forse?"

msgctxt "172||||4"
msgid "Hm? What was that?"
msgstr "Uhm? Cos'hai detto?"

msgctxt "173||||4"
msgid "No-no-no-nope-nope-nope!\r\nThis is turning out to be a good day! <symbol=heart_with_outline>"
msgstr "No-no-no-niente-niente-niente!\r\nOggi è davvero una bella giornata! <symbol=heart_with_outline>"

msgctxt "174||||4"
msgid "My mom, I guess."
msgstr "Mia madre, immagino."

msgctxt "175||||4"
msgid "What!? You mean I would be your mom?"
msgstr "Cosa!? Vuoi dire che io sarei tua madre?"

msgctxt "176||||4"
msgid "Yeah. I feel like you'd do\r\na great job raising me."
msgstr "Sì. Sento che faresti un\r\nottimo lavoro nel crescermi."

msgctxt "177||||4"
msgid "Kiryu-san, what exactly do you see me as?"
msgstr "Kiryu-san, esattamente come mi vedi?"

msgctxt "178||||4"
msgid "Well, I can't deny it would be\r\npretty great living together with you."
msgstr "Beh, non posso negare che sarebbe\r\nmolto bello vivere insieme a te."

msgctxt "179||||4"
msgid "That does make me happy.\r\nBut, you should make me your wife, then."
msgstr "Questo mi rende felice.\r\nMa allora, dovresti farmi tua moglie."

msgctxt "180||||4"
msgid "Yeah, good point..."
msgstr "Sì, hai ragione..."

msgctxt "181||||4"
msgid "Today's been fun. Thanks."
msgstr "Oggi è stato divertente. Grazie."

msgctxt "182||||4"
msgid "No, I should be thanking you. <symbol=heart_with_outline>\r\nBy the way, I have a proposal..."
msgstr "No, sono io a dover ringraziare te. <symbol=heart_with_outline>\r\nA proposito, avrei una proposta..."

msgctxt "183||||4"
msgid "Hm? What's that?"
msgstr "Uhm? Di che si tratta?"

msgctxt "184||||4"
msgid "Um, are you free after this?\r\nI was wondering if you'd like to go on a date."
msgstr "Uhm, sei libero dopo?\r\nMi chiedevo se ti andasse di uscire con me."

msgctxt "185||||4"
msgid "I don't mind.\r\nYou're good to go?"
msgstr "Per me va bene.\r\nTu sei pronta per uscire?"

msgctxt "186||||4"
msgid "Of course! I'd follow you to the\r\nends of the Earth! All right! It's a promise!"
msgstr "Certo! Ti seguirei in capo\r\nal mondo! Va bene! È una promessa!"

msgctxt "187||||4"
msgid "You okay with meeting in\r\nfront of the Millennium Tower?"
msgstr "Ti va bene se ci vediamo di\r\nfronte alla Millennium Tower?"

msgctxt "188||||4"
msgid "I'll text you later."
msgstr "Ti mando un messaggio dopo."

msgctxt "189||||4"
msgid "Yeah. See you soon."
msgstr "Sì. A presto."

msgctxt "190||||4"
msgid "Okay! Oh, I can't wait!"
msgstr "Okay! Oh, non vedo l'ora!"

msgctxt "191||||4"
msgid "My hobbies?\r\nMaybeee... fantasizing?"
msgstr "I miei hobby?\r\nForseeee... fantasticare?"

msgctxt "192||||4"
msgid "F-Fantasizing?"
msgstr "F-Fantasticare?"

msgctxt "193||||4"
msgid "Yeah. I fantasize all the time! You know, like,\r\n\"What would it be like to date that guy?\""
msgstr "Già. Fantastico in continuazione! Sai, tipo:\r\n\"Come sarebbe uscire con quel ragazzo?\""

msgctxt "194||||4"
msgid "Then, I write it all down in a notebook so\r\nI can come back to it if I want to."
msgstr "Poi, mi scrivo tutto su un taccuino così\r\nposso rileggerlo quando mi va."

msgctxt "195||||4"
msgid "Sounds like a good read.\r\nCan I see the notebook?"
msgstr "Sembra una lettura interessante.\r\nPosso vederlo, questo taccuino?"

msgctxt "196||||4"
msgid "Whaaaat!? No way!\r\nI'd just die!"
msgstr "Cosaaaa!? Scordatelo!\r\nNe morirei d'imbarazzo!"

msgctxt "197||||4"
msgid "Aww, why not?"
msgstr "Aww, e perché no?"

msgctxt "198||||4"
msgid "Hmmm... Fine, how 'bout I choose some fantasies\r\nI'm okay with sharing and you can see those?"
msgstr "Mhmmm... Va bene, che ne dici se scelgo delle fantasie\r\nche mi va di condividere e tu leggi quelle?"

msgctxt "199||||4"
msgid "It'd be too embarrassing to show\r\nyou the low quality ones."
msgstr "Sarebbe troppo imbarazzante farti\r\nleggere quelle di bassa qualità."

msgctxt "200||||4"
msgid "S-Sure...\r\nThe mind of a pro is something else..."
msgstr "C-Certo...\r\nLa mente di una pro è un mondo a parte..."

msgctxt "201||||4"
msgid "You're not fantasizing about me, are you?"
msgstr "Non è che stai fantasticando su di me, vero?"

msgctxt "202||||4"
msgid "Doesn't being told not to do something just make\r\nyou want to do it more? What should I picture?"
msgstr "Non ti capita mai che, se ti dicono di non fare qualcosa,\r\nti viene ancora più voglia di farla? Cosa dovrei immaginarmi?"

msgctxt "203||||4"
msgid "Heeey..."
msgstr "Ehii..."

msgctxt "204||||4"
msgid "Think you could fit me\r\ninto one of your fantasies?"
msgstr "Pensi di potermi inserire\r\nin una delle tue fantasie?"

msgctxt "205||||4"
msgid "Sure! Kiryu-san...\r\nHmm, let's see here..."
msgstr "Certo! Kiryu-san...\r\nUhm, vediamo un po'..."

msgctxt "206||||4"
msgid "Kiryu-san is actually a firefighter...\r\nAnd after we start dating, there's a fire..."
msgstr "Kiryu-san in realtà è un vigile del fuoco...\r\nE dopo che iniziamo a frequentarci, scoppia un incendio..."

msgctxt "207||||4"
msgid "So he comes to save me, but...\r\nNaaaw, this is getting too clichéd."
msgstr "Così lui arriva per salvarmi, ma...\r\nNaaah, sta diventando troppo da cliché."

msgctxt "208||||4"
msgid "Aww..."
msgstr "Aww..."

msgctxt "209||||4"
msgid "I let myself get some sleep on my days off!\r\nAnd maybe fit in some online shopping?"
msgstr "Cerco di recuperare il sonno nei miei giorni liberi!\r\nE magari di farci stare un po' di shopping online?"

msgctxt "210||||4"
msgid "My job takes a lot out of me physically, so on\r\nmy days off, I just want to veg."
msgstr "Il mio lavoro mi sfinisce fisicamente, quindi nei\r\nmiei giorni liberi voglio solo poltrire."

msgctxt "211||||4"
msgid "Not too long, actually.\r\nThere's still a lot I'm not used to."
msgstr "Non da molto, in realtà.\r\nCi sono ancora tante cose a cui non mi sono abituata."

msgctxt "212||||4"
msgid "I want to pick up the pace a little\r\nand figure out how to be a little more girly."
msgstr "Voglio prendere un po' il ritmo\r\ne capire come essere un po' più femminile."

msgctxt "213||||4"
msgid "Based on the slight accent... Kyoto?"
msgstr "A giudicare da quel leggero accento... Kyoto?"

msgctxt "214||||4"
msgid "Wow, good guess, Kiryu-san!\r\nI <font_kind=yakuza_italic>am</font_kind> from Kyoto."
msgstr "Wow, ci hai azzeccato, Kiryu-san!\r\nSono <font_kind=yakuza_italic>davvero</font_kind> di Kyoto."

msgctxt "215||||4"
msgid "Monkfish liver, I guess.\r\nAnything that goes down well with booze."
msgstr "Fegato di coda di rospo, immagino.\r\nQualsiasi cosa vada giù bene con l'alcol."

msgctxt "216||||4"
msgid "I'm glad you asked!\r\nI like my men like I like my gorillas!"
msgstr "Sono felice che tu me l'abbia chiesto!\r\nMi piacciono i miei uomini così come mi piacciono i miei gorilla!"

msgctxt "217||||4"
msgid "G-Gorillas?"
msgstr "G-Gorilla?"

msgctxt "218||||4"
msgid "You mean, manly and rugged like a gorilla?"
msgstr "Intendi mascolino e rude come un gorilla?"

msgctxt "219||||4"
msgid "Exactly, rugged is a good word for it.\r\nAnd gorillas have the kindest faces, right?"
msgstr "Esatto, rude calza a pennello.\r\nE i gorilla hanno dei visi dolcissimi, giusto?"

msgctxt "220||||4"
msgid "A gorilla, huh?\r\nSo, someone like me?"
msgstr "Un gorilla, eh?\r\nQuindi, uno come me?"

msgctxt "221||||4"
msgid "You <font_kind=yakuza_italic>may</font_kind> be just rugged enough\r\nto qualify as a gorilla, Kiryu-san!"
msgstr "Tu <font_kind=yakuza_italic>potresti</font_kind> essere abbastanza rude\r\nda poterti qualificare come un gorilla, Kiryu-san!"

msgctxt "222||||4"
msgid "But you're like... a pure, refined,\r\nurban gorilla, or something. In a good way?"
msgstr "Ma tu sei tipo... un puro, raffinato\r\ngorilla urbano, o una roba simile. In senso buono?"

msgctxt "223||||4"
msgid "An urban gorilla...\r\nI don't know how to feel about that."
msgstr "Un gorilla urbano...\r\nNon so come prenderla."

msgctxt "224||||4"
msgid "Ook ook..."
msgstr "Uu-uu ah-ah..."

msgctxt "225||||4"
msgid "Kiryu-san...!"
msgstr "Kiryu-san...!"

msgctxt "226||||4"
msgid "Never mind.\r\nForget I ever did that."
msgstr "Lascia perdere.\r\nDimentica di averlo mai sentito."

msgctxt "227||||4"
msgid "But that was pretty funny, Kiryu-san!\r\nYou're a riot!"
msgstr "Ma è stato piuttosto divertente, Kiryu-san!\r\nSei uno spasso!"

msgctxt "228||||4"
msgid "When I fall in love, I want to do anything I can\r\nfor that person. I'd even cook for him every day."
msgstr "Quando mi innamoro, voglio fare tutto il possibile per\r\nquella persona. Cucinerei persino per lui ogni giorno."

msgctxt "229||||4"
msgid "But when I say that kind of stuff, people tell\r\nme it's kind of out of character for me."
msgstr "Ma quando dico cose del genere, le persone mi dicono\r\nche è una cosa poco da me."

msgctxt "230||||4"
msgid "I don't think that's true. On the inside,\r\nmaybe you're girlier than you think."
msgstr "Non credo sia vero. Sotto sotto,\r\nforse sei più femminile di quanto credi."

msgctxt "231||||4"
msgid "Huh? You think so? You're the only person\r\nwho's ever told me that. I'm all happy now."
msgstr "Eh? Pensi davvero? Sei l'unica persona che mi\r\nabbia mai detto una cosa simile. Ne sono felicissima."

msgctxt "232||||4"
msgid "As a pro wrestler, only being the best.\r\nIn my private life, getting married, I guess?"
msgstr "Come wrestler, solo essere la migliore.\r\nNella mia vita privata, sposarmi, immagino."

msgctxt "233||||4"
msgid "You wouldn't know to look at me, but I'm a great\r\ncook, and I'd be such a devoted, great wife to my husband!"
msgstr "Non si direbbe a guardarmi, ma sono un'ottima cuoca, e\r\nsarei una moglie perfetta e devota per mio marito!"

msgctxt "234||||4"
msgid "You're sure of yourself, huh?"
msgstr "Sei molto sicura di te, eh?"

msgctxt "235||||4"
msgid "Sometimes you've gotta make a case for yourself,\r\ny'know? You mull it over, Kiryu-san. Sound good?"
msgstr "A volte bisogna farsi un po' di pubblicità,\r\nsai? Pensaci su, Kiryu-san. Ti va bene?"

msgctxt "236||||4"
msgid "My parents were both into martial arts,\r\nso I always dreamed of being some kind of fighter."
msgstr "I miei genitori praticavano entrambi arti marziali,\r\nquindi ho sempre sognato di fare la lottatrice."

msgctxt "237||||4"
msgid "Honestly though, I never thought I'd become a pro\r\nwrestler. Life has a strange way of working out."
msgstr "Onestamente però, non avrei mai pensato di diventare\r\nuna wrestler. La vita prende strane pieghe, a volte."

msgctxt "238||||4"
msgid "Special skills?\r\nHmmmmm.... I s'pose I'm a pretty good cook."
msgstr "Abilità speciali?\r\nMhmmmm.... Suppongo di essere una brava cuoca."

msgctxt "239||||4"
msgid "Other than that...\r\nhigh kicks and sleeper holds?"
msgstr "A parte quello...\r\ncalci alti e mosse di sottomissione?"

msgctxt "240||||4"
msgid "Those are more techniques than skills..."
msgstr "Più che abilità, sono tecniche..."

msgctxt "241||||4"
msgid "True! Oh, speaking of special techniques,\r\nI have a few original ones, you know."
msgstr "Vero! Oh, a proposito di mosse speciali,\r\nne ho un paio inventate da me, sai."

msgctxt "242||||4"
msgid "Yeah? What are they called?"
msgstr "Ah sì? Come si chiamano?"

msgctxt "243||||4"
msgid "Oh, whatever could they be?\r\nHere's a hint: \"Blank Galaxy.\""
msgstr "Oh, cosa mai potranno essere?\r\nEcco un indizio: \"Galaxy e qualcosa.\""

msgctxt "244||||4"
msgid "Salaryman Galaxy!\r\nIs that right?"
msgstr "Salaryman Galaxy!\r\nGiusto?"

msgctxt "245||||4"
msgid "Huh!? How did you know!? That's amazing!\r\nAre you a mind-reader?"
msgstr "Eh!? Come facevi a saperlo!? Incredibile!\r\nMi leggi nel pensiero per caso?"

msgctxt "246||||4"
msgid "Nah, but maybe I'd heard it somewhere."
msgstr "Nah, ma forse l'avevo sentito da qualche parte."

msgctxt "247||||4"
msgid "Whoa. Does that mean I'm actually getting famous?\r\nThat's the best news! <symbol=note_with_outline>"
msgstr "Whoa. Vuol dire che sto diventando famosa?\r\nÈ una notizia fantastica! <symbol=note_with_outline>"

msgctxt "248||||4"
msgid "Lover Love Galaxy!\r\nIs that right?"
msgstr "Lover Love Galaxy!\r\nGiusto?"

msgctxt "249||||4"
msgid "Bzzzt!\r\nThe right answer was \"Salaryman Galaxy\"!"
msgstr "Bzzzt!\r\nLa risposta corretta era \"Salaryman Galaxy\"!"

msgctxt "250||||4"
msgid "How was I supposed to guess that...?"
msgstr "Come avrei dovuto indovinarlo...?"

msgctxt "251||||4"
msgid "But \"Lover Love Galaxy\" is kind of cute.\r\nMaybe that's what I'll call my next one..."
msgstr "Ma \"Lover Love Galaxy\" è piuttosto carino.\r\nForse la mia prossima mossa la chiamerò così..."

msgctxt "252||||4"
msgid "Nah, it's too embarrassing.\r\nForget it..."
msgstr "Nah, è troppo imbarazzante.\r\nLascia perdere..."

msgctxt "253||||4"
msgid "Cinderella Galaxy!\r\nIs that right?"
msgstr "Cinderella Galaxy!\r\nGiusto?"

msgctxt "254||||4"
msgid "Whoa! Isn't that some old song? And it's wrong,\r\nanyway! The right answer was \"Salaryman Galaxy\"!"
msgstr "Whoa! Non è una vecchia canzone? Ed è sbagliata,\r\ncomunque! La risposta corretta era \"Salaryman Galaxy\"!"

msgctxt "255||||4"
msgid "I never would have gotten that..."
msgstr "Non ci sarei mai arrivato..."

msgctxt "256||||4"
msgid "Something interesting...\r\nHmmm... Meeting you, Kiryu-san?"
msgstr "Qualcosa di interessante...\r\nMhmmm... L'averti incontrato, Kiryu-san?"

msgctxt "257||||4"
msgid "Am I that interesting?"
msgstr "Sono così interessante?"

msgctxt "258||||4"
msgid "Kiryu-san, you're super interesting.\r\nMaybe you just don't know it?"
msgstr "Kiryu-san, sei super interessante.\r\nForse non ne sei consapevole?"

msgctxt "259||||4"
msgid "Not too many.\r\nI have a few good friends, though."
msgstr "Non moltissimi.\r\nPerò ho qualche caro amico."

msgctxt "260||||4"
msgid "Huh, I see.\r\nYou seem like the type to have a lot."
msgstr "Mh, capisco.\r\nSembri il tipo da averne molti."

msgctxt "261||||4"
msgid "You know how girls tend to hang out in packs?\r\nI've never really liked that."
msgstr "Sai come le ragazze tendono a uscire in branco?\r\nA me non è mai piaciuto molto."

msgctxt "262||||4"
msgid "Maybe that part of me's kinda boyish.\r\nBut once I fall in love, I'm all woman. <symbol=heart_with_outline>"
msgstr "Forse questo mio lato è un po' da maschiaccio.\r\nMa quando mi innamoro, sono tutta donna. <symbol=heart_with_outline>"

msgctxt "263||||4"
msgid "Makes sense. I think guys tend\r\nto like dating girls like that."
msgstr "Ha senso. Penso che ai ragazzi tenda\r\na piacere uscire con ragazze così."

msgctxt "264||||4"
msgid "That's good. Pro wrestling is dominated by men.\r\nMaybe that's a good fit for me, in that sense."
msgstr "Meno male. Il wrestling è dominato dagli uomini.\r\nForse è un ambiente che mi si addice, in un certo senso."

msgctxt "265||||4"
msgid "I totally suck at games. But I like watching\r\nsometimes. I'd watch you play, Kiryu-san."
msgstr "Faccio davvero pena coi videogiochi. Ma a volte mi\r\npiace guardare. Ti guarderei volentieri giocare, Kiryu-san."

msgctxt "266||||4"
msgid "Hm? What's this then?\r\nWhat are these deep, dark secrets?"
msgstr "Uhm? E questo cos'è, allora?\r\nQuali sono questi oscuri, inconfessabili segreti?"

msgctxt "267||||4"
msgid "I was actually a wrestler myself at one\r\ntime called \"Dragon Mask.\""
msgstr "Un tempo ero anche io un wrestler\r\nchiamato \"Dragon Mask\"."

msgctxt "268||||4"
msgid "What!? Are you serious?"
msgstr "Cosa!? Dici sul serio?"

msgctxt "269||||4"
msgid "I only did it to entertain some kids, though."
msgstr "L'ho fatto solo per far divertire dei bambini, però."

msgctxt "270||||4"
msgid "It's actually kind of hard to have a serious\r\nfight while trying to entertain an audience."
msgstr "In effetti è piuttosto difficile combattere sul serio\r\nmentre cerchi di intrattenere un pubblico."

msgctxt "271||||4"
msgid "Yeah. You can't be just strong. You have to\r\nfight in a way the audience wants to watch."
msgstr "Già. Non basta essere solo forte. Devi combattere\r\nin un modo che il pubblico abbia voglia di guardare."

msgctxt "272||||4"
msgid "It made me realize how deep pro wrestling is.\r\nIn fact, I found a new respect for pros like you."
msgstr "Mi ha fatto capire quanto sia profondo il wrestling. Infatti,\r\nora ho un rispetto nuovo per i professionisti come te."

msgctxt "273||||4"
msgid "Kiryu-san... Thank you.\r\nYou're too nice to me."
msgstr "Kiryu-san... Grazie.\r\nSei troppo gentile con me."

msgctxt "274||||4"
msgid "Huh!? You have a tattoo, Kiryu-san!?\r\nI wanna see! Tear your shirt off, right now!"
msgstr "Eh!? Hai un tatuaggio, Kiryu-san!?\r\nVoglio vederlo! Strappati la camicia, ora!"

msgctxt "275||||4"
msgid "U-Uh... I can't do that in here..."
msgstr "E-Ehm... Non posso farlo qui dentro..."

msgctxt "276||||4"
msgid "Alcohol? I love a good drink!"
msgstr "Alcol? Adoro una bella bevuta!"

msgctxt "277||||4"
msgid "As favorites go, it's shochu and sake...\r\nBut pretty much anything goes!"
msgstr "Le mie preferite sono lo shochu e il sake...\r\nMa mi bevo praticamente di tutto!"

msgctxt "278||||4"
msgid "Then we should drink the place dry."
msgstr "Allora dovremmo prosciugare questo locale."

msgctxt "279||||4"
msgid "Totally! Let's really crank up the fun.\r\nBesides, if sales go up, so does my rank!"
msgstr "Assolutamente! Facciamo decollare il divertimento.\r\nE poi, se salgono le vendite, sale anche il mio rango!"

msgctxt "280||||4"
msgid "You're pretty clever."
msgstr "Sei piuttosto furba."

msgctxt "281||||4"
msgid "I'm just joking.\r\nBut I'm plenty serious about the fun part. <symbol=note_with_outline>"
msgstr "Stavo solo scherzando.\r\nMa sono serissima sulla parte del divertimento. <symbol=note_with_outline>"

msgctxt "282||||4"
msgid "Wow. It's unusual for someone your age to get\r\ninto the hard liquor."
msgstr "Wow. È insolito per una della tua età darsi\r\nai superalcolici."

msgctxt "283||||4"
msgid "I know, right? But I like how they're meant to\r\nbe savored, and they go great with snacks."
msgstr "Vero? Ma mi piace come siano fatti per essere\r\nassaporati, e stanno benissimo con gli stuzzichini."

msgctxt "284||||4"
msgid "You know the right way to enjoy a drink.\r\nAnd I'll drink to that."
msgstr "Sai il modo giusto per goderti un drink.\r\nE io bevo a questo."

msgctxt "285||||4"
msgid "Oh, sounds good!\r\nI'll join you!"
msgstr "Oh, mi sembra perfetto!\r\nMi unisco a te!"

msgctxt "286||||4"
msgid "Nice, then... I'll have a water!"
msgstr "Ottimo, allora... Io prenderò dell'acqua!"

msgctxt "287||||4"
msgid "What the<symbol=em_dash_with_outline> You can't just do that!"
msgstr "Ma che<symbol=em_dash_with_outline> Non puoi fare così!"

msgctxt "288||||4"
msgid "I'm joking."
msgstr "Sto scherzando."

msgctxt "289||||4"
msgid "Oh, Kiryu-san's apparently a comedian...\r\nYou're real funny..."
msgstr "Oh, a quanto pare Kiryu-san è un comico...\r\nSei molto divertente..."

msgctxt "290||||4"
msgid "The Tojo... Clan?\r\nWasn't that the name of a pro wrestling team?"
msgstr "Il Clan... Tojo?\r\nNon era il nome di un team di wrestling?"

msgctxt "291||||4"
msgid "No, it's not a wrestling team... Though they\r\nsure do get into about as many brawls..."
msgstr "No, non è un team di wrestling... Però di certo\r\nsi ritrovano in un sacco di risse..."

msgctxt "292||||4"
msgid "Oh, I know her!\r\nShe was on TV a while back, right?"
msgstr "Oh, la conosco!\r\nEra in TV un po' di tempo fa, giusto?"

msgctxt "293||||4"
msgid "If I recall, she did a concert with another\r\ngroup called T-Back..."
msgstr "Se non sbaglio, aveva fatto un concerto\r\ncon un altro gruppo chiamato T-Back..."

msgctxt "294||||4"
msgid "...Pretty sure it was T-Set."
msgstr "...Sono abbastanza sicuro fossero le T-Set."

msgctxt "295||||4"
msgid "Oh man, I'd love to hear about\r\nyour crazy adventures, Kiryu-san!"
msgstr "Oh cavoli, mi piacerebbe tantissimo sentire\r\ndelle tue folli avventure, Kiryu-san!"

msgctxt "296||||4"
msgid "They weren't that crazy...\r\nAnd they'll take a while to explain..."
msgstr "Non sono state così folli...\r\nE ci vorrebbe un po' per spiegartele..."

msgctxt "297||||4"
msgid "Oh, long story?\r\nThat's okay, forget it then!"
msgstr "Oh, è una storia lunga?\r\nFa niente, allora lascia perdere!"

msgctxt "298||||4"
msgid "Hey now..."
msgstr "Ehi, aspetta..."

msgctxt "299||||4"
msgid "I'm sure I don't look the part, but I cook a lot.\r\nI'm pretty good at making stews."
msgstr "So che non sembro il tipo, ma cucino molto.\r\nMe la cavo piuttosto bene con gli stufati."

msgctxt "300||||4"
msgid "I'm good at stuff like stews and hot pots."
msgstr "Sono brava in cose tipo gli stufati e piatti caldi."

msgctxt "301||||4"
msgid "Those sound great. Now that I think about it,\r\nI haven't had hot pot in a long time."
msgstr "Sembrano deliziosi. Ora che ci penso,\r\nè da un bel po' che non mangio un piatto caldo."

msgctxt "302||||4"
msgid "Yeah, it's not a one-person meal.\r\nWanna come over and share some?"
msgstr "Già, non è un pasto per una persona.\r\nVuoi venire da me e condividerlo?"

msgctxt "303||||4"
msgid "You wouldn't mind?"
msgstr "Non ti dispiace?"

msgctxt "304||||4"
msgid "Course not! It'd be awesome\r\nto share a hot pot with you! <symbol=heart_with_outline>"
msgstr "Certo che no! Sarebbe fantastico\r\ncondividere un piatto caldo con te! <symbol=heart_with_outline>"

msgctxt "305||||4"
msgid "Looking forward to it."
msgstr "Non vedo l'ora."

msgctxt "306||||4"
msgid "What type do you think I am?"
msgstr "Che tipo credi che io sia?"

msgctxt "307||||4"
msgid "Hmm..."
msgstr "Mh..."

msgctxt "308||||4"
msgid "Type A!"
msgstr "Tipo A!"

msgctxt "309||||4"
msgid "Oh, good guess!"
msgstr "Oh, bella intuizione!"

msgctxt "310||||4"
msgid "Type B!"
msgstr "Tipo B!"

msgctxt "311||||4"
msgid "Nope. I'm a type A!"
msgstr "No. Sono un tipo A!"

msgctxt "312||||4"
msgid "Either AB or O."
msgstr "O tipo AB, o tipo 0."

msgctxt "313||||4"
msgid "Hey, c'mon now, Kiryu-san! No fair!\r\nThey're both wrong anyway!"
msgstr "Ehi, andiamo, Kiryu-san! Non vale!\r\nSono entrambi sbagliati, comunque!"

msgctxt "314||||4"
msgid "You really want to know?\r\nWell I'm not telling, mister pervert."
msgstr "Vuoi davvero saperlo?\r\nBeh non te lo dico, signor maniaco."

msgctxt "315||||4"
msgid "Nope! This is your chance, Kiryu-san!"
msgstr "No! Questa è la tua occasione, Kiryu-san!"

msgctxt "316||||4"
msgid "A lot of reasons really, but the biggest one\r\nhas to do with overcoming my complex."
msgstr "Un sacco di ragioni a dir la verità, ma la più grande\r\nha a che fare col superare i miei complessi."

msgctxt "317||||4"
msgid "Complex?"
msgstr "Complessi?"

msgctxt "318||||4"
msgid "Between my personality and being a pro wrestler,\r\nI don't get treated like a girl very often."
msgstr "Tra la mia personalità e l'essere una wrestler,\r\nnon vengo trattata spesso come una ragazza."

msgctxt "319||||4"
msgid "And part of me's not okay with that..."
msgstr "E una parte di me non sta bene con questa cosa..."

msgctxt "320||||4"
msgid "That makes sense."
msgstr "Ha senso."

msgctxt "321||||4"
msgid "So I thought maybe working as a hostess would\r\nhelp me figure out how to be more feminine."
msgstr "Così ho pensato che lavorare come hostess potesse\r\naiutarmi a capire come essere più femminile."

msgctxt "322||||4"
msgid "It's certainly true that femininity is how you\r\nget ahead in a cabaret club. It's the right idea."
msgstr "È certamente vero che la femminilità fa strada in un\r\ncabaret club. È l'idea giusta."

msgctxt "323||||4"
msgid "Yeah, I'm going to keep trying to work\r\non being more of a girly girl."
msgstr "Già, continuerò a impegnarmi per essere\r\npiù femminile e aggraziata."

msgctxt "324||||4"
msgid "Well, if you ask me, I think you're feminine\r\nenough as you are. I only see you as a woman."
msgstr "Beh, se me lo chiedi, per me sei già abbastanza femminile\r\ncosì come sei. Io ti vedo solo come una donna."

msgctxt "325||||4"
msgid "Kiryu-san...! Thank you so much! Keep smooth\r\ntalkin' me like that and I might fall for you."
msgstr "Kiryu-san...! Grazie mille! Continua a parlarmi\r\ncosì dolcemente e potrei innamorarmi di te."

msgctxt "326||||4"
msgid "Whoa, Kiryu-san! That's a new one.\r\nYou're a funny guy."
msgstr "Whoa, Kiryu-san! Questa è nuova.\r\nSei un tipo divertente."

msgctxt "327||||4"
msgid "I'm so not playing the king game, though."
msgstr "Scordatelo che io giochi al gioco del re, però."

msgctxt "329||||4"
msgid "Hmm... These days I've been listening to a lot\r\nof love songs and music aimed at girls."
msgstr "Uhm... Ultimemente ho ascoltato un sacco di canzoni\r\nd'amore e musica adatta alle ragazze."

msgctxt "330||||4"
msgid "Huh, that's different."
msgstr "Uhm, niente male."

msgctxt "331||||4"
msgid "I may not have the look, but I'm pretty girly\r\non the inside. Cute, right?"
msgstr "Potrei non averne l'aspetto, ma sono piuttosto femminile\r\ninteriormente. Carina come cosa, no?"

msgctxt "332||||4"
msgid "It's fun talking with you too, Kiryu-san."
msgstr "È divertente parlare con te, Kiryu-san."

msgctxt "333||||4"
msgid "Agreed... If I get sick from not dressing warm\r\nenough, I won't be able to wrestle."
msgstr "D'accordo... Se mi ammalo per non essermi coperta\r\nabbastanza, non potrò combattere."

msgctxt "334||||4"
msgid "Yeah... Try not to catch a cold, Kiryu-san."
msgstr "Già... Cerca di non prenderti un raffreddore, Kiryu-san."

msgctxt "335||||4"
msgid "Okay, how about I warm you up a bit?\r\nJoking. <symbol=heart_with_outline>"
msgstr "Okay, che ne dici se ti riscaldo io un po'?\r\nScherzavo. <symbol=heart_with_outline>"

msgctxt "336||||4"
msgid "Nice! That makes me really happy to hear.\r\nLet's throw a few more back!"
msgstr "Ottimo! Mi fa davvero piacere sentirtelo dire.\r\nBeviamone un altro paio, dai!"

msgctxt "337||||4"
msgid "Wow, thank you so much!"
msgstr "Wow, grazie mille!"

msgctxt "338||||4"
msgid "Wait, what!? You're just gonna confess to me\r\nout of the blue? I wasn't ready for that..."
msgstr "Aspetta, cosa!? Mi confessi i tuoi sentimenti così,\r\ndi punto in bianco? Non ero pronta a questo..."

msgctxt "339||||4"
msgid "I was kidding."
msgstr "Stavo scherzando."

msgctxt "340||||4"
msgid "Oh, you're terrible!"
msgstr "Oh, ma sei terribile!"

msgctxt "341||||4"
msgid "Yaaaaaaaay!\r\nThis is so fun."
msgstr "Evvivaaaaaa!\r\nÈ divertentissimo."

msgctxt "342||||4"
msgid "Hi! How ya doin'?"
msgstr "Ciao! Come ti butta?"

msgctxt "343||||4"
msgid "Great, thanks to you."
msgstr "Alla grande, grazie a te."

msgctxt "344||||4"
msgid "Huh? Wait, just out of the blue like that!?\r\nAre you serious, Kiryu-san?"
msgstr "Eh? Aspetta, così di punto in bianco!?\r\nDici sul serio, Kiryu-san?"

msgctxt "345||||4"
msgid "Yeah. I'm very serious."
msgstr "Sì. Sono serissimo."

msgctxt "346||||4"
msgid "I've never had anyone ask me\r\nto let them touch me so seriously like that!"
msgstr "Nessuno mi aveva mai chiesto in\r\nmodo così serio di lasciarsi toccare!"

msgctxt "347||||4"
msgid "Really?"
msgstr "Davvero?"

msgctxt "348||||4"
msgid "Yes! You're a weird one, Kiryu-san."
msgstr "Sì! Sei un tipo strano, Kiryu-san."

msgctxt "349||||4"
msgid "I'm not serious."
msgstr "Non sono serio."

msgctxt "350||||4"
msgid "You're such a funny guy!\r\nWell, either way, no touching!"
msgstr "Sei proprio un tipo divertente!\r\nBeh, in ogni caso, vietato toccare!"

msgctxt "352||||4"
msgid "It's an American joke!"
msgstr "È una battuta all'americana!"

msgctxt "353||||4"
msgid "That's not an American joke at all!\r\nKiryu-san... You're so funny."
msgstr "Questa non è affatto una battuta all'americana!\r\nKiryu-san... Sei così divertente."

msgctxt "354||||4"
msgid "(Wait... I can't get a read on her...)"
msgstr "(Aspetta... Non riesco a inquadrarla...)"

msgctxt "355||||4"
msgid "I'm so happy to hear that.\r\nOh no, I'm seein' hearts..."
msgstr "Sono così felice di sentirtelo dire.\r\nOh no, mi vengono gli occhi a cuoricino..."

msgctxt "356||||4"
msgid "Oh, I'm not, really!"
msgstr "Oh, davvero, non scherzo!"

msgctxt "357||||4"
msgid "Wow! Kiryu-san, you're fluent in English!\r\nGood English!"
msgstr "Wow! Kiryu-san, sei fluente in inglese!\r\nGood English!"

msgctxt "358||||4"
msgid "Thank you."
msgstr "Grazie."

msgctxt "359||||4"
msgid "Only you?\r\nHm, what should I do?"
msgstr "Solo te?\r\nUhm, cosa dovrei fare?"

msgctxt "360||||4"
msgid "Hey... You should only look\r\nat me too, okay?"
msgstr "Ehi... Dovresti guardare solo\r\nme anche tu, okay?"

msgctxt "361||||4"
msgid "Huh? That's a secret. <symbol=note_with_outline>"
msgstr "Eh? È un segreto. <symbol=note_with_outline>"

msgctxt "362||||4"
msgid "You want me to tell you?\r\nHm, should I? <symbol=note_with_outline>"
msgstr "Vuoi che te lo dica?\r\nUhm, dovrei? <symbol=note_with_outline>"

msgctxt "363||||4"
msgid "Is there anyone you like?"
msgstr "C'è qualcuno che ti piace?"

msgctxt "364||||4"
msgid "Oh, don't make me say it!\r\nOf course there is... <symbol=heart_with_outline>"
msgstr "Oh, non farmelo dire!\r\nCerto che c'è... <symbol=heart_with_outline>"

msgctxt "365||||4"
msgid "Really?\r\nMaybe I'll see what happens... <symbol=heart_with_outline>"
msgstr "Davvero?\r\nMagari vedrò cosa succederà... <symbol=heart_with_outline>"

msgctxt "366||||4"
msgid "Thank you. The owners are really good people,\r\nso it's a nice place to work."
msgstr "Grazie. I proprietari sono persone fantastiche,\r\nquindi è un bel posto in cui lavorare."

msgctxt "367||||4"
msgid "And they're really open-minded to actually hire\r\na pro wrestler like me."
msgstr "E hanno la mente davvero aperta per\r\nassumere una wrestler come me."

msgctxt "368||||4"
msgid "I'd say they're good at their jobs to hire\r\na girl like you."
msgstr "Direi che sanno fare bene il loro lavoro, per\r\nassumere una ragazza come te."

msgctxt "369||||4"
msgid "Too smooth, Kiryu-san!\r\nYou make me feel like I can do anything! <symbol=heart_with_outline>"
msgstr "Sei un rubacuori, Kiryu-san!\r\nMi fai sentire come se potessi fare tutto! <symbol=heart_with_outline>"

msgctxt "370||||4"
msgid "I don't know too many, actually.\r\nBut I'm eager to try some new ones."
msgstr "Non ne conosco molti, a dire il vero.\r\nMa sono impaziente di provarne di nuovi."

msgctxt "371||||4"
msgid "You go to places like that...? Oh no,\r\nI'm starting to imagine it! Let's change subjects!"
msgstr "Vai in posti simili...? Oh no,\r\nsto iniziando a immaginarmelo! Cambiamo argomento!"

msgctxt "372||||4"
msgid "Huh!? You wrecked a convenience store?\r\nYou sure you don't wanna be a pro wrestler?"
msgstr "Cosa!? Hai distrutto un konbini?\r\nSicuro di non voler fare il wrestler?"

msgctxt "373||||4"
msgid "Hmm, well, it wasn't intentional..."
msgstr "Uhm, beh, non è stato intenzionale..."

msgctxt "374||||4"
msgid "Destroying a convenience store... Actually,\r\na convenience store death match could totally work!"
msgstr "Distruggere un konbini... In effetti, un death\r\nmatch in un konbini ci starebbe alla grande!"

msgctxt "375||||4"
msgid "That's a great idea! Thank you!"
msgstr "Ottima idea! Grazie!"

msgctxt "376||||4"
msgid "S-Sure..."
msgstr "C-Certo..."

msgctxt "377||||4"
msgid "Whoa! Pulling out the heavy topics!"
msgstr "Whoa! Hai tirato fuori un argomento pesante!"

msgctxt "378||||4"
msgid "Memories of someone who's passed on, huh? You\r\ncan't help but think about it sometimes."
msgstr "I ricordi di qualcuno che è venuto a mancare, eh?\r\nNon puoi fare a meno di pensarci, a volte."

msgctxt "379||||4"
msgid "Maybe it's not my place to say, but, I think\r\nyou've got to work hard for his sake, too."
msgstr "Forse non spetta a me dirlo, ma credo che tu\r\ndebba impegnarti molto anche per il suo bene."

msgctxt "380||||4"
msgid "True enough.\r\nI think that's the right attitude."
msgstr "Vero.\r\nCredo sia l'atteggiamento giusto."

msgctxt "381||||4"
msgid "Yeah. I'm glad we got to talk about this."
msgstr "Già. Mi fa piacere averne parlato."

msgctxt "382||||4"
msgid "A true friend, huh? That's someone you can say\r\nwhatever you really feel without holding back, I guess."
msgstr "Un vero amico, eh? Qualcuno a cui puoi dire quello\r\nche provi senza trattenerti, immagino."

msgctxt "383||||4"
msgid "Speaking of friends...\r\ndo you think men and women can be just friends?"
msgstr "A proposito di amici...\r\npensi che uomini e donne possano essere solo amici?"

msgctxt "384||||4"
msgid "Why not?\r\nI have some friends where gender means nothing."
msgstr "Perché no?\r\nHo degli amici in cui il genere non conta nulla."

msgctxt "385||||4"
msgid "Exactly, right!?\r\nI have a lot of guy friends!"
msgstr "Esatto, vero!?\r\nIo ho un sacco di amici maschi!"

msgctxt "386||||4"
msgid "You're probably the type of person\r\nguys find easy to talk to."
msgstr "Probabilmente sei il tipo di persona con cui i\r\nragazzi trovano facile parlare."

msgctxt "387||||4"
msgid "You think so?\r\nPeople are always saying I'm so manly, though."
msgstr "Lo pensi davvero?\r\nPerò tutti dicono sempre che sono così mascolina."

msgctxt "388||||4"
msgid "I don't think so.\r\nA guy always has ulterior motives."
msgstr "Non credo.\r\nUn ragazzo ha sempre dei secondi fini."

msgctxt "389||||4"
msgid "What? You think so? I've got a lot of guy friends,\r\nso that's making me wonder."
msgstr "Cosa? Lo pensi davvero? Ho un sacco di amici maschi,\r\nquindi questo mi fa venire dei dubbi."

msgctxt "390||||4"
msgid "You think so?\r\nPeople are always saying I'm so manly, though."
msgstr "Lo pensi davvero?\r\nPerò tutti dicono sempre che sono così mascolina."

msgctxt "391||||4"
msgid "I think they can, but...\r\nI couldn't make that work with you."
msgstr "Credo di sì, ma...\r\nNon potrei farlo funzionare con te."

msgctxt "392||||4"
msgid "Huh!? Why not!?\r\nDid I say something that got under your skin?"
msgstr "Eh!? Perché no!?\r\nHo detto qualcosa che ti ha dato fastidio?"

msgctxt "393||||4"
msgid "No, I just mean I see you more\r\nas a woman than a friend."
msgstr "No, intendo dire che ti vedo\r\npiù come una donna che come un'amica."

msgctxt "394||||4"
msgid "K-Kiryu-san...! Seriously,\r\ndo you always have to be so cool?"
msgstr "K-Kiryu-san...! Dico sul serio,\r\ndevi sempre essere così affascinante?"

msgctxt "395||||4"
msgid "Whew... I haven't felt a rush\r\nlike that in a while."
msgstr "Fiuh... Non provavo un brivido\r\nsimile da un po'."

msgctxt "396||||4"
msgid "Mission accomplished."
msgstr "Missione compiuta."

msgctxt "397||||4"
msgid "Really!? You <font_kind=yakuza_italic>do</font_kind> seem like you'd spoil them.\r\nYou're really kind."
msgstr "Davvero!? In effetti <font_kind=yakuza_italic>sembri</font_kind> uno che li vizierebbe.\r\nSei davvero gentile."

msgctxt "398||||4"
msgid "Maybe if I were just a baby,\r\nyou'd be nicer to me!"
msgstr "Forse se fossi solo una bambina,\r\nsaresti più carino con me!"

msgctxt "399||||4"
msgid "Hey, I'm plenty nice now, aren't I?"
msgstr "Ehi, sono già abbastanza gentile adesso, no?"

msgctxt "400||||4"
msgid "You're right."
msgstr "Hai ragione."

msgctxt "401||||4"
msgid "You fish, Kiryu-san?"
msgstr "Tu peschi, Kiryu-san?"

msgctxt "402||||4"
msgid "Yeah, I've been spearfishing lately."
msgstr "Sì, ultimamente mi do alla pesca subacquea."

msgctxt "403||||4"
msgid "That's so cool! I bet the fish\r\nyou catch would taste amazing!"
msgstr "Che forte! Scommetto che il pesce che\r\ncatturi avrebbe un sapore fantastico!"

msgctxt "404||||4"
msgid "Wow, so kind of like a war between two teams?\r\nThis sounds like a pro wrestling storyline."
msgstr "Wow, quindi tipo una guerra tra due team?\r\nSembra una trama da wrestling."

msgctxt "405||||4"
msgid "It's just because you look so strong, right?\r\nYou can't help but wanna conquer something strong."
msgstr "È solo perché sembri così forte, giusto?\r\nNon si può fare a meno di voler conquistare qualcosa di forte."

msgctxt "406||||4"
msgid "If I'm bein' honest...\r\nI'd like to fight you sometime!"
msgstr "Ad essere onesta...\r\nMi piacerebbe sfidarti prima o poi!"

msgctxt "407||||4"
msgid "Hey, it's not like I enjoy violence."
msgstr "Ehi, mica mi piace la violenza."

msgctxt "408||||4"
msgid "Sorry Kiryu-san, but that doesn't sound\r\nvery convincing coming from you."
msgstr "Scusa Kiryu-san, ma non sembra molto\r\nconvincente detto da te."

msgctxt "409||||4"
msgid "Have you ever heard of Pocket Circuit?"
msgstr "Hai mai sentito parlare del Pocket Circuit?"

msgctxt "410||||4"
msgid "Of course I have! When I was little, I used to\r\nplay down at the stadium with all the boys."
msgstr "Certamente! Quando ero piccola ci\r\ngiocavo allo stadio con tutti i ragazzi."

msgctxt "411||||4"
msgid "My best car was a Golem Tiger, and for\r\nmy motor, I customized it like this..."
msgstr "La mia auto migliore era una Golem Tiger e\r\nil motore l'avevo modificato così..."

msgctxt "412||||4"
msgid "Wow! You really know your stuff!"
msgstr "Wow! Te ne intendi davvero!"

msgctxt "413||||4"
msgid "You're a gym rat, Kiryu-san?\r\nGood, if you don't work out, you'll get all weak."
msgstr "Sei un maniaco della palestra, Kiryu-san?\r\nOttimo, se non ti alleni diventerai un rammollito."

msgctxt "414||||4"
msgid "It'd be pretty fun to go on a gym date\r\nwith you sometime...<symbol=heart_with_outline>"
msgstr "Sarebbe piuttosto divertente un appuntamento in\r\npalestra con te prima o poi...<symbol=heart_with_outline>"

msgctxt "415||||4"
msgid "Yeah, you seem like the quiet type, Kiryu-san."
msgstr "Già, sembri un tipo tranquillo, Kiryu-san."

msgctxt "416||||4"
msgid "But don't you ever feel like you\r\nwanna cut loose and get loud?"
msgstr "Ma non ti viene mai voglia di\r\nlasciarti andare e fare un po' di casino?"

msgctxt "417||||4"
msgid "Not really.\r\nThis is my default level."
msgstr "Non proprio.\r\nQuesto è il mio livello base."

msgctxt "418||||4"
msgid "You serious? I bet you have your\r\nmoments where you get amped up."
msgstr "Sul serio? Scommetto che anche tu hai i tuoi\r\nmomenti in cui ti carichi al massimo."

msgctxt "419||||4"
msgid "Well, who can say..."
msgstr "Beh, chi può dirlo..."

msgctxt "420||||4"
msgid "I guess when I'm singing karaoke...\r\nI might get a little carried away."
msgstr "Immagino che quando canto al karaoke...\r\npotrei lasciarmi prendere la mano."

msgctxt "421||||4"
msgid "Awesome! Now this I've gotta see!\r\nKiryu-san getting into the groove!"
msgstr "Fantastico! Questa devo proprio vederla!\r\nKiryu-san che entra nel giusto ritmo!"

msgctxt "422||||4"
msgid "Sometimes I might unintentionally,\r\nvery subconsciously, get like that."
msgstr "A volte potrei involontariamente,\r\ninconsciamente, diventare così."

msgctxt "423||||4"
msgid "Huh? You mean that?\r\nI bet you totally do it on purpose."
msgstr "Eh? Dici sul serio?\r\nScommetto che lo fai assolutamente apposta."

msgctxt "424||||4"
msgid "Maybe just when I'm around you."
msgstr "Forse solo quando sono con te."

msgctxt "425||||4"
msgid "Huh? If this is getting loud,\r\nwhat are you like normally...?"
msgstr "Eh? Se per te questo è fare casino,\r\ncome sei di solito...?"

msgctxt "426||||4"
msgid "Oh, really? I just assumed\r\nyou were the aggressive type."
msgstr "Oh, davvero? Avevo dato per scontato\r\nche fossi un tipo aggressivo."

msgctxt "427||||4"
msgid "Well, don't feel like you have to go all\r\nvegetarian with me! I'm a carnivore's delight."
msgstr "Beh, non sentirti in dovere di fare il\r\nvegetariano con me! Sono un bocconcino da carnivori."

msgctxt "428||||4"
msgid "I actually don't warm up to people very easily."
msgstr "In realtà non mi fido molto facilmente delle persone."

msgctxt "429||||4"
msgid "Really? But you're doing just fine with me.\r\nMaybe we're compatible."
msgstr "Davvero? Ma con me vai alla grande.\r\nForse siamo compatibili."

msgctxt "430||||4"
msgid "Yeah, maybe."
msgstr "Già, forse."

msgctxt "431||||4"
msgid "Even if it's not a special occasion?\r\nYou go every time?"
msgstr "Anche se non è un'occasione speciale?\r\nCi vai ogni volta?"

msgctxt "432||||4"
msgid "A man likes to show off."
msgstr "A un uomo piace mettersi in mostra."

msgctxt "433||||4"
msgid "I see... Well if it were me,\r\nI'd put that money to better use."
msgstr "Capisco... Beh, se fossi io, userei\r\nquei soldi in modo migliore."

msgctxt "434||||4"
msgid "You seem like the kinda guy that's younger than\r\nhe looks... I'll say, 39? How's that?"
msgstr "Sembri il tipo di ragazzo che è più giovane di\r\nquanto sembra... Direi, 39? Che ne dici?"

msgctxt "435||||4"
msgid "It's nice to hear it, but unfortunately\r\nI'm well into my 40s."
msgstr "Fa piacere sentirlo, ma sfortunatamente\r\nho passato i 40 da un pezzo."

msgctxt "436||||4"
msgid "Really!? You don't look that old at all!\r\nYou seem so young and brimming with energy!"
msgstr "Davvero!? Non sembri affatto così vecchio!\r\nSembri così giovane e pieno di energie!"

msgctxt "437||||4"
msgid "You're kinda like a sharp knife.\r\nYou look intimidating, but really cool, too."
msgstr "Sei tipo un coltello affilato. Sembri\r\nminaccioso, ma sei anche molto figo."

msgctxt "438||||4"
msgid "I think you're a great guy. You look\r\npretty intimidating, but you're a sweetheart."
msgstr "Penso tu sia un ragazzo fantastico. Sembri\r\npiuttosto minaccioso, ma sei un tesoro."

msgctxt "439||||4"
msgid "Older guys, I guess.\r\nI prefer a man who can take the lead."
msgstr "Uomini più grandi, direi.\r\nPreferisco un uomo che sappia prendere l'iniziativa."

msgctxt "440||||4"
msgid "I don't think I have any big fetishes!\r\nI make up for it with my fantasies."
msgstr "Non credo di avere feticismi particolari!\r\nCompenserò con le mie fantasie."

msgctxt "441||||4"
msgid "What do I want?\r\nA belt, I guess."
msgstr "Cosa voglio?\r\nUna cintura, suppongo."

msgctxt "442||||4"
msgid "A belt?\r\nFor your pants?"
msgstr "Una cintura?\r\nPer i pantaloni?"

msgctxt "443||||4"
msgid "No no, the wrestling kind."
msgstr "No no, quella da wrestling."

msgctxt "444||||4"
msgid "Of course I want a champion's belt, Kiryu-san...\r\nbut yours would be fine..."
msgstr "Certo che voglio una cintura da campione, Kiryu-san...\r\nma andrebbe bene anche la tua..."

msgctxt "445||||4"
msgid "Hm? Excuse me?"
msgstr "Uhm? Scusami?"

msgctxt "446||||4"
msgid "N-Never mind!\r\nI said nothing!"
msgstr "N-Niente!\r\nNon ho detto nulla!"

msgctxt "447||||4"
msgid "My first love, huh? It was so long ago,\r\nand I was so young. Such bittersweet memories..."
msgstr "Il mio primo amore, eh? È stato molto tempo fa,\r\ned ero così giovane. Che ricordi agrodolci..."

msgctxt "448||||4"
msgid "What!? You can't ask a girl that!"
msgstr "Cosa!? Non si può chiedere una cosa simile a una ragazza!"

msgctxt "449||||4"
msgid "What a perv, Kiryu-san!\r\nI'm not answering any weird questions!"
msgstr "Che maniaco, Kiryu-san!\r\nNon rispondo alle tue domande ambigue!"

msgctxt "450||||4"
msgid "Marriage, huh?\r\nWell, I dream about it as much as any girl!"
msgstr "Matrimonio, eh?\r\nBeh, lo sogno tanto quanto qualsiasi altra ragazza!"

msgctxt "451||||4"
msgid "What about you?"
msgstr "E tu?"

msgctxt "452||||4"
msgid "Me?\r\nWell... maybe someday..."
msgstr "Io?\r\nBeh... forse, un giorno..."

msgctxt "453||||4"
msgid "Oh, you're red red red!"
msgstr "Oh, sei rosso come un peperone!"

msgctxt "454||||4"
msgid "Marriage, huh? If I found a guy like you,\r\nI'd jump right in, Kiryu-san. <symbol=heart_with_outline>"
msgstr "Matrimonio, eh? Se trovassi un tipo come te,\r\nmi ci butterei a capofitto, Kiryu-san. <symbol=heart_with_outline>"

msgctxt "455||||4"
msgid "I don't really know how to respond when\r\nyou put me on the spot like that..."
msgstr "Non so davvero cosa rispondere quando\r\nmi metti con le spalle al muro così..."

msgctxt "456||||4"
msgid "Oh, Kiryu-san! I'm just joking. <symbol=note_with_outline>\r\nNo need to get all flustered. <symbol=heart_with_outline>"
msgstr "Oh, Kiryu-san! Sto solo scherzando. <symbol=note_with_outline>\r\nNon c'è bisogno di agitarsi. <symbol=heart_with_outline>"

msgctxt "457||||4"
msgid "No one's ever told me that before.\r\nI'm not even that good at it!"
msgstr "Nessuno me l'aveva mai detto prima.\r\nNon sono nemmeno così brava in quello!"

msgctxt "458||||4"
msgid "Really?\r\nThen maybe you're just naturally beautiful."
msgstr "Davvero?\r\nAllora forse la tua è pura bellezza naturale."

msgctxt "459||||4"
msgid "Whoa! Kiryu-san, too smooth!"
msgstr "Whoa! Kiryu-san, che rubacuori!"

msgctxt "460||||4"
msgid "Hey... Have we met somewhere before?"
msgstr "Ehi... Ci siamo già visti da qualche parte?"

msgctxt "461||||4"
msgid "Huh? Have we...?"
msgstr "Eh? Davvero...?"

msgctxt "462||||4"
msgid "I might've seen you at a wrestling match."
msgstr "Potrei averti vista a un incontro di wrestling."

msgctxt "463||||4"
msgid "Oh, that'd make sense.\r\nI suppose it's possible!"
msgstr "Oh, questo avrebbe senso.\r\nSuppongo sia possibile!"

msgctxt "464||||4"
msgid "I'd be thrilled if you'd seen\r\none of my matches, Kiryu-san!"
msgstr "Sarei felicissima di sapere che hai\r\nvisto uno dei miei incontri, Kiryu-san!"

msgctxt "465||||4"
msgid "Nah, I was overthinking it.\r\nForget I said anything."
msgstr "Nah, ci stavo pensando troppo.\r\nDimentica quello che ho detto."

msgctxt "466||||4"
msgid "Aw, don't go gettin' my hopes\r\nup like that..."
msgstr "Aww, non farmi illudere\r\ncosì..."

msgctxt "467||||4"
msgid "Maybe... we met in a dream."
msgstr "Forse... ci siamo incontrati in un sogno."

msgctxt "468||||4"
msgid "And now you're a romantic all of a sudden,\r\nKiryu-san? You're a real strange guy..."
msgstr "E ora sei un romanticone, tutto d'un tratto,\r\nKiryu-san? Sei proprio un tipo strano..."

msgctxt "469||||4"
msgid "Thanks! Maybe it's because I train so much. \r\nAlthough I'm worried my abs are starting to show..."
msgstr "Grazie! Forse è perché mi alleno tanto.\r\nAnche se temo che mi si inizino a vedere gli addominali..."

msgctxt "470||||4"
msgid "Cheating? Well, it certainly\r\nsucks when it happens to you!"
msgstr "Tradimento? Beh, fa sicuramente schifo\r\nquando succede a te!"

msgctxt "471||||4"
msgid "Don't tell me...\r\nYou're a cheater, Kiryu-san!?"
msgstr "Non dirmi che...\r\nTu tradisci, Kiryu-san!?"

msgctxt "472||||4"
msgid "Yes, actually..."
msgstr "Sì, a dire il vero..."

msgctxt "473||||4"
msgid "Whoa! Putting it right out there, huh!? Well,\r\nKiryu-san, I'm sure you're popular with the ladies."
msgstr "Whoa! Sputi proprio il rospo, eh!? Beh, Kiryu-san,\r\nsono certa che tu sia popolare tra le donne."

msgctxt "474||||4"
msgid "I get it! You get a pass this once, Kiryu-san!"
msgstr "Capisco! Te la farò passare per questa volta, Kiryu-san!"

msgctxt "475||||4"
msgid "O-Oh. Thanks..."
msgstr "O-Oh. Grazie..."

msgctxt "476||||4"
msgid "No, that's not what I meant."
msgstr "No, non è quello che intendevo."

msgctxt "477||||4"
msgid "Really? That's what they all say. A lady's man\r\nlike you, Kiryu-san? I'm kinda suspicious..."
msgstr "Davvero? Dicono tutti così. Un donnaiolo\r\ncome te, Kiryu-san? Sono un po' sospettosa..."

msgctxt "478||||4"
msgid "You're the only one for me."
msgstr "Tu sei l'unica per me."

msgctxt "479||||4"
msgid "Wh-What's all this out of the blue, Kiryu-san!?"
msgstr "M-Ma cosa ti prende così all'improvviso, Kiryu-san!?"

msgctxt "480||||4"
msgid "You're making me all flustered!\r\nYou've got a mean sense of humor..."
msgstr "Mi fai agitare tutta!\r\nHai un senso dell'umorismo perfido..."

msgctxt "482||||4"
msgid "I prefer staying in, I think. I get so much\r\nexercise, I just wanna relax at home when I can."
msgstr "Preferisco stare a casa, penso. Faccio così tanto esercizio\r\nche voglio solo rilassarmi a casa, quando posso."

msgctxt "483||||4"
msgid "Oh, you're one of those people, Kiryu-san?\r\nMe too!"
msgstr "Oh, sei uno di quelli, Kiryu-san?\r\nAnch'io!"

msgctxt "484||||4"
msgid "Maybe it's because I push myself so hard every\r\nday, but it makes me just want to relax at home."
msgstr "Forse è perché mi sforzo tanto ogni\r\ngiorno, ma mi fa venire voglia di rilassarmi a casa."

msgctxt "485||||4"
msgid "I'm on the same page!\r\nIf we were dating, I'm sure we'd get along. <symbol=heart_with_outline>"
msgstr "La pensiamo allo stesso modo!\r\nSe stessimo assieme, andremmo di sicuro d'accordo. <symbol=heart_with_outline>"

msgctxt "486||||4"
msgid "Yeah, I did. So, pop quiz.\r\nWhat team was I on?"
msgstr "Sì. Allora, test a sorpresa.\r\nIn che team ero?"

msgctxt "487||||4"
msgid "You're tall, so... volleyball?"
msgstr "Sei alta, quindi... pallavolo?"

msgctxt "488||||4"
msgid "Whoa! You got it, Kiryu-san!\r\nI'm impressed."
msgstr "Whoa! Hai indovinato, Kiryu-san!\r\nSono impressionata."

msgctxt "489||||4"
msgid "I heard they scout people based on height.\r\nI'm sure you were the perfect fit."
msgstr "Ho sentito che reclutano in base all'altezza.\r\nSono sicuro che fossi perfetta."

msgctxt "490||||4"
msgid "Aw, thanks."
msgstr "Aw, grazie."

msgctxt "491||||4"
msgid "You're a pro wrestler, so... wrestling?"
msgstr "Sei una wrestler professionista, quindi... wrestling?"

msgctxt "492||||4"
msgid "Nope! Wrong.\r\nBack then I wasn't that into wrestling yet."
msgstr "No! Sbagliato.\r\nAll'epoca non ero ancora così interessata al wrestling."

msgctxt "493||||4"
msgid "I love it now, but the right answer\r\nwas the volleyball team."
msgstr "Ora lo amo, ma la risposta corretta\r\nera la squadra di pallavolo."

msgctxt "494||||4"
msgid "Volleyball, huh?\r\nYou do seem like you'd be a good fit for that."
msgstr "Pallavolo, eh?\r\nIn effetti mi sembri molto adatta."

msgctxt "495||||4"
msgid "Were you... not on a team?"
msgstr "Quindi non eri... in una squadra?"

msgctxt "496||||4"
msgid "Bzzzt! The right answer is... the volleyball team!\r\nI just told I was on a team, didn't I?"
msgstr "Bzzzt! La risposta corretta è... pallavolo!\r\nTi avevo appena detto di essere in una squadra, no?"

msgctxt "497||||4"
msgid "But when I was a kid, I kinda lost sight of my\r\ngoals... I was just coasting without a plan."
msgstr "Ma quando ero una ragazzina, ho un po' perso di vista\r\ni miei obiettivi... Vivacchiavo senza alcun piano."

msgctxt "498||||4"
msgid "Looking back on it, I have no idea what I was\r\nthinking. I was just a dumb teenager, I guess."
msgstr "Ripensandoci, non ho idea di cosa avessi\r\nper la testa. Ero solo un'adolescente stupida, credo."

msgctxt "499||||4"
msgid "That's life."
msgstr "Così è la vita."

msgctxt "500||||4"
msgid "What? No way. Laundry sucks.\r\nWash them yourself, please."
msgstr "Cosa? Scordatelo. Fare il bucato fa schifo.\r\nLavatele da solo, per favore."

msgctxt "501||||4"
msgid "Oh, are you asking me to be your girlfriend?\r\nWhatever should I do...? <symbol=heart_with_outline>"
msgstr "Oh, mi stai chiedendo di farti da fidanzata?\r\nChe cosa dovrei fare...? <symbol=heart_with_outline>"

msgctxt "502||||4"
msgid "You should save that line for\r\nthe girl you want to marry."
msgstr "Dovresti conservare questa frase per\r\nla ragazza che vorresti sposare."

msgctxt "503||||4"
msgid "Huh? Are you serious?"
msgstr "Eh? Dici sul serio?"

msgctxt "504||||4"
msgid "Huh? A-Are you asking...\r\nIf you'll have me... <symbol=heart_with_outline>"
msgstr "Eh? M-Mi stai chiedendo...\r\nSe mi vorrai... <symbol=heart_with_outline>"

msgctxt "505||||4"
msgid "Oho? Why do you think that?"
msgstr "Oho? Perché pensi questo?"

msgctxt "506||||4"
msgid "Most of them can't even speak properly."
msgstr "La maggior parte di loro non sa neanche parlare."

msgctxt "507||||4"
msgid "Y'know, Kiryu...\r\nIt ain't right."
msgstr "Sai, Kiryu...\r\nNon va bene."

msgctxt "508||||4"
msgid "Hey, is that how you really talk?"
msgstr "Ehi, parli davvero così?"

msgctxt "509||||4"
msgid "Joking, joking. <symbol=heart_with_outline> If you can be polite to\r\nstrangers, then be polite to your friends."
msgstr "Scherzo, scherzo. <symbol=heart_with_outline> Se riesci a essere educato con gli\r\nsconosciuti, allora sii educato anche coi tuoi amici."

msgctxt "510||||4"
msgid "They just lack conviction."
msgstr "Gli manca la convinzione."

msgctxt "511||||4"
msgid "Oh, I can get on board with that.\r\nI see it a lot in young pro wrestlers."
msgstr "Oh, in questo sono d'accordo con te.\r\nLo vedo spesso nei giovani wrestler."

msgctxt "512||||4"
msgid "It's like... they have no passion.\r\nNo desire to make it big."
msgstr "È come se... non avessero passione.\r\nNessun desiderio di sfondare."

msgctxt "513||||4"
msgid "Man, saying all this makes me sound like an\r\nold woman. I gotta watch it."
msgstr "Cavoli, a parlare così sembro una vecchia\r\nsignora. Devo starci attenta."

msgctxt "514||||4"
msgid "Looks like we're on the same side."
msgstr "Sembra che siamo dalla stessa parte."

msgctxt "515||||4"
msgid "Hey, you take that back.\r\nI'm still young and lively, I swear!"
msgstr "Ehi, rimangiati ciò che hai detto.\r\nSono ancora giovane e vispa, lo giuro!"

msgctxt "516||||4"
msgid "The girls are really letting themselves go...\r\nKinda gross."
msgstr "Le ragazze si stanno davvero lasciando andare...\r\nFa un po' schifo."

msgctxt "517||||4"
msgid "Oh, is that what you meant?\r\nI was thinking you'd have a lot worse to say!"
msgstr "Oh, intendevi questo?\r\nPensavo che avresti detto di molto peggio!"

msgctxt "518||||4"
msgid "I sing a lot, but I like the cutesy songs.\r\nThey're such a breath of fresh air."
msgstr "Canto un sacco, ma mi piacciono le canzoni tenere.\r\nSono una bella boccata d'aria fresca."

msgctxt "519||||4"
msgid "Really? I don't know if I agree.\r\nI like a man who's more calm and collected."
msgstr "Davvero? Non so se sono d'accordo.\r\nMi piacciono gli uomini più calmi e composti."

msgctxt "520||||4"
msgid "Someone who's kind and open-minded...\r\nwith a face like a gorilla!"
msgstr "Qualcuno di gentile e di larghe vedute...\r\ncon un volto da gorilla!"

msgctxt "521||||4"
msgid "A gorilla..."
msgstr "Un gorilla..."

msgctxt "522||||4"
msgid "He wears an eyepatch and he's half naked under a\r\nweird jacket? Is this Majima-san a pro wrestler?"
msgstr "Indossa una benda e sta mezzo nudo sotto\r\nuna giacca strana? Questo Majima è un wrestler?"

msgctxt "523||||4"
msgid "No, he's a civilian... Well, not exactly.\r\nBut, he's strong enough to impress a wrestler."
msgstr "No, è un civile... Beh, non esattamente.\r\nMa è forte abbastanza da fare colpo su una wrestler."

msgctxt "524||||4"
msgid "What!? I really want to meet him now...\r\nI might totally fall for this guy if we met..."
msgstr "Cosa!? Adesso voglio proprio conoscerlo...\r\nPotrei finire per innamorarmene..."

msgctxt "525||||4"
msgid "Ah, Majima-san..."
msgstr "Ah, Majima-san..."

msgctxt "526||||4"
msgid "Hey, what part of anything I just said\r\nmakes this guy sound attractive?"
msgstr "Ehi, quale parte di ciò che ho detto\r\nlo fa sembrare un tipo attraente?"

msgctxt "527||||4"
msgid "A detective, huh? Sounds a little scatterbrained,\r\nbut I'm sure he's good guy."
msgstr "Un detective, eh? Sembra un po' sbadato,\r\nma sono sicura che sia un bravo ragazzo."

msgctxt "528||||4"
msgid "This Akiyama-san is an entrepreneur?\r\nSounds rich! Ah, you should bring him by!"
msgstr "Questo Akiyama-san è un imprenditore?\r\nSembra ricco! Ah, dovresti portarmelo qui!"

msgctxt "529||||4"
msgid "If I can just get him to request me..."
msgstr "Sempre che riesca a farmi richiedere da lui..."

msgctxt "530||||4"
msgid "What!?\r\nHe took down a bear!?"
msgstr "Cosa!?\r\nHa sconfitto un orso!?"

msgctxt "531||||4"
msgid "It's my <font_kind=yakuza_italic>dream</font_kind> as a fighter to take down a bear!\r\nGive me details here!"
msgstr "È il mio <font_kind=yakuza_italic>sogno</font_kind> da lottatrice poter sconfiggere un orso!\r\nDammi tutti i dettagli!"

msgctxt "532||||4"
msgid "S-Sure...\r\nDidn't figure that would strike a chord..."
msgstr "C-Certo...\r\nNon credevo avrebbe fatto colpo..."

msgctxt "533||||4"
msgid "You trust him a lot, huh? I'd like\r\nto get to that level with you, Kiryu-san."
msgstr "Ti fidi molto di lui, eh? Mi piacerebbe\r\narrivare a quel livello con te, Kiryu-san."

msgctxt "534||||4"
msgid "I've never been before.\r\nWhat do you do for fun there, Kiryu-san?"
msgstr "Non ci sono mai stata.\r\nCosa fai lì per divertirti, Kiryu-san?"

msgctxt "535||||4"
msgid "Well...\r\nAbout all they've got there are bars."
msgstr "Beh...\r\nPraticamente hanno solo dei bar lì."

msgctxt "536||||4"
msgid "I spend most of the time just chatting with\r\nthe bartender, sipping a glass of liquor."
msgstr "Passo la maggior parte del tempo a chiacchierare col\r\nbarista, sorseggiando un bicchiere di liquore."

msgctxt "537||||4"
msgid "Huh! That sounds like a nice little situation.\r\nI could have some good fantasies about that... <symbol=heart_with_outline>"
msgstr "Ah! Sembra un bel quadretto.\r\nPotrei scriverci su delle belle fantasie... <symbol=heart_with_outline>"

msgctxt "538||||4"
msgid "Don't go too crazy."
msgstr "Non andarci giù troppo pesante."
