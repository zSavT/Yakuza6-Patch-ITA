msgstr "Nei momenti decisivi, <color=batting_pitch_yellow>Battuta</color> e <color=batting_pitch_yellow>Potenza</color> <color=batting_pitch_blue>diminuiscono</color>."

msgctxt "34||skill_006||explanation"
msgid "When under pressure, <color=batting_pitch_yellow>the likelihood of striking out</color> <color=batting_pitch_blue>increases</color>."
msgstr "Quando si è sotto pressione, <color=batting_pitch_yellow>la probabilità di strikeout</color> <color=batting_pitch_blue>aumenta</color>."

msgctxt "35||skill_007||explanation"
