msgctxt "29||skill_001||explanation"
msgid "In clutch moments, <color=batting_pitch_yellow>Batting</color> and <color=batting_pitch_yellow>Slugging</color> <color=batting_pitch_red>increase slightly</color>."
msgstr "Nei momenti decisivi, <color=batting_pitch_yellow>Battuta</color> e <color=batting_pitch_yellow>Potenza</color> <color=batting_pitch_red>aumentano leggermente</color>."

msgctxt "30||skill_002||explanation"
msgid "In clutch moments, <color=batting_pitch_yellow>Batting</color> and <color=batting_pitch_yellow>Slugging</color> <color=batting_pitch_red>increase moderately</color>."
msgstr "Nei momenti decisivi, <color=batting_pitch_yellow>Battuta</color> e <color=batting_pitch_yellow>Potenza</color> <color=batting_pitch_red>aumentano moderatamente</color>."

msgctxt "31||skill_003||explanation"
msgid "In clutch moments, <color=batting_pitch_yellow>Batting</color> and <color=batting_pitch_yellow>Slugging</color> <color=batting_pitch_red>increase greatly</color>."
msgstr "Nei momenti decisivi, <color=batting_pitch_yellow>Battuta</color> e <color=batting_pitch_yellow>Potenza</color> <color=batting_pitch_red>aumentano notevolmente</color>."

msgctxt "32||skill_004||explanation"
