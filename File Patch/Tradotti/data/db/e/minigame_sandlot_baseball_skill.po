msgctxt "76||skill_048||explanation"
msgid "When his pitches get hit repeatedly, his <color=batting_pitch_yellow>Speed</color> and <color=batting_pitch_yellow>Control</color>\r\n<color=batting_pitch_blue>decrease moderately</color> while going against the next batter."
msgstr "Quando i suoi lanci vengono colpiti ripetutamente, <color=batting_pitch_yellow>Velocità</color> e <color=batting_pitch_yellow>Controllo</color>\r\n<color=batting_pitch_blue>diminuiscono moderatamente</color> contro il battitore successivo."

msgctxt "77||skill_049||explanation"
msgid "<color=batting_pitch_yellow>The likelihood of striking out a batter</color> <color=batting_pitch_red>increases tremendously</color>."
msgstr "<color=batting_pitch_yellow>La probabilità di eliminare un battitore per strikeout</color> <color=batting_pitch_red>aumenta immensamente</color>."

msgctxt "78||skill_050||explanation"
msgid "In clutch moments, <color=batting_pitch_yellow>Speed</color> and <color=batting_pitch_yellow>Control</color> <color=batting_pitch_red>increase tremendously</color>."
msgstr "Nei momenti decisivi, <color=batting_pitch_yellow>Velocità</color> e <color=batting_pitch_yellow>Controllo</color> <color=batting_pitch_red>aumentano immensamente</color>."

msgctxt "79||skill_051||explanation"
msgid "<color=batting_pitch_yellow>Speed</color> <color=batting_pitch_red>increases moderately</color>."
msgstr "La <color=batting_pitch_yellow>Velocità</color> <color=batting_pitch_red>aumenta moderatamente</color>."

msgctxt "80||skill_052||explanation"
msgid "When pitching the ball diagonally from the\r\ndominant arm, <color=batting_pitch_yellow>Speed</color> <color=batting_pitch_red>increases moderately</color>."
msgstr "Quando lancia la palla in diagonale dal\r\nbraccio dominante, la <color=batting_pitch_yellow>Velocità</color> <color=batting_pitch_red>aumenta moderatamente</color>."

msgctxt "81||skill_053||explanation"
msgid "When taking the mound at 7th inning or later, <color=batting_pitch_yellow>Speed</color> <color=batting_pitch_red>increases moderately</color>."
msgstr "Quando sale sul monte dal 7° inning in poi, la <color=batting_pitch_yellow>Velocità</color> <color=batting_pitch_red>aumenta moderatamente</color>."

msgctxt "82||skill_054||explanation"
msgid "<color=batting_pitch_yellow>Speed</color> <color=batting_pitch_red>increases moderately</color>."
msgstr "La <color=batting_pitch_yellow>Velocità</color> <color=batting_pitch_red>aumenta moderatamente</color>."
