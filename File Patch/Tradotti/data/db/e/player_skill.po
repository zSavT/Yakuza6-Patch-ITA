msgctxt "531||btl_cmb_speed_01||explanation"
msgid "Increases attack speed slightly."
msgstr "Aumenta leggermente la velocità d'attacco."

msgctxt "532||btl_cmb_speed_02||explanation"
msgid "Increases attack speed further."
msgstr "Aumenta ulteriormente la velocità d'attacco."

msgctxt "533||btl_cmb_speed_03||explanation"
msgid "Increases attack speed to its fullest."
msgstr "Aumenta al massimo la velocità d'attacco."

msgctxt "534||btl_dash_atk||explanation"
msgid "Attack immediately after sprinting."
msgstr "Attacca immediatamente dopo uno scatto."

msgctxt "535||btl_stand_atk||explanation"
msgid "Attack immediately after recovering from knock down."
msgstr "Attacca immediatamente dopo esserti rialzato da un atterramento."

msgctxt "536||btl_stand_quick||explanation"
msgid "Recover while getting knocked down."
msgstr "Recupera mentre vieni atterrato."

msgctxt "537||btl_blowback||explanation"
msgid "Regain your stance quickly after an enemy blocks your attack."
msgstr "Recupera rapidamente la posizione dopo che un nemico ha parato un tuo attacco."

msgctxt "538||btl_reguard||explanation"
msgid "Quickly regain ability to guard after guard is\r\nbroken."
msgstr "Recupera rapidamente la capacità di parare dopo che la guardia è stata\r\nspezzata."

msgctxt "539||btl_ukenagashi_01||explanation"
msgid "Parry an enemy's attack."
msgstr "Devia l'attacco di un nemico."

msgctxt "540||btl_ukenagashi_02||explanation"
msgid "Your parry stance lasts longer."
msgstr "La tua posizione di deviazione dura più a lungo."

msgctxt "541||btl_sway_atk||explanation"
msgid "Attack immediately after a Quickstep."
msgstr "Attacca immediatamente dopo un passo rapido."

msgctxt "542||btl_sway_01||explanation"
msgid "Perform two Quicksteps back-to-back."
msgstr "Esegui due passi rapidi di fila."

msgctxt "543||btl_sway_02||explanation"
msgid "Perform three consecutive Quicksteps."
msgstr "Esegui tre passi rapidi consecutivi."

msgctxt "544||btl_sway_dash||explanation"
msgid "Lunge forward while running to gain a lot of distance quickly."
msgstr "Affonda in avanti mentre corri per coprire rapidamente molta distanza."

msgctxt "545||btl_sway_dash_atk||explanation"
msgid "An attack performed directly from a lunge."
msgstr "Un attacco eseguito direttamente da un affondo."

msgctxt "546||btl_toraotoshi_01||explanation"
msgid "Perform powerful counterattacks."
msgstr "Esegui potenti contrattacchi."

msgctxt "547||btl_toraotoshi_02||explanation"
msgid "Lengthens the window during which you can execute\r\na Tiger Drop."
msgstr "Prolunga la finestra di tempo in cui puoi eseguire\r\nuna Caduta della tigre."

msgctxt "548||btl_gb01||explanation"
msgid "By timing your attack just right, you'll strike with enough\r\npower to break through the enemy's guard."
msgstr "Sincronizzando l'attacco con precisione, colpirai con potenza sufficiente\r\nper spezzare la guardia nemica."

msgctxt "550||btl_fin_hold||explanation"
msgid "Dynamically throw an enemy after a Finishing Blow."
msgstr "Lancia dinamicamente un nemico dopo un colpo finale."

msgctxt "551||btl_anti_stn||explanation"
msgid "Shorten the time it takes to recover from being stunned."
msgstr "Riduci il tempo necessario per riprenderti dallo stordimento."

msgctxt "552||btl_charge||explanation"
msgid "Perform a charge attack with all your might.\r\nYour movements will be limited while charging."
msgstr "Esegui un attacco caricato con tutta la tua forza.\r\nI tuoi movimenti saranno limitati durante il caricamento."

msgctxt "553||btl_cancel_sway||explanation"
msgid "Perform a Quickstep to cancel certain actions."
msgstr "Esegui un passo rapido per annullare determinate azioni."

msgctxt "554||btl_involve||explanation"
msgid "Damage is increased to any additional enemies hit by\r\nyour attacks."
msgstr "I danni inflitti a qualsiasi nemico aggiuntivo colpito dai\r\ntuoi attacchi aumentano."

msgctxt "555||btl_anti_atk||explanation"
msgid "Deal more damage when you hit enemies while they\r\nare attacking."
msgstr "Infliggi più danni quando colpisci i nemici mentre\r\nstanno attaccando."

msgctxt "556||hct_rush||explanation"
msgid "Your Rush Combo during Extreme Heat Mode increases\r\nfrom 4 hits to 8 hits."
msgstr "La tua Combo base in Modalità Furore Estremo passa\r\nda 4 a 8 colpi."

msgctxt "557||hct_stock_01||explanation"
msgid "Increase Heat Orbs by one."
msgstr "Aumenta i globi Furore di uno."

msgctxt "558||hct_stock_02||explanation"
msgid "Increase Heat Orbs by one."
msgstr "Aumenta i globi Furore di uno."

msgctxt "559||hct_stock_03||explanation"
msgid "Increase Heat Orbs by one."
msgstr "Aumenta i globi Furore di uno."

msgctxt "560||hct_atk_up_01||explanation"
msgid "Increase damage for attacks using the Heat Gauge."
msgstr "Aumenta i danni degli attacchi che usano la barra Furore."

msgctxt "561||hct_atk_up_02||explanation"
msgid "Increase damage for attacks using the Heat Gauge even further."
msgstr "Aumenta ulteriormente i danni degli attacchi che usano la barra Furore."

msgctxt "562||hct_atk_up_03||explanation"
msgid "Increase damage for attacks using the Heat Gauge to their\r\nfullest."
msgstr "Aumenta al massimo i danni degli attacchi che usano\r\nla barra Furore."

