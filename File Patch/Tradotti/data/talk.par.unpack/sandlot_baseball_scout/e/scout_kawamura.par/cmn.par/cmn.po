#. Max bytes: 37
msgctxt "Offset_0x1D20_Len_37"
msgid "(Hm, that guy looks pretty muscular.)"
msgstr "(Hm, quel tizio sembra muscoloso.)"

#. Max bytes: 51
msgctxt "Offset_0x1E10_Len_51"
msgid "(I bet he would be a great asset for the Warriors.)"
msgstr "(Sarebbe un gran rinforzo per i Warriors.)"

#. Max bytes: 47
msgctxt "Offset_0x1F30_Len_47"
msgid "(Okay, then. I should go see what his deal is.)"
msgstr "(Bene, vado a vedere cosa vuole.)"

#. Max bytes: 44
msgctxt "Offset_0x34B4_Len_44"
msgid "(Hm... So he wants some protein from RIZAP.)"
msgstr "(Hm... Quindi vuole le proteine RIZAP.)"

#. Max bytes: 51
msgctxt "Offset_0x35A4_Len_51"
msgid "(I guess I'll buy some when I'm back in Kamurocho.)"
msgstr "(Ne comprerò quando torno a Kamurocho.)"

#. Max bytes: 40
msgctxt "Offset_0x3A20_Len_40"
msgid "(I don't think it works that quickly...)"
msgstr "(Non fa effetto così in fretta...)"

#. Max bytes: 28
msgctxt "Offset_0x3B10_Len_28"
msgid "(All right, welcome aboard!)"
msgstr "(Bene, benvenuto a bordo!)"

#. Max bytes: 95
msgctxt "Offset_0x3BE0_Len_95"
msgid ""
"(I'll need to keep finding players for the Warriors\n"
"if I want to help the team really succeed.)"
msgstr ""
"(Devo continuare a cercare giocatori\n"
"per portare i Warriors al successo.)"

#. Max bytes: 47
msgctxt "Offset_0x3D20_Len_47"
msgid "(Wait, maybe I shouldn't give it to him yet...)"
msgstr "(Aspetta, meglio non darglielo ancora...)"

#. Max bytes: 42
msgctxt "Offset_0x2C2A4_Len_42"
msgid "Kawamura has joined the Setouchi Warriors."
msgstr "Kawamura entra nei Setouchi Warriors."

