msgctxt "Offset_0x11FC_Len_101"
msgid ""
"(Countless tile-roofed temples dot the mountainside.\r\n"
"Onomichi must have been bustling in its prime.)"
msgstr ""
"(Templi dai tetti in tegole punteggiano il monte.\r\n"
"Onomichi doveva essere vivace ai suoi tempi.)"

