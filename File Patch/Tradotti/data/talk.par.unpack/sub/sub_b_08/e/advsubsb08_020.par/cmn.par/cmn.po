#. Max bytes: 31
msgctxt "Offset_0x98C98_Len_31"
msgid "Who'll win the top horse races?"
msgstr "Chi vince ai cavalli?"

#. Max bytes: 32
msgctxt "Offset_0x98CD8_Len_32"
msgid "Where will I be a year from now?"
msgstr "Dove sarò tra un anno?"

#. Max bytes: 25
msgctxt "Offset_0x992D8_Len_25"
msgid "All right, I believe you."
msgstr "Va bene, ti credo."

#. Max bytes: 30
msgctxt "Offset_0x99318_Len_30"
msgid "You can't expect that to work."
msgstr "Non puoi credere che vada."

#. Max bytes: 38
msgctxt "Offset_0x99358_Len_38"
msgid "You know, you're actually pretty cute."
msgstr "Sai, in fondo sei molto carina."

