#. Max bytes: 66
msgctxt "Offset_0x40AC8_Len_66"
msgid ""
"(I wonder who this guy is...\n"
"Wait, I think I recognize his voice.)"
msgstr ""
"(Chi sarà mai questo tizio...\n"
"Aspetta, riconosco la voce.)"

#. Max bytes: 23
msgctxt "Offset_0x40BF8_Len_23"
msgid "(Could it be... Daigo?)"
msgstr "(Che sia... Daigo?)"

#. Max bytes: 45
msgctxt "Offset_0x40CC8_Len_45"
msgid "(No. Daigo's young, but he's not this young.)"
msgstr "(No. Daigo è giovane, ma non così tanto.)"

#. Max bytes: 23
msgctxt "Offset_0x40DD8_Len_23"
msgid "(Could it be... Daigo?)"
msgstr "(Che sia... Daigo?)"

#. Max bytes: 45
msgctxt "Offset_0x40EA8_Len_45"
msgid "(No. Daigo's young, but he's not this young.)"
msgstr "(No. Daigo è giovane, ma non così tanto.)"

#. Max bytes: 37
msgctxt "Offset_0x40FB8_Len_37"
msgid "(It couldn't be Haruto, could it...?)"
msgstr "(Non sarà mica Haruto...?)"

#. Max bytes: 77
msgctxt "Offset_0x41098_Len_77"
msgid ""
"(No, Haruto's too young to stand up\n"
"on his own, let alone talk on the phone.)"
msgstr ""
"(No, non sta nemmeno in piedi da solo,\n"
"figuriamoci parlare al telefono.)"

#. Max bytes: 37
msgctxt "Offset_0x411C8_Len_37"
msgid "(It couldn't be Haruto, could it...?)"
msgstr "(Non sarà mica Haruto...?)"

#. Max bytes: 77
msgctxt "Offset_0x412A8_Len_77"
msgid ""
"(No, Haruto's too young to stand up\n"
"on his own, let alone talk on the phone.)"
msgstr ""
"(No, non sta nemmeno in piedi da solo,\n"
"figuriamoci parlare al telefono.)"

#. Max bytes: 25
msgctxt "Offset_0x436A0_Len_25"
msgid "(That sounds reasonable.)"
msgstr "(Sembra ragionevole.)"

#. Max bytes: 12
msgctxt "Offset_0x43760_Len_12"
msgid "(Hold on...)"
msgstr "(Aspetta...)"

#. Max bytes: 67
msgctxt "Offset_0x43820_Len_67"
msgid ""
"(I feel like I've heard about scams\n"
"that sound a little like this.)"
msgstr ""
"(Ho sentito di truffe\n"
"che assomigliano a questa.)"

#. Max bytes: 43
msgctxt "Offset_0x43950_Len_43"
msgid "(I should figure out what's going on here.)"
msgstr "(Devo capire cosa sta succedendo.)"

#. Max bytes: 63
msgctxt "Offset_0x44F28_Len_63"
msgid ""
"(This is no time to be distrustful.\n"
"Taichi needs my help here.)"
msgstr ""
"(Non è il momento di diffidare.\n"
"Taichi ha bisogno di me.)"

#. Max bytes: 49
msgctxt "Offset_0x4714C_Len_49"
msgid ""
"(What is that even supposed to mean?\n"
"I wonder...)"
msgstr "(Che dovrebbe significare?\nChissà...)"

#. Max bytes: 71
msgctxt "Offset_0x4AB3C_Len_71"
msgid ""
"(What is he even talking about?\n"
"I wonder why he's acting so strange...)"
msgstr ""
"(Ma di che parla?\n"
"Chissà perché si comporta così...)"

#. Max bytes: 80
msgctxt "Offset_0x4AC7C_Len_80"
msgid ""
"(With everything that's happened,\n"
"he's probably just looking for a distraction.)"
msgstr ""
"(Con tutto quello che è successo,\n"
"cerca solo un modo per distrarsi.)"

#. Max bytes: 80
msgctxt "Offset_0x4B6F8_Len_80"
msgid ""
"(With everything that's happened,\n"
"he's probably just looking for a distraction.)"
msgstr ""
"(Con tutto quello che è successo,\n"
"cerca solo un modo per distrarsi.)"

#. Max bytes: 43
msgctxt "Offset_0x4B848_Len_43"
msgid "(I should try to help get his mind off it.)"
msgstr "(Dovrei aiutarlo a distrarsi.)"

#. Max bytes: 41
msgctxt "Offset_0x4CC00_Len_41"
msgid "(This must be someone trying to scam me.)"
msgstr "(Deve essere uno che prova a truffarmi.)"

#. Max bytes: 76
msgctxt "Offset_0x4CD10_Len_76"
msgid ""
"(I can't believe they'd really steal from\n"
"a random stranger over the phone.)"
msgstr ""
"(Non credo rubino davvero a uno sconosciuto\n"
"qualsiasi per telefono.)"

#. Max bytes: 68
msgctxt "Offset_0x4CE30_Len_68"
msgid ""
"(I should play along and show him\n"
"what happens to people like that.)"
msgstr ""
"(Starò al gioco e gli farò vedere\n"
"che succede a chi fa così.)"

