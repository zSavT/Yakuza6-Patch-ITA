#. Max bytes: 54
msgctxt "Offset_0x25198_Len_54"
msgid ""
"\"Good. Now send me photos\n"
"of the numbers on each one.\""
msgstr ""
"\"Bene. Ora mandami le foto\n"
"dei numeri su ciascuna.\""

#. Max bytes: 35
msgctxt "Offset_0x25298_Len_35"
msgid "\"What the hell's going on, Kiryu!?\""
msgstr "\"Che diavolo succede, Kiryu!?\""

#. Max bytes: 62
msgctxt "Offset_0x25388_Len_62"
msgid ""
"\"Kiryu, you've been had!\n"
"My account got hacked the other day!\""
msgstr ""
"\"Kiryu, ti hanno fregato!\n"
"Mi hanno hackerato l'account!\""

#. Max bytes: 37
msgctxt "Offset_0x254A8_Len_37"
msgid "\"That wasn't me you were talking to!\""
msgstr "\"Non ero io quello a cui parlavi!\""

#. Max bytes: 41
msgctxt "Offset_0x255B8_Len_41"
msgid "\"Your 50 grand could be anywhere by now!\""
msgstr "\"I tuoi 50.000 saranno ovunque!\""

#. Max bytes: 13
msgctxt "Offset_0x25698_Len_13"
msgid "\"No, dammit!\""
msgstr "\"No, cavolo!\""

#. Max bytes: 68
msgctxt "Offset_0x25758_Len_68"
msgid ""
"\"I'll see what I can do.\n"
"That scammer's not getting away with this.\""
msgstr ""
"\"Vedrò che fare.\n"
"Quel truffatore non la passerà liscia.\""

#. Max bytes: 83
msgctxt "Offset_0x25888_Len_83"
msgid ""
"\"Sorry, 50 grand really is a lot.\n"
"I'll buy you a drink sometime to make up for it.\""
msgstr ""
"\"Scusa, 50.000 sono tanti.\n"
"Ti offrirò un drink per farmi perdonare.\""

#. Max bytes: 16
msgctxt "Offset_0x259D8_Len_16"
msgid "\"Family issues.\""
msgstr "\"Guaio in casa.\""

#. Max bytes: 12
msgctxt "Offset_0x25AA8_Len_12"
msgid "\"Kamurocho.\""
msgstr ""

#. Max bytes: 46
msgctxt "Offset_0x25B68_Len_46"
msgid ""
"\"Just send them already.\n"
"I'm in a hurry here.\""
msgstr ""
"\"Mandale e basta.\n"
"Sono di fretta qui.\""

#. Max bytes: 22
msgctxt "Offset_0x25C48_Len_22"
msgid "\"Fine. Let's meet up.\""
msgstr "\"Va bene. Vediamoci.\""

#. Max bytes: 34
msgctxt "Offset_0x25D18_Len_34"
msgid "\"The roof of the Senryo Building.\""
msgstr "\"Il tetto del Senryo Building.\""

#. Max bytes: 15
msgctxt "Offset_0x26228_Len_15"
msgid "Send the Photos"
msgstr "Manda le foto"

#. Max bytes: 21
msgctxt "Offset_0x26268_Len_21"
msgid "Ask Why He Wants Them"
msgstr "Chiedi a che servono"

