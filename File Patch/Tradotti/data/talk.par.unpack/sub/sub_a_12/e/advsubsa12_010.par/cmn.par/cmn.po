#. Max bytes: 34
msgctxt "Offset_0x1B8E8_Len_34"
msgid "\"Please? I really need your help.\""
msgstr "\"Ti prego? Mi serve il tuo aiuto.\""

#. Max bytes: 73
msgctxt "Offset_0x1B9D8_Len_73"
msgid "\"Can you head over to a convenience store\nand buy me some prepaid cards?\""
msgstr "\"Puoi andare in un minimarket\ne comprarmi delle carte prepagate?\""

#. Max bytes: 35
msgctxt "Offset_0x1BB08_Len_35"
msgid "\"Does it matter?\nI just need some.\""
msgstr "\"Importa?\nMe ne servono alcune.\""

#. Max bytes: 33
msgctxt "Offset_0x1BBF8_Len_33"
msgid "\"Thanks. Buy five \\10,000 cards.\""
msgstr "\"Grazie. Comprane 5 da \\10.000.\""

#. Max bytes: 32
msgctxt "Offset_0x1BCE8_Len_32"
msgid "\"Let me know when you get them.\""
msgstr "\"Avvisami quando le hai.\""

#. Max bytes: 35
msgctxt "Offset_0x1BF28_Len_35"
msgid "Sorry, I'm a little busy right now."
msgstr "Scusa, ora sono un po' occupato."

#. Max bytes: 32
msgctxt "Offset_0x1BF68_Len_32"
msgid "Yeah. What do you need me to do?"
msgstr "Sì. Cosa devo fare?"
