#. Max bytes: 16
msgctxt "Offset_0x65A50_Len_16"
msgid "Become a member."
msgstr "Diventa membro."

#. Max bytes: 22
msgctxt "Offset_0x65A90_Len_22"
msgid "Don't become a member."
msgstr "Non diventare membro."

#. Max bytes: 57
msgctxt "Offset_0x661E0_Len_57"
msgid ""
"Talk to Makuta when you want to\n"
"begin a training session."
msgstr ""
"Parla con Makuta quando vuoi\n"
"iniziare un allenamento."

#. Max bytes: 101
msgctxt "Offset_0x662D0_Len_101"
msgid ""
"The EXP you earn from training will be\n"
"granted once you complete a full round\n"
"of the RIZAP Challenge."
msgstr ""
"L'EXP ottenuta dall'allenamento sarà\n"
"concessa al termine di un round\n"
"completo della Sfida RIZAP."

