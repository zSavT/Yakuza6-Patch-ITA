msgctxt "Offset_0x56A6C_Len_26"
msgid "I want everything you own."
msgstr "Voglio ciò che possiedi."

#. Max bytes: 27
msgctxt "Offset_0x56AAC_Len_27"
msgid "I want you to be my friend."
msgstr "Voglio che siamo amici."

#. Max bytes: 31
msgctxt "Offset_0x56AEC_Len_31"
msgid "I want you on my baseball team."
msgstr "Ti voglio in squadra."

