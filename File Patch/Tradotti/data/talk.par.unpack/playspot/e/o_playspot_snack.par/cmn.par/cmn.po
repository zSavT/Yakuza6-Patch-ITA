#. Max bytes: 51
msgctxt "Offset_0x744_Len_51"
msgid ""
"Head into New Gaudi?\n"
"The cover charge is 3,000 yen."
msgstr ""
"Entri nel New Gaudi?\n"
"L'ingresso costa 3.000 yen."

#. Max bytes: 3
msgctxt "Offset_0x844_Len_3"
msgid "Yes"
msgstr ""

#. Max bytes: 2
msgctxt "Offset_0x884_Len_2"
msgid "No"
msgstr ""

#. Max bytes: 33
msgctxt "Offset_0x1824_Len_33"
msgid "(Maybe I'll drop in for a drink.)"
msgstr "(Forse entro a farmi un drink.)"

#. Max bytes: 30
msgctxt "Offset_0x1914_Len_30"
msgid "(I don't have enough money...)"
msgstr "(Non ho abbastanza soldi...)"

#. Max bytes: 31
msgctxt "Offset_0x19F4_Len_31"
msgid "(I'll have to come back later.)"
msgstr "(Dovrò tornare più tardi.)"

#. Max bytes: 33
msgctxt "Offset_0x1AC4_Len_33"
msgid "(I wonder what everyone's up to.)"
msgstr "(Chissà cosa stanno facendo.)"

#. Max bytes: 67
msgctxt "Offset_0x1BC4_Len_67"
msgid ""
"(I'm feeling pretty damn drunk.\n"
"I should sober up before going in.)"
msgstr ""
"(Mi sento ubriaco fradicio.\n"
"Dovrei smaltire prima di entrare.)"

