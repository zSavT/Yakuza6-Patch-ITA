#. Max bytes: 7
msgctxt "Offset_0x3069D_Len_7"
msgid " |Eqm~E"
msgstr ""

#. Max bytes: 46
msgctxt "Offset_0x4B6A4_Len_46"
msgid "So, what's wrong, Ando-san? What's got y'down?"
msgstr ""

#. Max bytes: 42
msgctxt "Offset_0x4B904_Len_42"
msgid "Something happen at the pawn shop earlier?"
msgstr ""

#. Max bytes: 11
msgctxt "Offset_0x4BBC4_Len_11"
msgid "A customer?"
msgstr ""

#. Max bytes: 48
msgctxt "Offset_0x4BDE4_Len_48"
msgid "Care to talk? No promises, but maybe it'll help."
msgstr ""

#. Max bytes: 50
msgctxt "Offset_0x4C054_Len_50"
msgid "It'd be a miracle if we actually solved a problem."
msgstr ""

#. Max bytes: 10
msgctxt "Offset_0x4C2C4_Len_10"
msgid "True that."
msgstr ""

#. Max bytes: 11
msgctxt "Offset_0x4C2E4_Len_11"
msgid "Trunk that."
msgstr ""

#. Max bytes: 17
msgctxt "Offset_0x4C304_Len_17"
msgid "That old popstar?"
msgstr ""

#. Max bytes: 12
msgctxt "Offset_0x4C334_Len_12"
msgid "That's true."
msgstr ""

#. Max bytes: 24
msgctxt "Offset_0x4C964_Len_24"
msgid "Aw, you're really upset."
msgstr ""

#. Max bytes: 46
msgctxt "Offset_0x4CBA4_Len_46"
msgid "That guy from earlier came t'sell something..."
msgstr ""

#. Max bytes: 8
msgctxt "Offset_0x4CDF4_Len_8"
msgid "Oh shit."
msgstr ""

#. Max bytes: 11
msgctxt "Offset_0x4CE24_Len_11"
msgid "Oh hell no."
msgstr ""

#. Max bytes: 9
msgctxt "Offset_0x4CE44_Len_9"
msgid "For real?"
msgstr ""

#. Max bytes: 63
msgctxt "Offset_0x4CE64_Len_63"
msgid "A wedding ring... 'Cept it had my ex-wife's and my names on it."
msgstr ""

#. Max bytes: 37
msgctxt "Offset_0x4D0D4_Len_37"
msgid "Wha? Ex-wife? Meaning y'got divorced?"
msgstr ""

#. Max bytes: 48
msgctxt "Offset_0x4D334_Len_48"
msgid "That's right. We split up a while back though..."
msgstr ""

#. Max bytes: 10
msgctxt "Offset_0x4D5A4_Len_10"
msgid "You can't!"
msgstr ""

#. Max bytes: 18
msgctxt "Offset_0x4D5D4_Len_18"
msgid "She probably died."
msgstr ""

#. Max bytes: 9
msgctxt "Offset_0x4D604_Len_9"
msgid "You were?"
msgstr ""

#. Max bytes: 59
msgctxt "Offset_0x4D624_Len_59"
msgid "But weren't y'talkin' about gettin' her back jus' recently?"
msgstr ""

#. Max bytes: 36
msgctxt "Offset_0x4D894_Len_36"
msgid "Oh, y'must be real broken up then..."
msgstr ""

#. Max bytes: 8
msgctxt "Offset_0x4DAE4_Len_8"
msgid "So true."
msgstr ""

#. Max bytes: 9
msgctxt "Offset_0x4DB14_Len_9"
msgid "So wrong."
msgstr ""

#. Max bytes: 9
msgctxt "Offset_0x4DB34_Len_9"
msgid "Soda pop."
msgstr ""

#. Max bytes: 52
msgctxt "Offset_0x4DB54_Len_52"
msgid "Sometimes y'don't know what ya got until ya lose it!"
msgstr ""

#. Max bytes: 54
msgctxt "Offset_0x4DDD4_Len_54"
msgid "But by the time y'realize it, it's usually too late..."
msgstr ""

#. Max bytes: 47
msgctxt "Offset_0x4E044_Len_47"
msgid "Mama... Y'don't gotta rub salt in his wounds..."
msgstr ""

#. Max bytes: 18
msgctxt "Offset_0x4E2A4_Len_18"
msgid "Not if she's dead."
msgstr ""

#. Max bytes: 11
msgctxt "Offset_0x4E2E4_Len_11"
msgid "Yeah right."
msgstr ""

#. Max bytes: 13
msgctxt "Offset_0x4E304_Len_13"
msgid "You think so?"
msgstr ""

#. Max bytes: 51
msgctxt "Offset_0x4E324_Len_51"
msgid "Still, the relationship ain't beyond repair, right?"
msgstr ""

#. Max bytes: 48
msgctxt "Offset_0x4E594_Len_48"
msgid "Yeah, she's been slowly replying to my messages."
msgstr ""

#. Max bytes: 46
msgctxt "Offset_0x4E804_Len_46"
msgid "We even talked about meetin' up over dinner..."
msgstr ""

#. Max bytes: 47
msgctxt "Offset_0x4EA54_Len_47"
msgid "Sounds like a tease t'me. She some kinda witch?"
msgstr ""

#. Max bytes: 37
msgctxt "Offset_0x4ECC4_Len_37"
msgid "I wouldn't say she's a tease, though."
msgstr ""

#. Max bytes: 50
msgctxt "Offset_0x4EF14_Len_50"
msgid "Women hide behind lots of different masks in life."
msgstr ""

#. Max bytes: 18
msgctxt "Offset_0x4F1A4_Len_18"
msgid "Women, am I right?"
msgstr ""

#. Max bytes: 16
msgctxt "Offset_0x4F1D4_Len_16"
msgid "Men, am I right?"
msgstr ""

#. Max bytes: 49
msgctxt "Offset_0x4F204_Len_49"
msgid "Maybe y'never even got to see who she really was."
msgstr ""

#. Max bytes: 22
msgctxt "Offset_0x4F474_Len_22"
msgid "Wow Mama, that's deep."
msgstr ""

#. Max bytes: 36
msgctxt "Offset_0x4F6B4_Len_36"
msgid "It jus' takes time. Pay her no mind."
msgstr ""

#. Max bytes: 34
msgctxt "Offset_0x4F904_Len_34"
msgid "No more open tabs for you nitwits."
msgstr ""

#. Max bytes: 10
msgctxt "Offset_0x4FD64_Len_10"
msgid "Come on..."
msgstr ""

#. Max bytes: 32
msgctxt "Offset_0x4FF84_Len_32"
msgid "It's bad to crack your knuckles."
msgstr ""

#. Max bytes: 21
msgctxt "Offset_0x4FFD4_Len_21"
msgid "It's all speculation."
msgstr ""

#. Max bytes: 26
msgctxt "Offset_0x50014_Len_26"
msgid "What happened to the ring?"
msgstr ""

#. Max bytes: 15
msgctxt "Offset_0x50054_Len_15"
msgid "Well, anyway..."
msgstr ""

#. Max bytes: 27
msgctxt "Offset_0x50274_Len_27"
msgid "What happened to that ring?"
msgstr ""

#. Max bytes: 21
msgctxt "Offset_0x504A4_Len_21"
msgid "Did you turn it down?"
msgstr ""

#. Max bytes: 22
msgctxt "Offset_0x50784_Len_22"
msgid "Huh? What did you say?"
msgstr ""

#. Max bytes: 34
msgctxt "Offset_0x509B4_Len_34"
msgid "N-No, sorry. Ignore what I said..."
msgstr ""

#. Max bytes: 60
msgctxt "Offset_0x50CA4_Len_60"
msgid "I'm still a businessman, so I bought it off him. 10,000 yen."
msgstr ""

#. Max bytes: 11
msgctxt "Offset_0x50F14_Len_11"
msgid "It sure is."
msgstr ""

#. Max bytes: 11
msgctxt "Offset_0x50F34_Len_11"
msgid "Not really."
msgstr ""

#. Max bytes: 21
msgctxt "Offset_0x50F54_Len_21"
msgid "I'll give you TRAGIC."
msgstr ""

#. Max bytes: 23
msgctxt "Offset_0x50F84_Len_23"
msgid "Oh no, that's tragic..."
msgstr ""

#. Max bytes: 46
msgctxt "Offset_0x511B4_Len_46"
msgid "Who came to sell it? It wasn't your ex, right?"
msgstr ""

#. Max bytes: 23
msgctxt "Offset_0x51414_Len_23"
msgid "Some young, suave type."
msgstr ""

#. Max bytes: 29
msgctxt "Offset_0x51654_Len_29"
msgid "Y'think he's her new husband?"
msgstr ""

#. Max bytes: 14
msgctxt "Offset_0x51884_Len_14"
msgid "Am I her type?"
msgstr ""

#. Max bytes: 17
msgctxt "Offset_0x518B4_Len_17"
msgid "Are you her type?"
msgstr ""

#. Max bytes: 13
msgctxt "Offset_0x518E4_Len_13"
msgid "Are you sure?"
msgstr ""

#. Max bytes: 44
msgctxt "Offset_0x51904_Len_44"
msgid "No way she remarried!  ...He's not her type!"
msgstr ""

#. Max bytes: 42
msgctxt "Offset_0x51B74_Len_42"
msgid "Women do like t'change things up though..."
msgstr ""

#. Max bytes: 21
msgctxt "Offset_0x51DD4_Len_21"
msgid "Okay, enough of that."
msgstr ""

#. Max bytes: 18
msgctxt "Offset_0x52214_Len_18"
msgid "Did the love fade?"
msgstr ""

#. Max bytes: 13
msgctxt "Offset_0x52254_Len_13"
msgid "Too personal!"
msgstr ""

#. Max bytes: 16
msgctxt "Offset_0x52274_Len_16"
msgid "Can we ask that?"
msgstr ""

#. Max bytes: 30
msgctxt "Offset_0x522A4_Len_30"
msgid "Why'd you two split up anyway?"
msgstr ""

#. Max bytes: 47
msgctxt "Offset_0x524E4_Len_47"
msgid "I was a workaholic, so I didn't come home much."
msgstr ""

#. Max bytes: 54
msgctxt "Offset_0x52744_Len_54"
msgid "I knew she was lonely, but I thought she understood..."
msgstr ""

#. Max bytes: 41
msgctxt "Offset_0x529B4_Len_41"
msgid "A divorce kinda makes sense in that case."
msgstr ""

#. Max bytes: 49
msgctxt "Offset_0x52C24_Len_49"
msgid "But I did some soul searchin', and I quit my job."
msgstr ""

#. Max bytes: 10
msgctxt "Offset_0x52EA4_Len_10"
msgid "I get you."
msgstr ""

#. Max bytes: 17
msgctxt "Offset_0x52EC4_Len_17"
msgid "I get the chills."
msgstr ""

#. Max bytes: 19
msgctxt "Offset_0x52EF4_Len_19"
msgid "I'll get your coat."
msgstr ""

#. Max bytes: 52
msgctxt "Offset_0x52F24_Len_52"
msgid "I opened my pawn shop t'spend more time with family."
msgstr ""

#. Max bytes: 59
msgctxt "Offset_0x531A4_Len_59"
msgid "Business is good, so I thought maybe we could start over..."
msgstr ""

#. Max bytes: 7
msgctxt "Offset_0x53424_Len_7"
msgid "Me too."
msgstr ""

#. Max bytes: 16
msgctxt "Offset_0x53444_Len_16"
msgid "Pain don't hurt."
msgstr ""

#. Max bytes: 10
msgctxt "Offset_0x53474_Len_10"
msgid "Don't lie!"
msgstr ""

#. Max bytes: 47
msgctxt "Offset_0x53494_Len_47"
msgid "I'm seriously startin' to feel sorry for you..."
msgstr ""

#. Max bytes: 45
msgctxt "Offset_0x536E4_Len_45"
msgid "Yeah, I feel bad I wasn't paying attention..."
msgstr ""

#. Max bytes: 14
msgctxt "Offset_0x53944_Len_14"
msgid "Hey, hey, hey."
msgstr ""

#. Max bytes: 8
msgctxt "Offset_0x53964_Len_8"
msgid "Hey now."
msgstr ""

#. Max bytes: 18
msgctxt "Offset_0x53984_Len_18"
msgid "Hey is for horses."
msgstr ""

#. Max bytes: 52
msgctxt "Offset_0x539B4_Len_52"
msgid "Pay attention, then! C'mon, at least pretend t'care."
msgstr ""

#. Max bytes: 27
msgctxt "Offset_0x53C44_Len_27"
msgid "Anyone got New Years plans?"
msgstr ""

#. Max bytes: 27
msgctxt "Offset_0x53C84_Len_27"
msgid "You should talk to your ex."
msgstr ""

#. Max bytes: 27
msgctxt "Offset_0x53CD4_Len_27"
msgid "Who's got the bill tonight?"
msgstr ""

#. Max bytes: 15
msgctxt "Offset_0x53D14_Len_15"
msgid "Well, anyway..."
msgstr ""

#. Max bytes: 42
msgctxt "Offset_0x53F34_Len_42"
msgid "Why don't you go talk it out with your ex?"
msgstr ""

#. Max bytes: 50
msgctxt "Offset_0x54184_Len_50"
msgid "Yeah, you'll have to talk to her to get the truth."
msgstr ""

#. Max bytes: 17
msgctxt "Offset_0x544A4_Len_17"
msgid "Hm? What's wrong?"
msgstr ""

#. Max bytes: 31
msgctxt "Offset_0x546D4_Len_31"
msgid "S-Sorry, I dozed off for a bit."
msgstr ""

#. Max bytes: 54
msgctxt "Offset_0x54914_Len_54"
msgid "Keep it together. Why don't you try calling her first?"
msgstr ""

#. Max bytes: 56
msgctxt "Offset_0x54C34_Len_56"
msgid "Actually, I've been calling all day. She won't answer..."
msgstr ""

#. Max bytes: 10
msgctxt "Offset_0x54EE4_Len_10"
msgid "It's fine."
msgstr ""

#. Max bytes: 18
msgctxt "Offset_0x54F04_Len_18"
msgid "She probably died."
msgstr ""

#. Max bytes: 24
msgctxt "Offset_0x54F34_Len_24"
msgid "That doesn't sound good."
msgstr ""

#. Max bytes: 45
msgctxt "Offset_0x55164_Len_45"
msgid "What if she shows up t'introduce her new man?"
msgstr ""

#. Max bytes: 22
msgctxt "Offset_0x553D4_Len_22"
msgid "Come on, Akiyoshi-kun."
msgstr ""

#. Max bytes: 12
msgctxt "Offset_0x55614_Len_12"
msgid "Oh, sorry..."
msgstr ""

#. Max bytes: 25
msgctxt "Offset_0x55834_Len_25"
msgid "You mean you'll run away."
msgstr ""

#. Max bytes: 17
msgctxt "Offset_0x55874_Len_17"
msgid "You mean to Mars?"
msgstr ""

#. Max bytes: 14
msgctxt "Offset_0x558A4_Len_14"
msgid "You mean that?"
msgstr ""

#. Max bytes: 23
msgctxt "Offset_0x558C4_Len_23"
msgid "Maybe I'll jus' travel."
msgstr ""

#. Max bytes: 59
msgctxt "Offset_0x55D04_Len_59"
msgid "I came out here so we could start over, but this is just..."
msgstr ""

#. Max bytes: 12
msgctxt "Offset_0x55F84_Len_12"
msgid "She's right."
msgstr ""

#. Max bytes: 24
msgctxt "Offset_0x55FA4_Len_24"
msgid "Join the yakuza instead."
msgstr ""

#. Max bytes: 26
msgctxt "Offset_0x55FD4_Len_26"
msgid "Open an orphanage instead."
msgstr ""

#. Max bytes: 29
msgctxt "Offset_0x56004_Len_29"
msgid "Hey, don't go down that path!"
msgstr ""

#. Max bytes: 65
msgctxt "Offset_0x56244_Len_65"
msgid "No, I already decided. I'm gonna get a fresh start in a new city!"
msgstr ""

#. Max bytes: 28
msgctxt "Offset_0x564D4_Len_28"
msgid "The hell is he raving about?"
msgstr ""

#. Max bytes: 32
msgctxt "Offset_0x56934_Len_32"
msgid "It's still too early to give up!"
msgstr ""

#. Max bytes: 26
msgctxt "Offset_0x56B74_Len_26"
msgid "It's too early to give up!"
msgstr ""

#. Max bytes: 28
msgctxt "Offset_0x56DA4_Len_28"
msgid "But, I don't got a choice..."
msgstr ""

#. Max bytes: 45
msgctxt "Offset_0x56FD4_Len_45"
msgid "That ring raised more questions than answers."
msgstr ""

#. Max bytes: 45
msgctxt "Offset_0x57234_Len_45"
msgid "Can't you wait until we have a clear picture?"
msgstr ""

#. Max bytes: 14
msgctxt "Offset_0x574A4_Len_14"
msgid "Damn straight."
msgstr ""

#. Max bytes: 58
msgctxt "Offset_0x576B4_Len_58"
msgid "'Sides, if you close, where else am I gonna buy tableware?"
msgstr ""

#. Max bytes: 36
msgctxt "Offset_0x57934_Len_36"
msgid "So y'got these from the pawn shop..."
msgstr ""

#. Max bytes: 56
msgctxt "Offset_0x57B84_Len_56"
msgid "I really like your store, y'know? Y'oughta rethink this."
msgstr ""

#. Max bytes: 46
msgctxt "Offset_0x57DE4_Len_46"
msgid "Guys... Okay, I'll think it through some more."
msgstr ""

#. Max bytes: 57
msgctxt "Offset_0x58034_Len_57"
msgid "You've worked hard, Ando-san. Yer luck's bound to change."
msgstr ""

#. Max bytes: 56
msgctxt "Offset_0x582A4_Len_56"
msgid "Then raise a glass to Ando-san findin' his happiness...!"
msgstr ""

#. Max bytes: 16
msgctxt "Offset_0x58724_Len_16"
msgid "No... It's fine."
msgstr ""

#. Max bytes: 55
msgctxt "Offset_0x58954_Len_55"
msgid "Where can I find a boat to the nearest deserted island?"
msgstr ""

#. Max bytes: 44
msgctxt "Offset_0x58BC4_Len_44"
msgid "C'mon now, let's just start with this drink."
msgstr ""

#. Max bytes: 28
msgctxt "Offset_0x58E14_Len_28"
msgid "We'll keep ya company today."
msgstr ""

#. Max bytes: 29
msgctxt "Offset_0x59254_Len_29"
msgid "(We couldn't cheer him up...)"
msgstr ""

